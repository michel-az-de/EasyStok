{
  "name": "casa-da-baba-apk",
  "version": "1.0.0",
  "description": "Wrapper Capacitor para empacotar o PWA Casa da Baba como APK Android.",
  "private": true,
  "scripts": {
    "copy-web": "node scripts/copy-web.js",
    "init": "cap init \"Casa da Baba\" com.casadababa.app --web-dir=web",
    "add-android": "cap add android",
    "sync": "cap sync android",
    "build-debug": "cd android && gradlew.bat assembleDebug && cd ..",
    "build-release": "cd android && gradlew.bat assembleRelease && cd ..",
    "full": "npm run copy-web && npm run sync && npm run build-debug"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/core": "^6.2.0"
  }
}
