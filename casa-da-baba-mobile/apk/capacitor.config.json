{
  "appId": "com.casadababa.app",
  "appName": "Casa da Baba",
  "webDir": "web",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#1a1410"
  },
  "server": {
    "androidScheme": "https",
    "cleartext": false
  },
  "plugins": {
    "CapacitorUpdater": {
      "autoUpdate": true,
      "updateUrl": "https://easystok-web.onrender.com/downloads/apk/manifest",
      "statsUrl": "",
      "directUpdate": "never",
      "responseTimeout": 20,
      "appReadyTimeout": 30000,
      "autoDeleteFailed": true,
      "resetWhenUpdate": false
    }
  }
}
