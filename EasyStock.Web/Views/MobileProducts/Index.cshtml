@using EasyStock.Web.Services
@using EasyStock.Web.Models.Api
@model List<MobileProductApi>
@{
    ViewBag.Title = "Produtos do mobile";
    Layout = "_Layout";
    var produtosErp = ViewBag.ProdutosErp as List<ProdutoResumo> ?? new List<ProdutoResumo>();
    var pendentes = Model.Where(p => p.IsCustom && !p.IsApproved && p.ErpProductId == null).ToList();
    var linkados = Model.Where(p => p.ErpProductId.HasValue).ToList();
    var aprovadosMobileOnly = Model.Where(p => p.IsApproved && !p.ErpProductId.HasValue && p.IsCustom).ToList();
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Produtos do mobile</h1>
        <p>@pendentes.Count pendente@(pendentes.Count == 1 ? "" : "s") · @linkados.Count linkado@(linkados.Count == 1 ? "" : "s") ao ERP · @aprovadosMobileOnly.Count aprovado@(aprovadosMobileOnly.Count == 1 ? "" : "s") só no mobile</p>
    </div>
    @if (linkados.Any())
    {
        <a href="/produtos-mobile/divergencias" class="text-sm text-slate-600 hover:text-indigo-700 font-medium">
            Ver divergências de estoque →
        </a>
    }
</div>

@if (pendentes.Any())
{
    <div class="ws mb-6">
        <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between">
            <h2 class="text-base font-semibold text-slate-900">⚠ Aguardando revisão</h2>
            <span class="text-xs text-slate-500">criados pelo app, ainda não aprovados</span>
        </div>
        <div class="overflow-x-auto">
        <table class="w-full min-w-[720px]">
            <thead>
                <tr class="text-left text-xs text-slate-500 uppercase tracking-wider border-b border-slate-200">
                    <th class="px-4 py-3">Produto</th>
                    <th class="px-4 py-3">Categoria</th>
                    <th class="px-4 py-3">Estoque</th>
                    <th class="px-4 py-3">Criado por</th>
                    <th class="px-4 py-3">Quando</th>
                    <th class="px-4 py-3 text-right">Ações</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var p in pendentes)
                {
                    <tr>
                        <td class="px-4 py-3">
                            <div class="font-medium text-slate-900">@p.Emoji @p.Name</div>
                            <div class="text-xs text-slate-500 font-mono">@p.Id</div>
                        </td>
                        <td class="px-4 py-3 text-sm text-slate-700 capitalize">@p.Category</td>
                        <td class="px-4 py-3 text-sm text-slate-700">@p.Stock @(p.Unit ?? "un")</td>
                        <td class="px-4 py-3 text-sm text-slate-700">@(p.LastOperatorName ?? "—")</td>
                        <td class="px-4 py-3 text-sm text-slate-700">@p.CreatedAt.ToString("dd/MM HH:mm")</td>
                        <td class="px-4 py-3 text-right space-x-1">
                            <button type="button"
                                    x-data
                                    @@click="$dispatch('open-modal', 'link-@(p.Id)')"
                                    class="text-xs text-indigo-600 hover:text-indigo-800 font-medium">
                                Linkar ao ERP
                            </button>
                            <span class="text-xs text-slate-300">|</span>
                            <form method="post" action="/produtos-mobile/@p.Id/aprovar" class="inline"
                                  data-confirm='{"titulo":"Aprovar produto mobile-only?","mensagem":"O produto sera aprovado sem link com ERP. Voce ainda pode linkar manualmente depois.","textoBotao":"Aprovar","classBotao":"bg-emerald-600 hover:bg-emerald-700"}'>
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-xs text-emerald-600 hover:text-emerald-800 font-medium">
                                    Aprovar (mobile-only)
                                </button>
                            </form>
                        </td>
                    </tr>

                    <!-- Modal: linkar este produto -->
                    <tr class="hidden">
                        <td colspan="6">
                            <div x-data="{ open: false }"
                                 x-show="open"
                                 x-on:open-modal.window="if ($event.detail === 'link-@(p.Id)') open = true"
                                 x-on:keydown.escape.window="open = false"
                                 x-cloak
                                 class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50">
                                <div @@click.outside="open = false" class="bg-white rounded-xl shadow-xl max-w-md w-full p-6">
                                    <h3 class="text-lg font-semibold text-slate-900 mb-2">Linkar @p.Name ao ERP</h3>
                                    <p class="text-xs text-slate-500 mb-4">Escolha qual produto do ERP corresponde a este produto criado no mobile. Próxima sync vai unificar nome/preço.</p>
                                    <form method="post" action="/produtos-mobile/@p.Id/linkar" class="space-y-4">
                                        @Html.AntiForgeryToken()
                                        <div>
                                            <label class="block text-sm font-medium text-slate-700 mb-1">Produto ERP</label>
                                            @if (produtosErp.Any())
                                            {
                                                <select name="erpProductId" required
                                                        class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                                                    <option value="">— escolha —</option>
                                                    @foreach (var prod in produtosErp.OrderBy(x => x.Nome))
                                                    {
                                                        <option value="@prod.Id">@prod.Nome @(prod.Marca != null ? "(" + prod.Marca + ")" : "")</option>
                                                    }
                                                </select>
                                            }
                                            else
                                            {
                                                <div class="p-3 bg-amber-50 border border-amber-200 rounded text-xs text-amber-800">
                                                    Nenhum produto ERP cadastrado. <a href="/produtos" class="underline font-medium">Crie um produto</a> primeiro.
                                                </div>
                                            }
                                        </div>
                                        <div class="flex justify-end gap-2 pt-2">
                                            <button type="button" @@click="open = false"
                                                    class="px-4 py-2 text-sm text-slate-700 hover:bg-slate-100 rounded-lg">Cancelar</button>
                                            <button type="submit"
                                                    @(produtosErp.Any() ? "" : "disabled")
                                                    class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 disabled:opacity-50">
                                                Linkar
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
}

@if (linkados.Any() || aprovadosMobileOnly.Any())
{
    <div class="ws">
        <div class="px-6 py-4 border-b border-slate-200">
            <h2 class="text-base font-semibold text-slate-900">Já revisados</h2>
        </div>
        <div class="overflow-x-auto">
        <table class="w-full min-w-[560px]">
            <thead>
                <tr class="text-left text-xs text-slate-500 uppercase tracking-wider border-b border-slate-200">
                    <th class="px-4 py-3">Produto</th>
                    <th class="px-4 py-3">Status</th>
                    <th class="px-4 py-3">Aprovado em</th>
                    <th class="px-4 py-3 text-right">Ações</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var p in linkados.Concat(aprovadosMobileOnly).OrderByDescending(x => x.ApprovedAt ?? x.UpdatedAt))
                {
                    <tr>
                        <td class="px-4 py-3">
                            <div class="font-medium text-slate-900">@p.Emoji @p.Name</div>
                            <div class="text-xs text-slate-500 font-mono">@p.Id</div>
                        </td>
                        <td class="px-4 py-3">
                            @if (p.ErpProductId.HasValue)
                            {
                                <span class="inline-block px-2 py-1 text-xs font-semibold bg-indigo-100 text-indigo-700 rounded">Linkado ao ERP</span>
                            }
                            else
                            {
                                <span class="inline-block px-2 py-1 text-xs font-semibold bg-emerald-100 text-emerald-800 rounded">Mobile-only</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-sm text-slate-700">@p.ApprovedAt?.ToString("dd/MM HH:mm")</td>
                        <td class="px-4 py-3 text-right">
                            <form method="post" action="/produtos-mobile/@p.Id/desfazer" class="inline"
                                  data-confirm='{"titulo":"Desfazer aprovacao?","mensagem":"O produto volta para a lista de pendentes.","textoBotao":"Desfazer","classBotao":"bg-slate-600 hover:bg-slate-700"}'>
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-xs text-slate-500 hover:text-red-600 font-medium">
                                    Desfazer
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="ws p-12 text-center">
        <div class="text-6xl mb-4">📦</div>
        <h2 class="text-lg font-semibold text-slate-900 mb-2">Nenhum produto criado pelo mobile ainda</h2>
        <p class="text-sm text-slate-500">Quando o operador cadastrar um produto novo no app, ele aparecerá aqui pra revisão.</p>
    </div>
}
