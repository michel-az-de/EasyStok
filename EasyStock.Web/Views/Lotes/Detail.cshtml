@model LoteDetailViewModel
@{
    var l = Model.Detalhe.Lote;
    ViewBag.Title = $"Lote {l.Codigo}";
    Layout = "_Layout";

    string statusPill = l.Status switch {
        "em_producao" => "bg-blue-50 text-blue-700 ring-blue-200",
        "finalizado"  => "bg-emerald-50 text-emerald-800 ring-emerald-200",
        "expirado"    => "bg-red-50 text-red-700 ring-red-200",
        _             => "bg-slate-50 text-slate-600 ring-slate-200"
    };
    string statusDot = l.Status switch {
        "em_producao" => "bg-blue-500",
        "finalizado"  => "bg-emerald-500",
        "expirado"    => "bg-red-500",
        _             => "bg-slate-400"
    };
    string statusLabel = l.Status switch {
        "em_producao" => "Em produção",
        "finalizado"  => "Finalizado",
        "expirado"    => "Expirado",
        _             => l.Status ?? "—"
    };

    string etqStatusClass(string s) => s switch {
        "conferida"  => "bg-emerald-50 text-emerald-800 ring-1 ring-emerald-200",
        "divergente" => "bg-red-50 text-red-700 ring-1 ring-red-200",
        "consumida"  => "bg-slate-100 text-slate-600 ring-1 ring-slate-200",
        _            => "bg-amber-50 text-amber-800 ring-1 ring-amber-200"
    };
}

<div class="flex items-center gap-3 mb-6">
    <a asp-action="Index" asp-controller="Lotes" class="text-slate-400 hover:text-slate-600" aria-label="Voltar para lotes">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <h1 class="text-2xl font-bold text-slate-900 font-mono">@l.Codigo</h1>
    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-xs font-medium ring-1 @statusPill">
        <span class="w-1.5 h-1.5 rounded-full @statusDot"></span>
        @statusLabel
    </span>
    <div class="ml-auto flex gap-2">
        @if (l.Status == "em_producao")
        {
            <form asp-action="Finalizar" asp-controller="Lotes" asp-route-id="@l.Id" method="post" data-confirm='@($"{{\"titulo\":\"Finalizar lote?\",\"mensagem\":\"Será gerado(s) {l.TotalUnidades} etiqueta(s) e o lote ficará congelado para alterações.\",\"textoBotao\":\"Finalizar lote\",\"classBotao\":\"bg-indigo-600 hover:bg-indigo-700\"}}")'>
                @Html.AntiForgeryToken()
                <button type="submit" class="px-3.5 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg">
                    🏁 Finalizar lote
                </button>
            </form>
        }
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1 space-y-4">
        <div class="ws">
            <h2 class="font-semibold text-slate-900 mb-3">Resumo</h2>
            <dl class="space-y-2 text-sm">
                <div><dt class="text-slate-500">Data produção</dt><dd>@l.DataProducao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd></div>
                @if (!string.IsNullOrEmpty(l.OperadorNome)) { <div><dt class="text-slate-500">Operador</dt><dd>@l.OperadorNome</dd></div> }
                <div><dt class="text-slate-500">Itens</dt><dd>@l.ItensCount item(s) · @l.TotalUnidades unidades</dd></div>
                <div><dt class="text-slate-500">Etiquetas</dt>
                     <dd>
                        @if (l.TotalUnidades == 0) { <span class="text-slate-400">— (finalizar para gerar)</span> }
                        else { <span>@l.EtiquetasConferidas/@l.TotalUnidades conferidas</span> }
                        @if (l.EtiquetasDivergentes > 0) { <div class="text-xs text-red-600 mt-1">@l.EtiquetasDivergentes divergente(s)</div> }
                     </dd></div>
                @if (l.FinalizadoEm.HasValue) { <div><dt class="text-slate-500">Finalizado</dt><dd>@l.FinalizadoEm.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd></div> }
                @if (!string.IsNullOrEmpty(l.Observacoes)) { <div class="pt-2 border-t"><dt class="text-slate-500">Observações</dt><dd class="whitespace-pre-line">@l.Observacoes</dd></div> }
                @if (!string.IsNullOrEmpty(l.MobileBatchId)) { <div class="pt-2 border-t"><dt class="text-slate-500">Mobile batch</dt><dd class="font-mono text-xs">@l.MobileBatchId</dd></div> }
            </dl>
        </div>
    </div>

    <div class="lg:col-span-2 space-y-4" x-data="{ tab: 'itens' }">
        <div class="ws p-0">
            <div class="flex border-b border-slate-200 px-4 pt-2 gap-1">
                @foreach (var (key, label, count) in new[] {
                    ("itens",     "Itens",     Model.Detalhe.Itens.Count),
                    ("etiquetas", "Etiquetas", (int)l.TotalUnidades)
                })
                {
                    <button type="button" @@click="tab = '@key'"
                            :class="tab === '@key' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-slate-500 hover:text-slate-700'"
                            class="px-3 py-2 text-sm font-medium border-b-2">
                        @label <span class="text-xs text-slate-400">(@count)</span>
                    </button>
                }
            </div>

            <!-- Itens -->
            <div x-show="tab === 'itens'" class="p-4">
                @if (Model.Detalhe.Itens.Any())
                {
                    <table class="w-full text-sm mb-4">
                        <thead class="text-xs text-slate-500"><tr><th class="text-left py-1">Item</th><th class="text-right py-1">Qtd</th><th class="text-right py-1">Peso/un</th><th class="text-right py-1">Validade</th><th></th></tr></thead>
                        <tbody class="divide-y divide-slate-100">
                        @foreach (var it in Model.Detalhe.Itens)
                        {
                            var isEmbalado = string.Equals(it.TipoEmbalagem, "Embalado", StringComparison.OrdinalIgnoreCase);
                            var pesoFaltando = isEmbalado && (!it.PesoG.HasValue || it.PesoG.Value <= 0);
                            <tr x-data="@($"itemPesoRow({{ itemId: '{it.Id}', loteId: '{l.Id}', pesoAtual: {(it.PesoG.HasValue ? it.PesoG.Value.ToString() : "null")}, podeEditar: {(l.Status == "em_producao" ? "true" : "false")} }})")">
                                <td class="py-2">
                                    <span class="font-medium">@it.Emoji @it.Nome</span>
                                    @if (!string.IsNullOrEmpty(it.Unidade)) { <span class="text-xs text-slate-400">@it.Unidade</span> }
                                    @if (isEmbalado)
                                    {
                                        <span class="ml-2 inline-flex items-center px-1.5 py-0 rounded text-[10px] font-semibold bg-amber-100 text-amber-800 border border-amber-200" title="Produto marcado como Embalado — peso obrigatório por RDC 727/2022">Embalado</span>
                                    }
                                </td>
                                <td class="text-right">@it.Quantidade.ToString("0.##", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</td>
                                <td class="text-right">
                                    @* C2 (R3 + backfill): inline edit do peso. Bloqueado se lote finalizado. *@
                                    <div x-show="!editando">
                                        <span x-show="peso !== null && peso > 0" x-text="peso + 'g'"></span>
                                        @if (pesoFaltando)
                                        {
                                            <span x-show="peso === null || peso <= 0" class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-semibold bg-red-100 text-red-800 border border-red-200" title="Embalado sem peso: RDC 727 exige. Clique em Backfill para preencher.">
                                                ⚠ Sem peso
                                            </span>
                                        }
                                        @if (!isEmbalado && !it.PesoG.HasValue)
                                        {
                                            <span class="text-slate-400">—</span>
                                        }
                                        @if (l.Status == "em_producao")
                                        {
                                            <button type="button" @@click="editando = true; $nextTick(() => $refs.inputPeso.focus())"
                                                    class="ml-1 text-[10px] text-indigo-600 hover:text-indigo-700"
                                                    title="Editar peso">@(pesoFaltando ? "Backfill" : "editar")</button>
                                        }
                                    </div>
                                    <div x-show="editando" x-cloak class="flex items-center gap-1 justify-end">
                                        <input type="number" x-model.number="pesoEdit" x-ref="inputPeso"
                                               min="1" step="1" placeholder="g/un"
                                               class="ui-field text-sm w-20 text-right"
                                               @@keydown.enter.prevent="salvarPeso()"
                                               @@keydown.escape="editando = false; pesoEdit = peso" />
                                        <button type="button" @@click="salvarPeso()" :disabled="salvando" class="text-xs text-emerald-600 hover:text-emerald-700">✓</button>
                                        <button type="button" @@click="editando = false; pesoEdit = peso" class="text-xs text-slate-400 hover:text-slate-600">✕</button>
                                    </div>
                                    <p x-show="erro" x-cloak class="text-[10px] text-red-600 mt-0.5" x-text="erro"></p>
                                </td>
                                <td class="text-right text-xs">@(it.ExpiraEm.HasValue ? it.ExpiraEm.Value.ToLocalTime().ToString("dd/MM/yy") : "—")</td>
                                <td class="text-right">
                                    @if (l.Status == "em_producao")
                                    {
                                        <form asp-action="RemoveItem" asp-controller="Lotes" asp-route-id="@l.Id" asp-route-itemId="@it.Id" method="post" class="inline" data-confirm='{"titulo":"Remover item do lote?","mensagem":"Esta ação não pode ser desfeita.","textoBotao":"Remover","classBotao":"bg-red-600 hover:bg-red-700"}'>
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-xs text-red-600 hover:text-red-700">Remover</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
                else { <p class="text-sm text-slate-500 mb-4">Nenhum item.</p> }

                @if (l.Status == "em_producao")
                {
                    <form asp-action="AddItem" asp-controller="Lotes" asp-route-id="@l.Id" method="post" class="grid grid-cols-12 gap-2 pt-3 border-t">
                        @Html.AntiForgeryToken()
                        <input type="text"   name="nome"          placeholder="Nome *"  required class="ui-field text-sm col-span-4" />
                        <input type="number" name="quantidade"    min="1" required placeholder="Qtd"  class="ui-field text-sm col-span-2" />
                        <input type="text"   name="unidade"       placeholder="Un"      class="ui-field text-sm col-span-1" />
                        <input type="number" name="pesoG"         placeholder="g/un"    class="ui-field text-sm col-span-2" />
                        <input type="number" name="validadeDias"  placeholder="Val (d)" class="ui-field text-sm col-span-1" />
                        <button type="submit" class="app-primary-btn col-span-2 px-3 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">+ Item</button>
                    </form>
                }
            </div>

            <!-- Etiquetas -->
            <div x-show="tab === 'etiquetas'" x-cloak class="p-4">
                @if (Model.Detalhe.Etiquetas.Any())
                {
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
                    @foreach (var e in Model.Detalhe.Etiquetas)
                    {
                        <div class="border border-slate-200 rounded-lg p-2 text-xs">
                            <div class="font-mono text-slate-700">@e.Codigo</div>
                            <div class="flex items-center justify-between mt-1">
                                <span class="px-1.5 py-0.5 rounded-full text-[10px] font-medium @etqStatusClass(e.Status)">@e.Status</span>
                                <span class="text-slate-400">#@e.Sequencial</span>
                            </div>
                            @if (e.ConferidaEm.HasValue)
                            {
                                <div class="text-[10px] text-slate-400 mt-1">@e.ConferidaEm.Value.ToLocalTime().ToString("dd/MM HH:mm") @(string.IsNullOrEmpty(e.ConferidaPorNome) ? "" : "· " + e.ConferidaPorNome)</div>
                            }
                            @if (!string.IsNullOrEmpty(e.ObservacaoConferencia))
                            {
                                <div class="text-[10px] text-amber-800 mt-1">⚠ @e.ObservacaoConferencia</div>
                            }
                        </div>
                    }
                    </div>
                }
                else
                {
                    <p class="text-sm text-slate-500">
                        @if (l.Status == "em_producao") { <text>Etiquetas serão geradas ao finalizar o lote.</text> }
                        else { <text>Nenhuma etiqueta.</text> }
                    </p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// C2 (R3 + backfill): inline edit do peso de um item de lote. Bloqueado
// se lote ja finalizado (server retorna 422 LOTE_FINALIZADO).
function itemPesoRow({ itemId, loteId, pesoAtual, podeEditar }) {
    return {
        editando: false,
        salvando: false,
        peso: pesoAtual,
        pesoEdit: pesoAtual,
        erro: '',
        async salvarPeso() {
            this.erro = '';
            const novo = parseInt(this.pesoEdit, 10);
            if (!novo || novo <= 0) { this.erro = 'Peso > 0.'; return; }
            if (!podeEditar) { this.erro = 'Lote ja finalizado.'; return; }
            this.salvando = true;
            try {
                const token = document.querySelector('[name=__RequestVerificationToken]')?.value;
                const res = await esFetch(`/lotes/${loteId}/itens/${itemId}/peso`, {
                    method: 'PATCH',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ pesoG: novo })
                });
                const data = await res.json().catch(() => ({}));
                if (res.ok && data.success) {
                    this.peso = novo;
                    this.editando = false;
                    if (window.showToast) window.showToast('Peso atualizado.', 'success');
                } else {
                    this.erro = (data.error && data.error.message) || 'Falha ao salvar.';
                }
            } catch {
                this.erro = 'Sem conexão.';
            } finally {
                this.salvando = false;
            }
        }
    };
}
</script>
}
