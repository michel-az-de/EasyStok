@model EasyStock.Web.Models.ViewModels.ConfiguracaoFiscal.ConfiguracaoFiscalViewModel
@*
    Aba "Fiscal" de Configurações (ADR-0032 fatia 8; reskin #590 para o DS navy+laranja).
    Os formulários continuam POSTando para /configuracao-fiscal/* (ConfiguracaoFiscalController),
    que redireciona de volta para /configuracoes?tab=fiscal com Toast. Apenas reskin estrutural:
    endpoints, name= de campos, data-cep-* e a lógica disabled do regime são preservados 1:1.
*@
@{
    var habilitada = Model.Habilitada;
    var podeHabilitar = Model.PodeHabilitar;

    var heroMod = habilitada ? "cfg-hero--ok" : (podeHabilitar ? "cfg-hero--warn" : "");
    var heroIco = habilitada ? "shield-check" : (podeHabilitar ? "zap" : "file-text");
    var heroIcoMod = (!habilitada && podeHabilitar) ? "cfg-ico--accent" : "";
    var statusBadge = habilitada ? "badge-ok" : (podeHabilitar ? "badge-warn" : "badge-neutral");
    var statusTexto = habilitada ? "Emissão ativa" : (podeHabilitar ? "Pronta — habilite" : "Configure para começar");
    var heroTitulo = habilitada ? "Emissão de NFC-e ativa" : (podeHabilitar ? "Configuração pronta" : "Configuração fiscal");
    var heroSub = habilitada
        ? "Suas notas podem ser emitidas normalmente."
        : (podeHabilitar ? "Falta só habilitar a emissão (passo 6 abaixo)." : "Defina regime, emitente, provedor e CSC para liberar a emissão de NFC-e.");

    var provedorAtual = (Model.Provedor ?? "mock").ToLowerInvariant();
}

<!-- Status-first -->
<div class="cfg-hero @heroMod">
    <span class="cfg-ico @heroIcoMod"><es-icon name="@heroIco"></es-icon></span>
    <div class="cfg-hero__txt">
        <h2>@heroTitulo</h2>
        <p>@heroSub</p>
    </div>
    <span class="badge @statusBadge">@statusTexto</span>
</div>

@if (Model.IsMock)
{
    <div class="cfg-note cfg-note--info" style="margin-bottom:18px;">
        <es-icon name="info"></es-icon>
        <div>
            <strong>Modo simulação ativo.</strong> O provedor "mock" emite notas fictícias sem
            chamar a SEFAZ — use para validar o fluxo end-to-end no admin sem certificado real.
            Em produção, troque para "focus" e cadastre o certificado A1.
        </div>
    </div>
}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <!-- Passo 1: Dados do emitente -->
    <section class="ws">
        <div class="cfg-sec__hd" style="margin-bottom:16px;">
            <span class="cfg-ico"><es-icon name="building-2"></es-icon></span>
            <div class="cfg-sec__txt">
                <span class="cfg-eyebrow">Passo 1</span>
                <h2>Dados do emitente</h2>
            </div>
        </div>

        <form method="post" action="/configuracao-fiscal/dados-emitente">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="cfg-label" for="regimeTributario">Regime tributário</label>
                <select id="regimeTributario" name="regimeTributario" class="ui-select"
                        @(Model.Configurado ? "disabled" : "")>
                    @{
                        var regimes = new[] { "Simples", "MicroempreendedorIndividual", "LucroPresumido", "LucroReal" };
                        var regimeAtual = Model.RegimeTributario ?? "Simples";
                    }
                    @foreach (var r in regimes)
                    {
                        if (r == regimeAtual)
                        {
                            <option value="@r" selected>@r</option>
                        }
                        else
                        {
                            <option value="@r">@r</option>
                        }
                    }
                </select>
                @if (Model.Configurado)
                {
                    <input type="hidden" name="regimeTributario" value="@regimeAtual" />
                    <p class="cfg-help-inline">Regime não pode ser alterado após criado (afeta CST/CSOSN de notas já emitidas).</p>
                }
            </div>

            <div class="grid grid-cols-2 gap-3 mb-3">
                <div>
                    <label class="cfg-label" for="inscricaoEstadual">Inscrição Estadual</label>
                    <input type="text" id="inscricaoEstadual" name="inscricaoEstadual" value="@Model.InscricaoEstadual"
                           placeholder="ISENTO ou número" class="ui-field" />
                </div>
                <div>
                    <label class="cfg-label" for="inscricaoMunicipal">Inscrição Municipal</label>
                    <input type="text" id="inscricaoMunicipal" name="inscricaoMunicipal" value="@Model.InscricaoMunicipal"
                           placeholder="opcional" class="ui-field" />
                </div>
            </div>

            <fieldset class="cfg-fieldset mb-3">
                <legend>Endereço do emitente</legend>
                <div class="grid grid-cols-3 gap-2 mb-2">
                    <div class="col-span-2">
                        <label class="cfg-label" for="logradouro">Logradouro</label>
                        <input type="text" id="logradouro" name="logradouro" value="@Model.Endereco?.Logradouro" class="ui-field" />
                    </div>
                    <div>
                        <label class="cfg-label" for="numero">Número</label>
                        <input type="text" id="numero" name="numero" value="@Model.Endereco?.Numero" class="ui-field" />
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-2 mb-2">
                    <div>
                        <label class="cfg-label" for="complemento">Complemento</label>
                        <input type="text" id="complemento" name="complemento" value="@Model.Endereco?.Complemento" class="ui-field" />
                    </div>
                    <div>
                        <label class="cfg-label" for="bairro">Bairro</label>
                        <input type="text" id="bairro" name="bairro" value="@Model.Endereco?.Bairro" class="ui-field" />
                    </div>
                </div>
                <div class="grid grid-cols-4 gap-2">
                    <div class="col-span-2">
                        <label class="cfg-label" for="cidade">Cidade</label>
                        <input type="text" id="cidade" name="cidade" value="@Model.Endereco?.Cidade" class="ui-field" />
                    </div>
                    <div>
                        <label class="cfg-label" for="uf">UF</label>
                        <input type="text" id="uf" name="uf" value="@Model.Endereco?.Uf" maxlength="2" class="ui-field uppercase" />
                    </div>
                    <div>
                        <label class="cfg-label" for="cep">CEP</label>
                        <input type="text" id="cep" name="cep" value="@Model.Endereco?.Cep" maxlength="9"
                               placeholder="00000-000" data-mask="cep" inputmode="numeric"
                               data-cep-autofill
                               data-cep-logradouro='[name="logradouro"]'
                               data-cep-bairro='[name="bairro"]'
                               data-cep-cidade='[name="cidade"]'
                               data-cep-uf='[name="uf"]'
                               data-cep-focus='[name="numero"]'
                               class="ui-field" />
                    </div>
                </div>
            </fieldset>

            <button type="submit" class="btn btn-navy btn-sm">Salvar dados do emitente</button>
        </form>
    </section>

    <!-- Passo 2: Provedor SEFAZ -->
    <section class="ws">
        <div class="cfg-sec__hd" style="margin-bottom:16px;">
            <span class="cfg-ico"><es-icon name="server"></es-icon></span>
            <div class="cfg-sec__txt">
                <span class="cfg-eyebrow">Passo 2</span>
                <h2>Provedor SEFAZ</h2>
            </div>
        </div>

        <form method="post" action="/configuracao-fiscal/provedor">
            @Html.AntiForgeryToken()

            <p class="cfg-help-inline" style="margin-bottom:14px;">
                Em desenvolvimento, prefira "mock" — emite notas simuladas sem credenciais reais.
                Em produção, use "focus" com token Focus NFe + certificado A1 cadastrados.
            </p>

            <div class="space-y-2" style="margin-bottom:16px;">
                @{
                    var provedores = new[] {
                        ("mock", "Mock (simulação)", "Resposta sintética, sem chamar a SEFAZ. Apenas Sandbox."),
                        ("focus", "Focus NFe", "Provedor real. Requer token Focus + certificado A1."),
                        ("enotas", "eNotas", "Provedor real (em desenvolvimento — não implementado).")
                    };
                }
                @foreach (var (id, nome, desc) in provedores)
                {
                    var on = provedorAtual == id;
                    var disabled = id == "enotas";
                    <label class="cfg-choice @(on ? "cfg-choice--on" : "") @(disabled ? "cfg-choice--disabled" : "")">
                        <input type="radio" name="provedor" value="@id" class="mt-1" @(on ? "checked" : "") @(disabled ? "disabled" : "") />
                        <div>
                            <div class="cfg-choice__name">@nome</div>
                            <div class="cfg-choice__desc">@desc</div>
                        </div>
                    </label>
                }
            </div>

            <button type="submit" class="btn btn-navy btn-sm">Salvar provedor</button>
        </form>
    </section>

    <!-- Passo 3: Série + Ambiente -->
    <section class="ws">
        <div class="cfg-sec__hd" style="margin-bottom:16px;">
            <span class="cfg-ico"><es-icon name="hash"></es-icon></span>
            <div class="cfg-sec__txt">
                <span class="cfg-eyebrow">Passo 3</span>
                <h2>Série e ambiente</h2>
            </div>
        </div>

        <form method="post" action="/configuracao-fiscal/serie-ambiente">
            @Html.AntiForgeryToken()

            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="cfg-label" for="serieNfce">Série NFC-e</label>
                    <input type="number" id="serieNfce" name="serieNfce" value="@Model.SerieNfce" min="1" max="999" class="ui-field" />
                    <p class="cfg-help-inline">Próximo número: <strong>@Model.ProximoNumeroNfce</strong></p>
                </div>
                <div>
                    <label class="cfg-label" for="ambiente">Ambiente</label>
                    <select id="ambiente" name="ambiente" class="ui-select">
                        @{
                            var ambienteAtual = Model.Ambiente ?? "Sandbox";
                        }
                        @if (ambienteAtual == "Sandbox") { <option value="Sandbox" selected>Sandbox / Homologação</option> } else { <option value="Sandbox">Sandbox / Homologação</option> }
                        @if (ambienteAtual == "Production") { <option value="Production" selected>Produção (SEFAZ real)</option> } else { <option value="Production">Produção (SEFAZ real)</option> }
                    </select>
                </div>
            </div>

            <button type="submit" class="btn btn-navy btn-sm" style="margin-top:14px;">Salvar série e ambiente</button>
        </form>
    </section>

    <!-- Passo 4: CSC (NFC-e) -->
    <section class="ws">
        <div class="cfg-sec__hd" style="margin-bottom:16px;">
            <span class="cfg-ico"><es-icon name="key"></es-icon></span>
            <div class="cfg-sec__txt">
                <span class="cfg-eyebrow">Passo 4</span>
                <h2>CSC — Código de Segurança do Contribuinte</h2>
            </div>
        </div>

        <form method="post" action="/configuracao-fiscal/csc">
            @Html.AntiForgeryToken()

            <p class="cfg-help-inline" style="margin-bottom:14px;">
                Usado na geração do QR Code da NFC-e. Você obtém CSC ID e Token no portal da SEFAZ
                do seu estado. Em modo simulação, use valores fictícios (ex.: ID "000001").
            </p>

            <div class="mb-3">
                <label class="cfg-label" for="cscId">CSC ID</label>
                <input type="text" id="cscId" name="cscId" value="@Model.CscId" placeholder="000001" class="ui-field" />
            </div>
            <div class="mb-3">
                <label class="cfg-label" for="cscToken">CSC Token</label>
                <input type="text" id="cscToken" name="cscToken"
                       placeholder="@(Model.TemCsc ? "(token cadastrado — preencha para substituir)" : "token SEFAZ")"
                       class="ui-field" style="font-family:var(--font-mono);" />
                @if (Model.TemCsc)
                {
                    <p class="cfg-help-inline" style="color:var(--ok-700);">CSC já cadastrado.</p>
                }
            </div>

            <button type="submit" class="btn btn-navy btn-sm">Salvar CSC</button>
        </form>
    </section>

    <!-- Passo 5: Certificado A1 -->
    <section class="ws lg:col-span-2">
        <div class="cfg-sec__hd" style="margin-bottom:16px;">
            <span class="cfg-ico"><es-icon name="shield-check"></es-icon></span>
            <div class="cfg-sec__txt">
                <span class="cfg-eyebrow">Passo 5</span>
                <h2>Certificado digital A1</h2>
            </div>
        </div>

        @if (Model.IsMock)
        {
            <div class="cfg-note cfg-note--info">
                <es-icon name="info"></es-icon>
                <div>
                    O provedor "mock" não requer certificado A1. Em produção, troque o provedor para
                    "focus" e faça upload do .pfx via API
                    <code class="t-mono" style="background:var(--ink-100);padding:1px 6px;border-radius:6px;">POST /api/configuracao-fiscal/certificado</code>
                    (upload via UI vem na próxima onda).
                </div>
            </div>
        }
        else if (Model.Certificado is not null)
        {
            var diasRest = Model.Certificado.DiasParaExpirar ?? 0;
            var corBadge = diasRest < 7 ? "badge-crit" : (diasRest < 30 ? "badge-warn" : "badge-ok");
            <div class="flex items-center justify-between gap-4" style="padding:16px;border:1px solid var(--border-soft);border-radius:var(--radius-control);background:var(--surface-sunken);">
                <div>
                    <p class="cfg-row__label">Certificado cadastrado</p>
                    <p class="cfg-help-inline">Válido até @Model.Certificado.ValidoAte?.ToString("dd/MM/yyyy") (@diasRest dias restantes)</p>
                </div>
                <span class="badge @corBadge">@(diasRest < 7 ? "Expirando" : diasRest < 30 ? "Atenção" : "OK")</span>
            </div>
        }
        else
        {
            <div class="cfg-note cfg-note--warn">
                <es-icon name="alert-triangle"></es-icon>
                <div>
                    <strong>Certificado A1 não cadastrado.</strong> Em produção com provedor real,
                    faça upload do arquivo .pfx via API. Suporte a upload via UI vem na próxima onda.
                </div>
            </div>
        }
    </section>

</div>

<!-- Passo 6: Habilitar / Desabilitar -->
<section class="ws" style="margin-top:18px;">
    <div class="cfg-sec__hd" style="margin-bottom:16px;">
        <span class="cfg-ico @(podeHabilitar && !habilitada ? "cfg-ico--accent" : "")"><es-icon name="zap"></es-icon></span>
        <div class="cfg-sec__txt">
            <span class="cfg-eyebrow">Passo 6</span>
            <h2>Habilitar emissão</h2>
        </div>
    </div>

    @if (habilitada)
    {
        <p class="t-small" style="margin-bottom:14px;">
            A emissão fiscal está <strong style="color:var(--ok-700);">ativa</strong>.
            Notas podem ser emitidas pela tela <a href="/notas-fiscais" style="color:var(--action-accent);font-weight:600;">Notas Fiscais</a>.
        </p>
        <form method="post" action="/configuracao-fiscal/desabilitar" onsubmit="return confirm('Desabilitar a emissão? Nenhuma nota poderá ser emitida até reabilitar.');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger btn-sm">Desabilitar emissão</button>
        </form>
    }
    else if (podeHabilitar)
    {
        <p class="t-small" style="margin-bottom:14px;">
            A configuração mínima está completa (IE + endereço com CEP e UF).
            Clique abaixo para liberar a emissão de NFC-e.
        </p>
        <form method="post" action="/configuracao-fiscal/habilitar">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success btn-sm">
                <span style="display:inline-flex;align-items:center;gap:8px;"><es-icon name="check" class="es-icon--sm"></es-icon> Habilitar emissão</span>
            </button>
        </form>
    }
    else
    {
        <div class="cfg-note cfg-note--warn">
            <es-icon name="alert-triangle"></es-icon>
            <div>
                <strong>Configuração incompleta.</strong> Preencha pelo menos:
                <ul style="list-style:disc;margin:8px 0 0;padding-left:20px;line-height:1.6;">
                    @if (string.IsNullOrWhiteSpace(Model.InscricaoEstadual))
                    {
                        <li>Inscrição Estadual (use "ISENTO" se for o caso)</li>
                    }
                    @if (Model.Endereco is null || string.IsNullOrWhiteSpace(Model.Endereco.Cep) || string.IsNullOrWhiteSpace(Model.Endereco.Uf))
                    {
                        <li>Endereço com CEP e UF</li>
                    }
                </ul>
            </div>
        </div>
    }
</section>
