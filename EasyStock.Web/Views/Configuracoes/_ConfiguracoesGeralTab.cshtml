@model ConfiguracoesViewModel
@*
    Aba "Geral" de Configurações (ADR-0032 fatia 8; reskin #590 para o DS navy+laranja).
    POST para /configuracoes (ConfiguracoesController.Salvar) com os campos sem prefixo
    (binda direto em ConfiguracoesViewModel). Toggles mantêm o par hidden-input +
    button[role=switch] (estado via Alpine) — os name= são idênticos ao backend.
*@
<form asp-action="Salvar" asp-controller="Configuracoes" method="post"
      class="settings-form" x-data="{ loading: false }" @@submit="loading = true">
    @Html.AntiForgeryToken()

    <div class="cfg-stack">

        <!-- Alertas de Estoque -->
        <section class="ws">
            <div class="cfg-sec__hd">
                <span class="cfg-ico"><es-icon name="package"></es-icon></span>
                <div class="cfg-sec__txt">
                    <span class="cfg-eyebrow">Estoque</span>
                    <h2>Alertas de estoque</h2>
                    <p>Limiares que definem quando um produto entra em atenção, crítico, validade próxima ou parado.</p>
                </div>
            </div>
            <div class="cfg-rows">
                <div class="cfg-row">
                    <div class="cfg-row__txt">
                        <div class="cfg-row__label">Validade próxima (dias)</div>
                        <p class="cfg-row__help">Produtos com validade em menos de X dias serão destacados.</p>
                    </div>
                    <div class="cfg-row__ctrl">
                        <input asp-for="DiasAlertaValidade" type="number" min="1" max="365" class="ui-field cfg-num" />
                    </div>
                </div>
                <div class="cfg-row">
                    <div class="cfg-row__txt">
                        <div class="cfg-row__label">Produto parado (dias sem movimentação)</div>
                        <p class="cfg-row__help">Produtos sem saída há mais de X dias serão marcados como "parados".</p>
                    </div>
                    <div class="cfg-row__ctrl">
                        <input asp-for="DiasAlertaParado" type="number" min="1" max="365" class="ui-field cfg-num" />
                    </div>
                </div>
                <div class="cfg-row">
                    <div class="cfg-row__txt">
                        <div class="cfg-row__label">Quantidade mínima padrão</div>
                        <p class="cfg-row__help">Usada quando o produto não tem estoque mínimo definido. Abaixo deste valor o item entra em <strong>Atenção</strong>.</p>
                    </div>
                    <div class="cfg-row__ctrl">
                        <input asp-for="QtyMinPadrao" type="number" min="0" max="9999" class="ui-field cfg-num" />
                    </div>
                </div>
                <div class="cfg-row">
                    <div class="cfg-row__txt">
                        <div class="cfg-row__label">Quantidade crítica padrão</div>
                        <p class="cfg-row__help">Igual ou abaixo deste valor o item fica em <strong>Crítico</strong>. Deve ser menor que a quantidade mínima.</p>
                    </div>
                    <div class="cfg-row__ctrl">
                        <input asp-for="QtyCritPadrao" type="number" min="0" max="9999" class="ui-field cfg-num" />
                    </div>
                </div>
            </div>
        </section>

        <!-- Notificações -->
        <section class="ws">
            <div class="cfg-sec__hd">
                <span class="cfg-ico"><es-icon name="bell"></es-icon></span>
                <div class="cfg-sec__txt">
                    <span class="cfg-eyebrow">Notificações</span>
                    <h2>Notificações push</h2>
                    <p>Escolha quais eventos disparam um aviso no aplicativo.</p>
                </div>
            </div>
            <div class="cfg-rows">
                @{
                    var toggles = new[]
                    {
                        (asp: "NotifEstoqueCritico", label: "Estoque crítico", desc: "Quando um produto atingir o estoque mínimo"),
                        (asp: "NotifValidade", label: "Validade próxima", desc: "Quando produtos estiverem próximos do vencimento"),
                        (asp: "NotifParado", label: "Produto parado", desc: "Quando um produto ficar sem movimentação"),
                        (asp: "NotifReposicao", label: "Sugestão de reposição", desc: "Recomendações automáticas de recompra")
                    };
                }
                @foreach (var t in toggles)
                {
                    var propVal = t.asp switch
                    {
                        "NotifEstoqueCritico" => Model.NotifEstoqueCritico,
                        "NotifValidade" => Model.NotifValidade,
                        "NotifParado" => Model.NotifParado,
                        "NotifReposicao" => Model.NotifReposicao,
                        _ => false
                    };
                    <div class="cfg-row" x-data="{ on: @propVal.ToString().ToLower() }">
                        <div class="cfg-row__txt">
                            <div class="cfg-row__label">@t.label</div>
                            <p class="cfg-row__help">@t.desc</p>
                        </div>
                        <div class="cfg-row__ctrl">
                            <input type="hidden" name="@t.asp" :value="on ? 'true' : 'false'" />
                            <button type="button" role="switch" :aria-checked="on.toString()"
                                    aria-label="@t.label" @@click="on = !on" class="cfg-toggle">
                                <span class="cfg-toggle__dot"></span>
                            </button>
                        </div>
                    </div>
                }
            </div>
        </section>

        <!-- Operacional -->
        <section class="ws" x-data="{ fifo: @Model.Fifo.ToString().ToLower(), kds: @Model.KdsHabilitado.ToString().ToLower() }">
            <div class="cfg-sec__hd">
                <span class="cfg-ico"><es-icon name="sliders-horizontal"></es-icon></span>
                <div class="cfg-sec__txt">
                    <span class="cfg-eyebrow">Operação</span>
                    <h2>Regras operacionais</h2>
                    <p>Estratégia de saída do estoque e módulo de produção.</p>
                </div>
            </div>
            <div class="cfg-rows">
                <div class="cfg-row">
                    <div class="cfg-row__txt">
                        <div class="cfg-row__label">Estratégia de saída: <span x-text="fifo ? 'FEFO (primeiro a vencer)' : 'FIFO (primeiro a entrar)'"></span></div>
                        <p class="cfg-row__help" x-text="fifo ? 'Reduz perdas por vencimento — recomendado para produtos perecíveis.' : 'Prioriza os lotes mais antigos, independente da validade.'"></p>
                    </div>
                    <div class="cfg-row__ctrl">
                        <input type="hidden" name="Fifo" :value="fifo ? 'true' : 'false'" />
                        <button type="button" role="switch" :aria-checked="fifo.toString()"
                                aria-label="Estratégia de saída FEFO" @@click="fifo = !fifo" class="cfg-toggle">
                            <span class="cfg-toggle__dot"></span>
                        </button>
                    </div>
                </div>
                <div class="cfg-row">
                    <div class="cfg-row__txt">
                        <div class="cfg-row__label">Produção / KDS habilitado</div>
                        <p class="cfg-row__help">Ativa o fluxo de cozinha (KDS) e adapta o "Meu dia" do menu para produção (pedidos, KDS, lotes e estoque).</p>
                    </div>
                    <div class="cfg-row__ctrl">
                        <input type="hidden" name="KdsHabilitado" :value="kds ? 'true' : 'false'" />
                        <button type="button" role="switch" :aria-checked="kds.toString()"
                                aria-label="Produção / KDS habilitado" @@click="kds = !kds" class="cfg-toggle">
                            <span class="cfg-toggle__dot"></span>
                        </button>
                    </div>
                </div>
            </div>
        </section>

    </div>

    <div class="cfg-savebar">
        <span class="cfg-savebar__hint">
            <es-icon name="info"></es-icon>
            As alterações valem para a loja atual.
        </span>
        <button type="submit" class="btn btn-primary btn-sm" :disabled="loading" :aria-busy="loading.toString()">
            <span x-show="!loading" style="display:inline-flex;align-items:center;gap:8px;">
                <es-icon name="save" class="es-icon--sm"></es-icon> Salvar configurações
            </span>
            <span x-show="loading" x-cloak>Salvando…</span>
        </button>
    </div>
</form>
