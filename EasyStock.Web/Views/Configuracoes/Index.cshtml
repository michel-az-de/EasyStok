@model ConfiguracoesViewModel
@{
    ViewBag.Title = "Configurações";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Configurações</h1>
        <p>Ajuste alertas, notificações e regras operacionais</p>
    </div>
</div>

<form asp-action="Salvar" asp-controller="Configuracoes" method="post" class="settings-form space-y-6" x-data="{ loading: false }" @@submit="loading = true">
    @Html.AntiForgeryToken()

    <!-- Alertas de Estoque -->
    <div class="ws">
        <h2 class="font-semibold text-slate-900 mb-4">Alertas de Estoque</h2>
        <div class="space-y-4">
            <div class="flex items-start gap-4">
                <div class="flex-1">
                    <label asp-for="DiasAlertaValidade"
                           class="block text-sm font-medium text-slate-700 mb-1">
                        Alertar produtos perto da validade (dias)
                    </label>
                    <p class="text-xs text-slate-500 mb-2">
                        Produtos com validade em menos de X dias serão destacados.
                    </p>
                </div>
                <input asp-for="DiasAlertaValidade" type="number" min="1" max="365"
                       class="ui-field w-24 text-center text-sm" />
            </div>
            <div class="flex items-start gap-4">
                <div class="flex-1">
                    <label asp-for="DiasAlertaParado"
                           class="block text-sm font-medium text-slate-700 mb-1">
                        Alertar produtos parados (dias sem movimentação)
                    </label>
                    <p class="text-xs text-slate-500 mb-2">
                        Produtos sem saída há mais de X dias serão marcados como "parados".
                    </p>
                </div>
                <input asp-for="DiasAlertaParado" type="number" min="1" max="365"
                       class="ui-field w-24 text-center text-sm" />
            </div>
            <div class="flex items-start gap-4">
                <div class="flex-1">
                    <label asp-for="QtyMinPadrao"
                           class="block text-sm font-medium text-slate-700 mb-1">
                        Quantidade mínima padrão para reposição
                    </label>
                    <p class="text-xs text-slate-500 mb-2">
                        Usado quando o produto não tem estoque mínimo definido. Abaixo deste valor o item entra em status <strong>Atenção</strong>.
                    </p>
                </div>
                <input asp-for="QtyMinPadrao" type="number" min="0" max="9999"
                       class="ui-field w-24 text-center text-sm" />
            </div>
            <div class="flex items-start gap-4">
                <div class="flex-1">
                    <label asp-for="QtyCritPadrao"
                           class="block text-sm font-medium text-slate-700 mb-1">
                        Quantidade crítica padrão
                    </label>
                    <p class="text-xs text-slate-500 mb-2">
                        Igual ou abaixo deste valor o item fica em status <strong>Crítico</strong>. Deve ser menor que a quantidade mínima.
                    </p>
                </div>
                <input asp-for="QtyCritPadrao" type="number" min="0" max="9999"
                       class="ui-field w-24 text-center text-sm" />
            </div>
        </div>
    </div>

    <!-- Notificações -->
    <div class="ws" x-data="{}">
        <h2 class="font-semibold text-slate-900 mb-4">Notificações Push</h2>
        <div class="space-y-3">
            @{
                var toggles = new[]
                {
                    (asp: "NotifEstoqueCritico", label: "Estoque crítico", desc: "Quando um produto atingir o estoque mínimo"),
                    (asp: "NotifValidade", label: "Validade próxima", desc: "Quando produtos estiverem próximos do vencimento"),
                    (asp: "NotifParado", label: "Produto parado", desc: "Quando um produto ficar sem movimentação"),
                    (asp: "NotifReposicao", label: "Sugestão de reposição", desc: "Recomendações automáticas de recompra")
                };
            }
            @foreach (var t in toggles)
            {
                <div class="flex items-center justify-between py-2">
                    <div>
                        <div class="text-sm font-medium text-slate-700">@t.label</div>
                        <div class="text-xs text-slate-500">@t.desc</div>
                    </div>
                    @{
                        var propVal = t.asp switch {
                            "NotifEstoqueCritico" => Model.NotifEstoqueCritico,
                            "NotifValidade" => Model.NotifValidade,
                            "NotifParado" => Model.NotifParado,
                            "NotifReposicao" => Model.NotifReposicao,
                            _ => false
                        };
                    }
                    <div x-data="{ on: @propVal.ToString().ToLower() }" class="relative">
                        <input type="hidden" name="@t.asp" :value="on ? 'true' : 'false'" />
                        <button type="button" role="switch" :aria-pressed="on.toString()"
                                :aria-label="'@t.label'" @@click="on = !on"
                                :class="on ? 'bg-indigo-600' : 'bg-slate-200'"
                                class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none">
                            <span :class="on ? 'translate-x-6' : 'translate-x-1'"
                                  class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform shadow"></span>
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Operacional -->
    <div class="ws" x-data="{ fifo: @Model.Fifo.ToString().ToLower(), kds: @Model.KdsHabilitado.ToString().ToLower() }">
        <h2 class="font-semibold text-slate-900 mb-4">Operacional</h2>
        <div class="flex items-center justify-between gap-4 py-2">
            <div class="flex-1 min-w-0">
                <div class="text-sm font-medium text-slate-700">Estratégia de saída: <span x-text="fifo ? 'FEFO (Primeiro a Vencer, Primeiro a Sair)' : 'FIFO (Primeiro a Entrar, Primeiro a Sair)'"></span></div>
                <div class="text-xs text-slate-500" x-text="fifo ? 'Reduz perdas por vencimento — recomendado para produtos perecíveis' : 'Prioriza lotes mais antigos independente da validade'"></div>
            </div>
            <div class="relative">
                <input type="hidden" name="Fifo" :value="fifo ? 'true' : 'false'" />
                <button type="button" @@click="fifo = !fifo"
                        :class="fifo ? 'bg-indigo-600' : 'bg-slate-200'"
                        class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none">
                    <span :class="fifo ? 'translate-x-6' : 'translate-x-1'"
                          class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform shadow"></span>
                </button>
            </div>
        </div>
        <div class="flex items-center justify-between gap-4 py-2 mt-2 pt-4 border-t border-slate-100">
            <div class="flex-1 min-w-0">
                <div class="text-sm font-medium text-slate-700">Produção / KDS habilitado</div>
                <div class="text-xs text-slate-500">Ativa o fluxo de cozinha (KDS) e adapta o "Meu dia" do menu para produção (pedidos, KDS, lotes e estoque).</div>
            </div>
            <div class="relative">
                <input type="hidden" name="KdsHabilitado" :value="kds ? 'true' : 'false'" />
                <button type="button" @@click="kds = !kds"
                        :class="kds ? 'bg-indigo-600' : 'bg-slate-200'"
                        class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none">
                    <span :class="kds ? 'translate-x-6' : 'translate-x-1'"
                          class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform shadow"></span>
                </button>
            </div>
        </div>
    </div>

    <div class="flex justify-end">
        <button type="submit"
                :disabled="loading"
                :class="{ 'opacity-50 cursor-not-allowed': loading }"
                class="px-6 py-2.5 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 text-sm">
            <span x-show="!loading">Salvar Configurações</span>
            <span x-show="loading" x-cloak class="flex items-center gap-2">
                <span class="spinner"></span> Salvando...
            </span>
        </button>
    </div>
</form>
