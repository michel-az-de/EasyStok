@model AnalyticsViewModel
@{
    ViewBag.Title = "Analytics";
    Layout = "_Layout";
    var ptBR = new System.Globalization.CultureInfo("pt-BR");
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Analytics</h1>
    <a asp-action="Movimentacoes" asp-controller="Analytics"
       class="text-sm text-indigo-600 hover:text-indigo-700 font-medium">
        Ver movimentações →
    </a>
</div>

<!-- KPIs do estoque atual -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="ws">
        <div class="kpi-lbl">Receita est. (período)</div>
        <div class="kpi-val text-green-600">R$ @Model.ReceitaEstimadaPeriodo.ToString("N2")</div>
    </div>
    <div class="ws">
        <div class="kpi-lbl">Unid. vendidas (último mês)</div>
        <div class="kpi-val">@Model.UnidadesVendidasMes</div>
    </div>
    <div class="ws">
        <div class="kpi-lbl">Valor em estoque</div>
        <div class="kpi-val text-blue-600">R$ @Model.ValorEstoque.ToString("N2")</div>
    </div>
    <div class="ws">
        <div class="kpi-lbl">Itens em estoque</div>
        <div class="kpi-val">@Model.TotalEstoque</div>
    </div>
</div>

<!-- Projeções derivadas da velocidade média diária -->
<div class="ws mb-6">
    <h2 class="font-semibold text-gray-900 mb-1">Projeções de Demanda</h2>
    <p class="text-xs text-gray-400 mb-4">Baseado na velocidade média de saída: @Model.MediaVendasDiaria.ToString("N1") un./dia</p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="text-center p-3 bg-gray-50 rounded-lg">
            <div class="text-xl font-bold text-gray-900">@Model.ProjUnidadesDia.ToString("N0")</div>
            <div class="text-xs text-gray-500 mt-1">unidades/dia</div>
        </div>
        <div class="text-center p-3 bg-gray-50 rounded-lg">
            <div class="text-xl font-bold text-gray-900">@Model.ProjUnidades7d.ToString("N0")</div>
            <div class="text-xs text-gray-500 mt-1">próximos 7 dias</div>
        </div>
        <div class="text-center p-3 bg-gray-50 rounded-lg">
            <div class="text-xl font-bold text-gray-900">@Model.ProjUnidades30d.ToString("N0")</div>
            <div class="text-xs text-gray-500 mt-1">próximos 30 dias</div>
        </div>
        <div class="text-center p-3 bg-indigo-50 rounded-lg">
            <div class="text-xl font-bold text-indigo-600">R$ @Model.ProjReceita30d.ToString("N2")</div>
            <div class="text-xs text-gray-500 mt-1">receita proj. 30d</div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Reposição urgente -->
    <div class="ws">
        <h2 class="font-semibold text-gray-900 mb-4">Reposição Urgente</h2>
        @if (!Model.ItensReposicaoUrgente.Any())
        {
            <p class="text-sm text-gray-400 text-center py-6">Nenhum item crítico</p>
        }
        else
        {
            <table class="tbl-full">
                <thead>
                    <tr><th>Produto</th><th>Estoque</th><th>Mín.</th><th>Dias</th></tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.ItensReposicaoUrgente.Take(10))
                    {
                        <tr>
                            <td>
                                <div class="font-medium text-sm">@(s.NomeProduto ?? s.CodigoInterno ?? s.ProdutoId)</div>
                            </td>
                            <td class="text-red-600 font-medium">@s.QuantidadeAtual</td>
                            <td class="text-gray-500">@s.QuantidadeMinima</td>
                            <td>
                                @if (s.DiasAteRuptura.HasValue)
                                {
                                    <span class="badge-critical">@s.DiasAteRuptura d</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Alertas -->
    <div class="ws">
        <h2 class="font-semibold text-gray-900 mb-4">Alertas Ativos</h2>
        @if (!Model.Alertas.Any())
        {
            <p class="text-sm text-gray-400 text-center py-6">Sem alertas</p>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var a in Model.Alertas)
                {
                    var alertColor = a.Tipo switch {
                        "critico" => "border-red-300 bg-red-50",
                        "validade" => "border-orange-300 bg-orange-50",
                        _ => "border-yellow-300 bg-yellow-50"
                    };
                    var titleColor = a.Tipo switch {
                        "critico" => "text-red-700",
                        "validade" => "text-orange-700",
                        _ => "text-yellow-700"
                    };
                    <div class="border rounded-lg p-3 @alertColor">
                        <div class="font-medium text-sm @titleColor">@a.Titulo</div>
                        <div class="text-xs text-gray-600 mt-0.5">@a.Mensagem</div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Gráfico receita mensal -->
@if (Model.GraficoLabels.Any())
{
    <div class="ws mb-6">
        <h2 class="font-semibold text-gray-900 mb-4">Receita Bruta — últimos meses</h2>
        <canvas id="grafico-receita-analytics" height="120"></canvas>
    </div>
}

@section Scripts {
    @if (Model.GraficoLabels.Any())
    {
        <script>
            const ctx = document.getElementById('grafico-receita-analytics');
            if (ctx) {
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoLabels)),
                        datasets: [{
                            label: 'Receita Bruta',
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoDados)),
                            backgroundColor: 'rgba(99,102,241,0.7)',
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: {
                                ticks: {
                                    callback: v => 'R$ ' + v.toLocaleString('pt-BR')
                                }
                            }
                        }
                    }
                });
            }
        </script>
    }
}
