@model AnalyticsViewModel
@{
    ViewBag.Title = "Análises";
    Layout = "_Layout";
    var ptBR = new System.Globalization.CultureInfo("pt-BR");
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Análises</h1>
        <p>Tendências, alertas e projeções do seu estoque</p>
    </div>
    <a href="/analytics/movimentacoes"
       class="text-sm text-indigo-600 hover:text-indigo-700 font-medium">
        Ver movimentações →
    </a>
</div>

<!-- KPIs do estoque atual -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="ws">
        <div class="kpi-lbl">Receita no período</div>
        <div class="kpi-val text-green-600">@Model.ReceitaEstimadaPeriodo.ToString("C", ptBR)</div>
    </div>
    <div class="ws">
        <div class="kpi-lbl">Unid. vendidas (último mês)</div>
        <div class="kpi-val">@Model.UnidadesVendidasMes</div>
    </div>
    <div class="ws">
        <div class="kpi-lbl">Valor em estoque</div>
        <div class="kpi-val text-blue-600">@Model.ValorEstoque.ToString("C", ptBR)</div>
    </div>
    <div class="ws">
        <div class="kpi-lbl">Itens em estoque</div>
        <div class="kpi-val">@Model.TotalEstoque</div>
    </div>
</div>

<!-- Projeções derivadas da velocidade média diária -->
@if (Model.MediaVendasDiaria > 0)
{
<div class="ws mb-6">
    <h2 class="font-semibold text-slate-900 mb-1">Projeções de Demanda</h2>
    <p class="text-xs text-slate-400 mb-4">Baseado na velocidade média de saída: @Model.MediaVendasDiaria.ToString("N1") un./dia</p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="text-center p-3 bg-slate-50 rounded-lg border border-slate-100">
            <div class="text-xl font-bold text-slate-900">@Model.ProjUnidadesDia.ToString("N0")</div>
            <div class="text-xs text-slate-500 mt-1">unidades/dia</div>
        </div>
        <div class="text-center p-3 bg-slate-50 rounded-lg border border-slate-100">
            <div class="text-xl font-bold text-slate-900">@Model.ProjUnidades7d.ToString("N0")</div>
            <div class="text-xs text-slate-500 mt-1">próximos 7 dias</div>
        </div>
        <div class="text-center p-3 bg-slate-50 rounded-lg border border-slate-100">
            <div class="text-xl font-bold text-slate-900">@Model.ProjUnidades30d.ToString("N0")</div>
            <div class="text-xs text-slate-500 mt-1">próximos 30 dias</div>
        </div>
        <div class="text-center p-3 bg-indigo-50 rounded-lg border border-indigo-100">
            @if (Model.ReceitaProjetadaDisponivel)
            {
                <div class="text-xl font-bold text-indigo-600">@Model.ProjReceita30d.ToString("C", ptBR)</div>
            }
            else
            {
                <div class="text-sm font-semibold text-slate-500">Receita indisponível</div>
                <div class="text-xs text-slate-400 mt-1">Produtos sem preço cadastrado</div>
                <a href="/produtos" class="text-xs text-indigo-500 hover:underline">Cadastrar preços →</a>
            }
            <div class="text-xs text-slate-500 mt-1">receita proj. 30d</div>
        </div>
    </div>
</div>
}
else
{
<div class="ws mb-6">
    <h2 class="font-semibold text-slate-900 mb-1">Projeções de Demanda</h2>
    <div class="flex flex-col items-center justify-center py-8 text-slate-400">
        <p class="text-sm font-semibold text-slate-500">Sem projeções ainda</p>
        <p class="text-xs mt-1">Registre pelo menos 7 dias de saídas para ver as projeções.</p>
        <a href="/saidas/nova" class="mt-3 text-xs text-indigo-600 hover:text-indigo-700 font-medium">Registrar saída →</a>
    </div>
</div>
}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Reposição urgente -->
    <div class="ws">
        <div class="flex items-center justify-between mb-4">
            <h2 class="font-semibold text-slate-900">Reposição necessária</h2>
            <a href="/listas-compras/nova" class="text-xs text-indigo-600 hover:text-indigo-700 font-medium">Criar lista de compras →</a>
        </div>
        @if (!Model.ItensReposicaoUrgente.Any())
        {
            <div class="text-center py-6 text-slate-400">
                <p class="font-semibold text-slate-500">Tudo em ordem</p>
                <p class="text-xs mt-1">Nenhum produto precisa de reposição agora.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
            <table class="tbl-full">
                <thead>
                    <tr><th>Produto</th><th>Estoque</th><th>Mín.</th><th>Dias</th></tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.ItensReposicaoUrgente.Take(10))
                    {
                        <tr>
                            <td>
                                <div class="font-medium text-sm">@(s.NomeProduto ?? s.CodigoInterno ?? s.ProdutoId)</div>
                            </td>
                            <td class="text-red-600 font-medium">@s.QuantidadeAtual</td>
                            <td class="text-slate-500">@s.QuantidadeMinima</td>
                            <td>
                                @if (s.DiasAteRuptura.HasValue)
                                {
                                    <span class="badge-critical">@s.DiasAteRuptura d</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        }
    </div>

    <!-- Alertas -->
    <div class="ws">
        <h2 class="font-semibold text-slate-900 mb-4">Alertas Ativos</h2>
        @if (!Model.Alertas.Any())
        {
            <div class="text-center py-6 text-slate-400">
                <p class="font-semibold text-slate-500">Sem alertas ativos</p>
                <p class="text-xs mt-1">Tudo certo por aqui.</p>
            </div>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var a in Model.Alertas)
                {
                    var alertColor = a.Tipo switch {
                        "critico" => "border-red-300 bg-red-50",
                        "validade" => "border-orange-300 bg-orange-50",
                        _ => "border-yellow-300 bg-yellow-50"
                    };
                    var titleColor = a.Tipo switch {
                        "critico" => "text-red-700",
                        "validade" => "text-orange-700",
                        _ => "text-yellow-700"
                    };
                    <div class="border rounded-lg p-3 @alertColor">
                        <div class="font-medium text-sm @titleColor">@a.Titulo</div>
                        <div class="text-xs text-slate-600 mt-0.5">@a.Mensagem</div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Gráfico receita mensal -->
@if (Model.GraficoLabels.Any() && Model.GraficoDados.Any(d => d > 0))
{
    <div class="ws mb-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="font-semibold text-slate-900">Receita Bruta</h2>
            <div class="flex gap-1">
                @foreach (var (m, label) in new[] { (3, "3m"), (6, "6m"), (12, "12m") })
                {
                    var isActive = (ViewBag.MesesGrafico as int? ?? 6) == m;
                    <a href="/analytics?meses=@m"
                       class="px-2.5 py-1 text-xs font-medium rounded-lg @(isActive ? "bg-indigo-600 text-white" : "text-slate-500 hover:bg-slate-100")">
                        @label
                    </a>
                }
            </div>
        </div>
        <div style="position:relative;height:220px">
            <canvas id="grafico-receita-analytics"></canvas>
        </div>
    </div>
}

@section Scripts {
    @if (Model.GraficoLabels.Any() && Model.GraficoDados.Any(d => d > 0))
    {
        <script>
            const ctx = document.getElementById('grafico-receita-analytics');
            if (ctx) {
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoLabels)),
                        datasets: [{
                            label: 'Receita Bruta',
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoDados)),
                            backgroundColor: 'rgba(30, 72, 168,0.7)',
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: { mode: 'index', intersect: false },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: ctx => ' R$ ' + ctx.parsed.y.toLocaleString('pt-BR', { minimumFractionDigits: 2 })
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: { callback: v => 'R$ ' + v.toLocaleString('pt-BR') }
                            }
                        }
                    }
                });
            }
        </script>
    }
}
