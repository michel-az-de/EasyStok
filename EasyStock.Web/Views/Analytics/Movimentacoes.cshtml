@model MovimentacoesViewModel
@{
    ViewBag.Title = "Movimentações";
    Layout = "_Layout";
}

<div class="flex items-center gap-3 mb-6">
    <a asp-action="Index" asp-controller="Analytics" class="text-slate-400 hover:text-slate-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <h1 class="text-2xl font-bold text-slate-900">Movimentações</h1>
</div>

<!-- Filtros -->
<form method="get" class="ws mb-6">
    <div class="flex flex-wrap gap-3 items-end">
        <div class="flex gap-2">
            @foreach (var (val, label) in new[] { ("", "Todas"), ("entrada", "Entradas"), ("saida", "Saídas") })
            {
                var isActive = Model.FiltroTipo == val || (val == "" && Model.FiltroTipo == null);
                <a href="@Url.Action("Movimentacoes", "Analytics", new { tipo = val == "" ? null : val, de = Model.PeriodoInicio, ate = Model.PeriodoFim })"
                   class="px-3 py-1.5 rounded-full text-sm font-medium @(isActive ? "bg-indigo-600 text-white" : "bg-white border border-slate-300 text-slate-700 hover:bg-slate-50")">
                    @label
                </a>
            }
        </div>
        <div class="flex gap-2 items-center ml-auto">
            <input type="date" name="de" value="@Model.PeriodoInicio"
                   class="border border-slate-300 rounded-lg px-3 py-1.5 text-sm" />
            <span class="text-slate-400 text-sm">a</span>
            <input type="date" name="ate" value="@Model.PeriodoFim"
                   class="border border-slate-300 rounded-lg px-3 py-1.5 text-sm" />
            <button type="submit"
                    class="px-4 py-1.5 bg-slate-100 border border-slate-300 rounded-lg text-sm hover:bg-slate-200">
                Filtrar
            </button>
        </div>
    </div>
</form>

<!-- Tabela -->
<div class="ws">
    @if (!Model.Itens.Any())
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIcon", "📋" },
            { "EmptyTitle", "Nenhuma movimentação encontrada" },
            { "EmptyDescription", "Tente ajustar os filtros ou registre uma nova entrada." },
            { "EmptyCta", "+ Nova Entrada" },
            { "EmptyCtaHref", "/entradas/nova" }
        })
    }
    else
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead>
                <tr>
                    <th>Tipo</th>
                    <th>Resumo</th>
                    <th>Qtd</th>
                    <th>Valor</th>
                    <th>Data</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Itens)
                {
                    var isEntrada = m.Tipo.Contains("entrada", StringComparison.OrdinalIgnoreCase);
                    var tipoIcon = isEntrada ? "↑" : "↓";
                    var tipoColor = isEntrada ? "text-green-600" : "text-red-500";
                    var dataStr = m.Data.ToString("yyyy-MM-dd");
                    var tipoParam = isEntrada ? "entrada" : "saida";
                    <tr class="cursor-pointer hover:bg-slate-50 transition-colors"
                        @@click="window.location.href='/analytics/movimentacoes?de=@dataStr&ate=@dataStr&tipo=@tipoParam'"
                        title="Ver detalhes de @m.Data.ToString("dd/MM/yyyy")">
                        <td>
                            <span class="font-medium @tipoColor">@tipoIcon</span>
                            <span class="text-sm text-slate-600 ml-1">@(m.Tipo == "Saida" ? "Saída" : m.Tipo)</span>
                        </td>
                        <td>
                            <div class="font-medium text-slate-900 text-sm">@m.Resumo</div>
                        </td>
                        <td class="font-medium">@m.Qty</td>
                        <td>
                            @if (m.Valor.HasValue)
                            {
                                <span>R$ @m.Valor.Value.ToString("N2")</span>
                            }
                            else
                            {
                                <span class="text-slate-400">—</span>
                            }
                        </td>
                        <td class="text-slate-500">
                            @m.Data.ToString("dd/MM/yyyy")
                            <svg class="w-3 h-3 inline ml-1 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>

        @if (Model.Paginacao.Pages > 1)
        {
            <div class="flex justify-center gap-2 mt-6">
                @for (int p = 1; p <= Model.Paginacao.Pages; p++)
                {
                    <a href="@Url.Action("Movimentacoes", "Analytics", new { page = p, tipo = Model.FiltroTipo, de = Model.PeriodoInicio, ate = Model.PeriodoFim })"
                       class="px-3 py-1.5 rounded text-sm @(p == Model.Paginacao.Page ? "bg-indigo-600 text-white" : "bg-white border border-slate-300 text-slate-700 hover:bg-slate-50")">
                        @p
                    </a>
                }
            </div>
        }
    }
</div>
