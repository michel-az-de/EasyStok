@model MovimentacoesViewModel
@{
    ViewBag.Title = "Movimentações";
    Layout = "_Layout";
}

<div class="flex items-center gap-3 mb-6">
    <a asp-action="Index" asp-controller="Analytics" class="text-gray-400 hover:text-gray-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <h1 class="text-2xl font-bold text-gray-900">Movimentações</h1>
</div>

<!-- Filtros -->
<form method="get" class="ws mb-6">
    <div class="flex flex-wrap gap-3 items-end">
        <div class="flex gap-2">
            @foreach (var (val, label) in new[] { ("", "Todas"), ("entrada", "Entradas"), ("saida", "Saídas") })
            {
                var isActive = Model.FiltroTipo == val || (val == "" && Model.FiltroTipo == null);
                <a href="@Url.Action("Movimentacoes", "Analytics", new { tipo = val == "" ? null : val, de = Model.PeriodoInicio, ate = Model.PeriodoFim })"
                   class="px-3 py-1.5 rounded-full text-sm font-medium @(isActive ? "bg-indigo-600 text-white" : "bg-white border border-gray-300 text-gray-700 hover:bg-gray-50")">
                    @label
                </a>
            }
        </div>
        <div class="flex gap-2 items-center ml-auto">
            <input type="date" name="de" value="@Model.PeriodoInicio"
                   class="border border-gray-300 rounded-lg px-3 py-1.5 text-sm" />
            <span class="text-gray-400 text-sm">a</span>
            <input type="date" name="ate" value="@Model.PeriodoFim"
                   class="border border-gray-300 rounded-lg px-3 py-1.5 text-sm" />
            <button type="submit"
                    class="px-4 py-1.5 bg-gray-100 border border-gray-300 rounded-lg text-sm hover:bg-gray-200">
                Filtrar
            </button>
        </div>
    </div>
</form>

<!-- Tabela -->
<div class="ws">
    @if (!Model.Itens.Any())
    {
        <div class="text-center py-12 text-gray-400">
            <p class="text-sm">Nenhuma movimentação encontrada</p>
        </div>
    }
    else
    {
        <table class="tbl-full">
            <thead>
                <tr>
                    <th>Tipo</th>
                    <th>Resumo</th>
                    <th>Qtd</th>
                    <th>Valor</th>
                    <th>Data</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Itens)
                {
                    var tipoIcon = m.Tipo.Contains("entrada") || m.Tipo == "entrada"
                        ? "↑" : "↓";
                    var tipoColor = m.Tipo.Contains("entrada") || m.Tipo == "entrada"
                        ? "text-green-600" : "text-red-500";
                    <tr>
                        <td>
                            <span class="font-medium @tipoColor">@tipoIcon</span>
                            <span class="text-sm text-gray-600 ml-1 capitalize">@m.Tipo</span>
                        </td>
                        <td>
                            <div class="font-medium text-gray-900 text-sm">@m.ProdutoNome</div>
                            @if (!string.IsNullOrEmpty(m.VariacaoNome))
                            {
                                <div class="text-xs text-gray-400">@m.VariacaoNome</div>
                            }
                        </td>
                        <td class="font-medium">@m.Qty</td>
                        <td>
                            @if (m.Valor.HasValue)
                            {
                                <span>R$ @m.Valor.Value.ToString("N2")</span>
                            }
                            else
                            {
                                <span class="text-gray-400">—</span>
                            }
                        </td>
                        <td class="text-gray-500">@m.Data.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.Paginacao.Pages > 1)
        {
            <div class="flex justify-center gap-2 mt-6">
                @for (int p = 1; p <= Model.Paginacao.Pages; p++)
                {
                    <a href="@Url.Action("Movimentacoes", "Analytics", new { page = p, tipo = Model.FiltroTipo, de = Model.PeriodoInicio, ate = Model.PeriodoFim })"
                       class="px-3 py-1.5 rounded text-sm @(p == Model.Paginacao.Page ? "bg-indigo-600 text-white" : "bg-white border border-gray-300 text-gray-700 hover:bg-gray-50")">
                        @p
                    </a>
                }
            </div>
        }
    }
</div>
