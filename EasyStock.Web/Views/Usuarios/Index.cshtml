@using EasyStock.Web.Models.Api
@model UsuariosViewModel
@{
    ViewBag.Title = "Usuários";
    Layout = "_Layout";
    var perfis = UsuariosViewModel.PerfisDisponiveis;
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Usuários</h1>
        <p>@Model.TotalAdmins @(Model.TotalAdmins == 1 ? "administrador" : "administradores") · @Model.TotalColaboradores @(Model.TotalColaboradores == 1 ? "colaborador" : "colaboradores")</p>
    </div>
    <button type="button"
            x-data @@click="$dispatch('open-modal', 'convidar')"
            class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
        + Novo Usuário
    </button>
</div>

<div class="ws">
    @if (!Model.Usuarios.Any())
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIcon", "👤" },
            { "EmptyTitle", "Nenhum usuário cadastrado" },
            { "EmptyDescription", "Crie o primeiro usuário para dar acesso à equipe." },
            { "EmptyCta", "+ Novo Usuário" },
            { "EmptyCtaModal", "convidar" }
        })
    }
    else
    {
        <div class="overflow-x-auto users-table-wrap">
        <table class="tbl-full">
            <thead>
                <tr><th>Nome</th><th>Email</th><th>Função</th><th>Perfil / Loja</th><th>Ações</th></tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Usuarios)
                {
                    <tr x-data="{ editando: false, nomeEdit: '@u.Nome', editPerfil: false }">
                        <td class="font-medium text-slate-900">@u.Nome</td>
                        <td class="text-slate-500 text-sm">@u.Email</td>
                        <td>
                            <div x-show="!editando">
                                @{
                                    var (roleLabel, badgeClass) = UsuariosViewModel.GetPerfilDisplay(u.Role);
                                }
                                <span class="px-2 py-0.5 rounded-full text-xs font-medium @badgeClass">
                                    @roleLabel
                                </span>
                            </div>
                            <form action="/usuarios/@u.Id/editar" method="post"
                                  x-show="editando" x-cloak class="flex gap-2 items-center">
                                @Html.AntiForgeryToken()
                                <input type="text" name="nome" x-model="nomeEdit"
                                       class="ui-field border border-slate-300 rounded px-2 py-1 text-xs" required />
                                <button type="submit"
                                        class="app-primary-btn px-2 py-1 bg-indigo-600 text-white text-xs rounded hover:bg-indigo-700">
                                    Salvar
                                </button>
                            </form>
                        </td>
                        <td>
                            <div x-show="!editPerfil">
                                @{
                                    var lojaMatch = Model.Lojas.FirstOrDefault(l => l.Id == u.LojaId);
                                }
                                <span class="text-xs text-slate-500">
                                    @(lojaMatch?.Nome ?? "—")
                                </span>
                                <button type="button" @@click="editPerfil = true"
                                        class="ml-1 text-xs text-indigo-600 hover:text-indigo-700">
                                    Alterar
                                </button>
                            </div>
                            <form action="/usuarios/@u.Id/perfil" method="post"
                                  x-show="editPerfil" x-cloak class="space-y-1">
                                @Html.AntiForgeryToken()
                                <select name="perfilId"
                                        class="ui-select w-full border border-slate-300 rounded px-2 py-1 text-xs">
                                    @foreach (var (val, label, _) in perfis)
                                    {
                                        if (u.Role == val)
                                        {
                                            <option value="@val" selected="selected">@label</option>
                                        }
                                        else
                                        {
                                            <option value="@val">@label</option>
                                        }
                                    }
                                </select>
                                <select name="lojaId"
                                        class="ui-select w-full border border-slate-300 rounded px-2 py-1 text-xs">
                                    <option value="">Sem loja</option>
                                    @foreach (var l in Model.Lojas)
                                    {
                                        if (l.Id == u.LojaId)
                                        {
                                            <option value="@l.Id" selected="selected">@l.Nome</option>
                                        }
                                        else
                                        {
                                            <option value="@l.Id">@l.Nome</option>
                                        }
                                    }
                                </select>
                                <div class="flex gap-1">
                                    <button type="submit"
                                            class="app-primary-btn px-2 py-1 bg-indigo-600 text-white text-xs rounded hover:bg-indigo-700">
                                        Salvar
                                    </button>
                                    <button type="button" @@click="editPerfil = false"
                                            class="px-2 py-1 text-xs text-slate-500 hover:text-slate-700">
                                        Cancelar
                                    </button>
                                </div>
                            </form>
                        </td>
                        <td class="users-actions-cell">
                            <div class="flex items-center gap-3 whitespace-nowrap">
                                <button type="button" @@click="editando = !editando"
                                        class="grid-action-btn grid-action-btn--primary">
                                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                    <span x-text="editando ? 'Cancelar' : 'Editar'"></span>
                                </button>
                                <button type="button"
                                        @@click="$dispatch('confirm-action', { titulo: 'Remover usuário', mensagem: 'Remover <strong>' + nomeEdit + '</strong>? Esta ação revoga o acesso imediatamente.', textoBotao: 'Remover', classBotao: 'bg-red-600 hover:bg-red-700', formAction: '/usuarios/@u.Id/excluir' })"
                                        class="grid-action-btn grid-action-btn--danger">
                                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                    Remover
                                </button>
                            </div>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>

<!-- Modal convidar -->
<div x-data="{ open: false }" @@open-modal.window="open = ($event.detail === 'convidar')"
     x-show="open" x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
     @@click.self="open = false">
    <div class="ui-modal bg-white rounded-xl shadow-xl w-full max-w-md p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Novo Usuário</h2>
        <form asp-action="Convidar" asp-controller="Usuarios" method="post">
            @Html.AntiForgeryToken()
            <div class="space-y-3 mb-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Nome *</label>
                    <input type="text" name="Nome" required
                           class="ui-field w-full text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Email *</label>
                    <input type="email" name="Email" required
                           class="ui-field w-full text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Senha *</label>
                    <input type="password" name="Senha" required
                           class="ui-field w-full text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Perfil</label>
                    <select name="PerfilId"
                            class="ui-select w-full text-sm">
                        @foreach (var (val, label, _) in perfis)
                        {
                            if (val == "Operador")
                            {
                                <option value="@val" selected="selected">@label</option>
                            }
                            else
                            {
                                <option value="@val">@label</option>
                            }
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Loja</label>
                    <select name="LojaId"
                            class="ui-select w-full text-sm">
                        <option value="">Sem loja específica</option>
                        @foreach (var l in Model.Lojas)
                        {
                            <option value="@l.Id">@l.Nome</option>
                        }
                    </select>
                </div>
            </div>
            <div class="flex justify-end gap-3">
                <button type="button" @@click="open = false"
                        class="ui-secondary-btn px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                    Cancelar
                </button>
                <button type="submit" x-data="{ loading: false }" @@click="loading = true"
                        :disabled="loading" :class="{ 'opacity-50 cursor-not-allowed': loading }"
                        class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                    <span x-show="!loading">Novo Usuário</span>
                    <span x-show="loading" x-cloak class="flex items-center gap-2"><span class="spinner"></span> Salvando...</span>
                </button>
            </div>
        </form>
    </div>
</div>
