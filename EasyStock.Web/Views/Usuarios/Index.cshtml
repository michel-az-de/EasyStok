@model UsuariosViewModel
@{
    ViewBag.Title = "Usuários";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold text-slate-900">Usuários</h1>
        <p class="text-sm text-slate-500 mt-1">
            @Model.TotalAdmins @(Model.TotalAdmins == 1 ? "administrador" : "administradores") · @Model.TotalColaboradores @(Model.TotalColaboradores == 1 ? "colaborador" : "colaboradores")
        </p>
    </div>
    <button type="button"
            x-data @@click="$dispatch('open-modal', 'convidar')"
            class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
        + Criar Usuário
    </button>
</div>

<div class="ws">
    @if (!Model.Usuarios.Any())
    {
        <div class="text-center py-12 text-slate-400">
            <div class="text-5xl mb-3">👤</div>
            <p class="font-semibold text-slate-600">Nenhum usuário cadastrado</p>
            <p class="text-sm mt-1">Crie o primeiro usuário para dar acesso à equipe.</p>
            <button type="button"
                    x-data @@click="$dispatch('open-modal', 'convidar')"
                    class="mt-4 inline-block px-4 py-2 text-sm text-indigo-600 border border-indigo-200 rounded-lg hover:bg-indigo-50">
                + Criar Usuário
            </button>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead>
                <tr><th>Nome</th><th>Email</th><th>Função</th><th>Ações</th></tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Usuarios)
                {
                    <tr x-data="{ editando: false, confirm: false, nomeEdit: '@u.Nome' }">
                        <td class="font-medium text-slate-900">@u.Nome</td>
                        <td class="text-slate-500 text-sm">@u.Email</td>
                        <td>
                            <div x-show="!editando">
                                @{
                                    var badgeClass = u.Role switch
                                    {
                                        "SuperAdmin" or "Admin" => "bg-indigo-100 text-indigo-700",
                                        "Gerente" => "bg-amber-100 text-amber-700",
                                        _ => "bg-slate-100 text-slate-600"
                                    };
                                    var roleLabel = u.Role switch
                                    {
                                        "SuperAdmin" => "Super Admin",
                                        "Admin" => "Administrador",
                                        "Gerente" => "Gerente",
                                        _ => "Operador"
                                    };
                                }
                                <span class="px-2 py-0.5 rounded-full text-xs font-medium @badgeClass">
                                    @roleLabel
                                </span>
                            </div>
                            <form asp-action="Editar" asp-controller="Usuarios"
                                  asp-route-id="@u.Id" method="post"
                                  x-show="editando" x-cloak class="flex gap-2 items-center">
                                @Html.AntiForgeryToken()
                                <input type="text" name="nome" x-model="nomeEdit"
                                       class="border border-slate-300 rounded px-2 py-1 text-xs" required />
                                <button type="submit"
                                        class="px-2 py-1 bg-indigo-600 text-white text-xs rounded hover:bg-indigo-700">
                                    Salvar
                                </button>
                            </form>
                        </td>
                        <td>
                            <div class="flex items-center gap-3">
                                <button type="button" @@click="editando = !editando"
                                        class="text-xs text-indigo-600 hover:text-indigo-700">
                                    <span x-text="editando ? 'Cancelar' : 'Editar'"></span>
                                </button>
                                <button type="button" @@click="confirm = true"
                                        class="text-xs text-red-600 hover:text-red-700">Remover</button>
                            </div>

                            <!-- Modal confirmar remoção -->
                            <div x-show="confirm" x-cloak
                                 class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                                 @@click.self="confirm = false">
                                <div class="bg-white rounded-xl p-6 w-80 shadow-xl">
                                    <h3 class="font-semibold text-slate-900 mb-2">Remover usuário</h3>
                                    <p class="text-sm text-slate-600 mb-4">
                                        Remover <strong>@u.Nome</strong>? Esta ação revoga o acesso imediatamente.
                                    </p>
                                    <div class="flex justify-end gap-3">
                                        <button type="button" @@click="confirm = false"
                                                class="px-3 py-1.5 text-sm border rounded-lg hover:bg-slate-50">
                                            Cancelar
                                        </button>
                                        <form asp-action="Excluir" asp-controller="Usuarios"
                                              asp-route-id="@u.Id" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="px-3 py-1.5 bg-red-600 text-white text-sm rounded-lg hover:bg-red-700">
                                                Remover
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>

<!-- Modal convidar -->
<div x-data="{ open: false }" @@open-modal.window="open = ($event.detail === 'convidar')"
     x-show="open" x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
     @@click.self="open = false">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Criar Usuário</h2>
        <form asp-action="Convidar" asp-controller="Usuarios" method="post">
            @Html.AntiForgeryToken()
            <div class="space-y-3 mb-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Nome *</label>
                    <input type="text" name="Nome" required
                           class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Email *</label>
                    <input type="email" name="Email" required
                           class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Senha *</label>
                    <input type="password" name="Senha" required
                           class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
                </div>
            </div>
            <div class="flex justify-end gap-3">
                <button type="button" @@click="open = false"
                        class="px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                    Cancelar
                </button>
                <button type="submit"
                        class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                    Criar Usuário
                </button>
            </div>
        </form>
    </div>
</div>
