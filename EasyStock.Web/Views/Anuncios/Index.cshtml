@model AnunciosViewModel
@{
    ViewBag.Title = "Anúncios IA";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold text-slate-900">Anúncios IA ✨</h1>
        <p class="text-sm text-slate-500 mt-1">Gere anúncios profissionais com inteligência artificial</p>
    </div>
</div>
@Html.AntiForgeryToken()

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Painel de configuração -->
    <div class="lg:col-span-1">
        <div class="ws" x-data="anuncioForm()">
            <h2 class="font-semibold text-slate-900 mb-4">Configurar Anúncio</h2>

            <!-- Busca de produto -->
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Produto *</label>
                <div class="relative">
                    <input type="text" placeholder="Buscar produto..." x-model="busca"
                           @@input.debounce.300ms="buscarProduto()" @@focus="showResults = true"
                           class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm
                                  focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" />
                    <div x-show="showResults && resultados.length > 0"
                         class="absolute z-10 w-full bg-white border border-slate-200 rounded-lg shadow-lg mt-1 max-h-48 overflow-y-auto"
                         x-cloak>
                        <template x-for="p in resultados" :key="p.id">
                            <button type="button" @@click="selecionarProduto(p)"
                                    class="w-full text-left px-3 py-2 hover:bg-slate-50 text-sm flex items-center gap-2">
                                <span x-text="p.nome" class="font-medium"></span>
                                <span x-text="p.sku" class="text-slate-400 text-xs"></span>
                            </button>
                        </template>
                    </div>
                </div>
            </div>

            <!-- Canal -->
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-2">Canal *</label>
                <div class="grid grid-cols-2 gap-2">
                    @foreach (var (val, label, icon) in new[] {
                        ("ML", "Mercado Livre", "🛒"),
                        ("shopee", "Shopee", "🛍️"),
                        ("instagram", "Instagram", "📷"),
                        ("whatsapp", "WhatsApp", "💬")
                    })
                    {
                        <label class="cursor-pointer">
                            <input type="radio" name="canal" value="@val" x-model="canal" class="sr-only" />
                            <div :class="canal === '@val' ? 'border-indigo-500 bg-indigo-50 text-indigo-700 ring-1 ring-indigo-100' : 'border-slate-200 hover:border-slate-300 text-slate-700'"
                                 class="border-2 rounded-lg p-2.5 text-center transition-all">
                                <div class="text-lg">@icon</div>
                                <div class="text-xs font-medium mt-1">@label</div>
                            </div>
                        </label>
                    }
                </div>
            </div>

            <!-- Tom -->
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Tom</label>
                <select x-model="tom"
                        class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500">
                    <option value="profissional">Profissional</option>
                    <option value="descontraido">Descontraído</option>
                    <option value="urgente">Urgente / Promoção</option>
                    <option value="tecnico">Técnico / Detalhado</option>
                </select>
            </div>

            <!-- Foco -->
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Foco do anúncio</label>
                <select x-model="foco"
                        class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500">
                    <option value="beneficios">Benefícios</option>
                    <option value="preco">Preço / Custo-benefício</option>
                    <option value="features">Características técnicas</option>
                    <option value="urgencia">Urgência / Escassez</option>
                </select>
            </div>

            <!-- Contexto extra -->
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Contexto adicional</label>
                <textarea x-model="contexto" rows="2"
                          placeholder="Ex: produto em promoção, frete grátis, kit especial..."
                          class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm resize-none
                                 focus:ring-2 focus:ring-indigo-500"></textarea>
            </div>

            <button type="button" @@click="gerarAnuncio()"
                    :disabled="!produtoId || gerando"
                    class="w-full py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700
                           disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2">
                <svg x-show="gerando" class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                <span x-text="gerando ? 'Gerando...' : '✨ Gerar Anúncio'"></span>
            </button>
        </div>
    </div>

    <!-- Resultado -->
    <div class="lg:col-span-2">
        <div class="ws h-full" x-data="anuncioResultado()">
            <div class="flex items-center justify-between mb-4">
                <h2 class="font-semibold text-slate-900">Resultado</h2>
                <div class="flex gap-2" x-show="resultado.length > 0">
                    <button type="button" @@click="copiar()"
                            class="px-3 py-1.5 text-sm border border-slate-300 rounded-lg text-slate-700 hover:bg-slate-50 flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                        </svg>
                        <span x-text="copiado ? 'Copiado!' : 'Copiar'"></span>
                    </button>
                    <button type="button" @@click="salvarRascunho()"
                            :disabled="salvando"
                            class="px-3 py-1.5 text-sm border border-slate-300 rounded-lg text-slate-700 hover:bg-slate-50 flex items-center gap-1.5">
                        <span x-show="!salvando">Salvar</span>
                        <span x-show="salvando" x-cloak class="flex items-center gap-1"><span class="spinner"></span> Salvando...</span>
                    </button>
                </div>
            </div>

            <div x-show="resultado.length === 0 && !gerando"
                 class="h-64 flex items-center justify-center text-slate-400">
                <div class="text-center">
                    <div class="text-4xl mb-3">✨</div>
                    <p class="text-sm">Configure e clique em "Gerar Anúncio"</p>
                </div>
            </div>

            <div x-show="gerando && resultado.length === 0"
                 class="h-64 flex items-center justify-center text-slate-400">
                <div class="text-center">
                    <svg class="animate-spin w-8 h-8 mx-auto mb-3 text-indigo-500" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                    </svg>
                    <p class="text-sm">Gerando...</p>
                </div>
            </div>

            <div x-show="resultado.length > 0">
                <textarea x-model="resultado"
                          rows="16"
                          class="w-full border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-800
                                 bg-slate-50 resize-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                          placeholder="O anúncio aparecerá aqui..."></textarea>
            </div>
        </div>
    </div>
</div>

<!-- Painel de Anúncios Salvos -->
<div class="mt-6 ws" x-data="anunciosSalvos()">
    <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold text-slate-900">Anúncios Salvos</h2>
        <span x-show="produtoId && !carregando && itens.length > 0"
              class="text-xs text-slate-400" x-text="itens.length + ' anúncio' + (itens.length !== 1 ? 's' : '')"></span>
    </div>

    <div x-show="!produtoId" class="text-center py-8 text-slate-400">
        <p class="text-sm">Selecione um produto para ver seus anúncios salvos.</p>
    </div>

    <div x-show="produtoId && carregando" class="flex justify-center py-8">
        <span class="spinner"></span>
    </div>

    <div x-show="produtoId && !carregando && itens.length === 0" class="text-center py-8 text-slate-400">
        <p class="text-sm">Nenhum anúncio salvo para este produto.</p>
        <p class="text-xs mt-1">Gere e salve um anúncio para vê-lo aqui.</p>
    </div>

    <div x-show="produtoId && !carregando && itens.length > 0"
         class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <template x-for="item in itens" :key="item.id">
            <div class="border border-slate-200 rounded-xl p-4 flex flex-col gap-3 hover:border-slate-300 transition-colors">
                <div class="text-xs text-slate-400" x-text="item.criadoEm"></div>
                <p class="text-sm text-slate-700 line-clamp-4 flex-1" x-text="item.conteudo"></p>
                <div class="flex gap-2 pt-1 border-t border-slate-100">
                    <button type="button" @@click="copiarItem(item.conteudo)"
                            class="flex-1 text-xs text-slate-600 border border-slate-200 rounded-lg py-1.5 hover:bg-slate-50 transition-colors flex items-center justify-center gap-1">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                        </svg>
                        Copiar
                    </button>
                    <button type="button" @@click="deletar(item.id)"
                            class="px-3 text-xs text-red-500 border border-red-200 rounded-lg py-1.5 hover:bg-red-50 transition-colors">
                        Remover
                    </button>
                </div>
            </div>
        </template>
    </div>
</div>

@section Scripts {
<script src="/js/anuncios.js"></script>
}
