@model EstoqueListViewModel
@{
    var statusOpcoes = new[] { ("", "Tudo"), ("ok", "OK"), ("atencao", "Atenção"), ("critico", "Crítico"), ("parado", "Parado") };
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Estoque</h1>
        <p>@Model.Paginacao.Total @(Model.Paginacao.Total == 1 ? "item no estoque" : "itens no estoque") <span class="text-slate-400 text-xs font-normal">· por lote/entrada</span></p>
    </div>
    <div class="flex items-center gap-2">
        <a href="/estoque/exportar-csv"
           class="flex items-center gap-1.5 text-sm text-slate-600 border border-slate-300 hover:bg-slate-50 px-3 py-2 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            CSV
        </a>
        <a href="/entradas/nova"
           class="flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Nova entrada
        </a>
    </div>
</div>

<!-- Filtros -->
<div class="ws mb-4">
    <form method="get" class="flex flex-wrap gap-3 items-center">
        <input type="hidden" name="status" value="@Model.StatusFiltro" />
        <input type="hidden" name="categoria" value="@Model.Categoria" />
        <input type="text" name="search" value="@Model.Search" placeholder="Buscar produto ou SKU..."
               class="flex-1 min-w-48 px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />

        <!-- Pills de status -->
        <div class="flex gap-1">
            @foreach (var (val, label) in statusOpcoes)
            {
                var isActive = (Model.StatusFiltro ?? "") == val;
                <a href="?status=@val&categoria=@Model.Categoria&search=@Model.Search"
                   class="px-3 py-1.5 text-xs font-semibold rounded-full border transition-colors @(isActive ? "bg-indigo-600 text-white border-indigo-600" : "bg-white text-slate-600 border-slate-300 hover:border-indigo-300")">
                    @label
                </a>
            }
        </div>

        <button type="submit"
                class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            Buscar
        </button>
    </form>
</div>

<!-- Modal saída rápida (Alpine global) -->
<div x-data="saidaModal()" id="saida-modal-wrapper">
    <div x-show="open" class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center" x-transition>
        <div @@click.stop class="bg-white rounded-2xl shadow-2xl p-6 max-w-sm w-full mx-4">
            <h3 class="font-bold text-slate-900 text-lg mb-1">Registrar saída</h3>
            <p class="text-slate-500 text-sm mb-4" x-text="produtoNome"></p>

            <div class="flex gap-2 mb-4">
                <button @@click="natureza = 'venda'"
                        :class="natureza === 'venda' ? 'bg-indigo-600 text-white' : 'bg-slate-100 text-slate-600'"
                        class="flex-1 py-2 text-xs font-semibold rounded-lg transition-colors">Venda</button>
                <button @@click="natureza = 'perda'"
                        :class="natureza === 'perda' ? 'bg-red-600 text-white' : 'bg-slate-100 text-slate-600'"
                        class="flex-1 py-2 text-xs font-semibold rounded-lg transition-colors">Perda</button>
                <button @@click="natureza = 'prejuizo'"
                        :class="natureza === 'prejuizo' ? 'bg-amber-500 text-white' : 'bg-slate-100 text-slate-600'"
                        class="flex-1 py-2 text-xs font-semibold rounded-lg transition-colors">Prejuízo</button>
            </div>

            <div class="space-y-3 mb-4">
                <div>
                    <label class="text-xs font-semibold text-slate-700 mb-1 block">Quantidade *</label>
                    <input type="number" x-model.number="qty" min="1" :max="qtyDisponivel"
                           class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    <p class="text-xs text-slate-400 mt-1" x-text="'Disponível: ' + qtyDisponivel"></p>
                </div>
                <div x-show="natureza === 'venda'">
                    <label class="text-xs font-semibold text-slate-700 mb-1 block">Valor (R$)</label>
                    <input type="number" x-model.number="valor" step="0.01" min="0"
                           class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-700 mb-1 block">Data *</label>
                    <input type="date" x-model="data"
                           class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                </div>
            </div>

            <!-- CSRF token para o fetch -->
            @Html.AntiForgeryToken()

            <div class="flex gap-3">
                <button @@click="open = false"
                        class="flex-1 py-2.5 text-sm font-semibold border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
                    Cancelar
                </button>
                <button @@click="confirmarSaida()"
                        :disabled="loading"
                        class="flex-1 py-2.5 text-sm font-semibold bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-colors disabled:opacity-50">
                    <span x-text="loading ? 'Salvando...' : 'Confirmar'"></span>
                </button>
            </div>
        </div>
    </div>

    <!-- Tabela -->
    <div class="ws">
        @if (Model.Itens.Any())
        {
            <div class="overflow-x-auto">
            <table class="tbl-full">
                <thead>
                    <tr>
                        <th>Produto / Variação</th>
                        <th>SKU</th>
                        <th class="text-center">Qtd</th>
                        <th class="text-center hidden md:table-cell">Rotatividade</th>
                        <th class="hidden md:table-cell">Último mov.</th>
                        <th>Validade</th>
                        <th class="text-center">Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Itens)
                    {
                        var diasParaVencer = item.Validade.HasValue
                            ? (item.Validade.Value.ToDateTime(TimeOnly.MinValue) - DateTime.Today).Days
                            : (int?)null;
                        var velInt = (int)Math.Min(Math.Round(item.Vel * 5), 5);
                        <tr id="row-@item.Id">
                            <td>
                                <div class="font-semibold text-slate-900">@(item.Produto?.Nome ?? item.Sku)</div>
                                <div class="text-xs text-slate-400">@(item.Variacao?.Nome ?? "Padrão")</div>
                            </td>
                            <td class="font-mono text-xs text-slate-500">@item.Sku</td>
                            <td class="text-center">
                                <span class="font-bold text-lg @(item.Qty == 0 ? "text-red-600" : item.Qty < 5 ? "text-amber-600" : "text-slate-900")">
                                    @item.Qty
                                </span>
                            </td>
                            <td class="text-center hidden md:table-cell">
                                <div class="vel-bar justify-center" title="@item.Vel.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) un/dia (últimos 30 dias)">
                                    @for (int seg = 1; seg <= 5; seg++)
                                    {
                                        var segClass = seg <= velInt
                                            ? (velInt >= 4 ? "g" : velInt >= 2 ? "a" : "r")
                                            : "";
                                        <div class="vel-seg @segClass"></div>
                                    }
                                </div>
                            </td>
                            <td class="text-slate-500 text-xs hidden md:table-cell">
                                @item.LastMov.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                @if (item.Validade.HasValue)
                                {
                                    <span class="@(diasParaVencer <= 7 ? "text-red-600 font-semibold" : "text-slate-600") text-xs">
                                        @item.Validade.Value.ToString("dd/MM/yyyy")
                                        @if (diasParaVencer <= 7)
                                        {
                                            <span class="badge-critical ml-1 px-1.5 py-0.5 rounded text-xs font-semibold">@diasParaVencer d</span>
                                        }
                                    </span>
                                }
                                else
                                {
                                    <span class="text-slate-400">—</span>
                                }
                            </td>
                            <td class="text-center">
                                @{
                                    var sClass = item.Status?.ToLower() switch
                                    {
                                        "ok" or "normal" => "badge-ok",
                                        "critico" or "crítico" => "badge-critical",
                                        "parado" => "badge-slow",
                                        _ => "badge-warn"
                                    };
                                }
                                <span class="@sClass px-2 py-0.5 rounded-full text-xs font-semibold">@item.Status</span>
                            </td>
                            <td>
                                <div class="flex items-center justify-end gap-2">
                                    <a href="/entradas/reposicao?itemId=@item.Id"
                                       class="grid-action-btn grid-action-btn--primary">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m14.836 2A8.001 8.001 0 005.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-14.837-2m14.837 2H15" />
                                        </svg>
                                        Repor
                                    </a>
                                    <button @@click="openModal('@item.Id', '@(item.Produto?.Nome ?? item.Sku)'.replace(/'/g, ''), @item.Qty)"
                                            class="grid-action-btn grid-action-btn--danger">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                                        </svg>
                                        Saída
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>

            <!-- Paginação -->
            @if (Model.Paginacao.Pages > 1)
            {
                var estPgStart = Math.Max(1, Model.Paginacao.Page - 2);
                var estPgEnd = Math.Min(Model.Paginacao.Pages, Model.Paginacao.Page + 2);
                <div class="flex items-center justify-between mt-4 pt-4 border-t border-slate-100">
                    <span class="text-sm text-slate-500">Página @Model.Paginacao.Page de @Model.Paginacao.Pages</span>
                    <div class="flex items-center gap-1">
                        @if (Model.Paginacao.HasPrevious)
                        {
                            <a href="?page=@(Model.Paginacao.Page - 1)&status=@Model.StatusFiltro&categoria=@Model.Categoria&search=@Model.Search"
                               class="px-2.5 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-50">←</a>
                        }
                        @if (estPgStart > 1)
                        {
                            <a href="?page=1&status=@Model.StatusFiltro&categoria=@Model.Categoria&search=@Model.Search"
                               class="px-2.5 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-50">1</a>
                            if (estPgStart > 2) { <span class="px-1 text-slate-400 text-sm">…</span> }
                        }
                        @for (int pg = estPgStart; pg <= estPgEnd; pg++)
                        {
                            <a href="?page=@pg&status=@Model.StatusFiltro&categoria=@Model.Categoria&search=@Model.Search"
                               class="px-2.5 py-1.5 text-sm border rounded-lg transition-colors @(pg == Model.Paginacao.Page ? "bg-indigo-600 text-white border-indigo-600" : "border-slate-300 hover:bg-slate-50")">@pg</a>
                        }
                        @if (estPgEnd < Model.Paginacao.Pages)
                        {
                            if (estPgEnd < Model.Paginacao.Pages - 1) { <span class="px-1 text-slate-400 text-sm">…</span> }
                            <a href="?page=@Model.Paginacao.Pages&status=@Model.StatusFiltro&categoria=@Model.Categoria&search=@Model.Search"
                               class="px-2.5 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-50">@Model.Paginacao.Pages</a>
                        }
                        @if (Model.Paginacao.HasNext)
                        {
                            <a href="?page=@(Model.Paginacao.Page + 1)&status=@Model.StatusFiltro&categoria=@Model.Categoria&search=@Model.Search"
                               class="px-2.5 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-50">→</a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-12 text-slate-400">
                <div class="text-5xl mb-3">📦</div>
                <p class="font-semibold text-slate-600">Nenhum item encontrado</p>
                <p class="text-sm mt-1">Tente ajustar os filtros ou <a href="/entradas/nova" class="text-indigo-600 hover:underline">registre uma nova entrada</a>.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function saidaModal() {
            return {
                open: false,
                estoqueId: null,
                produtoNome: '',
                qtyDisponivel: 0,
                natureza: 'venda',
                qty: 1,
                valor: null,
                data: new Date().toLocaleDateString('en-CA'),
                loading: false,

                openModal(id, nome, qty) {
                    this.estoqueId = id;
                    this.produtoNome = nome;
                    this.qtyDisponivel = qty;
                    this.qty = 1;
                    this.valor = null;
                    this.natureza = 'venda';
                    this.open = true;
                },

                async confirmarSaida() {
                    if (this.loading) return;
                    if (!this.qty || this.qty < 1) return;
                    if (this.qty > this.qtyDisponivel) {
                        window.showToast('Quantidade excede o estoque disponível (' + this.qtyDisponivel + ').', 'error');
                        return;
                    }
                    this.loading = true;
                    const token = document.querySelector('[name=__RequestVerificationToken]')?.value;
                    try {
                        const r = await fetch('/estoque/saida', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            },
                            body: JSON.stringify({
                                estoqueId: this.estoqueId,
                                natureza: this.natureza,
                                qty: this.qty,
                                valor: this.natureza === 'venda' ? this.valor : null,
                                data: this.data
                            })
                        });
                        if (r.ok) {
                            window.showToast('Saída registrada com sucesso!', 'success');
                            this.open = false;
                            setTimeout(() => location.reload(), 800);
                        } else {
                            const d = await r.json().catch(() => ({}));
                            window.showToast(d.errorMessage || 'Erro ao registrar saída.', 'error');
                        }
                    } catch {
                        window.showToast('Não foi possível conectar ao servidor.', 'error');
                    } finally {
                        this.loading = false;
                    }
                }
            };
        }
    </script>
}
