@model EstoqueListViewModel
@{
    var statusOpcoes = new[] { ("", "Todos"), ("ok", "OK"), ("atencao", "Atenção"), ("critico", "Crítico"), ("parado", "Parado") };
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Estoque</h1>
        <p>@Model.Paginacao.Total @(Model.Paginacao.Total == 1 ? "item" : "itens") em estoque</p>
    </div>
    <div class="flex items-center gap-2">
        <a href="/estoque/exportar-csv"
           class="flex items-center gap-1.5 text-sm text-slate-600 border border-slate-300 hover:bg-slate-50 px-3 py-2 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            CSV
        </a>
        <a href="/entradas/nova"
           class="flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Nova entrada
        </a>
    </div>
</div>

<!-- Filtros -->
<div class="ws mb-4">
    <form method="get" x-data="{}" class="flex flex-wrap gap-3 items-center" role="search" aria-label="Filtrar estoque">
        <input type="hidden" name="status" value="@Model.StatusFiltro" />
        <input type="hidden" name="categoria" value="@Model.Categoria" />
        <input type="search" name="search" value="@Model.Search" placeholder="Buscar produto ou SKU..."
               aria-label="Buscar produto ou SKU"
               @@input.debounce.600ms="$el.form.requestSubmit()"
               class="flex-1 min-w-48 px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />

        <!-- Pills de status -->
        <div class="flex gap-1">
            @foreach (var (val, label) in statusOpcoes)
            {
                var isActive = (Model.StatusFiltro ?? "") == val;
                <a href="?status=@val&categoria=@Model.Categoria&search=@Model.Search"
                   class="px-3 py-1.5 text-xs font-semibold rounded-full border transition-colors @(isActive ? "bg-indigo-600 text-white border-indigo-600" : "bg-white text-slate-600 border-slate-300 hover:border-indigo-300")">
                    @label
                </a>
            }
        </div>
    </form>
</div>

<!-- Modal saída rápida (Alpine global) -->
<div x-data="saidaModal()" id="saida-modal-wrapper">
    <div x-show="open" x-cloak
         class="modal-backdrop"
         @@click.self="open = false"
         @@keydown.window.escape="open = false"
         x-transition>
        <div class="modal-panel modal-sm"
             role="dialog" aria-modal="true" aria-labelledby="saida-title">
            <!-- Header -->
            <div class="modal-header">
                <div class="flex-1">
                    <h3 id="saida-title" class="text-base font-semibold m-0">Registrar saída</h3>
                    <p class="text-sm text-slate-500 mt-0.5" x-text="produtoNome"></p>
                </div>
                <button type="button" class="btn btn-ghost btn-sm" aria-label="Fechar" @@click="open = false">✕</button>
            </div>

            <!-- Body -->
            <div class="modal-body space-y-4">
                <!-- Erro inline -->
                <div x-show="erroMsg" x-cloak
                     class="text-sm rounded-lg px-3 py-2 bg-red-50 text-red-700 border border-red-200 dark:bg-red-900/30 dark:text-red-200 dark:border-red-800"
                     x-text="erroMsg" role="alert"></div>

                <!-- Tipo de saída: segmented com descrição -->
                <div>
                    <label class="text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1.5 block uppercase tracking-wide">
                        Tipo de saída
                    </label>
                    <div class="grid grid-cols-3 gap-2">
                        <button type="button" @@click="setNatureza('venda')"
                                :aria-pressed="natureza === 'venda'"
                                :class="natureza === 'venda' ? 'border-emerald-500 bg-emerald-50 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-200' : 'border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:border-slate-400'"
                                class="py-2 text-xs font-semibold rounded-lg border-2 transition-colors">
                            Venda
                        </button>
                        <button type="button" @@click="setNatureza('perda')"
                                :aria-pressed="natureza === 'perda'"
                                :class="natureza === 'perda' ? 'border-red-500 bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-200' : 'border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:border-slate-400'"
                                class="py-2 text-xs font-semibold rounded-lg border-2 transition-colors">
                            Perda
                        </button>
                        <button type="button" @@click="setNatureza('prejuizo')"
                                :aria-pressed="natureza === 'prejuizo'"
                                :class="natureza === 'prejuizo' ? 'border-amber-500 bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-200' : 'border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:border-slate-400'"
                                class="py-2 text-xs font-semibold rounded-lg border-2 transition-colors">
                            Prejuízo
                        </button>
                    </div>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-1.5" x-text="naturezaHint"></p>
                </div>

                <!-- Quantidade -->
                <div>
                    <label class="text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1 block uppercase tracking-wide">
                        Quantidade
                    </label>
                    <div class="flex items-center gap-2">
                        <button type="button" @@click="qty = Math.max(1, qty - 1)"
                                class="w-9 h-9 rounded-lg border border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800">−</button>
                        <input type="number" x-model.number="qty" min="1"
                               class="flex-1 px-3 py-2 border border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 rounded-lg text-sm text-center focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        <button type="button" @@click="qty = qty + 1"
                                class="w-9 h-9 rounded-lg border border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800">+</button>
                    </div>
                    <p class="text-xs mt-1"
                       :class="qty > qtyDisponivel ? 'text-amber-600 font-medium' : 'text-slate-500 dark:text-slate-400'">
                        <span x-show="qty <= qtyDisponivel">Disponível: <span x-text="qtyDisponivel"></span></span>
                        <span x-show="qty > qtyDisponivel" x-cloak>
                            ⚠ Excede estoque atual (<span x-text="qtyDisponivel"></span>un). Sistema vai repor <span x-text="qty - qtyDisponivel"></span>un automaticamente — revise depois.
                        </span>
                    </p>
                </div>

                <!-- Valor (somente Venda e Prejuízo) -->
                <div x-show="natureza === 'venda' || natureza === 'prejuizo'" x-cloak>
                    <label class="text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1 block uppercase tracking-wide">
                        <span x-show="natureza === 'venda'">Valor unitário (R$) <span class="text-red-500">*</span></span>
                        <span x-show="natureza === 'prejuizo'" x-cloak>Custo perdido por unidade (R$, opcional)</span>
                    </label>
                    <input type="number" x-model.number="valor" step="0.01" min="0.01"
                           placeholder="0,00"
                           :class="natureza === 'venda' && semPreco ? 'border-amber-400 focus:ring-amber-300' : 'border-slate-300 dark:border-slate-600 focus:ring-indigo-300'"
                           class="w-full px-3 py-2 dark:bg-slate-800 dark:text-slate-100 rounded-lg text-sm focus:outline-none focus:ring-2 border" />
                    <p x-show="natureza === 'venda' && semPreco" x-cloak
                       class="text-xs text-amber-600 mt-1">
                        Produto sem preço cadastrado. Informe o valor de venda para calcular a receita.
                    </p>
                </div>

                <!-- Motivo (Perda e Prejuízo) -->
                <div x-show="natureza === 'perda' || natureza === 'prejuizo'" x-cloak>
                    <label class="text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1 block uppercase tracking-wide">
                        Motivo
                    </label>
                    <input type="text" x-model="motivo"
                           placeholder="Ex: validade vencida, danificado no transporte…"
                           class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">
                        Registrado na auditoria — explique em uma frase.
                    </p>
                </div>

                <!-- Data -->
                <div>
                    <label class="text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1 block uppercase tracking-wide">
                        Data
                    </label>
                    <input type="date" x-model="data"
                           class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                </div>
            </div>

            <!-- CSRF token para o fetch -->
            @Html.AntiForgeryToken()

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" @@click="open = false"
                        class="flex-1 py-2.5 text-sm font-semibold border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition-colors">
                    Cancelar
                </button>
                <button type="button" @@click="confirmarSaida()"
                        :disabled="loading || !podeEnviar()"
                        :class="loading || !podeEnviar() ? 'opacity-50 cursor-not-allowed' : ''"
                        class="flex-1 py-2.5 text-sm font-semibold bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-colors">
                    <span x-show="!loading" x-text="ctaLabel"></span>
                    <span x-show="loading" x-cloak>Salvando…</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Tabela -->
    <div class="ws">
        @if (Model.Itens.Any())
        {
            <div class="overflow-x-auto">
            <table class="tbl-full">
                <thead>
                    <tr>
                        <th class="sticky left-0 z-10 bg-white">Produto / Variação</th>
                        <th>SKU</th>
                        <th class="text-center">Qtd</th>
                        <th class="text-center hidden md:table-cell">Giro</th>
                        <th class="hidden md:table-cell">Último mov.</th>
                        <th>Validade</th>
                        <th class="text-center">Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Itens)
                    {
                        var diasParaVencer = item.Validade.HasValue
                            ? (item.Validade.Value.ToDateTime(TimeOnly.MinValue) - DateTime.Today).Days
                            : (int?)null;
                        var velInt = (int)Math.Min(Math.Round(item.Vel * 5), 5);
                        <tr id="row-@item.Id">
                            <td class="sticky left-0 z-10 bg-white">
                                <div class="font-semibold text-slate-900">@(item.Produto?.Nome ?? item.Sku)</div>
                                <div class="text-xs text-slate-400">
                                    @(item.Variacao?.Nome ?? "Padrão")
                                    @if (!string.IsNullOrEmpty(item.Lote))
                                    {
                                        <span class="ml-1 text-slate-400">· Lote: @item.Lote</span>
                                    }
                                </div>
                            </td>
                            <td class="font-mono text-xs text-slate-500">@item.Sku</td>
                            <td class="text-center">
                                <span class="font-bold text-lg @(item.Qty == 0 ? "text-red-600" : item.Qty < 5 ? "text-amber-600" : "text-slate-900")">
                                    @item.Qty
                                </span>
                            </td>
                            <td class="text-center hidden md:table-cell">
                                @if (item.Vel == 0)
                                {
                                    <span class="text-xs text-slate-400" title="Sem saídas nos últimos 30 dias">Parado</span>
                                }
                                else
                                {
                                    <div class="vel-bar justify-center" title="@item.Vel.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) un/dia (últimos 30 dias) — cada barra = 0,5 un/dia">
                                        @for (int seg = 1; seg <= 5; seg++)
                                        {
                                            var segClass = seg <= velInt
                                                ? (velInt >= 4 ? "g" : velInt >= 2 ? "a" : "r")
                                                : "";
                                            <div class="vel-seg @segClass"></div>
                                        }
                                    </div>
                                }
                            </td>
                            <td class="text-slate-500 text-xs hidden md:table-cell">
                                @item.LastMov.AsDate()
                            </td>
                            <td>
                                @if (item.Validade.HasValue)
                                {
                                    <span class="@(diasParaVencer <= 7 ? "text-red-600 font-semibold" : "text-slate-600") text-xs">
                                        @item.Validade.Value.AsDate()
                                        @if (diasParaVencer <= 7)
                                        {
                                            <span class="badge-critical ml-1 px-1.5 py-0.5 rounded text-xs font-semibold">@diasParaVencer d</span>
                                        }
                                    </span>
                                }
                                else
                                {
                                    @if (item.Qty == 0)
                                    {
                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-semibold bg-amber-50 text-amber-700 border border-amber-200">Sem validade</span>
                                    }
                                    else
                                    {
                                        <span class="text-slate-400">—</span>
                                    }
                                }
                            </td>
                            <td class="text-center">
                                @{
                                    // Defesa em profundidade: Qty 0 SEMPRE renderiza como Esgotado, mesmo se
                                    // Status no banco ficou desatualizado (itens legacy zerados antes da regra).
                                    var statusEffective = item.Qty == 0 ? "esgotado" : (item.Status?.ToLower() ?? "");
                                    var sClass = statusEffective switch
                                    {
                                        "ok" or "normal" => "badge-ok",
                                        "critico" or "crítico" or "critical" => "badge-critical",
                                        "esgotado" => "badge-warn",
                                        "parado" or "slow" => "badge-slow",
                                        _ => "badge-warn"
                                    };
                                    var statusLabel = statusEffective switch {
                                        "critico" or "critical" => "Crítico",
                                        "esgotado" => "Esgotado",
                                        "atencao" or "warn" => "Atenção",
                                        "ok" => "OK",
                                        "parado" or "slow" => "Parado",
                                        "vencido" => "Vencido",
                                        "descartado" => "Descartado",
                                        "bloqueado" => "Bloqueado",
                                        _ => item.Status ?? "—"
                                    };
                                }
                                <span class="@sClass px-2 py-0.5 rounded-full text-xs font-semibold">@statusLabel</span>
                            </td>
                            <td class="min-w-48 whitespace-nowrap">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="/entradas/reposicao?itemId=@item.Id"
                                       class="grid-action-btn grid-action-btn--ghost"
                                       aria-label="Repor estoque de @(item.Produto?.Nome ?? item.Sku)">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                                        </svg>
                                        Repor
                                    </a>
                                    <button @@click="openModal('@item.Id', '@(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(item.Produto?.Nome ?? item.Sku ?? ""))', @item.Qty, @(item.PrecoVendaSugerido?.Valor.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "null"))"
                                            class="grid-action-btn grid-action-btn--warning"
                                            aria-label="Registrar saída de @(item.Produto?.Nome ?? item.Sku)">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                                        </svg>
                                        Saída
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>

            <!-- Paginação -->
            @if (Model.Paginacao.Pages > 1)
            {
                var estPgStart = Math.Max(1, Model.Paginacao.Page - 2);
                var estPgEnd = Math.Min(Model.Paginacao.Pages, Model.Paginacao.Page + 2);
                <div class="flex items-center justify-between mt-4 pt-4 border-t border-slate-100">
                    @{
                        var pgStart = (Model.Paginacao.Page - 1) * Model.Paginacao.Limit + 1;
                        var pgEnd = Math.Min(Model.Paginacao.Page * Model.Paginacao.Limit, Model.Paginacao.Total);
                    }
                    <span class="text-sm text-slate-500">Mostrando @pgStart–@pgEnd de @Model.Paginacao.Total @(Model.Paginacao.Total == 1 ? "lote" : "lotes")</span>
                    <div class="flex items-center gap-1">
                        @if (Model.Paginacao.HasPrevious)
                        {
                            <a href="?page=@(Model.Paginacao.Page - 1)&status=@Model.StatusFiltro&categoria=@Model.Categoria&search=@Model.Search"
                               class="px-2.5 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-50">←</a>
                        }
                        @if (estPgStart > 1)
                        {
                            <a href="?page=1&status=@Model.StatusFiltro&categoria=@Model.Categoria&search=@Model.Search"
                               class="px-2.5 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-50">1</a>
                            if (estPgStart > 2) { <span class="px-1 text-slate-400 text-sm">…</span> }
                        }
                        @for (int pg = estPgStart; pg <= estPgEnd; pg++)
                        {
                            <a href="?page=@pg&status=@Model.StatusFiltro&categoria=@Model.Categoria&search=@Model.Search"
                               class="px-2.5 py-1.5 text-sm border rounded-lg transition-colors @(pg == Model.Paginacao.Page ? "bg-indigo-600 text-white border-indigo-600" : "border-slate-300 hover:bg-slate-50")">@pg</a>
                        }
                        @if (estPgEnd < Model.Paginacao.Pages)
                        {
                            if (estPgEnd < Model.Paginacao.Pages - 1) { <span class="px-1 text-slate-400 text-sm">…</span> }
                            <a href="?page=@Model.Paginacao.Pages&status=@Model.StatusFiltro&categoria=@Model.Categoria&search=@Model.Search"
                               class="px-2.5 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-50">@Model.Paginacao.Pages</a>
                        }
                        @if (Model.Paginacao.HasNext)
                        {
                            <a href="?page=@(Model.Paginacao.Page + 1)&status=@Model.StatusFiltro&categoria=@Model.Categoria&search=@Model.Search"
                               class="px-2.5 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-50">→</a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-12 text-slate-400">
                <div class="text-5xl mb-3">📦</div>
                <p class="font-semibold text-slate-600">Nenhum item encontrado</p>
                <p class="text-sm mt-1">Tente ajustar os filtros ou <a href="/entradas/nova" class="text-indigo-600 hover:underline">registre uma nova entrada</a>.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function saidaModal() {
            return {
                open: false,
                loading: false,
                erroMsg: '',
                estoqueId: null,
                produtoNome: '',
                qtyDisponivel: 0,
                natureza: 'venda',
                qty: 1,
                valor: null,
                motivo: '',
                data: new Date().toLocaleDateString('en-CA'),

                precoSugerido: null,
                semPreco: false,

                openModal(id, nome, qty, precoSugerido) {
                    this.estoqueId = id;
                    this.produtoNome = nome;
                    this.qtyDisponivel = qty;
                    this.qty = 1;
                    this.precoSugerido = precoSugerido && precoSugerido !== 'null' ? Number(precoSugerido) : null;
                    this.valor = this.precoSugerido;
                    this.semPreco = this.precoSugerido === null;
                    this.motivo = '';
                    this.erroMsg = '';
                    this.natureza = 'venda';
                    this.data = new Date().toLocaleDateString('en-CA');
                    this.open = true;
                },

                setNatureza(n) {
                    this.natureza = n;
                    this.erroMsg = '';
                },

                get naturezaHint() {
                    if (this.natureza === 'venda') return 'Saída comercial — informe o valor unitário.';
                    if (this.natureza === 'perda') return 'Item retirado sem venda (vencido, quebrado). Motivo é registrado na auditoria.';
                    if (this.natureza === 'prejuizo') return 'Saída com custo conhecido mas sem receita (devolução, reposição grátis). Motivo é registrado.';
                    return '';
                },

                get ctaLabel() {
                    if (this.natureza === 'venda') return 'Registrar venda';
                    if (this.natureza === 'perda') return 'Registrar perda';
                    if (this.natureza === 'prejuizo') return 'Registrar prejuízo';
                    return 'Confirmar';
                },

                podeEnviar() {
                    // Excesso vs estoque NAO bloqueia mais — servidor faz reposicao automatica
                    // mantendo a operacao fluindo (regra do Felipe).
                    if (!this.qty || this.qty < 1) return false;
                    if (this.natureza === 'venda' && (!this.valor || this.valor <= 0)) return false;
                    if ((this.natureza === 'perda' || this.natureza === 'prejuizo') && !this.motivo.trim()) return false;
                    return true;
                },

                async confirmarSaida() {
                    if (this.loading) return;
                    if (!this.podeEnviar()) {
                        if (!this.qty || this.qty < 1) {
                            this.erroMsg = 'Quantidade deve ser maior ou igual a 1.';
                        } else if (this.natureza === 'venda' && (!this.valor || this.valor <= 0)) {
                            this.erroMsg = 'Informe o valor unitário da venda.';
                        } else {
                            this.erroMsg = 'Informe o motivo para registrar essa saída.';
                        }
                        return;
                    }
                    this.loading = true;
                    this.erroMsg = '';
                    const token = document.querySelector('[name=__RequestVerificationToken]')?.value;
                    try {
                        const r = await fetch('/estoque/saida', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            },
                            body: JSON.stringify({
                                estoqueId: this.estoqueId,
                                natureza: this.natureza,
                                qty: this.qty,
                                valor: (this.natureza === 'venda' || this.natureza === 'prejuizo') ? this.valor : null,
                                motivo: (this.natureza === 'perda' || this.natureza === 'prejuizo') ? this.motivo.trim() : null,
                                data: this.data
                            })
                        });
                        if (r.ok) {
                            let msg = 'Saída registrada com sucesso!';
                            let type = 'success';
                            let delay = 800;
                            try {
                                const d = await r.json();
                                if (d && d.ajusteAutomatico) {
                                    msg = d.mensagemAjuste || 'Saída registrada com ajuste automático de estoque. Revise o cadastro depois.';
                                    type = 'warning';
                                    delay = 1800;
                                }
                            } catch { /* corpo vazio ou não-JSON */ }
                            window.showToast(msg, type);
                            this.open = false;
                            setTimeout(() => location.reload(), delay);
                        } else {
                            const raw = await r.text();
                            let d = null;
                            try { d = raw ? JSON.parse(raw) : null; } catch { /* não-JSON */ }
                            const msg = (d && (d.errorMessage || d.error?.detail || d.error?.message))
                                || friendlyHttpSaida(r.status);
                            this.erroMsg = msg;
                            window.showToast(msg, 'error');
                        }
                    } catch {
                        this.erroMsg = 'Não foi possível conectar ao servidor.';
                        window.showToast(this.erroMsg, 'error');
                    } finally {
                        this.loading = false;
                    }

                    function friendlyHttpSaida(s) {
                        if (s === 400) return 'Dados inválidos. Verifique quantidade, valor e motivo.';
                        if (s === 401 || s === 403) return 'Sessão expirou. Recarregue a página e tente de novo.';
                        if (s === 404) return 'Item de estoque não encontrado.';
                        if (s === 409) return 'Conflito de dados. Recarregue a página.';
                        if (s === 501) return 'Operação não suportada nesta versão. Avise o suporte.';
                        if (s >= 500) return 'Erro no servidor. Tente novamente em alguns instantes.';
                        return 'Erro ao registrar saída (HTTP ' + s + ').';
                    }
                }
            };
        }
    </script>
}
