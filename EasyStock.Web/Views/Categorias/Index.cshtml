@using EasyStock.Web.Models.Api
@model List<CategoriaApi>
@{
    ViewBag.Title = "Categorias";
    Layout = "_Layout";
}

{{-- Modal Criar / Editar --}}
<div x-data="catModal()"
     x-show="open" x-cloak
     x-transition.opacity
     @@abrir-cat.window="handle($event.detail)"
     @@open-modal.window="if ($event.detail === 'criar-cat') handle({ mode: 'criar' })"
     @@keydown.escape.window="if (open) fechar()"
     class="fm-overlay"
     role="dialog" aria-modal="true" aria-labelledby="cat-modal-title"
     @@click.self="fechar()">
    <form x-ref="panel" class="fm-panel" style="max-width: 480px"
          @@submit.prevent="submit()">
        <header class="fm-header">
            <div>
                <h2 id="cat-modal-title" class="fm-header__title"
                    x-text="mode === 'criar' ? 'Nova categoria' : 'Editar categoria'"></h2>
                <p class="fm-header__subtitle"
                   x-text="mode === 'criar'
                     ? 'Organize seus produtos em categorias para facilitar o controle de estoque.'
                     : 'Atualize o nome ou os limiares de alerta desta categoria.'"></p>
            </div>
            <button type="button" class="fm-close" aria-label="Fechar" @@click="fechar()">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </header>

        <div class="fm-body">
            <div x-show="erroMsg" x-cloak class="fm-error" x-text="erroMsg" role="alert"></div>
            @Html.AntiForgeryToken()

            <fieldset class="fm-section">
                <legend class="fm-section__legend">Identificação</legend>
                <div class="fm-field">
                    <label class="fm-field__label" for="cat-nome">
                        Nome <span class="fm-field__required" aria-hidden="true">*</span>
                    </label>
                    <input id="cat-nome" type="text" x-model="form.nome"
                           placeholder="Ex: Bebidas, Higiene, Eletrônicos…"
                           maxlength="80" autocomplete="off"
                           @@input="erroMsg = ''"
                           class="ui-field w-full text-sm" />
                </div>
            </fieldset>

            <fieldset class="fm-section">
                <legend class="fm-section__legend">Controle de Estoque</legend>
                <p class="text-xs text-slate-500 -mt-2 mb-4">Limiares de alerta para produtos nesta categoria. Opcional.</p>
                <div class="fm-grid">
                    <div class="fm-field">
                        <label class="fm-field__label" for="cat-min">Qtd. mínima</label>
                        <input id="cat-min" type="number" x-model="form.quantidadeMinima"
                               min="0" max="9999" placeholder="Ex: 10"
                               class="ui-field w-full text-sm" />
                        <span class="fm-field__hint">Alerta laranja abaixo desse valor.</span>
                    </div>
                    <div class="fm-field">
                        <label class="fm-field__label" for="cat-crit">Qtd. crítica</label>
                        <input id="cat-crit" type="number" x-model="form.quantidadeCritica"
                               min="0" max="9999" placeholder="Ex: 3"
                               class="ui-field w-full text-sm" />
                        <span class="fm-field__hint">Alerta vermelho abaixo desse valor.</span>
                    </div>
                </div>
            </fieldset>
        </div>

        <footer class="fm-footer">
            <button type="button" @@click="fechar()"
                    class="px-4 py-2 text-sm font-medium text-slate-600 border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
                Cancelar
            </button>
            <button type="submit"
                    :disabled="loading"
                    :class="{ 'opacity-50 cursor-not-allowed': loading }"
                    class="inline-flex items-center gap-2 px-5 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors">
                <span x-show="loading" x-cloak
                      class="w-3.5 h-3.5 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                <span x-text="loading ? 'Salvando…' : (mode === 'criar' ? 'Criar categoria' : 'Salvar alterações')"></span>
            </button>
        </footer>
    </form>
</div>

{{-- Conteúdo da página --}}
<div x-data="{ q: '' }">
    <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
        <div class="pg-hd">
            <h1>Categorias</h1>
            <p>@Model.Count @(Model.Count == 1 ? "categoria cadastrada" : "categorias cadastradas")</p>
        </div>
        <button type="button"
                @@click="$dispatch('abrir-cat', { mode: 'criar' })"
                class="app-primary-btn inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Nova categoria
        </button>
    </div>

    @if (!Model.Any())
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIllustration", "box" },
            { "EmptyTitle", "Nenhuma categoria cadastrada" },
            { "EmptyDescription", "Crie categorias para organizar seus produtos por tipo e facilitar o controle de estoque." },
            { "EmptyCta", "Criar primeira categoria" },
            { "EmptyCtaModal", "criar-cat" }
        })
    }
    else
    {
        <div class="mb-4">
            <input x-model="q" type="search"
                   placeholder="Filtrar categorias…"
                   aria-label="Filtrar categorias"
                   class="ui-field w-full max-w-xs text-sm" />
        </div>

        <div class="ws overflow-x-auto">
            <table class="tbl-full">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Limiares</th>
                        <th class="text-right">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr data-search="@c.Nome.ToLowerInvariant()"
                            :class="{ 'hidden': q && !$el.dataset.search.includes(q.toLowerCase()) }">
                            <td>
                                <span class="font-medium text-slate-900">@(string.IsNullOrWhiteSpace(c.Nome) ? "(sem nome)" : c.Nome)</span>
                            </td>
                            <td>
                                @if (c.QuantidadeMinima.HasValue || c.QuantidadeCritica.HasValue)
                                {
                                    <div class="flex flex-wrap gap-1">
                                        @if (c.QuantidadeMinima.HasValue)
                                        {
                                            <span class="badge badge-warn">Mín: @c.QuantidadeMinima</span>
                                        }
                                        @if (c.QuantidadeCritica.HasValue)
                                        {
                                            <span class="badge badge-danger">Crít: @c.QuantidadeCritica</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-slate-400 text-xs">Sem limiares</span>
                                }
                            </td>
                            <td class="text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <button type="button"
                                            data-id="@c.Id"
                                            data-nome="@c.Nome"
                                            data-min="@(c.QuantidadeMinima?.ToString() ?? "")"
                                            data-crit="@(c.QuantidadeCritica?.ToString() ?? "")"
                                            @@click="$dispatch('abrir-cat', {
                                                mode: 'editar',
                                                id: $el.dataset.id,
                                                nome: $el.dataset.nome,
                                                min: $el.dataset.min !== '' ? parseInt($el.dataset.min) : null,
                                                crit: $el.dataset.crit !== '' ? parseInt($el.dataset.crit) : null
                                            })"
                                            class="grid-action-btn grid-action-btn--primary">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                        Editar
                                    </button>
                                    <button type="button"
                                            data-nome="@c.Nome"
                                            @@click="$dispatch('confirm-action', {
                                                titulo: 'Remover categoria',
                                                mensagem: 'Remover <strong>' + $el.dataset.nome + '</strong>? Produtos nessa categoria ficarão sem categoria.',
                                                textoBotao: 'Remover',
                                                classBotao: 'bg-red-600 hover:bg-red-700',
                                                formAction: '/categorias/@c.Id/excluir'
                                            })"
                                            class="grid-action-btn grid-action-btn--danger">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                        Remover
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
<script>
function catModal() {
    return {
        open: false,
        mode: 'criar',
        loading: false,
        erroMsg: '',
        currentId: null,
        form: { nome: '', quantidadeMinima: '', quantidadeCritica: '' },

        handle(d) {
            this.mode = d.mode || 'criar';
            if (d.mode === 'editar') {
                this.currentId = d.id;
                this.form = {
                    nome: d.nome || '',
                    quantidadeMinima: d.min != null ? String(d.min) : '',
                    quantidadeCritica: d.crit != null ? String(d.crit) : ''
                };
            } else {
                this.currentId = null;
                this.form = { nome: '', quantidadeMinima: '', quantidadeCritica: '' };
            }
            this.erroMsg = '';
            this.open = true;
            this.$nextTick(() => {
                document.body.style.overflow = 'hidden';
                var first = this.$refs.panel && this.$refs.panel.querySelector('input');
                if (first) first.focus();
            });
        },

        fechar() {
            this.open = false;
            document.body.style.overflow = '';
        },

        async submit() {
            if (this.loading) return;
            if (!this.form.nome.trim()) {
                this.erroMsg = 'Informe o nome da categoria.';
                return;
            }
            this.loading = true;
            this.erroMsg = '';
            var ep = this.mode === 'criar'
                ? '/categorias/criar-json'
                : '/categorias/' + this.currentId + '/editar-json';
            try {
                var tokenEl = document.querySelector('[name=__RequestVerificationToken]');
                var res = await fetch(ep, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': tokenEl ? tokenEl.value : ''
                    },
                    body: JSON.stringify({
                        nome: this.form.nome.trim(),
                        quantidadeMinima: this.form.quantidadeMinima === '' ? null : parseInt(this.form.quantidadeMinima, 10),
                        quantidadeCritica: this.form.quantidadeCritica === '' ? null : parseInt(this.form.quantidadeCritica, 10)
                    })
                });
                var data = await res.json();
                if (res.ok && data.success) {
                    window.location.reload();
                    return;
                }
                this.erroMsg = (data.error && data.error.message) || 'Não foi possível salvar. Tente de novo.';
            } catch (e) {
                this.erroMsg = 'Sem conexão com o servidor. Verifique sua internet.';
            } finally {
                this.loading = false;
            }
        }
    };
}
</script>
}
