@using EasyStock.Web.Models.Api
@model List<CategoriaApi>
@{
    ViewBag.Title = "Categorias";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Categorias</h1>
        <p>@Model.Count @(Model.Count == 1 ? "categoria cadastrada" : "categorias cadastradas")</p>
    </div>
    <button type="button"
            x-data @@click="$dispatch('open-modal', 'criar-cat')"
            class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
        + Nova Categoria
    </button>
</div>

<div class="ws">
    @if (!Model.Any())
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIcon", "🏷️" },
            { "EmptyTitle", "Nenhuma categoria cadastrada" },
            { "EmptyDescription", "Crie categorias para organizar seus produtos." },
            { "EmptyCta", "+ Nova Categoria" },
            { "EmptyCtaModal", "criar-cat" }
        })
    }
    else
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th class="text-center">Qtd. mínima</th>
                    <th class="text-center">Qtd. crítica</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr x-data="{ editando: false, editandoLimiar: false, nomeEdit: '' }"
                        x-init="nomeEdit = $el.dataset.nome"
                        data-nome="@c.Nome">
                        <td>
                            <div x-show="!editando" class="font-medium text-slate-900">@(string.IsNullOrWhiteSpace(c.Nome) ? "(sem nome)" : c.Nome)</div>
                            <form action="/categorias/@c.Id/editar" method="post"
                                  x-show="editando" x-cloak class="flex gap-2 items-center">
                                @Html.AntiForgeryToken()
                                <input type="text" name="nome" x-model="nomeEdit"
                                       class="border border-slate-300 rounded px-2 py-1 text-sm" required />
                                <button type="submit"
                                        class="px-2 py-1 bg-indigo-600 text-white text-xs rounded hover:bg-indigo-700">
                                    Salvar
                                </button>
                                <button type="button" @@click="editando = false"
                                        class="px-2 py-1 text-xs text-slate-500 hover:text-slate-700">
                                    Cancelar
                                </button>
                            </form>
                        </td>
                        <td class="text-center text-sm text-slate-600">
                            @(c.QuantidadeMinima.HasValue ? c.QuantidadeMinima.Value.ToString() : "—")
                        </td>
                        <td class="text-center text-sm text-slate-600">
                            @(c.QuantidadeCritica.HasValue ? c.QuantidadeCritica.Value.ToString() : "—")
                        </td>
                        <td>
                            <div class="flex items-center gap-3" x-show="!editandoLimiar">
                                <button type="button" @@click="editando = !editando"
                                        class="grid-action-btn grid-action-btn--primary"
                                        x-show="!editando">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                    Editar
                                </button>
                                <button type="button" @@click="editandoLimiar = true"
                                        class="grid-action-btn grid-action-btn--secondary"
                                        x-show="!editando">
                                    Limiares
                                </button>
                                <button type="button"
                                        @@click="$dispatch('confirm-action', { titulo: 'Remover categoria', mensagem: 'Remover <strong>' + nomeEdit + '</strong>? Produtos nessa categoria ficarão sem categoria.', textoBotao: 'Remover', classBotao: 'bg-red-600 hover:bg-red-700', formAction: '/categorias/@c.Id/excluir' })"
                                        class="grid-action-btn grid-action-btn--danger"
                                        x-show="!editando">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                    Remover
                                </button>
                            </div>
                            <form action="/categorias/@c.Id/limiar" method="post"
                                  x-show="editandoLimiar" x-cloak class="flex gap-2 items-center">
                                @Html.AntiForgeryToken()
                                <input type="number" name="quantidadeMinima" min="0" max="9999" placeholder="mín"
                                       value="@(c.QuantidadeMinima?.ToString() ?? "")"
                                       class="w-16 border border-slate-300 rounded px-2 py-1 text-sm text-center" />
                                <input type="number" name="quantidadeCritica" min="0" max="9999" placeholder="crít"
                                       value="@(c.QuantidadeCritica?.ToString() ?? "")"
                                       class="w-16 border border-slate-300 rounded px-2 py-1 text-sm text-center" />
                                <button type="submit"
                                        class="px-2 py-1 bg-indigo-600 text-white text-xs rounded hover:bg-indigo-700">
                                    Salvar
                                </button>
                                <button type="button" @@click="editandoLimiar = false"
                                        class="px-2 py-1 text-xs text-slate-500 hover:text-slate-700">
                                    Cancelar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>

<div x-data="{ open: false }" @@open-modal.window="open = ($event.detail === 'criar-cat')"
     x-show="open" x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
     @@click.self="open = false">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-sm p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Nova Categoria</h2>
        <form action="/categorias/criar" method="post" data-validate x-data="{ loading: false }" @@submit="loading = true">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Nome *</label>
                <input type="text" name="nome" required autofocus
                       minlength="2" maxlength="80"
                       data-error-message="Informe um nome de categoria entre 2 e 80 caracteres."
                       class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            </div>
            <div class="flex justify-end gap-3">
                <button type="button" @@click="open = false"
                        class="px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                    Cancelar
                </button>
                <button type="submit"
                        :disabled="loading" :class="{ 'opacity-50 cursor-not-allowed': loading }"
                        class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                    <span x-show="!loading">Criar</span>
                    <span x-show="loading" x-cloak class="flex items-center gap-2"><span class="spinner"></span> Salvando...</span>
                </button>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.cat-delete-form').forEach(function (form) {
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            var nome = form.dataset.catNome || 'esta categoria';
            var timer = null;
            var cancelled = false;

            // Close the confirm modal via Alpine if possible
            var row = form.closest('tr');
            if (row && row._x_dataStack) {
                try { row._x_dataStack[0].confirmando = false; } catch(ex) {}
            }

            function submitNow() {
                if (!cancelled) {
                    var clone = document.createElement('form');
                    clone.method = form.method;
                    clone.action = form.action;
                    form.querySelectorAll('input[type="hidden"]').forEach(function (inp) {
                        var copy = inp.cloneNode(true);
                        clone.appendChild(copy);
                    });
                    document.body.appendChild(clone);
                    clone.submit();
                }
            }

            timer = setTimeout(submitNow, 5000);

            if (window.showToast) {
                window.showToast(
                    '"' + nome + '" será removida.',
                    'warning',
                    5000,
                    function () {
                        cancelled = true;
                        clearTimeout(timer);
                    }
                );
            } else {
                submitNow();
            }
        });
    });
});
</script>
