@model EntradaFormViewModel

<div class="flex items-center gap-3 mb-6">
    <a href="/estoque" aria-label="Voltar" class="text-slate-400 hover:text-slate-600 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <div class="pg-hd">
        <h1>Nova Entrada de Estoque</h1>
        <p>Registre a entrada de produtos no estoque</p>
    </div>
</div>

<div x-data="entradaWizard()" class="max-w-3xl min-h-[calc(100vh-14rem)]">

    <!-- Barra de progresso -->
    <div class="ws mb-6">
        <div class="flex items-center">
            @{
                var steps = new[] { "Produto", "Detalhes", "Revisão", "Concluído" };
            }
            @for (int i = 0; i < steps.Length; i++)
            {
                var stepNum = i + 1;
                var isLast = i == steps.Length - 1;
                <div class="flex items-center @(isLast ? "" : "flex-1")">
                    <div class="step-circle" :class="step > @stepNum ? 'done' : step === @stepNum ? 'active' : ''">@stepNum</div>
                    <div class="ml-2 hidden sm:block">
                        <div class="text-xs font-semibold" :class="step === @stepNum ? 'text-indigo-600' : 'text-slate-400'">@steps[i]</div>
                    </div>
                    @if (!isLast)
                    {
                        <div class="step-connector flex-1 mx-3" :class="step > @stepNum ? 'step-connector--done' : ''"></div>
                    }
                </div>
            }
        </div>
        <div class="mt-2 text-xs text-slate-400 text-right">
            Passo <span x-text="step"></span> de @steps.Length
        </div>
    </div>

    <div>
        @Html.AntiForgeryToken()

        <!-- Passo 1: Selecionar produto -->
        <div x-show="step === 1">
            <div class="ws">
                <h3 class="font-bold text-slate-800 mb-4">Selecione o produto</h3>
                <div class="flex gap-2 mb-4">
                    <div class="relative flex-1 z-10">
                        <input type="text" x-model="buscaTerm"
                               @@input.debounce.300ms="buscarProduto()"
                               placeholder="Buscar por nome, marca, SKU ou bipar o código..."
                               class="w-full px-4 py-3 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        <div x-show="buscando" class="absolute right-3 top-3 text-slate-400 text-sm">Buscando...</div>
                    </div>
                    <button type="button" @@click="abrirScanner()"
                            class="shrink-0 px-4 py-3 border border-slate-300 rounded-lg text-slate-600 hover:bg-slate-50 transition-colors"
                            title="Ler código de barras com a câmera ou leitor USB" aria-label="Ler código de barras">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5h2v14H4zM9 5h1v14H9zM13 5h2v14h-2zM17 5h1v14h-1zM20 5h0v14h0z" />
                        </svg>
                    </button>
                </div>

                <div class="dropdown-list space-y-2" x-show="resultados.length > 0">
                    <template x-for="p in resultados" :key="p.id">
                        <button type="button" @@click="selecionarProduto(p)"
                                class="dropdown-item w-full flex items-center gap-3 p-3 border border-slate-200 rounded-xl hover:border-indigo-300 hover:bg-indigo-50 transition-all text-left">
                            <div class="w-10 h-10 bg-slate-100 rounded-lg overflow-hidden flex-shrink-0 flex items-center justify-center">
                                <template x-if="p.fotoUrl">
                                    <img :src="p.fotoUrl" :alt="'Foto de ' + p.nome" loading="lazy" decoding="async" class="w-full h-full object-cover object-top" />
                                </template>
                                <template x-if="!p.fotoUrl">
                                    <span class="text-xl">📦</span>
                                </template>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="font-semibold text-slate-900 truncate" x-text="p.nome"></div>
                                <div class="flex items-center gap-2">
                                    <span class="text-xs font-mono" :class="p.sku ? 'text-slate-400' : 'text-slate-300'" x-text="p.sku || 'Sem SKU'"></span>
                                    <span x-show="p.marca" class="text-xs text-slate-300">·</span>
                                    <span x-show="p.marca" class="text-xs text-slate-400" x-text="p.marca"></span>
                                </div>
                            </div>
                        </button>
                    </template>
                </div>

                <div x-show="buscaTerm.length > 1 && jaFezBusca && !buscando && resultados.length === 0" class="text-center py-6">
                    <p class="text-slate-400 text-sm mb-2">Nenhum produto encontrado</p>
                    <p class="text-slate-400 text-xs mb-3">Verifique o termo de busca ou cadastre um novo produto.</p>
                    <a href="/produtos/novo" class="inline-block px-4 py-2 text-sm font-medium text-indigo-600 border border-indigo-300 rounded-lg hover:bg-indigo-50 transition-colors">
                        + Cadastrar produto
                    </a>
                </div>
            </div>
        </div>

        <!-- Passo 2: Detalhes -->
        <div x-show="step === 2">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-2 ws space-y-4">
                    <h3 class="font-bold text-slate-800 mb-2">Detalhes da entrada</h3>

                    <div x-show="variacoes.length > 1" class="mb-4">
                        <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Variação</label>
                        <select x-model="varId"
                                @@change="const v = variacoes.find(x => x.id === varId); if (v && v.quantidadeEmEstoque !== undefined) { estoqueAtual = v.quantidadeEmEstoque; produtoUltimaEntrada = v.ultimaEntradaEm || null; produtoCodigoBarras = v.codigoBarras || produtoCodigoBarras; }"
                                class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
                            <template x-for="v in variacoes" :key="v.id">
                                <option :value="v.id" x-text="v.nome"></option>
                            </template>
                        </select>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="col-span-2">
                            <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Quantidade *</label>
                            <input type="number" x-model.number="qty" min="1"
                                   :class="qty < 0 ? 'border-red-400 ring-1 ring-red-200' : 'border-slate-300'"
                                   class="w-full px-3 py-2.5 border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @@input="calcularTotal()" />
                            <p x-show="qty < 0" x-cloak class="text-xs text-red-600 mt-1">Quantidade não pode ser negativa.</p>
                        </div>
                        <div>
                            <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Custo unitário (R$) *</label>
                            <input type="number" x-model.number="custo" step="0.01" min="0"
                                   :class="custo < 0 ? 'border-red-400 ring-1 ring-red-200' : 'border-slate-300'"
                                   class="w-full px-3 py-2.5 border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @@input="calcularTotal()" />
                            <p x-show="custo < 0" x-cloak class="text-xs text-red-600 mt-1">Custo não pode ser negativo.</p>
                        </div>
                        <div>
                            <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Preço sugerido (R$)</label>
                            <input type="number" x-model.number="preco" step="0.01" min="0"
                                   class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        </div>
                        <div>
                            <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Lote</label>
                            <div class="flex gap-2">
                                <div class="ped-combobox flex-1" @@click.outside="loteDropdownOpen = false">
                                    <div class="ped-combobox__input-wrap">
                                        <input type="text" x-model="lote" maxlength="40"
                                               autocomplete="off" role="combobox" aria-autocomplete="list"
                                               :aria-expanded="loteDropdownOpen ? 'true' : 'false'"
                                               placeholder="Buscar ou criar lote…"
                                               @@focus="buscarLotes()"
                                               @@input="lote = lote.toUpperCase(); buscarLotes()"
                                               @@keydown.arrow-down.prevent="navLote(1)"
                                               @@keydown.arrow-up.prevent="navLote(-1)"
                                               @@keydown.enter.prevent="confirmarLote()"
                                               @@keydown.escape.prevent="loteDropdownOpen = false"
                                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                                    </div>
                                    <ul x-show="loteDropdownOpen" x-cloak role="listbox" class="ped-combobox__list">
                                        <template x-for="(l, idx) in loteResultados" :key="l.codigo">
                                            <li role="option" :aria-selected="idx === loteIndex ? 'true' : 'false'"
                                                class="ped-combobox__option" :class="idx === loteIndex ? 'ped-combobox__option--active' : ''"
                                                @@mousedown.prevent="selecionarLote(l)">
                                                <span class="font-mono text-sm" x-text="l.codigo"></span>
                                                <span class="text-xs text-slate-400 ml-2"
                                                      x-text="l.status === 'finalizado' ? 'finalizado' : 'em produção'"></span>
                                            </li>
                                        </template>
                                        <li x-show="podeCriarLote()" role="option"
                                            :aria-selected="loteIndex === loteResultados.length ? 'true' : 'false'"
                                            class="ped-combobox__option" :class="loteIndex === loteResultados.length ? 'ped-combobox__option--active' : ''"
                                            @@mousedown.prevent="usarNovoLote()">
                                            <div class="text-sm font-semibold text-indigo-600">+ Usar novo lote "<span x-text="lote"></span>"</div>
                                            <div class="text-xs text-slate-500">Será criado e aparecerá em Lotes.</div>
                                        </li>
                                        <li x-show="loteResultados.length === 0 && !podeCriarLote()" class="px-2 py-2 text-xs text-slate-400">
                                            Digite para buscar ou criar um lote.
                                        </li>
                                    </ul>
                                </div>
                                <button type="button" @@click="gerarCodigoLote()" :disabled="gerandoLote || !produtoId"
                                        class="shrink-0 px-3 py-2.5 border border-indigo-300 text-indigo-600 rounded-lg text-sm font-semibold hover:bg-indigo-50 transition-colors disabled:opacity-50"
                                        title="Gerar código automático (LOTE-SKU-AAMMDD-NNN)">
                                    <span x-text="gerandoLote ? '…' : 'Gerar'"></span>
                                </button>
                            </div>
                            <p class="text-xs text-slate-400 mt-1">Opcional. Informe ou gere um lote para rastrear esta entrada em Lotes.</p>
                        </div>
                        <div>
                            <label class="text-sm font-semibold mb-1.5 block"
                                   :class="controlaValidade ? 'text-amber-800' : 'text-slate-700'">
                                Validade <span x-show="controlaValidade" class="text-amber-500">*</span>
                            </label>
                            <input type="date" x-model="validade"
                                   :class="controlaValidade && !validade ? 'border-amber-400 ring-1 ring-amber-200' : 'border-slate-300'"
                                   class="w-full px-3 py-2.5 border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        </div>
                        <div class="col-span-2">
                            <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Data da entrada *</label>
                            <input type="date" x-model="data"
                                   class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        </div>
                        <div class="col-span-2">
                            <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Observações</label>
                            <textarea x-model="observacoes" rows="2"
                                      class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"></textarea>
                        </div>
                    </div>

                    <div class="flex gap-3 mt-4">
                        <button type="button" @@click="step = 1"
                                class="px-4 py-2 border border-slate-300 text-slate-700 text-sm font-semibold rounded-lg hover:bg-slate-50">
                            ← Voltar
                        </button>
                        <button type="button" @@click="step = 3" :disabled="!qty || qty <= 0 || !custo || custo < 0 || !data || (controlaValidade && !validade)"
                                class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-2 rounded-lg transition-colors disabled:opacity-50">
                            Revisar →
                        </button>
                    </div>
                </div>

                <!-- Painel lateral: Produto selecionado + total -->
                <div class="ws h-fit space-y-4">
                    <h4 class="font-bold text-slate-800">Produto selecionado</h4>

                    <!-- Foto + identidade -->
                    <div class="flex items-start gap-3">
                        <a :href="'/produtos/' + produtoId" target="_blank" rel="noopener noreferrer" class="flex-shrink-0 block rounded-xl overflow-hidden ring-1 ring-slate-200 hover:ring-indigo-400 transition-all" title="Ver produto">
                            <template x-if="produtoFotoUrl">
                                <img :src="produtoFotoUrl" alt="" class="w-16 h-16 object-cover object-top" />
                            </template>
                            <template x-if="!produtoFotoUrl">
                                <div class="w-16 h-16 bg-slate-100 flex items-center justify-center text-2xl">📦</div>
                            </template>
                        </a>
                        <div class="min-w-0 flex-1">
                            <p class="font-semibold text-sm text-slate-900 leading-snug" x-text="produtoNome"></p>
                            <p class="text-xs font-mono mt-0.5" :class="produtoSku ? 'text-slate-400' : 'text-slate-300'" x-text="produtoSku || 'Sem SKU'"></p>
                            <p x-show="produtoMarca" class="text-xs text-slate-400 mt-0.5" x-text="produtoMarca"></p>
                            <a :href="'/produtos/' + produtoId" target="_blank" rel="noopener noreferrer"
                               class="text-xs text-indigo-500 hover:text-indigo-700 hover:underline mt-1 inline-block">↗ Ver cadastro completo</a>
                        </div>
                    </div>

                    <!-- Variação confirmada -->
                    <div x-show="variacoes.length > 1 && variacaoNome" class="flex items-center gap-2 text-xs bg-slate-50 rounded-lg px-3 py-2">
                        <span class="text-slate-500">Variação:</span>
                        <span class="font-semibold text-slate-800" x-text="variacaoNome"></span>
                    </div>

                    <!-- Estoque + código de barras + última entrada -->
                    <div class="border-t border-slate-100 pt-3 space-y-2 text-sm">
                        <div class="flex justify-between">
                            <span class="text-slate-500">Estoque atual</span>
                            <span class="font-semibold"
                                  :class="estoqueAtual === 0 ? 'text-red-500' : estoqueAtual < 5 ? 'text-amber-500' : 'text-slate-800'"
                                  x-text="estoqueAtual + ' un.'"></span>
                        </div>
                        <div x-show="produtoCodigoBarras" class="flex justify-between text-xs">
                            <span class="text-slate-400">Cód. barras</span>
                            <span class="font-mono text-slate-500" x-text="produtoCodigoBarras"></span>
                        </div>
                        <div x-show="produtoUltimaEntrada" class="flex justify-between text-xs">
                            <span class="text-slate-400">Última entrada</span>
                            <span class="text-slate-500" x-text="fmtData(produtoUltimaEntrada)"></span>
                        </div>
                        <div x-show="!produtoUltimaEntrada" class="text-xs text-slate-300 text-right">
                            Primeira entrada
                        </div>
                        <div x-show="produtoCriadoPor" class="flex justify-between text-xs">
                            <span class="text-slate-400">Cadastrado por</span>
                            <span class="text-slate-500" x-text="produtoCriadoPor"></span>
                        </div>
                        <div x-show="produtoAlteradoPor" class="flex justify-between text-xs">
                            <span class="text-slate-400">Últ. alteração por</span>
                            <span class="text-slate-500" x-text="produtoAlteradoPor"></span>
                        </div>
                    </div>

                    <!-- Resumo da operação -->
                    <div class="border-t border-slate-100 pt-3 space-y-2 text-sm">
                        <div class="flex justify-between">
                            <span class="text-slate-500">Qtd</span>
                            <span class="font-semibold" x-text="qty || 0"></span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-500">Custo unit.</span>
                            <span class="font-semibold" x-text="'R$ ' + (custo || 0).toFixed(2).replace('.', ',')"></span>
                        </div>
                        <!-- Margem em tempo real -->
                        <div x-show="margemRealtime !== null" class="flex justify-between text-xs">
                            <span class="text-slate-400">Margem s/ preço ref.</span>
                            <span class="font-semibold"
                                  :class="margemRealtime < 10 ? 'text-red-500' : margemRealtime < 30 ? 'text-amber-500' : 'text-emerald-600'"
                                  x-text="margemRealtime !== null ? margemRealtime.toFixed(1) + '%' : ''"></span>
                        </div>
                        <div class="flex justify-between font-bold border-t border-slate-100 pt-2">
                            <span>Total</span>
                            <span class="text-indigo-600" x-text="'R$ ' + total.toFixed(2).replace('.', ',')"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Passo 3: Revisão -->
        <div x-show="step === 3">
            <div class="ws">
                <h3 class="font-bold text-slate-800 mb-4">Revisar entrada</h3>
                <dl class="space-y-3 mb-6">
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <dt class="text-sm text-slate-500">Produto</dt>
                        <dd class="text-sm font-semibold" x-text="produtoNome"></dd>
                    </div>
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <dt class="text-sm text-slate-500">Quantidade</dt>
                        <dd class="text-sm font-semibold" x-text="qty"></dd>
                    </div>
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <dt class="text-sm text-slate-500">Custo unitário</dt>
                        <dd class="text-sm font-semibold" x-text="'R$ ' + (custo || 0).toFixed(2).replace('.', ',')"></dd>
                    </div>
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <dt class="text-sm text-slate-500">Total</dt>
                        <dd class="text-sm font-bold text-indigo-600" x-text="'R$ ' + total.toFixed(2).replace('.', ',')"></dd>
                    </div>
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <dt class="text-sm text-slate-500">Estoque atual → após entrada</dt>
                        <dd class="text-sm font-semibold">
                            <span x-text="estoqueAtual"></span> → <span class="text-emerald-600" x-text="Number(estoqueAtual) + Number(qty)"></span>
                        </dd>
                    </div>
                    <div class="flex justify-between py-2 border-b border-slate-50" x-show="lote">
                        <dt class="text-sm text-slate-500">Lote</dt>
                        <dd class="text-sm font-semibold font-mono" x-text="lote"></dd>
                    </div>
                    <div class="flex justify-between py-2" x-show="validade">
                        <dt class="text-sm text-slate-500">Validade</dt>
                        <dd class="text-sm font-semibold" x-text="validade ? new Date(validade + 'T00:00:00').toLocaleDateString('pt-BR') : ''"></dd>
                    </div>
                </dl>

                <div x-show="erroMsg" x-cloak class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700" x-text="erroMsg"></div>
                <div class="form-actions-sticky">
                    <button type="button" @@click="step = 2"
                            class="btn btn-secondary form-actions-sticky__cancel">
                        ← Voltar
                    </button>
                    <button type="button" @@click="submitEntrada()"
                            :disabled="submitting"
                            :aria-busy="submitting ? 'true' : 'false'"
                            class="btn btn-primary">
                        <span x-text="submitting ? 'Registrando…' : 'Confirmar entrada'"></span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Passo 4: Concluído -->
        <div x-show="step === 4" x-cloak>
            <div class="ws text-center">
                <div class="w-14 h-14 mx-auto rounded-full bg-emerald-100 flex items-center justify-center mb-4">
                    <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                </div>
                <h3 class="font-bold text-slate-800 text-lg mb-1">Entrada registrada!</h3>
                <p class="text-sm text-slate-500 mb-2" x-text="produtoNome"></p>
                <p x-show="loteSalvo" class="text-xs text-slate-500 mb-5">
                    Lote <span class="font-mono font-semibold" x-text="loteSalvo"></span> disponível em
                    <a href="/lotes" class="text-indigo-600 hover:underline">Lotes</a>.
                </p>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-md mx-auto">
                    <a :href="'/entradas/' + itemEstoqueId + '/etiqueta.pdf'" target="_blank" rel="noopener noreferrer"
                       :class="itemEstoqueId ? '' : 'opacity-50 pointer-events-none'"
                       class="inline-flex items-center justify-center gap-2 px-4 py-2.5 border border-slate-300 rounded-lg text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors">
                        🏷️ Imprimir etiqueta (PDF)
                    </a>
                    <a :href="'/entradas/' + itemEstoqueId + '/nota.pdf'" target="_blank" rel="noopener noreferrer"
                       :class="itemEstoqueId ? '' : 'opacity-50 pointer-events-none'"
                       class="inline-flex items-center justify-center gap-2 px-4 py-2.5 border border-slate-300 rounded-lg text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors">
                        📄 Nota de entrada (PDF)
                    </a>
                </div>

                <div class="flex gap-3 justify-center mt-6">
                    <a href="/estoque" class="px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-800">Ir para estoque</a>
                    <a href="/entradas/nova" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg">Nova entrada</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/entradas.js"></script>
    <script>
        function entradaWizard() {
            return {
                step: 1,
                buscaTerm: '',
                buscando: false,
                jaFezBusca: false,
                resultados: [],
                _searchAbort: null,
                produtoId: '',
                produtoNome: '',
                produtoSku: '',
                produtoEmoji: '',
                produtoFotoUrl: '',
                produtoMarca: '',
                produtoCodigoBarras: '',
                produtoUltimaEntrada: null,
                produtoCriadoPor: '',
                produtoAlteradoPor: '',
                estoqueAtual: 0,
                variacoes: [],
                varId: '',
                qty: 1,
                custo: null,
                preco: null,
                fornecedorId: '',
                lote: '',
                validade: '',
                observacoes: '',
                data: new Date().toLocaleDateString('en-CA'),
                total: 0,
                controlaValidade: false,
                erroMsg: '',
                submitting: false,
                // Combobox de lote (busca + criar inline + gerar)
                loteResultados: [],
                loteDropdownOpen: false,
                loteIndex: 0,
                gerandoLote: false,
                _loteAbort: null,
                // Resultado da entrada (passo 4)
                itemEstoqueId: '',
                loteSalvo: '',
                get variacaoNome() {
                    if (!this.varId || this.variacoes.length === 0) return '';
                    return this.variacoes.find(v => v.id === this.varId)?.nome || '';
                },
                get margemRealtime() {
                    if (!this.custo || !this.preco || this.preco <= 0) return null;
                    return ((this.preco - this.custo) / this.preco * 100);
                },
                fmtData(iso) {
                    if (!iso) return '';
                    // BUG-03: ultimaEntradaEm e instante UTC; formata no fuso BR p/ nao defasar -1 dia.
                    try { return new Date(iso).toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo', day: '2-digit', month: '2-digit', year: 'numeric' }); }
                    catch { return ''; }
                },
                _setProdutoDetalhe(d) {
                    this.variacoes = d.variacoes || [];
                    this.estoqueAtual = d.estoqueTotal || 0;
                    this.varId = this.variacoes.length > 0 ? this.variacoes[0].id : '';
                    if (d.custoReferencia) this.custo = d.custoReferencia;
                    if (d.precoReferencia) this.preco = d.precoReferencia;
                    this.controlaValidade = d.controlaValidade || false;
                    this.produtoFotoUrl = d.fotoUrl || '';
                    this.produtoMarca = d.marca || '';
                    this.produtoCodigoBarras = d.codigoBarras || '';
                    this.produtoUltimaEntrada = d.ultimaEntradaEm || null;
                    this.produtoCriadoPor = d.criadoPorNome || '';
                    this.produtoAlteradoPor = d.alteradoPorNome || '';
                    this.calcularTotal();
                },

                async init() {
                    const preId = '@(ViewBag.PreSelProdutoId ?? "")';
                    if (!preId) return;
                    try {
                        const r = await esFetch('/estoque/produto-detalhe/' + preId);
                        if (!r.ok) return;
                        const d = await r.json();
                        this.produtoId = d.id;
                        this.produtoNome = d.nome;
                        this.produtoSku = d.sku || '';
                        this._setProdutoDetalhe(d);
                        this.step = 2;
                    } catch (e) { console.error('[EasyStock]', e); window.showToast('Erro ao carregar produto pré-selecionado.', 'error'); }
                },

                async buscarProduto() {
                    if (this.buscaTerm.length < 2) { this.resultados = []; this.jaFezBusca = false; return; }
                    if (this._searchAbort) this._searchAbort.abort();
                    this._searchAbort = new AbortController();
                    this.jaFezBusca = false;
                    this.buscando = true;
                    try {
                        const r = await esFetch('/produtos/buscar?q=' + encodeURIComponent(this.buscaTerm), { signal: this._searchAbort.signal });
                        if (r.ok) {
                            this.resultados = await r.json();
                        } else {
                            this.resultados = [];
                            window.showToast('Erro ao buscar produtos. Tente novamente.', 'error');
                        }
                    } catch (e) {
                        if (e && e.name === 'AbortError') return;
                        this.resultados = [];
                        window.showToast('Não foi possível conectar ao servidor.', 'error');
                    } finally {
                        this.buscando = false;
                        this.jaFezBusca = true;
                    }
                },

                async selecionarProduto(p) {
                    this.produtoId = p.id;
                    this.produtoNome = p.nome;
                    this.produtoSku = p.sku || '';
                    this.produtoFotoUrl = '';
                    this.variacoes = [];
                    this.estoqueAtual = 0;
                    this.varId = '';
                    this.custo = p.custoReferencia || null;
                    this.preco = p.precoReferencia || null;
                    let detailOk = false;
                    try {
                        const dr = await esFetch('/estoque/produto-detalhe/' + p.id);
                        if (dr.ok) {
                            const d = await dr.json();
                            this._setProdutoDetalhe(d);
                            detailOk = true;
                        } else {
                            window.showToast('Erro ao carregar detalhes do produto. Tente novamente.', 'error');
                        }
                    } catch (e) { console.error('[EasyStock]', e);
                        window.showToast('Não foi possível conectar ao servidor.', 'error');
                    }
                    if (detailOk) this.step = 2;
                },

                // Le codigo de barras (camera/USB) reusando o scanner global e
                // resolve via /produtos/buscar (casa codigoBarras). 1 resultado =
                // auto-seleciona; varios = mostra a lista; nenhum = avisa.
                abrirScanner() {
                    window.dispatchEvent(new CustomEvent('barcode:open', { detail: { onScan: async (code) => {
                        this.buscaTerm = String(code || '').trim();
                        await this.buscarProduto();
                        if (this.resultados.length === 1) {
                            this.selecionarProduto(this.resultados[0]);
                        } else if (this.resultados.length === 0) {
                            window.showToast('Codigo ' + code + ' nao encontrado. Busque pelo nome ou cadastre o produto.', 'warning');
                        }
                    } } }));
                },

                calcularTotal() {
                    this.total = (this.qty || 0) * (this.custo || 0);
                    // Margem é calculada como getter reativo, não precisa de atualização manual
                },

                // ── Combobox de lote: busca + criar inline + gerar (espelha o seletor de categoria do pedido) ──
                _normLote(s) { return (s || '').toString().trim().toUpperCase(); },

                async buscarLotes() {
                    this.loteDropdownOpen = true;
                    this.loteIndex = 0;
                    if (this._loteAbort) this._loteAbort.abort();
                    this._loteAbort = new AbortController();
                    try {
                        const r = await esFetch('/entradas/lotes/buscar?q=' + encodeURIComponent(this.lote || ''), { signal: this._loteAbort.signal });
                        this.loteResultados = r.ok ? await r.json() : [];
                    } catch (e) {
                        if (e && e.name === 'AbortError') return;
                        this.loteResultados = [];
                    }
                },

                podeCriarLote() {
                    const q = this._normLote(this.lote);
                    if (!q) return false;
                    return !this.loteResultados.some(l => this._normLote(l.codigo) === q);
                },

                navLote(delta) {
                    this.loteDropdownOpen = true;
                    const total = this.loteResultados.length + (this.podeCriarLote() ? 1 : 0);
                    if (total === 0) { this.loteIndex = -1; return; }
                    let i = this.loteIndex + delta;
                    if (i < 0) i = total - 1;
                    if (i >= total) i = 0;
                    this.loteIndex = i;
                },

                confirmarLote() {
                    const n = this.loteResultados.length;
                    const temCriar = this.podeCriarLote();
                    const total = n + (temCriar ? 1 : 0);
                    let i = this.loteIndex;
                    if (i < 0 || i >= total) i = 0;
                    if (i < n) this.selecionarLote(this.loteResultados[i]);
                    else if (temCriar) this.usarNovoLote();
                },

                selecionarLote(l) {
                    this.lote = l.codigo;
                    this.loteDropdownOpen = false;
                    this.loteIndex = -1;
                },

                usarNovoLote() {
                    this.lote = this._normLote(this.lote);
                    this.loteDropdownOpen = false;
                    this.loteIndex = -1;
                },

                async gerarCodigoLote() {
                    if (!this.produtoId) { window.showToast('Selecione um produto antes de gerar o lote.', 'warning'); return; }
                    if (this.gerandoLote) return;
                    this.gerandoLote = true;
                    try {
                        const r = await esFetch('/entradas/lote/proximo-codigo?produtoId=' + encodeURIComponent(this.produtoId));
                        if (r.ok) {
                            const d = await r.json();
                            this.lote = d.codigo || this.lote;
                            this.loteDropdownOpen = false;
                            window.showToast('Código de lote gerado.', 'success');
                        } else {
                            window.showToast('Não foi possível gerar o código do lote.', 'error');
                        }
                    } catch (e) {
                        window.showToast('Não foi possível conectar ao servidor.', 'error');
                    } finally {
                        this.gerandoLote = false;
                    }
                },

                async submitEntrada() {
                    if (this.submitting) return;
                    this.submitting = true;
                    this.erroMsg = '';
                    try {
                        const token = document.querySelector('[name=__RequestVerificationToken]')?.value;
                        const body = {
                            produtoId: this.produtoId,
                            varId: this.varId || null,
                            qty: this.qty,
                            custo: this.custo,
                            preco: this.preco || null,
                            fornecedorId: this.fornecedorId || null,
                            lote: this.lote || null,
                            validade: this.validade || null,
                            observacoes: this.observacoes || null,
                            data: this.data
                        };
                        const res = await esFetch('/entradas/nova/json', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                            body: JSON.stringify(body)
                        });
                        const data = await res.json();
                        if (res.ok && data.success) {
                            this.itemEstoqueId = data.itemEstoqueId || '';
                            this.loteSalvo = data.lote || (this.lote ? this.lote.toUpperCase() : '');
                            this.step = 4;
                            window.showToast('Entrada registrada!', 'success');
                        } else {
                            this.erroMsg = data.errorMessage || 'Erro ao registrar entrada. Tente novamente.';
                            window.showToast(this.erroMsg, 'error', 4000);
                        }
                    } catch (e) { console.error('[EasyStock]', e);
                        this.erroMsg = 'Não foi possível conectar ao servidor. Verifique sua conexão.';
                        window.showToast(this.erroMsg, 'error', 4000);
                    } finally {
                        this.submitting = false;
                    }
                }
            };
        }
    </script>
}
