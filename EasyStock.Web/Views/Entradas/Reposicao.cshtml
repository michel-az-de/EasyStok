@model EntradaFormViewModel

<div class="flex items-center gap-3 mb-6">
    <a href="/estoque" class="text-slate-400 hover:text-slate-600 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <div class="pg-hd">
        <h1>Reposição Rápida</h1>
        <p>Reabasteça um produto rapidamente</p>
    </div>
</div>

<div x-data="reposicaoWizard()" class="max-w-3xl">
    <form asp-action="SalvarReposicao" asp-controller="Entradas" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ProdutoId" x-model="produtoId" />
        <input type="hidden" name="VarId" x-model="varId" />
        <input type="hidden" name="Qty" x-model="qty" />
        <input type="hidden" name="Custo" x-model="custo" />
        <input type="hidden" name="Preco" x-model="preco" />
        <input type="hidden" name="Lote" x-model="lote" />
        <input type="hidden" name="Validade" x-model="validade" />
        <input type="hidden" name="Data" x-model="data" />

        <!-- Passo 1: busca produto -->
        <div x-show="step === 1">
            <div class="ws">
                <h3 class="font-bold text-slate-800 mb-4">Qual produto repor?</h3>
                <div class="relative mb-4">
                    <input type="text" x-model="buscaTerm" @@input.debounce.300ms="buscar()"
                           placeholder="Buscar produto..."
                           class="w-full px-4 py-3 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                </div>
                <div class="space-y-2">
                    <template x-for="p in resultados" :key="p.id">
                        <button type="button" @@click="selecionar(p)"
                                class="w-full flex items-center gap-3 p-3 border border-slate-200 rounded-xl hover:border-indigo-300 hover:bg-indigo-50 transition-all text-left">
                            <span class="text-2xl" x-text="p.emoji || '📦'"></span>
                            <div>
                                <div class="font-semibold text-sm" x-text="p.nome"></div>
                                <div class="text-xs text-slate-400 font-mono" x-text="p.sku"></div>
                            </div>
                        </button>
                    </template>
                </div>
            </div>
        </div>

        <!-- Passo 2: detalhes pré-preenchidos -->
        <div x-show="step === 2">
            <div class="ws space-y-4">
                <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-3">
                        <span class="text-2xl" x-text="produtoEmoji"></span>
                        <div>
                            <div class="font-bold text-slate-900" x-text="produtoNome"></div>
                            <div class="text-xs text-slate-400 font-mono" x-text="produtoSku"></div>
                        </div>
                    </div>
                    <button type="button" @@click="step = 1"
                            class="text-sm text-indigo-600 hover:text-indigo-800 font-semibold">
                        Alterar produto
                    </button>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Quantidade *</label>
                        <input type="number" x-model.number="qty" min="1"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Custo unit. (R$) *</label>
                        <input type="number" x-model.number="custo" step="0.01" min="0"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Lote</label>
                        <input type="text" x-model="lote"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Validade</label>
                        <input type="date" x-model="validade"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                    <div class="col-span-2">
                        <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Data</label>
                        <input type="date" x-model="data"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                </div>

                <div class="flex gap-3 mt-2">
                    <button type="button" @@click="step = 1"
                            class="px-4 py-2 border border-slate-300 text-slate-700 text-sm font-semibold rounded-lg hover:bg-slate-50">
                        ← Voltar
                    </button>
                    <button type="button" @@click="step = 3" :disabled="!qty || !custo"
                            class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-2 rounded-lg disabled:opacity-50">
                        Revisar →
                    </button>
                </div>
            </div>
        </div>

        <!-- Passo 3: Confirmação -->
        <div x-show="step === 3">
            <div class="ws">
                <h3 class="font-bold text-slate-800 mb-4">Confirmar reposição</h3>
                <dl class="space-y-3 mb-6">
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <dt class="text-sm text-slate-500">Produto</dt>
                        <dd class="text-sm font-semibold" x-text="produtoNome"></dd>
                    </div>
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <dt class="text-sm text-slate-500">Quantidade</dt>
                        <dd class="text-sm font-semibold" x-text="qty"></dd>
                    </div>
                    <div class="flex justify-between py-2">
                        <dt class="text-sm text-slate-500">Total</dt>
                        <dd class="text-sm font-bold text-indigo-600"
                            x-text="'R$ ' + ((qty || 0) * (custo || 0)).toFixed(2)"></dd>
                    </div>
                </dl>
                <div class="flex gap-3">
                    <button type="button" @@click="step = 2"
                            class="px-4 py-2 border border-slate-300 text-slate-700 text-sm font-semibold rounded-lg hover:bg-slate-50">
                        ← Voltar
                    </button>
                    <button type="submit"
                            class="flex-1 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-2 rounded-lg">
                        Confirmar reposição ✓
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function reposicaoWizard() {
            return {
                step: 1,
                buscaTerm: '',
                resultados: [],
                produtoId: '', produtoNome: '', produtoSku: '', produtoEmoji: '📦',
                varId: '', qty: 1, custo: null, preco: null, lote: '', validade: '',
                data: new Date().toLocaleDateString('en-CA'),

                async buscar() {
                    if (this.buscaTerm.length < 2) { this.resultados = []; return; }
                    const r = await fetch('/produtos/buscar?q=' + encodeURIComponent(this.buscaTerm)).catch(() => null);
                    if (r && r.ok) this.resultados = await r.json();
                },

                async selecionar(p) {
                    this.produtoId = p.id;
                    this.produtoNome = p.nome;
                    this.produtoSku = p.sku;
                    this.produtoEmoji = p.emoji || '📦';
                    this.varId = '';
                    try {
                        const dr = await fetch('/estoque/produto-detalhe/' + p.id);
                        if (dr.ok) {
                            const d = await dr.json();
                            this.varId = d.variacoes && d.variacoes.length > 0 ? d.variacoes[0].id : '';
                        }
                    } catch { this.varId = ''; }
                    this.step = 2;
                }
            };
        }
    </script>
}
