@model ReposicaoFormViewModel

<div class="flex items-center gap-3 mb-6">
    <a href="/estoque" aria-label="Voltar" class="text-slate-400 hover:text-slate-600 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <div class="pg-hd">
        <h1>Reposição Rápida</h1>
        <p>Reabasteça um item de estoque existente</p>
    </div>
</div>

<div x-data="reposicaoWizard()" x-init="init()" class="max-w-3xl min-h-[calc(100vh-14rem)]">

    <!-- Barra de progresso -->
    <div class="ws mb-6">
        <div class="flex items-center">
            @{
                var steps = new[] { "Produto", "Lote", "Quantidade", "Confirmar" };
            }
            @for (int i = 0; i < steps.Length; i++)
            {
                var stepNum = i + 1;
                var isLast = i == steps.Length - 1;
                <div class="flex items-center @(isLast ? "" : "flex-1")">
                    <div class="step-circle" :class="step > @stepNum ? 'done' : step === @stepNum ? 'active' : ''">@stepNum</div>
                    <div class="ml-2 hidden sm:block">
                        <div class="text-xs font-semibold" :class="step === @stepNum ? 'text-indigo-600' : 'text-slate-400'">@steps[i]</div>
                    </div>
                    @if (!isLast)
                    {
                        <div class="step-connector flex-1 mx-3" :class="step > @stepNum ? 'step-connector--done' : ''"></div>
                    }
                </div>
            }
        </div>
    </div>

    <form asp-action="SalvarReposicao" asp-controller="Entradas" method="post" x-ref="mainForm" @@submit="submitting = true">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ItemEstoqueId" x-model="itemEstoqueId" />
        <input type="hidden" name="ProdutoId" x-model="produtoId" />
        <input type="hidden" name="ProdutoNome" x-model="produtoNome" />
        <input type="hidden" name="VariacaoNome" x-model="variacaoNome" />
        <input type="hidden" name="EstoqueAtual" x-model="estoqueAtual" />
        <input type="hidden" name="Qty" x-model="qty" />
        <input type="hidden" name="Custo" x-model="custo" />
        <input type="hidden" name="Preco" x-model="preco" />
        <input type="hidden" name="Validade" x-model="validade" />
        <input type="hidden" name="Observacoes" x-model="observacoes" />
        <input type="hidden" name="Data" x-model="data" />

        <!-- Passo 1: busca produto -->
        <div x-show="step === 1">
            <div class="ws">
                <h3 class="font-bold text-slate-800 mb-4">Qual produto repor?</h3>
                <div class="relative mb-4">
                    <input type="text" x-model="buscaTerm" @@input.debounce.300ms="buscar()"
                           aria-label="Buscar produto por nome, SKU ou código"
                           placeholder="Buscar por nome, SKU ou código..."
                           class="w-full px-4 py-3 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    <div x-show="buscando" class="absolute right-3 top-3 text-slate-400 text-sm">Buscando...</div>
                </div>
                <div class="dropdown-list space-y-2" x-show="resultados.length > 0">
                    <template x-for="p in resultados" :key="p.id">
                        <button type="button" @@click="selecionarProduto(p)"
                                class="dropdown-item w-full flex items-center gap-3 p-3 border border-slate-200 rounded-xl hover:border-indigo-300 hover:bg-indigo-50 transition-all text-left">
                            <div class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center text-lg flex-shrink-0">📦</div>
                            <div class="flex-1 min-w-0">
                                <div class="font-semibold text-slate-900 truncate" x-text="p.nome"></div>
                                <div class="text-xs text-slate-400 font-mono" x-text="p.sku || '-'"></div>
                            </div>
                        </button>
                    </template>
                </div>
                <div x-show="buscaTerm.length > 1 && !buscando && resultados.length === 0"
                     class="text-center py-6 text-slate-400 text-sm">
                    Nenhum produto encontrado
                </div>
            </div>
        </div>

        <!-- Passo 2: selecionar lote existente -->
        <div x-show="step === 2">
            <div class="ws">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-bold text-slate-800">Selecione o lote para repor</h3>
                    <button type="button" @@click="step = 1"
                            class="text-sm text-indigo-600 hover:text-indigo-800 font-semibold">
                        Selecionar produto
                    </button>
                </div>
                <div class="flex items-center gap-2 mb-4 p-3 bg-slate-50 rounded-lg">
                    <span class="text-xl">📦</span>
                    <div>
                        <div class="font-semibold text-sm text-slate-900" x-text="produtoNome"></div>
                        <div class="text-xs text-slate-400 font-mono" x-text="produtoSku"></div>
                    </div>
                </div>

                <div x-show="carregandoLotes" class="text-center py-6 text-slate-400 text-sm">
                    Carregando lotes...
                </div>

                <div x-show="!carregandoLotes && lotes.length === 0" class="text-center py-6">
                    <div class="text-slate-400 mb-3">Nenhum lote encontrado para este produto.</div>
                    <a href="/entradas/nova" class="text-indigo-600 hover:underline text-sm font-semibold">
                        Registrar nova entrada
                    </a>
                </div>

                <div class="space-y-2" x-show="!carregandoLotes && lotes.length > 0">
                    <template x-for="l in lotes" :key="l.id">
                        <button type="button" @@click="selecionarLote(l)"
                                class="w-full flex items-center gap-4 p-4 border border-slate-200 rounded-xl hover:border-indigo-300 hover:bg-indigo-50 transition-all text-left">
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="font-semibold text-sm text-slate-900"
                                          x-text="l.variacao?.nome || 'Padrão'"></span>
                                    <span x-show="l.lote"
                                          class="text-xs bg-slate-100 text-slate-600 px-2 py-0.5 rounded font-mono"
                                          x-text="'Lote: ' + l.lote"></span>
                                </div>
                                <div class="flex gap-4 text-xs text-slate-500">
                                    <span x-text="'Entrada: ' + new Date(l.entryDate).toLocaleDateString('pt-BR')"></span>
                                    <span x-show="l.validade" x-text="'Val: ' + new Date(l.validade).toLocaleDateString('pt-BR')"></span>
                                </div>
                            </div>
                            <div class="text-right flex-shrink-0">
                                <div class="text-lg font-bold" :class="l.qty <= 2 ? 'text-red-600' : l.qty <= 5 ? 'text-amber-600' : 'text-emerald-600'"
                                     x-text="l.qty + ' un'"></div>
                                <div class="text-xs text-slate-400"
                                     x-text="l.custoUnitario ? 'R$ ' + l.custoUnitario.valor.toFixed(2).replace('.', ',') : ''"></div>
                            </div>
                        </button>
                    </template>
                </div>
            </div>
        </div>

        <!-- Passo 3: quantidade e dados operacionais -->
        <div x-show="step === 3">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-2 ws space-y-4">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="font-bold text-slate-800">Dados da reposição</h3>
                        <button type="button" @@click="step = 2"
                                class="text-sm text-indigo-600 hover:text-indigo-800 font-semibold">
                            Alterar lote
                        </button>
                    </div>

                    <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-lg">
                        <span class="text-xl">📦</span>
                        <div class="flex-1">
                            <div class="font-semibold text-sm" x-text="produtoNome"></div>
                            <div class="text-xs text-slate-400" x-text="variacaoNome || 'Padrão'"></div>
                        </div>
                        <div class="text-right">
                            <div class="text-sm font-bold" x-text="estoqueAtual + ' un'"></div>
                            <div class="text-xs text-slate-400">Atual</div>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="col-span-2">
                            <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Quantidade a repor *</label>
                            <input type="number" x-model.number="qty" min="1"
                                   class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        </div>
                        <div>
                            <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Custo unitário (R$)</label>
                            @* BUG-001: text+inputmode=decimal (parse locale-safe) *@
                            <input type="text" inputmode="decimal" x-model.number="custo"
                                   class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   placeholder="Manter atual" />
                        </div>
                        <div>
                            <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Preço sugerido (R$)</label>
                            @* BUG-001: text+inputmode=decimal (parse locale-safe) *@
                            <input type="text" inputmode="decimal" x-model.number="preco"
                                   class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   placeholder="Manter atual" />
                        </div>
                        <div>
                            <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Validade</label>
                            <input type="date" x-model="validade"
                                   class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        </div>
                        <div>
                            <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Data</label>
                            <input type="date" x-model="data"
                                   class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        </div>
                        <div class="col-span-2">
                            <label class="text-sm font-semibold text-slate-700 mb-1.5 block">Observações</label>
                            <textarea x-model="observacoes" rows="2"
                                      class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"></textarea>
                        </div>
                    </div>

                    <div class="flex gap-3 mt-2">
                        <button type="button" @@click="step = 2"
                                class="px-4 py-2 border border-slate-300 text-slate-700 text-sm font-semibold rounded-lg hover:bg-slate-50">
                            ← Voltar
                        </button>
                        <button type="submit"
                                :disabled="submitting"
                                :class="{ 'opacity-50 cursor-not-allowed': submitting }"
                                class="flex-1 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-2 rounded-lg transition-colors">
                            <span x-show="!submitting">Confirmar reposição</span>
                            <span x-show="submitting" x-cloak>Registrando...</span>
                        </button>
                    </div>
                </div>

                <!-- Painel lateral: preview -->
                <div class="ws h-fit">
                    <h4 class="font-bold text-slate-800 mb-3">Preview</h4>
                    <div class="space-y-2">
                        <div class="flex justify-between text-sm">
                            <span class="text-slate-500">Estoque atual</span>
                            <span class="font-semibold" x-text="estoqueAtual"></span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-slate-500">Reposição</span>
                            <span class="font-semibold text-emerald-600" x-text="'+ ' + (qty || 0)"></span>
                        </div>
                        <div class="flex justify-between text-sm font-bold border-t border-slate-100 pt-2">
                            <span>Novo total</span>
                            <span class="text-indigo-600" x-text="Number(estoqueAtual) + Number(qty || 0)"></span>
                        </div>
                        <div class="flex justify-between text-sm border-t border-slate-100 pt-2" x-show="custo">
                            <span class="text-slate-500">Valor reposição</span>
                            <span class="font-semibold" x-text="'R$ ' + ((qty || 0) * (custo || 0)).toFixed(2).replace('.', ',')"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Passo 4: Confirmação -->
        <div x-show="step === 4">
            <div class="ws">
                <h3 class="font-bold text-slate-800 mb-4">Confirmar reposição</h3>
                <dl class="space-y-3 mb-6">
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <dt class="text-sm text-slate-500">Produto</dt>
                        <dd class="text-sm font-semibold" x-text="produtoNome"></dd>
                    </div>
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <dt class="text-sm text-slate-500">Variação</dt>
                        <dd class="text-sm font-semibold" x-text="variacaoNome || 'Padrão'"></dd>
                    </div>
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <dt class="text-sm text-slate-500">Estoque atual → após reposição</dt>
                        <dd class="text-sm font-semibold">
                            <span x-text="estoqueAtual"></span>
                            →
                            <span class="text-emerald-600" x-text="Number(estoqueAtual) + Number(qty)"></span>
                        </dd>
                    </div>
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <dt class="text-sm text-slate-500">Quantidade reposta</dt>
                        <dd class="text-sm font-semibold text-emerald-600" x-text="'+ ' + qty"></dd>
                    </div>
                    <div class="flex justify-between py-2 border-b border-slate-50" x-show="custo">
                        <dt class="text-sm text-slate-500">Custo unitário</dt>
                        <dd class="text-sm font-semibold" x-text="custo ? 'R$ ' + custo.toFixed(2).replace('.', ',') : 'Manter atual'"></dd>
                    </div>
                    <div class="flex justify-between py-2" x-show="custo">
                        <dt class="text-sm text-slate-500">Valor total reposição</dt>
                        <dd class="text-sm font-bold text-indigo-600"
                            x-text="'R$ ' + ((qty || 0) * (custo || 0)).toFixed(2).replace('.', ',')"></dd>
                    </div>
                </dl>

                <div class="flex gap-3">
                    <button type="button" @@click="step = 3"
                            class="px-4 py-2 border border-slate-300 text-slate-700 text-sm font-semibold rounded-lg hover:bg-slate-50">
                        ← Voltar
                    </button>
                    <button type="submit"
                            :disabled="submitting"
                            :class="{ 'opacity-50 cursor-not-allowed': submitting }"
                            class="flex-1 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-2 rounded-lg transition-colors">
                        <span x-show="!submitting">Confirmar reposição</span>
                        <span x-show="submitting" x-cloak>Registrando...</span>
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function reposicaoWizard() {
            return {
                step: 1,
                submitting: false,
                buscaTerm: '',
                buscando: false,
                resultados: [],
                carregandoLotes: false,
                lotes: [],

                // Dados do item selecionado
                itemEstoqueId: '@(Model.ItemEstoqueId ?? "")',
                produtoId: '@(Model.ProdutoId ?? "")',
                produtoNome: @Json.Serialize(Model.ProdutoNome ?? ""),
                produtoSku: '',
                variacaoNome: @Json.Serialize(Model.VariacaoNome ?? ""),
                estoqueAtual: @Model.EstoqueAtual,

                // Campos do form
                qty: 1,
                custo: @(Model.Custo.HasValue ? Model.Custo.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null"),
                preco: @(Model.Preco.HasValue ? Model.Preco.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null"),
                validade: '',
                observacoes: '',
                data: new Date().toLocaleDateString('en-CA'),

                init() {
                    // Se veio com itemId pre-preenchido, pular para step 3
                    if (this.itemEstoqueId) {
                        this.step = 3;
                    }
                },

                async buscar() {
                    if (this.buscaTerm.length < 2) { this.resultados = []; return; }
                    this.buscando = true;
                    try {
                        const r = await esFetch('/produtos/buscar?q=' + encodeURIComponent(this.buscaTerm));
                        if (r.ok) this.resultados = await r.json();
                    } finally {
                        this.buscando = false;
                    }
                },

                async selecionarProduto(p) {
                    this.produtoId = p.id;
                    this.produtoNome = p.nome;
                    this.produtoSku = p.sku || '';
                    this.carregandoLotes = true;
                    this.lotes = [];
                    this.step = 2;

                    try {
                        const r = await esFetch('/estoque/itens-por-produto/' + p.id);
                        if (r.ok) {
                            this.lotes = await r.json();
                            // Se so tem 1 lote, auto-selecionar
                            if (this.lotes.length === 1) {
                                this.selecionarLote(this.lotes[0]);
                            }
                        }
                    } catch {
                        this.lotes = [];
                    } finally {
                        this.carregandoLotes = false;
                    }
                },

                selecionarLote(l) {
                    this.itemEstoqueId = l.id;
                    this.estoqueAtual = l.qty;
                    this.variacaoNome = l.variacao?.nome || '';
                    this.custo = l.custoUnitario?.valor || null;
                    this.preco = l.precoVendaSugerido?.valor || null;
                    this.step = 3;
                }
            };
        }
    </script>
}
