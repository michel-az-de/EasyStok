@model AssinaturaViewModel
@{
    ViewBag.Title = "Assinatura";
    Layout = "_Layout";
}

<div class="pg-hd mb-6">
    <h1>Planos Disponíveis</h1>
    <p>Escolha o plano ideal para o seu negócio</p>
</div>

@if (Model.MostrarUpgradeWall)
{
    var recursoNome = Model.LimiteAtingidoRecurso switch
    {
        "lojas" => "lojas",
        "usuarios" => "usuários",
        "produtos" => "produtos",
        _ => Model.LimiteAtingidoRecurso
    };
    <div class="flex items-start gap-3 p-4 mb-6 rounded-xl bg-amber-50 border border-amber-200">
        <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M10.29 3.86l-7.11 12.3A2 2 0 004.91 19h14.18a2 2 0 001.73-2.84l-7.11-12.3a2 2 0 00-3.42 0z" />
        </svg>
        <div>
            <p class="text-sm font-semibold text-amber-800">Limite do plano atingido</p>
            <p class="text-sm text-amber-700 mt-0.5">
                Você atingiu o limite de <strong>@recursoNome</strong> do seu plano atual.
                Faça upgrade para continuar crescendo.
            </p>
            <a href="mailto:contato@easystock.com.br?subject=Upgrade de plano"
               class="inline-block mt-2 text-xs font-semibold text-amber-700 underline hover:text-amber-900">
                Entrar em contato para upgrade →
            </a>
        </div>
    </div>
}

@if (Model.Planos.Any())
{
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        @foreach (var plano in Model.Planos)
        {
            <div class="ws">
                <h3 class="font-bold text-slate-900 text-lg">@plano.Nome</h3>
                @if (!string.IsNullOrWhiteSpace(plano.Descricao))
                {
                    <p class="text-sm text-slate-500 mt-1">@plano.Descricao</p>
                }
                <p class="text-2xl font-bold text-indigo-600 my-3">
                    R$ @plano.PrecoMensal.ToString("N2")
                    <span class="text-sm font-normal text-slate-500">/mês</span>
                </p>
                <ul class="space-y-2">
                    <li class="flex items-center gap-2 text-sm text-slate-600">
                        <svg class="w-4 h-4 text-indigo-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                        </svg>
                        <span><strong>@PlanoInfo.FormatarLimite(plano.LimiteLojas)</strong> lojas</span>
                    </li>
                    <li class="flex items-center gap-2 text-sm text-slate-600">
                        <svg class="w-4 h-4 text-indigo-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <span><strong>@PlanoInfo.FormatarLimite(plano.LimiteUsuarios)</strong> usuários</span>
                    </li>
                    <li class="flex items-center gap-2 text-sm text-slate-600">
                        <svg class="w-4 h-4 text-indigo-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                        <span><strong>@PlanoInfo.FormatarLimite(plano.LimiteProdutos)</strong> produtos</span>
                    </li>
                </ul>
            </div>
        }
    </div>

    <p class="text-sm text-slate-500">Para alterar seu plano, <a href="mailto:contato@easystock.com.br?subject=Upgrade de plano" class="text-indigo-600 hover:underline">entre em contato</a>.</p>
}
else
{
    <div class="ws">
        <p class="text-slate-500">Nenhum plano disponível no momento.</p>
    </div>
}
