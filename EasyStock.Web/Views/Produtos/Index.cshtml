@model ProdutosListViewModel
@using System.Globalization
@{
    var ptBR = new CultureInfo("pt-BR");
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Produtos</h1>
        <p>@Model.Paginacao.Total produto(s) cadastrado(s)</p>
    </div>
    <a href="/produtos/novo"
       class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Novo produto
    </a>
</div>

<!-- Filtros -->
<div class="ws mb-4">
    <form method="get" class="flex flex-wrap gap-3">
        <input type="text" name="search" value="@Model.Search" placeholder="Buscar por nome ou SKU..."
               class="flex-1 min-w-48 px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
        <select name="categoria"
                class="px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
            <option value="">Todas as categorias</option>
        </select>
        <select name="status"
                class="px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
            <option value="">Todos os status</option>
            <option value="ativo" selected="@(Model.Status == "ativo")">Ativo</option>
            <option value="inativo" selected="@(Model.Status == "inativo")">Inativo</option>
        </select>
        <button type="submit"
                class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            Filtrar
        </button>
    </form>
</div>

<!-- Tabela -->
<div class="ws">
    @if (Model.Produtos.Any())
    {
        <table class="tbl-full">
            <thead>
                <tr>
                    <th>Produto</th>
                    <th>Categoria</th>
                    <th class="text-center">Variações</th>
                    <th class="text-right">Preço</th>
                    <th class="text-center">Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Produtos)
                {
                    <tr>
                        <td>
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 bg-slate-100 rounded-lg flex items-center justify-center text-lg flex-shrink-0">
                                    @(string.IsNullOrEmpty(p.Emoji) ? "📦" : p.Emoji)
                                </div>
                                <div>
                                    <div class="font-semibold text-slate-900">@p.Nome</div>
                                    <div class="text-xs text-slate-400 font-mono">@p.Sku</div>
                                </div>
                            </div>
                        </td>
                        <td class="text-slate-600">@p.Categoria</td>
                        <td class="text-center">
                            <span class="text-slate-600">@p.Variacoes.Count</span>
                        </td>
                        <td class="text-right font-semibold">@p.Preco.ToString("C", ptBR)</td>
                        <td class="text-center">
                            @{
                                var badgeClass = p.Status?.ToLower() switch
                                {
                                    "ativo" => "badge-ok",
                                    "inativo" => "badge-warn",
                                    _ => "badge-slow"
                                };
                            }
                            <span class="badge @badgeClass px-2 py-0.5 rounded-full text-xs font-semibold">@p.Status</span>
                        </td>
                        <td>
                            <div class="flex items-center justify-end gap-2">
                                <a href="/produtos/@p.Id"
                                   class="text-xs font-semibold text-indigo-600 hover:text-indigo-800 px-3 py-1.5 border border-indigo-200 rounded-lg hover:bg-indigo-50 transition-colors">
                                    Ver
                                </a>
                                <a href="/entradas/nova"
                                   class="text-xs font-semibold text-emerald-600 hover:text-emerald-800 px-3 py-1.5 border border-emerald-200 rounded-lg hover:bg-emerald-50 transition-colors">
                                    Entrada
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Paginação -->
        @if (Model.Paginacao.Pages > 1)
        {
            <div class="flex items-center justify-between mt-4 pt-4 border-t border-slate-100">
                <span class="text-sm text-slate-500">
                    Página @Model.Paginacao.Page de @Model.Paginacao.Pages
                </span>
                <div class="flex gap-2">
                    @if (Model.Paginacao.HasPrevious)
                    {
                        <a href="?page=@(Model.Paginacao.Page - 1)&search=@Model.Search&categoria=@Model.Categoria&status=@Model.Status"
                           class="px-3 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">← Anterior</a>
                    }
                    @if (Model.Paginacao.HasNext)
                    {
                        <a href="?page=@(Model.Paginacao.Page + 1)&search=@Model.Search&categoria=@Model.Categoria&status=@Model.Status"
                           class="px-3 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">Próximo →</a>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-12 text-slate-400">
            <div class="text-5xl mb-3">📦</div>
            @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Status))
            {
                <p class="font-semibold text-slate-600">Nenhum produto corresponde à busca</p>
                <p class="text-sm mt-1">Tente outros termos ou <a href="/produtos" class="text-indigo-600 hover:underline">limpe os filtros</a> para ver todos os produtos.</p>
            }
            else
            {
                <p class="font-semibold text-slate-600">Seu catálogo ainda está vazio</p>
                <p class="text-sm mt-1">Comece <a href="/produtos/novo" class="text-indigo-600 hover:underline">cadastrando o primeiro produto</a> para controlar seu estoque.</p>
            }
        </div>
    }
</div>
