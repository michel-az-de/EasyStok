@model ProdutosListViewModel
@using System.Globalization
@{
    var ptBR = new CultureInfo("pt-BR");
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Produtos</h1>
        <p>@Model.Paginacao.Total @(Model.Paginacao.Total == 1 ? "produto listado" : "produtos listados")</p>
    </div>
    <a href="/produtos/novo"
       class="app-primary-btn relative z-10 flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Novo produto
    </a>
</div>

<!-- Filtros -->
<div class="ws mb-4">
    <form method="get" x-data="{ q: '@Html.Raw(Model.Search?.Replace("'", "\\'") ?? "")' }" class="flex flex-wrap gap-3">
        <input type="text" name="search" x-model="q"
               @@input.debounce.400ms="$el.closest('form').submit()"
               value="@Model.Search" placeholder="Buscar por nome ou SKU..."
               class="ui-field flex-1 min-w-48" />
        <button type="submit"
                class="app-primary-btn bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
            Filtrar
        </button>
    </form>
</div>

<!-- Tabela -->
<div class="ws">
    @if (Model.Produtos.Any())
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead>
                <tr>
                    <th>Produto</th>
                    <th class="text-right">Preço</th>
                    <th class="text-center">Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Produtos)
                {
                    <tr x-data="{ confirm: false, menuOpen: false }">
                        <td>
                            <div class="flex items-center gap-3">
                                @if (p.PrimeiraFotoUrl is not null)
                                {
                                    <div class="product-list-thumb">
                                        <img src="@p.PrimeiraFotoUrl" alt="@p.Nome" class="w-full h-full object-cover object-top flex-shrink-0"
                                             onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden');" />
                                        <div class="product-list-thumb__placeholder hidden">
                                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                            </svg>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="product-list-thumb product-list-thumb__placeholder">
                                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                        </svg>
                                    </div>
                                }
                                <div>
                                    <div class="font-semibold text-slate-900">@p.Nome</div>
                                    <div class="text-xs text-slate-400 font-mono">@(p.SkuBase?.Value ?? string.Empty)</div>
                                </div>
                            </div>
                        </td>
                        <td class="text-right font-semibold">@((p.PrecoReferencia?.Valor ?? 0).ToString("C", ptBR))</td>
                        <td class="text-center">
                            @{
                                var badgeClass = p.StatusNome.ToLower() switch
                                {
                                    "ativo" => "badge-ok",
                                    "inativo" => "badge-warn",
                                    _ => "badge-slow"
                                };
                            }
                            <span class="badge @badgeClass px-2 py-0.5 rounded-full text-xs font-semibold">@p.StatusNome</span>
                        </td>
                        <td>
                            <div class="relative flex items-center justify-end">
                                <button type="button"
                                        @@click="menuOpen = !menuOpen"
                                        class="grid-action-btn grid-action-btn--ghost product-row-menu-btn"
                                        title="Abrir ações do produto"
                                        aria-label="Abrir ações do produto">
                                    <svg fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z" />
                                    </svg>
                                </button>
                                <div x-show="menuOpen" x-cloak @@click.outside="menuOpen = false"
                                     class="product-row-menu">
                                    <a href="/produtos/@p.Id" class="product-row-menu__item">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                        </svg>
                                        Ver produto
                                    </a>
                                    <a href="/entradas/nova?produtoId=@p.Id" class="product-row-menu__item product-row-menu__item--success">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                        </svg>
                                        Registrar entrada
                                    </a>
                                    <button type="button" @@click="menuOpen = false; confirm = true"
                                            class="product-row-menu__item product-row-menu__item--danger">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                        Excluir
                                    </button>
                                </div>
                            </div>

                            <!-- Modal confirmar exclusão -->
                            <div x-show="confirm" x-cloak
                                 class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                                 @@click.self="confirm = false">
                                <div class="ui-modal bg-white rounded-xl p-6 w-80 shadow-xl">
                                    <h3 class="font-semibold text-slate-900 mb-2">Excluir produto</h3>
                                    <p class="text-sm text-slate-600 mb-4">
                                        Excluir <strong>@p.Nome</strong>? Esta ação é irreversível.
                                    </p>
                                    <div class="flex justify-end gap-3">
                                        <button type="button" @@click="confirm = false"
                                                class="ui-secondary-btn px-3 py-1.5 text-sm border rounded-lg hover:bg-slate-50">
                                            Cancelar
                                        </button>
                                        <form action="/produtos/@p.Id/excluir" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="px-3 py-1.5 bg-red-600 text-white text-sm rounded-lg hover:bg-red-700">
                                                Excluir
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>

        <!-- Paginação -->
        @if (Model.Paginacao.Pages > 1)
        {
            <div class="flex items-center justify-between mt-4 pt-4 border-t border-slate-100">
                <span class="text-sm text-slate-500">
                    @if (Model.Paginacao.HasNext)
                    {
                        <text>Página @Model.Paginacao.Page — mais resultados →</text>
                    }
                    else
                    {
                        <text>Página @Model.Paginacao.Page (última)</text>
                    }
                </span>
                <div class="flex gap-2">
                    @if (Model.Paginacao.HasPrevious)
                    {
                        <a href="?page=@(Model.Paginacao.Page - 1)&search=@Model.Search"
                           class="px-3 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">← Anterior</a>
                    }
                    @if (Model.Paginacao.HasNext)
                    {
                        <a href="?page=@(Model.Paginacao.Page + 1)&search=@Model.Search"
                           class="px-3 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">Próximo →</a>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-12 text-slate-400">
            <div class="text-5xl mb-3">📦</div>
            <p class="font-semibold text-slate-600">Nenhum produto encontrado</p>
            <p class="text-sm mt-1">Tente ajustar os filtros ou <a href="/produtos/novo" class="text-indigo-600 hover:underline">cadastre um novo produto</a>.</p>
        </div>
    }
</div>
