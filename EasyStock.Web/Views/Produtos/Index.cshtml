@model ProdutosListViewModel
@using System.Globalization
@{
    var ptBR = new CultureInfo("pt-BR");
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Produtos</h1>
        <p>@Model.Paginacao.Total @(Model.Paginacao.Total == 1 ? "produto listado" : "produtos listados")</p>
    </div>
    <a href="/produtos/novo"
       class="app-primary-btn relative z-10 flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Novo produto
    </a>
</div>

<!-- Filtros -->
<div class="ws mb-4">
    <form method="get" class="flex flex-wrap gap-3 items-center" role="search" aria-label="Filtrar produtos">
        <input type="search" name="search" value="@Model.Search" placeholder="Buscar por nome ou SKU..."
               aria-label="Buscar por nome ou SKU" class="ui-field flex-1 min-w-48" />
        <div class="ui-select-shell">
            <select name="categoria" aria-label="Filtrar por categoria" class="ui-select ui-select--plain text-sm">
                <option value="">Todas as categorias</option>
                @foreach (var cat in Model.Categorias)
                {
                    if (Model.Categoria == cat.Nome)
                    {
                        <option value="@cat.Nome" selected="selected">@cat.Nome</option>
                    }
                    else
                    {
                        <option value="@cat.Nome">@cat.Nome</option>
                    }
                }
            </select>
            <span class="ui-select-shell__icon" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 9l-7 7-7-7" />
                </svg>
            </span>
        </div>
        <div class="ui-select-shell">
            <select name="status" aria-label="Filtrar por status" class="ui-select ui-select--plain text-sm">
                <option value="">Todos os status</option>
                @if (Model.Status == "Ativo")
                {
                    <option value="Ativo" selected="selected">Ativo</option>
                }
                else
                {
                    <option value="Ativo">Ativo</option>
                }
                @if (Model.Status == "Inativo")
                {
                    <option value="Inativo" selected="selected">Inativo</option>
                }
                else
                {
                    <option value="Inativo">Inativo</option>
                }
            </select>
            <span class="ui-select-shell__icon" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 9l-7 7-7-7" />
                </svg>
            </span>
        </div>
        <label class="flex items-center gap-1.5 text-sm text-slate-600 cursor-pointer select-none">
            <input type="checkbox" name="semPreco" value="true" @(Model.SemPreco ? "checked" : "")
                   class="w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-300" />
            Sem preço
        </label>
        <button type="submit"
                class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
            Filtrar
        </button>
        @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Categoria) || !string.IsNullOrEmpty(Model.Status) || Model.SemPreco)
        {
            <a href="/produtos" class="text-sm text-slate-500 hover:text-slate-700">Limpar</a>
        }
    </form>
</div>

<!-- Tabela -->
<div class="ws">
    @if (Model.Produtos.Any())
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead>
                <tr>
                    <th>Produto</th>
                    <th class="text-right">Preço</th>
                    <th class="text-center">Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Produtos)
                {
                    <tr x-data="{ menuOpen: false, precoModal: false, precoVal: '', precoSaving: false }" class="cursor-pointer hover:bg-slate-50 transition-colors" @@click="window.location.href='/produtos/@p.Id'">
                        <td>
                            <div class="flex items-center gap-3">
                                @if (p.PrimeiraFotoUrl is not null)
                                {
                                    <div class="product-list-thumb">
                                        <img src="@p.PrimeiraFotoUrl" alt="@p.Nome" loading="lazy" decoding="async" class="w-full h-full object-cover object-top flex-shrink-0"
                                             onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden');" />
                                        <div class="product-list-thumb__placeholder hidden">
                                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                            </svg>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="product-list-thumb product-list-thumb__placeholder">
                                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                        </svg>
                                    </div>
                                }
                                <div>
                                    <div class="font-semibold text-slate-900">@p.Nome</div>
                                    <div class="text-xs text-slate-400 font-mono">@(p.SkuBase?.Value ?? string.Empty)</div>
                                </div>
                            </div>
                        </td>
                        <td class="text-right font-semibold">
                            @if (p.PrecoReferencia?.Valor is > 0)
                            {
                                @p.PrecoReferencia.Valor.ToString("C", ptBR)
                            }
                            else
                            {
                                <button type="button" @@click.stop="precoModal = true; precoVal = ''"
                                        class="text-indigo-500 hover:text-indigo-700 text-xs font-medium underline underline-offset-2">
                                    Definir preço →
                                </button>
                            }
                        </td>
                        <td class="text-center">
                            @{
                                var badgeClass = p.StatusNome.ToLower() switch
                                {
                                    "ativo" => "badge-ok",
                                    "inativo" => "badge-warn",
                                    _ => "badge-slow"
                                };
                            }
                            <span class="badge @badgeClass px-2 py-0.5 rounded-full text-xs font-semibold">@p.StatusNome</span>
                        </td>
                        <td>
                            <div class="relative flex items-center justify-end">
                                <button type="button"
                                        @@click.stop="menuOpen = !menuOpen"
                                        class="grid-action-btn grid-action-btn--ghost product-row-menu-btn"
                                        title="Abrir ações do produto"
                                        aria-label="Abrir ações do produto">
                                    <svg fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z" />
                                    </svg>
                                </button>
                                <div x-show="menuOpen" x-cloak @@click.outside="menuOpen = false" @@click.stop
                                     class="product-row-menu">
                                    <a href="/produtos/@p.Id" class="product-row-menu__item">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                        </svg>
                                        Ver produto
                                    </a>
                                    <a href="/produtos/@p.Id/editar" class="product-row-menu__item">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                        Editar produto
                                    </a>
                                    <a href="/entradas/nova?produtoId=@p.Id" class="product-row-menu__item product-row-menu__item--success">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                        </svg>
                                        Registrar entrada
                                    </a>
                                    <button type="button"
                                            @@click="menuOpen = false; $dispatch('confirm-action', { titulo: 'Excluir produto', mensagem: 'Excluir <strong>@(p.Nome.Replace("'", "\\'"))</strong>? O produto será inativado.', textoBotao: 'Excluir', classBotao: 'bg-red-600 hover:bg-red-700', formAction: '/produtos/@p.Id/excluir' })"
                                            class="product-row-menu__item product-row-menu__item--danger">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                        Excluir
                                    </button>
                                </div>
                            </div>
                            <!-- Modal definir preço -->
                            <div x-show="precoModal" x-cloak @@click.stop
                                 class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                                 @@click.self="precoModal = false">
                                <div class="bg-white rounded-xl p-6 w-80 shadow-xl">
                                    <h3 class="font-semibold text-slate-900 mb-1">Definir preço</h3>
                                    <p class="text-sm text-slate-500 mb-4">@p.Nome</p>
                                    <div class="mb-4">
                                        <label class="block text-xs text-slate-500 mb-1">Preço de referência (R$)</label>
                                        <input type="number" step="0.01" min="0" x-model="precoVal" @@click.stop
                                               @@keydown.enter.prevent="if(precoVal > 0) $refs.btnSalvarPreco_@(p.Id.ToString().Replace("-","")).click()"
                                               class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-300 focus:outline-none"
                                               placeholder="0,00" autofocus />
                                    </div>
                                    <div class="flex justify-end gap-3">
                                        <button type="button" @@click.stop="precoModal = false"
                                                class="px-3 py-1.5 text-sm border rounded-lg hover:bg-slate-50">
                                            Cancelar
                                        </button>
                                        <button type="button" x-ref="btnSalvarPreco_@(p.Id.ToString().Replace("-",""))"
                                                :disabled="precoSaving || !precoVal || precoVal <= 0"
                                                :class="{ 'opacity-50 cursor-not-allowed': precoSaving || !precoVal || precoVal <= 0 }"
                                                @@click.stop="
                                                    precoSaving = true;
                                                    fetch('/produtos/@p.Id/preco-rapido', {
                                                        method: 'POST',
                                                        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest', 'RequestVerificationToken': document.querySelector('[name=__RequestVerificationToken]')?.value ?? '' },
                                                        body: 'preco=' + encodeURIComponent(precoVal)
                                                    }).then(r => r.json()).then(d => {
                                                        if(d.ok) { window.showToast('Preço atualizado!', 'success'); location.reload(); }
                                                        else { window.showToast(d.erro || 'Erro ao salvar.', 'error'); precoSaving = false; }
                                                    }).catch(() => { window.showToast('Erro ao salvar.', 'error'); precoSaving = false; })
                                                "
                                                class="px-3 py-1.5 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700">
                                            <span x-show="!precoSaving">Salvar</span>
                                            <span x-show="precoSaving" x-cloak class="flex items-center gap-1"><span class="spinner"></span> Salvando...</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>

        <!-- Paginação -->
        @if (Model.Paginacao.Pages > 1)
        {
            var from = (Model.Paginacao.Page - 1) * Model.Paginacao.Limit + 1;
            var to = Math.Min(Model.Paginacao.Page * Model.Paginacao.Limit, Model.Paginacao.Total);
            <div class="flex items-center justify-between mt-4 pt-4 border-t border-slate-100">
                <span class="text-sm text-slate-500">
                    Mostrando @from-@to de @Model.Paginacao.Total produto@(Model.Paginacao.Total == 1 ? "" : "s")
                </span>
                <partial name="_Pagination" model='new { Page = (int)Model.Paginacao.Page, TotalPages = (int)Model.Paginacao.Pages }' />
            </div>
        }
    }
    else
    {
        <div class="text-center py-12 text-slate-400">
            <es-icon name="package" class="mx-auto mb-3" style="width:48px; height:48px; color: var(--text-muted);"></es-icon>
            <p class="font-semibold text-slate-600">Nenhum produto encontrado</p>
            <p class="text-sm mt-1">Tente ajustar os filtros ou <a href="/produtos/novo" class="text-indigo-600 hover:underline">cadastre um novo produto</a>.</p>
        </div>
    }
</div>
