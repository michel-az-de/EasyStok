@model ProdutoDetailViewModel
@using System.Globalization
@{
    var ptBR = new CultureInfo("pt-BR");
    var p = Model.Produto;
}

<!-- Header -->
<div class="flex items-start justify-between mb-6">
    <div class="flex items-center gap-4">
        <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center justify-center text-3xl">
            📦
        </div>
        <div>
            <h1 class="text-2xl font-extrabold text-slate-900">@p.Nome</h1>
            <div class="flex items-center gap-3 mt-1">
                <span class="text-slate-400 text-sm font-mono">@(p.SkuBase ?? string.Empty)</span>
                @{
                    var statusBadge = p.StatusNome.ToLower() switch
                    {
                        "ativo" => "badge-ok",
                        _ => "badge-warn"
                    };
                }
                <span class="badge @statusBadge px-2 py-0.5 rounded-full text-xs font-semibold">@p.StatusNome</span>
            </div>
        </div>
    </div>
    <div class="flex items-center gap-2">
        <a href="/produtos/@p.ProdutoId/editar"
           class="px-4 py-2 text-sm font-semibold border border-indigo-300 text-indigo-600 rounded-lg hover:bg-indigo-50 transition-colors">
            Editar
        </a>
        <!-- Modal confirm excluir -->
        <div x-data="{ open: false }">
            <button @@click="open = true"
                    class="px-4 py-2 text-sm font-semibold border border-red-200 text-red-600 rounded-lg hover:bg-red-50 transition-colors">
                Excluir
            </button>
            <div x-show="open" class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center" x-transition>
                <div @@click.stop class="bg-white rounded-2xl shadow-2xl p-6 max-w-sm w-full mx-4">
                    <h3 class="font-bold text-slate-900 text-lg mb-2">Excluir produto?</h3>
                    <p class="text-slate-500 text-sm mb-6">Esta ação é irreversível. O produto <strong>@p.Nome</strong> será excluído permanentemente.</p>
                    <div class="flex gap-3 justify-end">
                        <button @@click="open = false"
                                class="px-4 py-2 text-sm font-semibold border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
                            Cancelar
                        </button>
                        <form asp-action="Excluir" asp-controller="Produtos" asp-route-id="@p.ProdutoId" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="px-4 py-2 text-sm font-semibold bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors">
                                Confirmar exclusão
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Abas -->
<div x-data="{ tab: 'info' }">
    <!-- Tab nav -->
    <div class="flex gap-1 border-b border-slate-200 mb-6">
        @{
            var tabs = new[] { ("info", "Informações"), ("estoque", "Estoque por variação"), ("historico", "Histórico") };
        }
        @foreach (var (tabId, tabLabel) in tabs)
        {
            <button @@click="tab = '@tabId'"
                    :class="tab === '@tabId' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                    class="px-4 py-2 text-sm transition-colors">
                @tabLabel
            </button>
        }
    </div>

    <!-- Tab: Informações -->
    <div x-show="tab === 'info'">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="ws">
                <h3 class="font-bold text-slate-800 mb-4">Dados do produto</h3>
                <dl class="space-y-3">
                    <div class="flex justify-between">
                        <dt class="text-sm text-slate-500">Preço de venda</dt>
                        <dd class="text-sm font-semibold">@((p.PrecoReferencia ?? 0).ToString("C", ptBR))</dd>
                    </div>
                    @if (p.CustoReferencia.HasValue)
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Custo</dt>
                            <dd class="text-sm font-semibold">@p.CustoReferencia.Value.ToString("C", ptBR)</dd>
                        </div>
                        @if ((p.PrecoReferencia ?? 0) > 0 && p.CustoReferencia > 0)
                        {
                            var margem = (p.PrecoReferencia!.Value - p.CustoReferencia.Value) / p.PrecoReferencia.Value * 100;
                            <div class="flex justify-between">
                                <dt class="text-sm text-slate-500">Margem calculada</dt>
                                <dd class="text-sm font-semibold text-emerald-600">@margem.ToString("F1")%</dd>
                            </div>
                        }
                    }
                    @if (p.MargemEstimada.HasValue)
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Margem estimada</dt>
                            <dd class="text-sm font-semibold text-emerald-600">@p.MargemEstimada.Value.ToString("F1")%</dd>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(p.Marca))
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Marca</dt>
                            <dd class="text-sm">@p.Marca</dd>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(p.CodigoBarras))
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Cod. Barras</dt>
                            <dd class="text-sm font-mono">@p.CodigoBarras</dd>
                        </div>
                    }
                    @if (p.Dimensoes != null)
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Peso</dt>
                            <dd class="text-sm font-mono">@($"{p.Dimensoes.Peso:F3} kg")</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Dimensões (L x A x C)</dt>
                            <dd class="text-sm font-mono">@($"{p.Dimensoes.Largura:F1} x {p.Dimensoes.Altura:F1} x {p.Dimensoes.Comprimento:F1} cm")</dd>
                        </div>
                    }
                </dl>
                @if (!string.IsNullOrEmpty(p.DescricaoBase))
                {
                    <div class="mt-4 pt-4 border-t border-slate-100">
                        <p class="text-sm text-slate-500 font-medium mb-1">Descrição</p>
                        <p class="text-sm text-slate-700">@p.DescricaoBase</p>
                    </div>
                }
            </div>

            <!-- Variações -->
            <div class="ws">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-bold text-slate-800">Variações (@p.Variacoes.Count)</h3>
                </div>
                @if (p.Variacoes.Any())
                {
                    <div class="space-y-2">
                        @foreach (var v in p.Variacoes)
                        {
                            <div class="flex items-center justify-between py-2 border-b border-slate-50">
                                <div>
                                    <span class="text-sm text-slate-700 font-medium">@v.Nome</span>
                                    @if (!string.IsNullOrEmpty(v.Sku))
                                    {
                                        <span class="text-xs text-slate-400 font-mono ml-2">@v.Sku</span>
                                    }
                                    @if (!string.IsNullOrEmpty(v.Cor) || !string.IsNullOrEmpty(v.Tamanho))
                                    {
                                        <span class="text-xs text-slate-400 ml-2">
                                            @(string.Join(" / ", new[] { v.Cor, v.Tamanho }.Where(x => !string.IsNullOrEmpty(x))))
                                        </span>
                                    }
                                    @if (!string.IsNullOrEmpty(v.DescricaoComercial))
                                    {
                                        <span class="text-xs text-slate-400 ml-2">- @v.DescricaoComercial</span>
                                    }
                                    @if (!string.IsNullOrEmpty(v.CodigoBarras))
                                    {
                                        <span class="text-xs text-slate-300 font-mono ml-2">@v.CodigoBarras</span>
                                    }
                                    <span class="text-xs ml-2 @(v.QuantidadeEmEstoque == 0 ? "text-red-500" : "text-slate-500")">(@v.QuantidadeEmEstoque un.)</span>
                                </div>
                                <form asp-action="RemoverVariacao" asp-controller="Produtos"
                                      asp-route-id="@p.ProdutoId" asp-route-vid="@v.VariacaoId" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-xs text-red-500 hover:text-red-700">Remover</button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-slate-400">Nenhuma variação cadastrada.</p>
                }

                <!-- Add variação -->
                <form asp-action="AdicionarVariacao" asp-controller="Produtos" asp-route-id="@p.ProdutoId" method="post" class="mt-4 flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="text" name="nome" placeholder="Nova variação (ex: M, Azul...)" required
                           class="flex-1 px-3 py-2 text-sm border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    <input type="text" name="sku" placeholder="SKU (opcional)"
                           class="w-32 px-3 py-2 text-sm font-mono border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    <button type="submit" class="px-3 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700">
                        Adicionar
                    </button>
                </form>

                <!-- Upload foto -->
                <div class="mt-6 pt-4 border-t border-slate-100">
                    <h4 class="text-sm font-semibold text-slate-700 mb-2">Foto do produto</h4>
                    <form asp-action="UploadFoto" asp-controller="Produtos" asp-route-id="@p.ProdutoId"
                          method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="file" name="foto" accept="image/jpeg,image/png,image/webp"
                               class="block text-sm text-slate-500 mb-2" />
                        <button type="submit" class="px-3 py-2 border border-slate-300 text-slate-700 text-sm rounded-lg hover:bg-slate-50">
                            Enviar foto
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Caracteristicas -->
        @if (p.Caracteristicas.Any())
        {
            <div class="ws mt-6">
                <h3 class="font-bold text-slate-800 mb-4">Características (@p.Caracteristicas.Count)</h3>
                <div class="overflow-x-auto">
                    <table class="tbl-full">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Descrição</th>
                                <th class="text-center">Quantidade</th>
                                <th>Variação</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in p.Caracteristicas.OrderBy(x => x.OrdemExibicao))
                            {
                                <tr>
                                    <td class="font-medium">@c.Nome</td>
                                    <td class="text-sm text-slate-500">@(c.Descricao ?? "-")</td>
                                    <td class="text-center text-sm">@(c.QuantidadeReferencia?.ToString() ?? "-")</td>
                                    <td class="text-sm text-slate-500">@(c.VariacaoPadrao ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Embalagens -->
        @if (p.Embalagens.Any())
        {
            <div class="ws mt-6">
                <h3 class="font-bold text-slate-800 mb-4">Embalagens (@p.Embalagens.Count)</h3>
                <div class="overflow-x-auto">
                    <table class="tbl-full">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Descrição</th>
                                <th>Dimensões</th>
                                <th class="text-center">Padrão</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in p.Embalagens)
                            {
                                <tr>
                                    <td class="font-medium">@e.Nome</td>
                                    <td class="text-sm text-slate-500">@(e.Descricao ?? "-")</td>
                                    <td class="text-sm font-mono text-slate-500">
                                        @if (e.Dimensoes != null)
                                        {
                                            @($"{e.Dimensoes.Peso:F3}kg | {e.Dimensoes.Largura:F1} x {e.Dimensoes.Altura:F1} x {e.Dimensoes.Comprimento:F1} cm")
                                        }
                                        else
                                        {
                                            <text>-</text>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (e.Padrao)
                                        {
                                            <span class="badge badge-ok px-2 py-0.5 rounded-full text-xs font-semibold">Sim</span>
                                        }
                                        else
                                        {
                                            <span class="text-sm text-slate-400">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <!-- Tab: Estoque por variação -->
    <div x-show="tab === 'estoque'">
        <div class="ws">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-slate-800">Estoque total</h3>
                <span class="text-lg font-bold @(p.QuantidadeTotalEstoque == 0 ? "text-red-600" : "text-slate-900")">@p.QuantidadeTotalEstoque un.</span>
            </div>
            @if (p.Variacoes.Any())
            {
                <div class="overflow-x-auto">
                <table class="tbl-full">
                    <thead>
                        <tr>
                            <th>Variação</th>
                            <th>SKU</th>
                            <th class="text-center">Qtd</th>
                            <th class="text-center">Status</th>
                            <th>Última entrada</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in p.Variacoes)
                        {
                            <tr>
                                <td>
                                    <span class="font-medium">@v.Nome</span>
                                    @if (!string.IsNullOrEmpty(v.Cor) || !string.IsNullOrEmpty(v.Tamanho))
                                    {
                                        <span class="text-xs text-slate-400 ml-1">
                                            (@(string.Join(" / ", new[] { v.Cor, v.Tamanho }.Where(x => !string.IsNullOrEmpty(x)))))
                                        </span>
                                    }
                                </td>
                                <td class="font-mono text-xs text-slate-500">@(v.Sku ?? "-")</td>
                                <td class="text-center">
                                    <span class="font-bold @(v.QuantidadeEmEstoque == 0 ? "text-red-600" : v.QuantidadeEmEstoque < 5 ? "text-amber-600" : "text-slate-900")">
                                        @v.QuantidadeEmEstoque
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(v.Ativa ? "badge-ok" : "badge-warn") px-2 py-0.5 rounded-full text-xs font-semibold">
                                        @(v.Ativa ? "Ativa" : "Inativa")
                                    </span>
                                </td>
                                <td class="text-sm text-slate-500">
                                    @(v.UltimaEntradaEm?.ToString("dd/MM/yyyy") ?? "-")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            }
            else
            {
                <p class="text-center py-8 text-slate-400 text-sm">Nenhuma variação cadastrada. Adicione variações na aba Informações.</p>
            }
        </div>
    </div>

    <!-- Tab: Histórico -->
    <div x-show="tab === 'historico'" x-effect="if (tab === 'historico') loadHistorico()">
        <div class="ws" id="historico-container">
            <div class="text-center py-8 text-slate-400">
                <div class="text-3xl mb-2">⏳</div>
                <p class="text-sm">Carregando histórico...</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadHistorico() {
            const container = document.getElementById('historico-container');
            if (container.dataset.loaded) return;
            container.dataset.loaded = '1';
            try {
                const r = await fetch('/produtos/@p.ProdutoId/historico-json');
                if (!r.ok) throw new Error();
                const items = await r.json();
                if (!Array.isArray(items) || items.length === 0) {
                    container.textContent = '';
                    const msg = document.createElement('p');
                    msg.className = 'text-center py-8 text-slate-400 text-sm';
                    msg.textContent = 'Nenhum registro de histórico encontrado.';
                    container.appendChild(msg);
                    return;
                }
                const table = document.createElement('table');
                table.className = 'tbl-full';
                const thead = table.createTHead();
                const hr = thead.insertRow();
                ['Data', 'Tipo', 'Qtd', 'Valor', 'Obs'].forEach(h => {
                    const th = document.createElement('th');
                    th.textContent = h;
                    hr.appendChild(th);
                });
                const tbody = table.createTBody();
                items.forEach(item => {
                    const row = tbody.insertRow();
                    const date = item.dataMovimentacao ? new Date(item.dataMovimentacao).toLocaleDateString('pt-BR') : '-';
                    [date, item.natureza ?? '-', item.quantidade ?? 0, item.valorTotal != null ? `R$ ${Number(item.valorTotal).toFixed(2)}` : '-', item.observacoes ?? '-']
                        .forEach(val => {
                            const td = row.insertCell();
                            td.className = 'text-sm';
                            td.textContent = String(val);
                        });
                });
                const wrapper = document.createElement('div');
                wrapper.className = 'overflow-x-auto';
                wrapper.appendChild(table);
                container.textContent = '';
                container.appendChild(wrapper);
            } catch {
                container.textContent = '';
                const msg = document.createElement('p');
                msg.className = 'text-center py-8 text-slate-400 text-sm';
                msg.textContent = 'Não foi possível carregar o histórico.';
                container.appendChild(msg);
            }
        }
    </script>
}
