@model ProdutoDetailViewModel
@using System.Globalization
@using System.Text.Json
@{
    var ptBR = new CultureInfo("pt-BR");
    var p = Model.Produto;
    var fotosJson = JsonSerializer.Serialize(p.Fotos.Select(f => new { fotoId = f.FotoId.ToString(), url = f.Url }));

    // ── Integrity score ──
    var iFields = new (bool ok, string label, int pts)[]
    {
        (p.Fotos.Any(),                               "Foto",        20),
        (!string.IsNullOrWhiteSpace(p.DescricaoBase), "Descrição",   15),
        (p.CustoReferencia is > 0,                    "Custo",       15),
        (p.PrecoReferencia is > 0,                    "Preço",       15),
        (!string.IsNullOrWhiteSpace(p.CodigoBarras),  "Cód.Barras",  10),
        (p.Variacoes.Any(),                           "Variações",   10),
        (!string.IsNullOrWhiteSpace(p.Marca),         "Marca",        5),
        (p.Dimensoes != null,                         "Dimensões",    5),
        (true,                                        "Nome",         3),
        (true,                                        "Categoria",    2),
    };
    var score = iFields.Where(f => f.ok).Sum(f => f.pts);
    var missing = iFields.Where(f => !f.ok).Select(f => f.label).ToList();
    // Map missing labels to edit form step
    var missingStepMap = new System.Collections.Generic.Dictionary<string, int>
    {
        ["Foto"] = 2, ["Preço"] = 2, ["Custo"] = 2,
        ["Variações"] = 3, ["Dimensões"] = 3,
        ["Descrição"] = 1, ["Cód.Barras"] = 1, ["Marca"] = 1, ["Nome"] = 1, ["Categoria"] = 1,
    };
    var barCss = score >= 80 ? "bg-emerald-500" : score >= 50 ? "bg-amber-400" : "bg-red-500";
    var scoreCss = score >= 80 ? "text-emerald-600" : score >= 50 ? "text-amber-600" : "text-red-600";

    var statusBadge = p.StatusNome.ToLower() == "ativo" ? "badge-ok" : "badge-warn";
    var tipoBadge = p.Tipo switch { 1 => "Alimento", 2 => "Servico", _ => "Fisico" };

    var temPreco = p.PrecoReferencia is > 0;
    var temCusto = p.CustoReferencia is > 0;
    decimal margem = 0;
    if (temPreco && temCusto)
        margem = (p.PrecoReferencia!.Value - p.CustoReferencia!.Value) / p.PrecoReferencia.Value * 100;
}

@Html.AntiForgeryToken()

<div x-data="produtoHub()" x-init="init()" class="produto-detail-page produto-detail-page--compact">

    <!-- ═══ BACK + BREADCRUMB ═══ -->
    <div class="flex items-center gap-2 mb-4 text-sm text-slate-500">
        <a href="/produtos" class="hover:text-indigo-600 transition-colors inline-flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Produtos
        </a>
        <span class="text-slate-300">/</span>
        <span class="text-slate-700 font-medium truncate max-w-xs">@p.Nome</span>
    </div>

    <!-- ═══ HERO: GALLERY + PRODUCT INFO ═══ -->
    <div class="produto-detail-hero grid grid-cols-1 lg:grid-cols-[minmax(0,0.94fr)_minmax(0,1.06fr)] gap-5 mb-5 items-start">

        <!-- ── LEFT: IMAGE GALLERY ── -->
        <div class="produto-detail-gallery space-y-2.5">
            <!-- Main image -->
            <div class="produto-gallery-card produto-gallery-card--hero bg-slate-50 rounded-2xl overflow-hidden border border-slate-200 shadow-sm relative group cursor-pointer"
                 @@click="if (photos.length > 0) { lightboxIdx = selectedPhotoIdx; lightboxOpen = true; }">
                <template x-if="photos.length > 0">
                    <img :src="mainPhoto" :key="mainPhoto" alt="@p.Nome"
                         class="w-full h-full object-contain transition-transform duration-300 group-hover:scale-105" />
                </template>
                <template x-if="photos.length === 0">
                    <div class="w-full h-full flex items-center justify-center flex-col gap-3 cursor-pointer select-none transition-colors"
                         :class="_dragOver ? 'bg-indigo-50' : 'bg-slate-50'"
                         @@click="$refs.photoInput.click()"
                         @@dragover.prevent="_dragOver = true"
                         @@dragleave="_dragOver = false"
                         @@drop.prevent="handleDrop($event)">
                        <div class="w-16 h-16 rounded-2xl flex items-center justify-center transition-colors"
                             :class="_dragOver ? 'bg-indigo-100' : 'bg-slate-100'">
                            <svg class="w-8 h-8 transition-colors" :class="_dragOver ? 'text-indigo-500' : 'text-slate-300'"
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <p class="text-sm font-semibold transition-colors" :class="_dragOver ? 'text-indigo-600' : 'text-slate-400'"
                           x-text="_dragOver ? 'Solte para enviar' : 'Adicionar fotos'"></p>
                        <p class="text-xs text-slate-300">Arraste ou clique · JPEG, PNG, WebP · máx. 10 MB cada</p>
                    </div>
                </template>
                <!-- Photo counter -->
                <div x-show="photos.length > 1" class="absolute bottom-3 right-3 bg-black/60 text-white text-xs font-semibold px-2.5 py-1 rounded-full backdrop-blur-sm">
                    <span x-text="selectedPhotoIdx + 1"></span> / <span x-text="photos.length"></span>
                </div>
                <!-- Nav arrows -->
                <template x-if="photos.length > 1">
                    <div>
                        <button @@click="selectedPhotoIdx = (selectedPhotoIdx - 1 + photos.length) % photos.length"
                                class="absolute left-2 top-1/2 -translate-y-1/2 w-9 h-9 bg-black/40 hover:bg-black/60 text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all backdrop-blur-sm">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                        </button>
                        <button @@click="selectedPhotoIdx = (selectedPhotoIdx + 1) % photos.length"
                                class="absolute right-2 top-1/2 -translate-y-1/2 w-9 h-9 bg-black/40 hover:bg-black/60 text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all backdrop-blur-sm">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        </button>
                    </div>
                </template>
            </div>

            <!-- Thumbnails row -->
            <div x-show="photos.length > 1" class="flex gap-2 overflow-x-auto pb-1">
                <template x-for="(foto, idx) in photos" :key="foto.fotoId">
                    <button @@click="selectedPhotoIdx = idx"
                            class="produto-thumb w-16 h-16 flex-shrink-0 rounded-xl overflow-hidden border-2 transition-all"
                            :class="selectedPhotoIdx === idx ? 'border-indigo-500 ring-2 ring-indigo-200' : 'border-slate-200 hover:border-slate-300'">
                        <img :src="foto.url" loading="lazy" decoding="async" class="w-full h-full object-cover object-top"
                             onload="if(this.naturalWidth===0){this.onerror&&this.onerror();}"
                             onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.classList.remove('hidden');" />
                        <span class="produto-thumb__placeholder hidden">
                            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                            </svg>
                        </span>
                    </button>
                    </template>
            </div>
        </div>

        <!-- ── RIGHT: PRODUCT INFO ── -->
        <div class="produto-detail-summary space-y-4">
            <!-- Title + badges -->
            <div>
                <div class="flex items-center gap-2 mb-2 flex-wrap">
                    <span class="badge @statusBadge px-2.5 py-0.5 rounded-full text-xs font-semibold">@p.StatusNome</span>
                    <span class="produto-chip produto-chip--neutral text-[11px] bg-slate-100 text-slate-500 px-2.5 py-0.5 rounded-full font-medium">@tipoBadge</span>
                    @if (p.QuantidadeTotalEstoque == 0)
                    {
                        <span class="produto-chip produto-chip--danger text-[11px] bg-red-50 text-red-600 px-2.5 py-0.5 rounded-full font-semibold">Sem estoque</span>
                        <a href="/entradas/reposicao?produtoId=@p.ProdutoId"
                           class="inline-flex items-center gap-1 text-xs font-semibold text-emerald-800 hover:text-emerald-800 hover:underline transition-colors">
                            Repor estoque
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </a>
                    }
                    else
                    {
                        <span class="produto-chip produto-chip--success text-[11px] bg-emerald-50 text-emerald-800 px-2.5 py-0.5 rounded-full font-semibold">@p.QuantidadeTotalEstoque un. em estoque</span>
                    }
                </div>
                <h1 class="produto-detail-title text-2xl font-extrabold text-slate-900 leading-tight mb-1">@p.Nome</h1>
                @if (!string.IsNullOrEmpty(p.SkuBase))
                {
                    <p class="text-xs font-mono text-slate-400">SKU: @p.SkuBase</p>
                }
                @if (!string.IsNullOrEmpty(p.Marca))
                {
                    <p class="text-sm text-slate-500 mt-1">Marca: <span class="font-medium text-slate-700">@p.Marca</span></p>
                }
            </div>

            <!-- Price block -->
            @if (temPreco || temCusto)
            {
                <div class="produto-price-card bg-gradient-to-br from-slate-50 to-slate-100 rounded-2xl p-4 border border-slate-200">
                    @if (temPreco)
                    {
                        <div class="flex items-baseline gap-2 mb-1">
                            <span class="produto-price-card__value text-3xl font-extrabold text-slate-900">@p.PrecoReferencia!.Value.ToString("C", ptBR)</span>
                        </div>
                    }
                    @if (temCusto)
                    {
                        <div class="flex items-center gap-3 text-sm">
                            <span class="text-slate-500">Custo: <span class="font-semibold text-slate-700">@p.CustoReferencia!.Value.ToString("C", ptBR)</span></span>
                            @if (temPreco)
                            {
                                <span class="text-slate-300">|</span>
                                <span class="font-semibold @(margem < 10 ? "text-red-600" : margem < 30 ? "text-amber-600" : "text-emerald-600")">
                                    @margem.ToString("F1")% margem
                                </span>
                            }
                        </div>
                    }
                    @if (p.MargemEstimada.HasValue && !(temPreco && temCusto))
                    {
                        <p class="text-sm text-emerald-600 font-semibold mt-1">Margem estimada: @p.MargemEstimada.Value.ToString("F1")%</p>
                    }
                </div>
            }

            <!-- Description -->
            @if (!string.IsNullOrEmpty(p.DescricaoBase))
            {
                <div>
                    <p class="text-sm text-slate-600 leading-relaxed">@p.DescricaoBase</p>
                </div>
            }

            <!-- Audit info -->
            <div class="flex flex-wrap gap-x-5 gap-y-1 text-xs text-slate-400 mt-1">
                @if (!string.IsNullOrEmpty(p.CriadoPorNome))
                {
                    <span>Cadastrado por <span class="font-medium text-slate-600">@p.CriadoPorNome</span> em @(p.CriadoEm?.ToLocalTime().ToString("dd/MM/yyyy") ?? "-")</span>
                }
                @if (!string.IsNullOrEmpty(p.AlteradoPorNome))
                {
                    <span>Alterado por <span class="font-medium text-slate-600">@p.AlteradoPorNome</span> em @(p.AlteradoEm?.ToLocalTime().ToString("dd/MM/yyyy") ?? "-")</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(p.ObservacaoInterna))
            {
                <div class="bg-amber-50 border border-amber-100 rounded-xl p-3 mt-2">
                    <p class="text-[11px] text-amber-600 font-semibold mb-0.5">Observação interna</p>
                    <p class="text-sm text-slate-700">@p.ObservacaoInterna</p>
                </div>
            }

            <!-- Details grid -->
            <div class="produto-detail-meta-grid grid grid-cols-2 gap-2.5">
                @if (!string.IsNullOrEmpty(p.CodigoBarras))
                {
                    <div class="produto-meta-card bg-slate-50 rounded-xl p-3 border border-slate-100 col-span-2">
                        <p class="text-[11px] text-slate-400 font-medium mb-1.5">Código de barras</p>
                        <div class="barcode-label">
                            <div class="barcode-label__meta">
                                @if (!string.IsNullOrEmpty(p.SkuBase))
                                {
                                    <span class="barcode-label__sku">SKU @p.SkuBase</span>
                                }
                                <span class="barcode-label__caption">Etiqueta pronta para leitura</span>
                            </div>
                            <div class="barcode-label__paper">
                                <svg id="barcode-svg" class="barcode-label__svg" aria-label="Código de barras do produto"></svg>
                            </div>
                        </div>
                    </div>
                }
                @if (p.ControlaValidade)
                {
                    <div class="produto-meta-card bg-slate-50 rounded-xl p-3 border border-slate-100">
                        <p class="text-[11px] text-slate-400 font-medium mb-0.5">Validade</p>
                        <p class="text-sm font-semibold text-emerald-600">Controlada</p>
                    </div>
                }
                @if (p.Dimensoes != null)
                {
                    <div class="produto-meta-card bg-slate-50 rounded-xl p-3 border border-slate-100">
                        <p class="text-[11px] text-slate-400 font-medium mb-0.5">Peso</p>
                        <p class="text-sm font-mono text-slate-700">@($"{p.Dimensoes.Peso:0.##} kg")</p>
                    </div>
                    <div class="produto-meta-card bg-slate-50 rounded-xl p-3 border border-slate-100">
                        <p class="text-[11px] text-slate-400 font-medium mb-0.5">Dimensões</p>
                        <p class="text-sm font-mono text-slate-700">@($"{p.Dimensoes.Largura:F1} x {p.Dimensoes.Altura:F1} x {p.Dimensoes.Comprimento:F1} cm")</p>
                    </div>
                }
            </div>

            <!-- Integrity bar -->
            <div class="produto-score-card bg-slate-50 rounded-xl p-3 border border-slate-100" title="A porcentagem resume o quanto do cadastro já está preenchido: fotos, descrição, custo, preço, código de barras, variações, marca, dimensões, nome e categoria.">
                <div class="flex items-center gap-2 mb-1">
                    <div class="flex-1 bg-slate-200 rounded-full h-2 overflow-hidden">
                        <div class="h-2 rounded-full @barCss transition-all" style="width: @score%"></div>
                    </div>
                    <span class="text-sm font-bold @scoreCss">@score%</span>
                </div>
                <p class="text-[11px] text-slate-400 mb-1">Completude do cadastro com base nos campos essenciais e comerciais do produto.</p>
                @if (missing.Any())
                {
                    <p class="text-[11px] text-slate-400">Falta:
                        @for (int mi = 0; mi < missing.Count; mi++)
                        {
                            var label = missing[mi];
                            var step = missingStepMap.TryGetValue(label, out var s) ? s : 1;
                            <a href="/produtos/@p.ProdutoId/editar?step=@step"
                               class="text-indigo-500 hover:text-indigo-700 hover:underline">@label</a>@(mi < missing.Count - 1 ? ", " : "")
                        }
                    </p>
                }
            </div>

            <!-- Action buttons -->
            <div class="produto-detail-actions flex flex-wrap gap-2">
                <a href="/produtos/@p.ProdutoId/editar"
                   class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition-colors shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Editar
                </a>
                <a href="/entradas/nova?produtoId=@p.ProdutoId"
                   class="inline-flex items-center gap-1.5 px-3.5 py-2.5 bg-emerald-50 text-emerald-800 border border-emerald-200 rounded-xl text-sm font-semibold hover:bg-emerald-100 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Entrada
                </a>
                <a href="/saidas/nova?produtoId=@p.ProdutoId"
                   class="inline-flex items-center gap-1.5 px-3.5 py-2.5 bg-red-50 text-red-600 border border-red-200 rounded-xl text-sm font-semibold hover:bg-red-100 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
                    </svg>
                    Saída
                </a>
                <div x-data="{ open: false }" class="relative">
                    <button @@click="open = !open" @@click.away="open = false"
                            class="produto-kebab-btn p-2.5 border border-slate-200 text-slate-500 rounded-xl hover:bg-slate-50 transition-colors"
                            title="Mais ações"
                            aria-label="Mais ações do produto">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/>
                        </svg>
                    </button>
                    <div x-show="open" x-transition:enter.duration.100ms
                         class="produto-menu absolute right-0 top-full mt-1 w-48 bg-white rounded-xl shadow-xl shadow-slate-200/80 border border-slate-100 py-1 z-20">
                        <button @@click="open=false; showExcluir=true"
                                class="w-full flex items-center gap-2 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                            Excluir produto
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ TABS ═══ -->
    <div class="produto-detail-tabs flex gap-0.5 border-b border-slate-200 mb-4 overflow-x-auto sticky top-0 z-10 bg-white">
        <button @@click="tab='variacoes'"
                :class="tab==='variacoes' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="flex-shrink-0 px-4 py-2.5 text-sm transition-colors inline-flex items-center gap-1.5">
            Variações
            <span class="text-[11px] font-bold px-1.5 py-0.5 rounded-full"
                  :class="tab==='variacoes' ? 'bg-indigo-100 text-indigo-600' : 'bg-slate-100 text-slate-500'">@p.Variacoes.Count</span>
        </button>
        <button @@click="tab='fotos'"
                :class="tab==='fotos' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="flex-shrink-0 px-4 py-2.5 text-sm transition-colors inline-flex items-center gap-1.5">
            Fotos
            <span x-show="photos.length > 0"
                  class="text-[11px] font-bold px-1.5 py-0.5 rounded-full"
                  :class="tab==='fotos' ? 'bg-indigo-100 text-indigo-600' : 'bg-slate-100 text-slate-500'"
                  x-text="photos.length"></span>
            <span x-show="photos.length === 0" x-cloak
                  class="w-2 h-2 rounded-full bg-amber-400 flex-shrink-0"
                  title="Sem fotos cadastradas"></span>
        </button>
        <button @@click="tab='estoque'"
                :class="tab==='estoque' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="flex-shrink-0 px-4 py-2.5 text-sm transition-colors">Estoque</button>
        <button @@click="tab='historico'; loadHistorico(); loadAlteracoes()"
                :class="tab==='historico' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="flex-shrink-0 px-4 py-2.5 text-sm transition-colors">Histórico</button>
        <button @@click="tab='detalhes'"
                :class="tab==='detalhes' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="flex-shrink-0 px-4 py-2.5 text-sm transition-colors">Detalhes</button>
    </div>

<!-- ═══ TAB: VARIACOES ═══ -->
<div x-show="tab==='variacoes'" x-cloak>
    <div class="ws produto-detail-tab-card">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-slate-800">Variações (@p.Variacoes.Count)</h3>
            <button @@click="showAddVariacao = !showAddVariacao"
                    class="text-xs font-semibold text-indigo-600 hover:bg-indigo-50 px-3 py-1.5 rounded-lg transition-colors">
                + Adicionar
            </button>
        </div>

        @if (p.Variacoes.Any())
        {
            <div class="space-y-1 mb-4">
                @foreach (var v in p.Variacoes)
                {
                    <div class="flex items-center justify-between py-3 border-b border-slate-50 last:border-0">
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="text-sm font-medium text-slate-800">@v.Nome</span>
                                @if (!string.IsNullOrEmpty(v.Sku))
                                {
                                    <span class="text-[11px] text-slate-400 font-mono">@v.Sku</span>
                                }
                                @if (!string.IsNullOrEmpty(v.Cor) || !string.IsNullOrEmpty(v.Tamanho))
                                {
                                    <span class="text-[11px] text-slate-400">@string.Join(" / ", new[] { v.Cor, v.Tamanho }.Where(x => !string.IsNullOrEmpty(x)))</span>
                                }
                                <span class="badge @(v.Ativa ? "badge-ok" : "badge-warn") px-1.5 py-0 rounded text-[10px] font-semibold">@(v.Ativa ? "Ativa" : "Inativa")</span>
                            </div>
                            <div class="flex items-center gap-3 mt-0.5">
                                <span class="text-xs @(v.QuantidadeEmEstoque == 0 ? "text-red-500 font-semibold" : v.QuantidadeEmEstoque < 5 ? "text-amber-600 font-semibold" : "text-slate-500")">
                                    @v.QuantidadeEmEstoque un.
                                </span>
                                @if (v.UltimaEntradaEm.HasValue)
                                {
                                    <span class="text-[11px] text-slate-400">ult. @v.UltimaEntradaEm.Value.ToString("dd/MM/yy")</span>
                                }
                                </div>
                            </div>
                            <form asp-action="RemoverVariacao" asp-controller="Produtos"
                                  asp-route-id="@p.ProdutoId" asp-route-vid="@v.VariacaoId" method="post">
                                @Html.AntiForgeryToken()
                                <button type="button" @@click="if (confirm('Remover variação ' + @Html.Raw(Json.Serialize(v.Nome)) + '?')) $el.closest('form').submit()"
                                        class="text-xs text-slate-300 hover:text-red-600 px-2 py-1 rounded hover:bg-red-50 transition-colors ml-2">x</button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-slate-400 mb-4">Nenhuma variação cadastrada.</p>
            }

            <!-- Add variacao inline -->
            <div x-show="showAddVariacao" x-transition class="p-4 bg-slate-50 rounded-xl border border-slate-200">
                <p class="text-xs font-semibold text-slate-600 mb-2">Nova variação</p>
                <form asp-action="AdicionarVariacao" asp-controller="Produtos" asp-route-id="@p.ProdutoId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="flex gap-2">
                        <input type="text" name="nome" x-ref="novaVarInput"
                               placeholder="Ex: M, Azul, P..." required
                               class="flex-1 px-3 py-2 text-sm border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300"/>
                        <input type="text" name="sku" placeholder="SKU"
                               class="w-24 px-3 py-2 text-sm font-mono border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300"/>
                        <button type="submit"
                                class="px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors">
                            OK
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ═══ TAB: FOTOS ═══ -->
    <div x-show="tab==='fotos'" x-cloak>
        <div class="ws produto-detail-tab-card produto-detail-photos-card">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <h3 class="font-bold text-slate-800">Fotos do produto</h3>
                    <p class="text-xs text-slate-400 mt-0.5">A primeira foto é usada como capa. Máx. 5 fotos (JPEG, PNG, WebP — 10 MB cada).</p>
                </div>
                <span class="text-sm font-semibold tabular-nums"
                      :class="photos.length===0?'text-slate-300':photos.length>=5?'text-emerald-600':'text-slate-500'"
                      x-text="photos.length + '/5'"></span>
            </div>

<!-- Grade de fotos + slot de upload integrado -->
<div class="grid grid-cols-3 sm:grid-cols-5 gap-3"
     @@dragover.prevent="_dragOver=true"
     @@dragleave="_dragOver=false"
     @@drop.prevent="handleDrop($event)">

    <!-- Fotos existentes -->
    <template x-for="(foto, idx) in photos" :key="foto.fotoId">
        <div class="relative group aspect-square rounded-xl overflow-hidden ring-2 transition-all cursor-grab active:cursor-grabbing"
             :class="[idx===0 ? 'ring-indigo-400 shadow-md shadow-indigo-100' : 'ring-slate-200 hover:ring-slate-300', _dragSrcIdx===idx ? 'opacity-40 scale-95' : '']"
             draggable="true"
             @@dragstart="if (!_uploading) { _dragSrcIdx = idx; }"
             @@dragend="_dragSrcIdx = null; _dragOverIdx = null; document.querySelectorAll('.foto-reorder-target').forEach(e=>e.classList.remove('foto-reorder-target'));"
             @@dragover.prevent="if (_dragSrcIdx !== null && _dragSrcIdx !== idx) { _dragOverIdx = idx; $el.classList.add('foto-reorder-target'); }"
             @@dragleave="$el.classList.remove('foto-reorder-target')"
             @@drop.prevent="movePhoto(_dragSrcIdx, idx); $el.classList.remove('foto-reorder-target');"
             title="Arraste para reordenar">
            <img :src="foto.url" class="w-full h-full object-cover object-top" />
            <!-- Capa badge -->
            <span x-show="idx===0"
                  class="absolute top-1.5 left-1.5 text-[9px] font-bold uppercase tracking-wide bg-indigo-600 text-white px-1.5 py-0.5 rounded-full shadow">
                Capa
            </span>
            <!-- Overlay hover -->
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all flex items-center justify-center">
                <button type="button" @@click="deletePhoto(foto.fotoId)"
                        :disabled="_deletingPhoto"
                        class="opacity-0 group-hover:opacity-100 w-8 h-8 bg-red-500 hover:bg-red-600 text-white rounded-full flex items-center justify-center shadow-lg transition-all active:scale-95"
                        title="Remover foto">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
        </div>
    </template>

                <!-- Slot de upload em progresso -->
                <div x-show="_uploading" class="relative aspect-square rounded-xl overflow-hidden bg-slate-100 ring-2 ring-indigo-200">
                    <img x-show="_previewUrl" :src="_previewUrl" class="w-full h-full object-cover opacity-30" />
                    <div class="absolute inset-0 flex flex-col items-center justify-center gap-1">
                        <svg class="animate-spin w-6 h-6 text-indigo-500" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                        </svg>
                        <span class="text-[11px] font-semibold text-indigo-600" x-text="_uploadPct < 100 ? _uploadPct + '%' : 'Salvando...'"></span>
                    </div>
                    <!-- Barra de progresso na base -->
                    <div class="absolute bottom-0 left-0 h-1 bg-indigo-500 transition-all duration-200 rounded-b-xl"
                         :style="'width:' + _uploadPct + '%'"></div>
                </div>

                <!-- Botão "Adicionar" (slot vazio) -->
                <button type="button" x-show="photos.length < 5 && !_uploading"
                        @@click="$refs.photoInput.click()"
                        :class="_dragOver ? 'border-indigo-400 bg-indigo-50 scale-[1.02]' : 'border-slate-200 hover:border-indigo-300 hover:bg-indigo-50/50'"
                        class="aspect-square rounded-xl border-2 border-dashed flex flex-col items-center justify-center gap-1.5 transition-all group cursor-pointer">
                    <div class="w-8 h-8 rounded-full bg-slate-100 group-hover:bg-indigo-100 flex items-center justify-center transition-colors">
                        <svg class="w-4 h-4 text-slate-400 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                    </div>
                    <span class="text-[11px] font-medium text-slate-400 group-hover:text-indigo-500 transition-colors">Adicionar</span>
                </button>
            </div>

<!-- Input oculto -->
<input type="file" x-ref="photoInput" accept="image/jpeg,image/png,image/webp"
       multiple class="sr-only" @@change="handleFileSelect($event)" />

            <!-- Dica de drag & drop -->
            <p x-show="photos.length < 5 && !_uploading" class="text-center text-xs text-slate-300 mt-3 select-none">
                ↑ Ou arraste uma foto diretamente nesta área
            </p>
            <!-- Limite atingido -->
            <p x-show="photos.length >= 5" class="text-center text-xs text-emerald-500 font-medium mt-3">
                ✓ Limite de 5 fotos atingido
            </p>
        </div>
    </div>

    <!-- ═══ TAB: ESTOQUE ═══ -->
    <div x-show="tab==='estoque'" x-cloak>
        <div class="ws produto-detail-tab-card">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-slate-800">Estoque por variação</h3>
                <div class="flex items-center gap-2">
                    <span class="text-sm text-slate-500">Total:</span>
                    <span class="text-xl font-extrabold @(p.QuantidadeTotalEstoque == 0 ? "text-red-600" : "text-slate-900")">@p.QuantidadeTotalEstoque</span>
                    <span class="text-sm text-slate-400">un.</span>
                </div>
            </div>

            @if (p.Variacoes.Any())
            {
                <div class="overflow-x-auto">
                    <table class="tbl-full">
                        <thead>
                            <tr>
                                <th>Variacao</th>
                                <th>SKU</th>
                                <th class="text-center">Qtd</th>
                                <th class="text-center">Status</th>
                                <th>Ult. entrada</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in p.Variacoes)
                            {
                                <tr>
                                    <td>
                                        <div class="font-medium text-slate-800">@v.Nome</div>
                                        @if (!string.IsNullOrEmpty(v.Cor) || !string.IsNullOrEmpty(v.Tamanho))
                                        {
                                            <div class="text-xs text-slate-400">@string.Join(" / ", new[] { v.Cor, v.Tamanho }.Where(x => !string.IsNullOrEmpty(x)))</div>
                                        }
                                    </td>
                                    <td class="font-mono text-xs text-slate-500">@(v.Sku ?? "-")</td>
                                    <td class="text-center">
                                        <span class="text-lg font-extrabold @(v.QuantidadeEmEstoque == 0 ? "text-red-600" : v.QuantidadeEmEstoque < 5 ? "text-amber-600" : "text-slate-900")">
                                            @v.QuantidadeEmEstoque
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(v.Ativa ? "badge-ok" : "badge-warn") px-2 py-0.5 rounded-full text-xs font-semibold">
                                            @(v.Ativa ? "Ativa" : "Inativa")
                                        </span>
                                    </td>
                                    <td class="text-sm text-slate-500">@(v.UltimaEntradaEm?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td>
                                        <a href="/entradas/nova?produtoId=@p.ProdutoId&variacaoId=@v.VariacaoId"
                                           class="text-xs font-semibold text-emerald-600 px-2.5 py-1 border border-emerald-200 rounded-lg hover:bg-emerald-50 transition-colors whitespace-nowrap">
                                            + Entrada
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-10 text-slate-400">
                    <p class="text-sm mb-2">Nenhuma variação cadastrada.</p>
                    <button @@click="tab='variacoes'; showAddVariacao=true; $nextTick(()=>$refs.novaVarInput?.focus())"
                            class="text-sm font-semibold text-indigo-600 hover:underline">
                        Adicionar variação →
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- ═══ TAB: HISTORICO ═══ -->
    <div x-show="tab==='historico'" x-cloak>

        <!-- Alterações do cadastro -->
        <div class="ws produto-detail-tab-card mb-4">
            <h3 class="font-bold text-slate-800 mb-4">Alterações do cadastro</h3>

            <div x-show="alteracoes===null" class="text-center py-6 text-slate-400 flex items-center justify-center gap-2">
                <span class="spinner"></span>
                <span class="text-sm">Carregando...</span>
            </div>

            <div x-show="alteracoes!==null && alteracoes.length===0" class="text-center py-6 text-slate-400">
                <p class="text-sm">Nenhuma alteração registrada.</p>
            </div>

            <div x-show="alteracoes!==null && alteracoes.length>0" class="overflow-x-auto produto-detail-table-wrap">
                <table class="tbl-full">
                    <thead>
                        <tr>
                            <th>Data/Hora</th>
                            <th>Ação</th>
                            <th>Usuário</th>
                            <th>Campos alterados</th>
                            <th>Motivo</th>
                            <th>Obs.</th>
                        </tr>
                    </thead>
                    <tbody>
                        <template x-for="(alt, i) in alteracoes" :key="i">
                            <tr>
                                <td class="text-sm text-slate-600 whitespace-nowrap"
                                    x-text="alt.alteradoEm ? new Date(alt.alteradoEm).toLocaleString('pt-BR') : '-'"></td>
                                <td>
                                    <span class="text-xs font-semibold px-2 py-0.5 rounded-full"
                                          :class="{
                                              'bg-emerald-50 text-emerald-800': alt.acao==='cadastrado'||alt.acao==='restaurado',
                                              'bg-blue-50 text-blue-700': alt.acao==='atualizado',
                                              'bg-red-50 text-red-600': alt.acao==='inativado'
                                          }"
                                          x-text="alt.acao"></span>
                                </td>
                                <td class="text-sm text-slate-600" x-text="alt.usuarioNome ?? '-'"></td>
                                <td class="text-sm text-slate-500">
                                    <template x-if="alt.alteracoesJson">
                                        <ul class="list-none space-y-0.5">
                                            <template x-for="(m, j) in JSON.parse(alt.alteracoesJson)" :key="j">
                                                <li>
                                                    <span class="font-medium text-slate-700" x-text="m.campo"></span>:
                                                    <span class="line-through text-slate-400" x-text="m.de ?? '—'"></span>
                                                    → <span class="text-slate-700" x-text="m.para ?? '—'"></span>
                                                </li>
                                            </template>
                                        </ul>
                                    </template>
                                    <template x-if="!alt.alteracoesJson">
                                        <span>—</span>
                                    </template>
                                </td>
                                <td class="text-sm text-slate-500 whitespace-nowrap" x-text="alt.motivo ?? '-'"></td>
                                <td class="text-sm text-slate-500 max-w-[180px] truncate" x-text="alt.observacao ?? '-'" :title="alt.observacao"></td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="ws produto-detail-tab-card">
            <h3 class="font-bold text-slate-800 mb-4">Histórico de movimentações</h3>

            <div x-show="historico===null" class="text-center py-10 text-slate-400 flex items-center justify-center gap-2">
                <span class="spinner"></span>
                <span class="text-sm">Carregando...</span>
            </div>

            <div x-show="historico!==null && historico.length===0" class="text-center py-10 text-slate-400">
                <svg class="w-10 h-10 mx-auto mb-2 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-sm font-medium text-slate-500 mb-3">Nenhum registro de movimentação ainda.</p>
                <div class="flex gap-3 justify-center">
                    <a href="/entradas/nova?produtoId=@p.ProdutoId"
                       class="text-sm font-semibold text-emerald-600 px-4 py-2 border border-emerald-200 rounded-lg hover:bg-emerald-50 transition-colors">
                        Registrar primeira entrada →
                    </a>
                </div>
            </div>

            <div x-show="historico!==null && historico.length>0" class="overflow-x-auto produto-detail-table-wrap">
                <table class="tbl-full">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Tipo</th>
                            <th class="text-center">Qtd</th>
                            <th class="text-right">Valor</th>
                            <th>Observação</th>
                        </tr>
                    </thead>
                    <tbody>
                        <template x-for="(item, i) in historico" :key="i">
                            <tr>
                                <td class="text-sm text-slate-600 whitespace-nowrap"
                                    x-text="item.dataMovimentacao ? new Date(item.dataMovimentacao).toLocaleDateString('pt-BR') : '-'"></td>
                                <td>
                                    <span class="text-xs font-semibold px-2 py-0.5 rounded-full"
                                          :class="(item.natureza||'').toLowerCase().includes('entrada')
                                              ? 'bg-emerald-50 text-emerald-800'
                                              : 'bg-red-50 text-red-600'"
                                          x-text="item.natureza ?? '-'"></span>
                                </td>
                                <td class="text-center font-bold" x-text="item.quantidade ?? 0"></td>
                                <td class="text-right text-sm font-semibold"
                                    x-text="item.valorTotal!=null ? 'R$ '+Number(item.valorTotal).toFixed(2) : '-'"></td>
                                <td class="text-sm text-slate-500 max-w-xs truncate"
                                    x-text="item.observacoes ?? '-'"></td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ═══ TAB: DETALHES (Caracteristicas + Embalagens) ═══ -->
    <div x-show="tab==='detalhes'" x-cloak>
        @if (!p.Caracteristicas.Any() && !p.Embalagens.Any())
        {
            <div class="ws produto-detail-tab-card text-center py-10 text-slate-400">
                <div class="text-3xl mb-2">📋</div>
                <p class="text-sm font-medium text-slate-500">Nenhum detalhe técnico cadastrado.</p>
                <p class="text-xs mt-1">Edite o produto para adicionar características ou embalagens.</p>
            </div>
        }
        @if (p.Caracteristicas.Any())
        {
            <div class="ws produto-detail-tab-card mb-4">
                <h3 class="font-bold text-slate-800 mb-3">Características (@p.Caracteristicas.Count)</h3>
                <div class="overflow-x-auto">
                    <table class="tbl-full">
                        <thead><tr><th>Nome</th><th>Descrição</th><th class="text-center">Qtd</th><th>Variação</th></tr></thead>
                        <tbody>
                            @foreach (var c in p.Caracteristicas.OrderBy(x => x.OrdemExibicao))
                            {
                                <tr>
                                    <td class="font-medium">@c.Nome</td>
                                    <td class="text-sm text-slate-500">@(c.Descricao ?? "-")</td>
                                    <td class="text-center text-sm">@(c.QuantidadeReferencia?.ToString() ?? "-")</td>
                                    <td class="text-sm text-slate-500">@(c.VariacaoPadrao ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (p.Embalagens.Any())
        {
            <div class="ws produto-detail-tab-card">
                <h3 class="font-bold text-slate-800 mb-3">Embalagens (@p.Embalagens.Count)</h3>
                <div class="overflow-x-auto">
                    <table class="tbl-full">
                        <thead><tr><th>Nome</th><th>Descrição</th><th>Dimensões</th><th class="text-center">Padrão</th></tr></thead>
                        <tbody>
                            @foreach (var e in p.Embalagens)
                            {
                                <tr>
                                    <td class="font-medium">@e.Nome</td>
                                    <td class="text-sm text-slate-500">@(e.Descricao ?? "-")</td>
                                    <td class="text-sm font-mono text-slate-500">
                                        @if (e.Dimensoes != null) { @($"{e.Dimensoes.Peso:0.##}kg - {e.Dimensoes.Largura:F1}x{e.Dimensoes.Altura:F1}x{e.Dimensoes.Comprimento:F1} cm") }
                                        else { <text>-</text> }
                                    </td>
                                    <td class="text-center">
                                        @if (e.Padrao) { <span class="badge badge-ok px-2 py-0.5 rounded-full text-xs font-semibold">Sim</span> }
                                        else { <span class="text-sm text-slate-400">-</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <!-- ═══ MODAL: EXCLUIR ═══ -->
    <div x-show="showExcluir" x-cloak
         class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center"
         x-transition @@click.self="showExcluir=false">
        <div class="bg-white rounded-2xl shadow-2xl p-6 max-w-sm w-full mx-4">
            <h3 class="font-bold text-slate-900 text-lg mb-2">Excluir produto?</h3>
            <p class="text-slate-500 text-sm mb-3">
                Esta ação é irreversível. O produto <strong>@p.Nome</strong> será excluído permanentemente.
            </p>
            <div class="mb-4 p-3 bg-amber-50 border border-amber-200 rounded-lg text-xs text-amber-800">
                <strong>Atenção:</strong> se o produto possui estoque, é necessário zerar o estoque antes de excluí-lo.
            </div>
            <div class="flex gap-3 justify-end">
                <button @@click="showExcluir=false"
                        class="px-4 py-2 text-sm font-semibold border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
                    Cancelar
                </button>
                <form asp-action="Excluir" asp-controller="Produtos" asp-route-id="@p.ProdutoId" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="px-4 py-2 text-sm font-semibold bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors">
                        Confirmar exclusão
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Lightbox -->
    <div x-show="lightboxOpen" x-cloak x-transition.opacity
         class="fixed inset-0 z-50 bg-black/90 flex items-center justify-center"
         @@click.self="lightboxOpen = false" @@keydown.escape.window="lightboxOpen = false">
        <button @@click="lightboxOpen = false" class="absolute top-4 right-4 text-white/70 hover:text-white z-10">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <button x-show="photos.length > 1" @@click="lightboxIdx = (lightboxIdx - 1 + photos.length) % photos.length"
                class="absolute left-4 text-white/70 hover:text-white z-10">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <img :src="photos[lightboxIdx]?.url" class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" />
        <button x-show="photos.length > 1" @@click="lightboxIdx = (lightboxIdx + 1) % photos.length"
                class="absolute right-4 text-white/70 hover:text-white z-10">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </button>
        <div x-show="photos.length > 1" class="absolute bottom-4 text-white/60 text-sm" x-text="(lightboxIdx + 1) + ' / ' + photos.length"></div>
    </div>

</div>

@section Scripts {
    <style>
        .foto-reorder-target { outline: 2px solid #1E48A8; outline-offset: 2px; border-radius: 0.75rem; }
    </style>
    @if (!string.IsNullOrEmpty(p.CodigoBarras))
    {
        <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                try { JsBarcode('#barcode-svg', '@p.CodigoBarras', { format: 'CODE128', height: 64, displayValue: true, textMargin: 6, fontSize: 18, margin: 10, background: 'transparent', lineColor: '#111827', width: 1.7 }); } catch(e) {}
            });
        </script>
    }
    <script>
        function produtoHub() {
            const initialPhotos = @Html.Raw(fotosJson);
            const prodId = '@p.ProdutoId';

            return {
                tab: 'variacoes',
                showAddVariacao: false,
                showExcluir: false,

                // ── Photo gallery ──
                selectedPhotoIdx: 0,
                lightboxOpen: false,
                lightboxIdx: 0,
                get mainPhoto() {
                    if (this.photos.length === 0) return '';
                    const idx = Math.min(this.selectedPhotoIdx, this.photos.length - 1);
                    return this.photos[idx]?.url ?? '';
                },

                // ── Photos management (custom upload) ──
                photos: Array.isArray(initialPhotos) ? initialPhotos.map(f => ({ ...f, toDelete: false })) : [],
                _uploading: false,
                _uploadPct: 0,
                _previewUrl: null,
                _dragOver: false,
                _uploadXhr: null,
                _uploadQueue: [],
                _queueProcessing: false,
                _dragSrcIdx: null,
                _dragOverIdx: null,

                init() {
                    const t = new URLSearchParams(window.location.search).get('tab');
                    if (['variacoes','fotos','estoque','historico','detalhes'].includes(t)) {
                        this.tab = t;
                        if (t === 'historico') { this.loadHistorico(); this.loadAlteracoes(); }
                    }
                    this.$watch('tab', val => {
                        if (val === 'historico') { if (!this._hlLoaded) this.loadHistorico(); if (!this._altLoaded) this.loadAlteracoes(); }
                    });
                },

                handleFileSelect(e) {
                    const files = [...(e.target.files ?? [])];
                    e.target.value = '';
                    const remaining = 5 - this.photos.length - this._uploadQueue.length;
                    const valid = files
                        .filter(f => ['image/jpeg','image/png','image/webp'].includes(f.type) && f.size <= 10*1024*1024)
                        .slice(0, Math.max(0, remaining));
                    if (valid.length < files.length)
                        window.showToast('Algumas fotos foram ignoradas (tipo inválido, muito grande ou limite atingido).', 'warning');
                    valid.forEach(f => this._uploadQueue.push(f));
                    this._processQueue();
                },

                handleDrop(e) {
                    this._dragOver = false;
                    const remaining = 5 - this.photos.length - this._uploadQueue.length;
                    if (remaining <= 0) { window.showToast('Limite de 5 fotos atingido.', 'warning'); return; }
                    const files = [...(e.dataTransfer?.files ?? [])]
                        .filter(f => ['image/jpeg','image/png','image/webp'].includes(f.type) && f.size <= 10*1024*1024)
                        .slice(0, remaining);
                    if (!files.length) { window.showToast('Tipo não aceito. Use JPEG, PNG ou WebP (máx. 10 MB).', 'warning'); return; }
                    files.forEach(f => this._uploadQueue.push(f));
                    this._processQueue();
                },

                async _processQueue() {
                    if (this._queueProcessing || this._uploadQueue.length === 0) return;
                    this._queueProcessing = true;
                    while (this._uploadQueue.length > 0) {
                        if (this.photos.length >= 5) { this._uploadQueue = []; break; }
                        const file = this._uploadQueue.shift();
                        await this._uploadOne(file);
                    }
                    this._queueProcessing = false;
                },

                _uploadOne(file) {
                    return new Promise(resolve => {
                        // Preview local imediato
                        const reader = new FileReader();
                        reader.onload = (ev) => { this._previewUrl = ev.target.result; };
                        reader.readAsDataURL(file);

                        this._uploading = true;
                        this._uploadPct = 0;

                        const token = document.querySelector('meta[name="csrf-token"]')?.content || '';
                        const fd = new FormData();
                        fd.append('foto', file);
                        fd.append('__RequestVerificationToken', token);

                        const xhr = new XMLHttpRequest();
                        this._uploadXhr = xhr;
                        xhr.open('POST', '/produtos/' + prodId + '/fotos/ajax');
                        xhr.timeout = 30000;

                        xhr.upload.onprogress = (e) => {
                            if (e.lengthComputable)
                                this._uploadPct = Math.round((e.loaded / e.total) * 95);
                        };

                        const done = (ok, msg) => {
                            if (msg) window.showToast(msg, ok ? 'success' : 'error');
                            this._uploading = false;
                            this._uploadPct = 0;
                            this._previewUrl = null;
                            this._uploadXhr = null;
                            resolve();
                        };

                        xhr.onload = () => {
                            this._uploadPct = 100;
                            try {
                                const data = JSON.parse(xhr.responseText);
                                if (xhr.status >= 200 && xhr.status < 300 && data.ok) {
                                    this.photos = [...this.photos, { fotoId: data.fotoId, url: data.url, toDelete: false }];
                                    done(true, this._uploadQueue.length === 0 ? 'Foto adicionada!' : null);
                                } else {
                                    done(false, data.erro || 'Erro ao enviar foto.');
                                }
                            } catch { done(false, 'Resposta inválida do servidor.'); }
                        };
                        xhr.onerror = () => done(false, 'Erro de conexão ao enviar foto.');
                        xhr.ontimeout = () => done(false, 'Tempo esgotado ao enviar foto.');
                        xhr.send(fd);
                    });
                },

                async movePhoto(fromIdx, toIdx) {
                    if (fromIdx === null || fromIdx === toIdx) return;
                    const updated = [...this.photos];
                    const [moved] = updated.splice(fromIdx, 1);
                    updated.splice(toIdx, 0, moved);
                    this.photos = updated;
                    this.selectedPhotoIdx = 0;
                    const novaOrdem = this.photos.map(f => f.fotoId);
                    const token = document.querySelector('meta[name="csrf-token"]')?.content
                               || document.querySelector('[name=__RequestVerificationToken]')?.value
                               || '';
                    try {
                        const r = await fetch('/produtos/' + prodId + '/fotos/reordenar', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                            body: JSON.stringify(novaOrdem)
                        });
                        const d = await r.json();
                        if (!d.ok) window.showToast(d.erro || 'Não foi possível salvar a nova ordem.', 'warning');
                    } catch { window.showToast('Erro ao salvar ordem.', 'warning'); }
                },

                _deletingPhoto: false,
                async deletePhoto(fotoId) {
                    if (this._deletingPhoto || this._uploading) return;
                    if (!confirm('Remover esta foto?')) return;
                    this._deletingPhoto = true;
                    const token = document.querySelector('meta[name="csrf-token"]')?.content
                               || document.querySelector('[name=__RequestVerificationToken]')?.value
                               || '';
                    const fd = new FormData();
                    fd.append('__RequestVerificationToken', token);
                    try {
                        const r = await fetch('/produtos/' + prodId + '/fotos/' + fotoId + '/remover', { method: 'POST', body: fd });
                        const d = await r.json();
                        if (!d.ok) throw new Error(d.erro ?? 'Erro');
                        this.photos = this.photos.filter(x => x.fotoId !== fotoId);
                        if (this.selectedPhotoIdx >= this.photos.length) this.selectedPhotoIdx = Math.max(0, this.photos.length - 1);
                        window.showToast('Foto removida.', 'success');
                    } catch (err) {
                        window.showToast('Erro ao remover foto.', 'error');
                    } finally {
                        this._deletingPhoto = false;
                    }
                },

                // ── Historico (lazy) ──
                historico: null,
                _hlLoaded: false,
                async loadHistorico() {
                    if (this._hlLoaded) return;
                    this._hlLoaded = true;
                    try {
                        const r = await fetch('/produtos/' + prodId + '/historico-json');
                        this.historico = r.ok ? await r.json() : [];
                    } catch { this.historico = []; }
                },

                // ── Alterações do cadastro (lazy) ──
                alteracoes: null,
                _altLoaded: false,
                async loadAlteracoes() {
                    if (this._altLoaded) return;
                    this._altLoaded = true;
                    try {
                        const r = await fetch('/produtos/' + prodId + '/alteracoes-json');
                        this.alteracoes = r.ok ? await r.json() : [];
                    } catch { this.alteracoes = []; }
                },

                destroy() {
                    if (this._uploadXhr) { this._uploadXhr.abort(); }
                },
            };
        }
    </script>
}
