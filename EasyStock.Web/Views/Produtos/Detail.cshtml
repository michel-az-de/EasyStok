@model ProdutoDetailViewModel
@using System.Globalization
@using System.Text.Json
@{
    var ptBR = new CultureInfo("pt-BR");
    var p = Model.Produto;
    var fotosJson = JsonSerializer.Serialize(p.Fotos.Select(f => new { fotoId = f.FotoId.ToString(), url = f.Url }));

    // ── Integrity score ──
    var iFields = new (bool ok, string label, int pts)[]
    {
        (p.Fotos.Any(),                               "Foto",        20),
        (!string.IsNullOrWhiteSpace(p.DescricaoBase), "Descrição",   15),
        (p.CustoReferencia is > 0,                    "Custo",       15),
        (p.PrecoReferencia is > 0,                    "Preço",       15),
        (!string.IsNullOrWhiteSpace(p.CodigoBarras),  "Cód.Barras",  10),
        (p.Variacoes.Any(),                           "Variações",   10),
        (!string.IsNullOrWhiteSpace(p.Marca),         "Marca",        5),
        (p.Dimensoes != null,                         "Dimensões",    5),
        (true,                                        "Nome",         3),
        (true,                                        "Categoria",    2),
    };
    var score = iFields.Where(f => f.ok).Sum(f => f.pts);
    var missing = iFields.Where(f => !f.ok).Select(f => f.label).ToList();
    var scoreColor = score >= 80 ? "emerald" : score >= 50 ? "amber" : "red";
    var scoreCss = score >= 80 ? "text-emerald-600" : score >= 50 ? "text-amber-600" : "text-red-600";
    var barCss = score >= 80 ? "bg-emerald-500" : score >= 50 ? "bg-amber-400" : "bg-red-500";

    var statusBadge = p.StatusNome.ToLower() == "ativo" ? "badge-ok" : "badge-warn";
    var tipoBadge = p.Tipo switch { 1 => "Alimento", 2 => "Serviço", _ => "Físico" };
}

@Html.AntiForgeryToken()

<div x-data="produtoHub()" x-init="init()">

    <!-- ═══ HEADER ═══ -->
    <div class="flex items-start gap-4 mb-5">
        <a href="/produtos" class="text-slate-400 hover:text-slate-600 transition-colors mt-1 flex-shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
        </a>

        <!-- Thumb -->
        <div class="w-14 h-14 rounded-xl overflow-hidden flex-shrink-0 border border-slate-200 shadow-sm">
            @if (p.Fotos.Any())
            {
                <img src="@p.Fotos.First().Url" alt="@p.Nome" class="w-full h-full object-cover" />
            }
            else
            {
                <div class="w-full h-full bg-slate-100 flex items-center justify-center">
                    <svg class="w-7 h-7 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                    </svg>
                </div>
            }
        </div>

        <!-- Info -->
        <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                    <h1 class="text-xl font-extrabold text-slate-900 leading-tight">@p.Nome</h1>
                    <div class="flex items-center gap-2 mt-1 flex-wrap">
                        @if (!string.IsNullOrEmpty(p.SkuBase))
                        {
                            <span class="text-xs font-mono text-slate-400">@p.SkuBase</span>
                        }
                        <span class="badge @statusBadge px-2 py-0.5 rounded-full text-xs font-semibold">@p.StatusNome</span>
                        <span class="text-[11px] bg-slate-100 text-slate-500 px-2 py-0.5 rounded-full font-medium">@tipoBadge</span>
                        @if (p.QuantidadeTotalEstoque == 0)
                        {
                            <span class="text-[11px] bg-red-50 text-red-600 px-2 py-0.5 rounded-full font-semibold">Sem estoque</span>
                        }
                        else
                        {
                            <span class="text-[11px] bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full font-semibold">@p.QuantidadeTotalEstoque un. em estoque</span>
                        }
                    </div>
                </div>

                <!-- Header actions -->
                <div class="flex items-center gap-2 flex-shrink-0">
                    <a href="/produtos/@p.ProdutoId/editar"
                       class="px-3 py-2 text-sm font-semibold border border-indigo-200 text-indigo-600 rounded-lg hover:bg-indigo-50 transition-colors">
                        Editar
                    </a>
                    <div x-data="{ open: false }" class="relative">
                        <button @@click="open = !open" @@click.away="open = false"
                                class="p-2 border border-slate-200 text-slate-500 rounded-lg hover:bg-slate-50 transition-colors">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/>
                            </svg>
                        </button>
                        <div x-show="open" x-transition:enter.duration.100ms
                             class="absolute right-0 top-full mt-1 w-48 bg-white rounded-xl shadow-xl shadow-slate-200/80 border border-slate-100 py-1 z-20">
                            <a href="/entradas/nova?produtoId=@p.ProdutoId"
                               class="flex items-center gap-2 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors">
                                <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                </svg>
                                Lançar entrada
                            </a>
                            <a href="/saidas/nova?produtoId=@p.ProdutoId"
                               class="flex items-center gap-2 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors">
                                <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
                                </svg>
                                Lançar saída
                            </a>
                            <div class="border-t border-slate-100 my-1"></div>
                            <button @@click="open=false; showExcluir=true"
                                    class="w-full flex items-center gap-2 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                </svg>
                                Excluir produto
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Integrity bar -->
            <div class="mt-3">
                <div class="flex items-center gap-2">
                    <div class="flex-1 bg-slate-100 rounded-full h-1.5 overflow-hidden">
                        <div class="h-1.5 rounded-full @barCss transition-all" style="width: @score%"></div>
                    </div>
                    <span class="text-xs font-bold @scoreCss">@score%</span>
                    <span class="text-xs text-slate-400">integridade</span>
                </div>
                @if (missing.Any())
                {
                    <p class="text-[11px] text-slate-400 mt-0.5">
                        Falta: <span class="text-slate-500">@string.Join(", ", missing)</span>
                    </p>
                }
            </div>
        </div>
    </div>

    <!-- ═══ QUICK ACTIONS ═══ -->
    <div class="flex gap-2 flex-wrap mb-5">
        <a href="/entradas/nova?produtoId=@p.ProdutoId"
           class="inline-flex items-center gap-1.5 px-4 py-2 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-lg text-sm font-semibold hover:bg-emerald-100 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Entrada
        </a>
        <a href="/saidas/nova?produtoId=@p.ProdutoId"
           class="inline-flex items-center gap-1.5 px-4 py-2 bg-red-50 text-red-600 border border-red-200 rounded-lg text-sm font-semibold hover:bg-red-100 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
            </svg>
            Saída
        </a>
        <button @@click="tab='fotos'; $nextTick(()=>$refs.fileInputTab?.click())"
                class="inline-flex items-center gap-1.5 px-4 py-2 bg-violet-50 text-violet-700 border border-violet-200 rounded-lg text-sm font-semibold hover:bg-violet-100 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            + Foto
        </button>
        <button @@click="tab='info'; showAddVariacao=true; $nextTick(()=>$refs.novaVarInput?.focus())"
                class="inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-50 text-indigo-700 border border-indigo-200 rounded-lg text-sm font-semibold hover:bg-indigo-100 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            + Variação
        </button>
        <button @@click="tab='historico'; loadHistorico()"
                class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-50 text-slate-600 border border-slate-200 rounded-lg text-sm font-semibold hover:bg-slate-100 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Histórico
        </button>
    </div>

    <!-- ═══ TABS ═══ -->
    <div class="flex gap-0.5 border-b border-slate-200 mb-5">
        <button @@click="tab='info'"
                :class="tab==='info' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="px-4 py-2 text-sm transition-colors">Informações</button>
        <button @@click="tab='fotos'"
                :class="tab==='fotos' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="px-4 py-2 text-sm transition-colors inline-flex items-center gap-1">
            Fotos
            <span class="text-[11px] font-bold px-1.5 py-0.5 rounded-full"
                  :class="tab==='fotos' ? 'bg-indigo-100 text-indigo-600' : 'bg-slate-100 text-slate-500'"
                  x-text="photos.filter(x=>!x.toDelete).length + pendingFiles.length"></span>
        </button>
        <button @@click="tab='estoque'"
                :class="tab==='estoque' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="px-4 py-2 text-sm transition-colors">Estoque</button>
        <button @@click="tab='historico'; loadHistorico()"
                :class="tab==='historico' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="px-4 py-2 text-sm transition-colors">Histórico</button>
    </div>

    <!-- ═══ TAB: INFORMAÇÕES ═══ -->
    <div x-show="tab==='info'">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">

            <!-- Dados -->
            <div class="ws">
                <h3 class="font-bold text-slate-800 mb-4">Dados do produto</h3>
                <dl class="space-y-3">
                    @if (p.PrecoReferencia is > 0)
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Preço de venda</dt>
                            <dd class="text-sm font-semibold">@p.PrecoReferencia!.Value.ToString("C", ptBR)</dd>
                        </div>
                    }
                    @if (p.CustoReferencia is > 0)
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Custo</dt>
                            <dd class="text-sm font-semibold">@p.CustoReferencia!.Value.ToString("C", ptBR)</dd>
                        </div>
                    }
                    @if (p.PrecoReferencia is > 0 && p.CustoReferencia is > 0)
                    {
                        var margem = (p.PrecoReferencia!.Value - p.CustoReferencia!.Value) / p.PrecoReferencia.Value * 100;
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Margem calculada</dt>
                            <dd class="text-sm font-semibold @(margem < 10 ? "text-red-600" : margem < 30 ? "text-amber-600" : "text-emerald-600")">@margem.ToString("F1")%</dd>
                        </div>
                    }
                    @if (p.MargemEstimada.HasValue)
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Margem estimada</dt>
                            <dd class="text-sm font-semibold text-emerald-600">@p.MargemEstimada.Value.ToString("F1")%</dd>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(p.Marca))
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Marca</dt>
                            <dd class="text-sm">@p.Marca</dd>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(p.CodigoBarras))
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Cód. Barras</dt>
                            <dd class="text-sm font-mono">@p.CodigoBarras</dd>
                        </div>
                    }
                    @if (p.ControlaValidade)
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Controla validade</dt>
                            <dd><span class="badge badge-ok px-2 py-0.5 rounded-full text-xs font-semibold">Sim</span></dd>
                        </div>
                    }
                    @if (p.Dimensoes != null)
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Peso</dt>
                            <dd class="text-sm font-mono">@($"{p.Dimensoes.Peso:F3} kg")</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Dimensões</dt>
                            <dd class="text-sm font-mono">@($"{p.Dimensoes.Largura:F1}×{p.Dimensoes.Altura:F1}×{p.Dimensoes.Comprimento:F1} cm")</dd>
                        </div>
                    }
                </dl>
                @if (!string.IsNullOrEmpty(p.DescricaoBase))
                {
                    <div class="mt-4 pt-4 border-t border-slate-100">
                        <p class="text-xs font-semibold text-slate-500 mb-1">Descrição</p>
                        <p class="text-sm text-slate-700 leading-relaxed">@p.DescricaoBase</p>
                    </div>
                }
                <div class="mt-4 pt-4 border-t border-slate-100 flex gap-2 flex-wrap">
                    <a href="/produtos/@p.ProdutoId/editar"
                       class="grid-action-btn grid-action-btn--primary">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        Editar dados
                    </a>
                    <a href="/entradas/nova?produtoId=@p.ProdutoId"
                       class="grid-action-btn grid-action-btn--success">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        + Entrada rápida
                    </a>
                </div>
            </div>

            <!-- Variações -->
            <div class="ws">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-bold text-slate-800">Variações (@p.Variacoes.Count)</h3>
                    <button @@click="showAddVariacao = !showAddVariacao"
                            class="grid-action-btn grid-action-btn--primary">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        + Adicionar
                    </button>
                </div>

                @if (p.Variacoes.Any())
                {
                    <div class="space-y-1 mb-4">
                        @foreach (var v in p.Variacoes)
                        {
                            <div class="flex items-center justify-between py-2 border-b border-slate-50 last:border-0">
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <span class="text-sm font-medium text-slate-800">@v.Nome</span>
                                        @if (!string.IsNullOrEmpty(v.Sku))
                                        {
                                            <span class="text-[11px] text-slate-400 font-mono">@v.Sku</span>
                                        }
                                        @if (!string.IsNullOrEmpty(v.Cor) || !string.IsNullOrEmpty(v.Tamanho))
                                        {
                                            <span class="text-[11px] text-slate-400">@string.Join(" / ", new[] { v.Cor, v.Tamanho }.Where(x => !string.IsNullOrEmpty(x)))</span>
                                        }
                                        <span class="badge @(v.Ativa ? "badge-ok" : "badge-warn") px-1.5 py-0 rounded text-[10px] font-semibold">@(v.Ativa ? "Ativa" : "Inativa")</span>
                                    </div>
                                    <div class="flex items-center gap-3 mt-0.5">
                                        <span class="text-xs @(v.QuantidadeEmEstoque == 0 ? "text-red-500 font-semibold" : v.QuantidadeEmEstoque < 5 ? "text-amber-600 font-semibold" : "text-slate-500")">
                                            @v.QuantidadeEmEstoque un.
                                        </span>
                                        @if (v.UltimaEntradaEm.HasValue)
                                        {
                                            <span class="text-[11px] text-slate-400">últ. @v.UltimaEntradaEm.Value.ToString("dd/MM/yy")</span>
                                        }
                                    </div>
                                </div>
                                <form asp-action="RemoverVariacao" asp-controller="Produtos"
                                      asp-route-id="@p.ProdutoId" asp-route-vid="@v.VariacaoId" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" onclick="return confirm('Remover variação @v.Nome?')"
                                            class="text-xs text-slate-300 hover:text-red-600 px-2 py-1 rounded hover:bg-red-50 transition-colors ml-2">✕</button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-slate-400 mb-4">Nenhuma variação cadastrada.</p>
                }

                <!-- Add variação inline -->
                <div x-show="showAddVariacao" x-transition class="p-3 bg-slate-50 rounded-xl border border-slate-200">
                    <p class="text-xs font-semibold text-slate-600 mb-2">Nova variação</p>
                    <form asp-action="AdicionarVariacao" asp-controller="Produtos" asp-route-id="@p.ProdutoId" method="post">
                        @Html.AntiForgeryToken()
                        <div class="flex gap-2">
                            <input type="text" name="nome" x-ref="novaVarInput"
                                   placeholder="Ex: M, Azul, P..." required
                                   class="flex-1 px-3 py-2 text-sm border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300"/>
                            <input type="text" name="sku" placeholder="SKU"
                                   class="w-24 px-3 py-2 text-sm font-mono border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300"/>
                            <button type="submit"
                                    class="px-3 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700 transition-colors">
                                OK
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Características -->
        @if (p.Caracteristicas.Any())
        {
            <div class="ws mt-5">
                <h3 class="font-bold text-slate-800 mb-3">Características (@p.Caracteristicas.Count)</h3>
                <div class="overflow-x-auto">
                    <table class="tbl-full">
                        <thead><tr><th>Nome</th><th>Descrição</th><th class="text-center">Qtd</th><th>Variação</th></tr></thead>
                        <tbody>
                            @foreach (var c in p.Caracteristicas.OrderBy(x => x.OrdemExibicao))
                            {
                                <tr>
                                    <td class="font-medium">@c.Nome</td>
                                    <td class="text-sm text-slate-500">@(c.Descricao ?? "-")</td>
                                    <td class="text-center text-sm">@(c.QuantidadeReferencia?.ToString() ?? "-")</td>
                                    <td class="text-sm text-slate-500">@(c.VariacaoPadrao ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Embalagens -->
        @if (p.Embalagens.Any())
        {
            <div class="ws mt-5">
                <h3 class="font-bold text-slate-800 mb-3">Embalagens (@p.Embalagens.Count)</h3>
                <div class="overflow-x-auto">
                    <table class="tbl-full">
                        <thead><tr><th>Nome</th><th>Descrição</th><th>Dimensões</th><th class="text-center">Padrão</th></tr></thead>
                        <tbody>
                            @foreach (var e in p.Embalagens)
                            {
                                <tr>
                                    <td class="font-medium">@e.Nome</td>
                                    <td class="text-sm text-slate-500">@(e.Descricao ?? "-")</td>
                                    <td class="text-sm font-mono text-slate-500">
                                        @if (e.Dimensoes != null) { @($"{e.Dimensoes.Peso:F3}kg · {e.Dimensoes.Largura:F1}×{e.Dimensoes.Altura:F1}×{e.Dimensoes.Comprimento:F1} cm") }
                                        else { <text>-</text> }
                                    </td>
                                    <td class="text-center">
                                        @if (e.Padrao) { <span class="badge badge-ok px-2 py-0.5 rounded-full text-xs font-semibold">Sim</span> }
                                        else { <span class="text-sm text-slate-400">-</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <!-- ═══ TAB: FOTOS (interativa, sem auto-save) ═══ -->
    <div x-show="tab==='fotos'">
        <div class="ws">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-slate-800">Fotos do produto</h3>
                <span class="text-xs text-slate-400"
                      x-text="(photos.filter(x=>!x.toDelete).length + pendingFiles.length) + '/5'"></span>
            </div>

            <!-- Grid -->
            <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3 mb-4">
                <template x-for="foto in photos" :key="foto.fotoId">
                    <div class="relative group aspect-square rounded-xl overflow-hidden border-2 transition-all"
                         :class="foto.toDelete ? 'border-red-400 opacity-50' : 'border-slate-200 hover:border-slate-300'">
                        <img :src="foto.url" class="w-full h-full object-cover"/>
                        <div x-show="foto.toDelete"
                             class="absolute inset-0 bg-red-500/20 flex items-center justify-center pointer-events-none">
                            <span class="bg-white/90 text-red-600 text-[10px] font-bold px-2 py-1 rounded-lg">Será removida</span>
                        </div>
                        <button type="button" @@click="toggleDelete(foto.fotoId)"
                                class="absolute top-1.5 right-1.5 w-6 h-6 rounded-full text-[11px] font-bold flex items-center justify-center shadow-sm transition-all"
                                :class="foto.toDelete
                                    ? 'bg-slate-700/90 text-white opacity-100'
                                    : 'bg-red-500/90 text-white opacity-0 group-hover:opacity-100'"
                                :title="foto.toDelete ? 'Restaurar' : 'Marcar para remoção'">
                            <span x-text="foto.toDelete ? '↩' : '×'"></span>
                        </button>
                    </div>
                </template>

                <template x-for="(pf, i) in pendingFiles" :key="'p'+i">
                    <div class="relative group aspect-square rounded-xl overflow-hidden border-2 border-indigo-400">
                        <img :src="pf.preview" class="w-full h-full object-cover"/>
                        <div class="absolute bottom-1.5 left-1.5 bg-indigo-500 text-white text-[9px] font-bold px-1.5 py-0.5 rounded-md">Nova</div>
                        <button type="button" @@click="removePending(i)"
                                class="absolute top-1.5 right-1.5 w-6 h-6 bg-red-500/90 text-white rounded-full text-[11px] font-bold opacity-0 group-hover:opacity-100 flex items-center justify-center shadow-sm transition-all">
                            ×
                        </button>
                    </div>
                </template>

                <template x-if="photos.filter(x=>!x.toDelete).length + pendingFiles.length < 5">
                    <button type="button" @@click="$refs.fileInputTab.click()"
                            class="aspect-square rounded-xl border-2 border-dashed border-slate-300 hover:border-indigo-400 hover:bg-indigo-50/50 flex flex-col items-center justify-center gap-1.5 text-slate-400 hover:text-indigo-500 transition-all cursor-pointer">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
                        </svg>
                        <span class="text-[11px] font-medium">Adicionar</span>
                    </button>
                </template>
            </div>

            <input type="file" x-ref="fileInputTab" accept="image/jpeg,image/png,image/webp" multiple class="hidden"
                   @@change="handlePhotoSelect($event)"/>

            <!-- Empty state -->
            <div x-show="photos.length===0 && pendingFiles.length===0" class="text-center py-10 text-slate-400">
                <svg class="w-10 h-10 mx-auto mb-2 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <p class="text-sm font-medium text-slate-500 mb-1">Nenhuma foto cadastrada</p>
                <p class="text-xs">Clique em "Adicionar" para enviar até 5 fotos (JPEG, PNG, WebP — máx. 5 MB cada)</p>
            </div>

            <!-- Barra staged (aparece quando há mudanças pendentes) -->
            <div x-show="photosDirty" x-transition:enter.duration.150ms
                 class="flex items-center gap-3 p-4 bg-indigo-50 border border-indigo-200 rounded-xl mt-2">
                <div class="flex-1 text-sm text-indigo-700 font-medium">
                    <span x-show="pendingFiles.length > 0" x-text="pendingFiles.length + ' nova(s)'"></span>
                    <span x-show="pendingFiles.length > 0 && photos.filter(p=>p.toDelete).length > 0"> · </span>
                    <span x-show="photos.filter(p=>p.toDelete).length > 0"
                          x-text="photos.filter(p=>p.toDelete).length + ' para remover'"></span>
                    <span class="text-indigo-500 font-normal ml-1">— alterações não salvas</span>
                </div>
                <button type="button" @@click="cancelPhotoChanges()"
                        class="px-4 py-2 text-sm font-semibold border border-slate-300 text-slate-600 rounded-lg hover:bg-white transition-colors flex-shrink-0">
                    Cancelar
                </button>
                <button type="button" @@click="savePhotos()" :disabled="savingPhotos"
                        class="px-5 py-2 text-sm font-semibold bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-colors disabled:opacity-60 inline-flex items-center gap-2 flex-shrink-0">
                    <span class="spinner w-3 h-3 border-white" x-show="savingPhotos" x-cloak></span>
                    <span x-text="savingPhotos ? 'Salvando...' : 'Salvar fotos'"></span>
                </button>
            </div>

            <!-- Erro -->
            <div x-show="photoError" x-cloak class="mt-3 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700" x-text="photoError"></div>
        </div>
    </div>

    <!-- ═══ TAB: ESTOQUE ═══ -->
    <div x-show="tab==='estoque'">
        <div class="ws">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-slate-800">Estoque por variação</h3>
                <div class="flex items-center gap-2">
                    <span class="text-sm text-slate-500">Total:</span>
                    <span class="text-xl font-extrabold @(p.QuantidadeTotalEstoque == 0 ? "text-red-600" : "text-slate-900")">@p.QuantidadeTotalEstoque</span>
                    <span class="text-sm text-slate-400">un.</span>
                </div>
            </div>

            @if (p.Variacoes.Any())
            {
                <div class="overflow-x-auto">
                    <table class="tbl-full">
                        <thead>
                            <tr>
                                <th>Variação</th>
                                <th>SKU</th>
                                <th class="text-center">Qtd</th>
                                <th class="text-center">Status</th>
                                <th>Últ. entrada</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in p.Variacoes)
                            {
                                <tr>
                                    <td>
                                        <div class="font-medium text-slate-800">@v.Nome</div>
                                        @if (!string.IsNullOrEmpty(v.Cor) || !string.IsNullOrEmpty(v.Tamanho))
                                        {
                                            <div class="text-xs text-slate-400">@string.Join(" / ", new[] { v.Cor, v.Tamanho }.Where(x => !string.IsNullOrEmpty(x)))</div>
                                        }
                                    </td>
                                    <td class="font-mono text-xs text-slate-500">@(v.Sku ?? "-")</td>
                                    <td class="text-center">
                                        <span class="text-lg font-extrabold @(v.QuantidadeEmEstoque == 0 ? "text-red-600" : v.QuantidadeEmEstoque < 5 ? "text-amber-600" : "text-slate-900")">
                                            @v.QuantidadeEmEstoque
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(v.Ativa ? "badge-ok" : "badge-warn") px-2 py-0.5 rounded-full text-xs font-semibold">
                                            @(v.Ativa ? "Ativa" : "Inativa")
                                        </span>
                                    </td>
                                    <td class="text-sm text-slate-500">@(v.UltimaEntradaEm?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td>
                                        <a href="/entradas/nova?produtoId=@p.ProdutoId&variacaoId=@v.VariacaoId"
                                           class="text-xs font-semibold text-emerald-600 px-2.5 py-1 border border-emerald-200 rounded-lg hover:bg-emerald-50 transition-colors whitespace-nowrap">
                                            + Entrada
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-10 text-slate-400">
                    <p class="text-sm mb-2">Nenhuma variação cadastrada.</p>
                    <button @@click="tab='info'; showAddVariacao=true; $nextTick(()=>$refs.novaVarInput?.focus())"
                            class="text-sm font-semibold text-indigo-600 hover:underline">
                        Adicionar variação →
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- ═══ TAB: HISTÓRICO ═══ -->
    <div x-show="tab==='historico'">
        <div class="ws">
            <h3 class="font-bold text-slate-800 mb-4">Histórico de movimentações</h3>

            <div x-show="historico===null" class="text-center py-10 text-slate-400 flex items-center justify-center gap-2">
                <span class="spinner"></span>
                <span class="text-sm">Carregando...</span>
            </div>

            <div x-show="historico!==null && historico.length===0" class="text-center py-10 text-slate-400">
                <svg class="w-10 h-10 mx-auto mb-2 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-sm font-medium text-slate-500 mb-3">Nenhum registro de movimentação ainda.</p>
                <div class="flex gap-3 justify-center">
                    <a href="/entradas/nova?produtoId=@p.ProdutoId"
                       class="text-sm font-semibold text-emerald-600 px-4 py-2 border border-emerald-200 rounded-lg hover:bg-emerald-50 transition-colors">
                        Registrar primeira entrada →
                    </a>
                </div>
            </div>

            <div x-show="historico!==null && historico.length>0" class="overflow-x-auto">
                <table class="tbl-full">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Tipo</th>
                            <th class="text-center">Qtd</th>
                            <th class="text-right">Valor</th>
                            <th>Observação</th>
                        </tr>
                    </thead>
                    <tbody>
                        <template x-for="(item, i) in historico" :key="i">
                            <tr>
                                <td class="text-sm text-slate-600 whitespace-nowrap"
                                    x-text="item.dataMovimentacao ? new Date(item.dataMovimentacao).toLocaleDateString('pt-BR') : '-'"></td>
                                <td>
                                    <span class="text-xs font-semibold px-2 py-0.5 rounded-full"
                                          :class="(item.natureza||'').toLowerCase().includes('entrada')
                                              ? 'bg-emerald-50 text-emerald-700'
                                              : 'bg-red-50 text-red-600'"
                                          x-text="item.natureza ?? '-'"></span>
                                </td>
                                <td class="text-center font-bold" x-text="item.quantidade ?? 0"></td>
                                <td class="text-right text-sm font-semibold"
                                    x-text="item.valorTotal!=null ? 'R$ '+Number(item.valorTotal).toFixed(2) : '-'"></td>
                                <td class="text-sm text-slate-500 max-w-xs truncate"
                                    x-text="item.observacoes ?? '-'"></td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ═══ MODAL: EXCLUIR ═══ -->
    <div x-show="showExcluir" x-cloak
         class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center"
         x-transition @@click.self="showExcluir=false">
        <div class="bg-white rounded-2xl shadow-2xl p-6 max-w-sm w-full mx-4">
            <h3 class="font-bold text-slate-900 text-lg mb-2">Excluir produto?</h3>
            <p class="text-slate-500 text-sm mb-3">
                Esta ação é irreversível. O produto <strong>@p.Nome</strong> será excluído permanentemente.
            </p>
            <div class="mb-4 p-3 bg-amber-50 border border-amber-200 rounded-lg text-xs text-amber-800">
                <strong>Atenção:</strong> se o produto possui estoque, é necessário zerar o estoque antes de excluí-lo.
            </div>
            <div class="flex gap-3 justify-end">
                <button @@click="showExcluir=false"
                        class="px-4 py-2 text-sm font-semibold border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
                    Cancelar
                </button>
                <form asp-action="Excluir" asp-controller="Produtos" asp-route-id="@p.ProdutoId" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="px-4 py-2 text-sm font-semibold bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors">
                        Confirmar exclusão
                    </button>
                </form>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        function produtoHub() {
            const initialPhotos = @Html.Raw(fotosJson);
            const prodId = '@p.ProdutoId';

            return {
                tab: 'info',
                showAddVariacao: false,
                showExcluir: false,

                // ── Photos ──
                photos: initialPhotos.map(f => ({ ...f, toDelete: false })),
                pendingFiles: [],
                photosDirty: false,
                savingPhotos: false,
                photoError: null,

                init() {
                    const t = new URLSearchParams(window.location.search).get('tab');
                    if (['info','fotos','estoque','historico'].includes(t)) {
                        this.tab = t;
                        if (t === 'historico') this.loadHistorico();
                    }
                },

                // ── Photo management (sem auto-save) ──
                handlePhotoSelect(e) {
                    const available = 5 - this.photos.filter(x => !x.toDelete).length - this.pendingFiles.length;
                    for (const f of Array.from(e.target.files).slice(0, Math.max(0, available))) {
                        if (f.size > 5 * 1024 * 1024) { window.showToast('Imagem muito grande (máx. 5 MB).', 'warning'); continue; }
                        if (!f.type.startsWith('image/')) continue;
                        this.pendingFiles.push({ file: f, preview: URL.createObjectURL(f) });
                    }
                    e.target.value = '';
                    this._dirty();
                },
                toggleDelete(fotoId) {
                    const f = this.photos.find(x => x.fotoId === fotoId);
                    if (f) { f.toDelete = !f.toDelete; this._dirty(); }
                },
                removePending(i) {
                    URL.revokeObjectURL(this.pendingFiles[i].preview);
                    this.pendingFiles.splice(i, 1);
                    this._dirty();
                },
                cancelPhotoChanges() {
                    this.photos.forEach(p => p.toDelete = false);
                    this.pendingFiles.forEach(pf => URL.revokeObjectURL(pf.preview));
                    this.pendingFiles = [];
                    this.photosDirty = false;
                    this.photoError = null;
                },
                _dirty() {
                    this.photosDirty = this.pendingFiles.length > 0 || this.photos.some(p => p.toDelete);
                },
                async savePhotos() {
                    this.savingPhotos = true;
                    this.photoError = null;
                    const token = document.querySelector('[name=__RequestVerificationToken]')?.value ?? '';

                    // Remover fotos marcadas
                    for (const foto of this.photos.filter(x => x.toDelete)) {
                        const fd = new FormData();
                        fd.append('__RequestVerificationToken', token);
                        try {
                            const r = await fetch(`/produtos/${prodId}/fotos/${foto.fotoId}/remover`, { method: 'POST', body: fd });
                            const d = await r.json();
                            if (!d.ok) throw new Error(d.erro ?? 'Erro');
                        } catch (err) {
                            this.photoError = 'Erro ao remover foto. Tente novamente.';
                            window.showToast(this.photoError, 'error');
                            this.savingPhotos = false;
                            return;
                        }
                    }
                    this.photos = this.photos.filter(x => !x.toDelete);

                    // Enviar novas fotos
                    let uploadError = false;
                    for (const pf of [...this.pendingFiles]) {
                        const fd = new FormData();
                        fd.append('foto', pf.file);
                        fd.append('__RequestVerificationToken', token);
                        try {
                            const r = await fetch(`/produtos/${prodId}/fotos/ajax`, { method: 'POST', body: fd });
                            const d = await r.json();
                            if (!d.ok) throw new Error(d.erro ?? 'Erro');
                            if (d.fotoId && d.url) this.photos.push({ fotoId: d.fotoId, url: d.url, toDelete: false });
                        } catch (err) {
                            uploadError = true;
                            this.photoError = 'Erro ao enviar foto: ' + (err.message ?? 'tente novamente.');
                            window.showToast(this.photoError, 'error');
                        }
                    }
                    this.pendingFiles.forEach(pf => URL.revokeObjectURL(pf.preview));
                    this.pendingFiles = [];
                    this.photosDirty = false;
                    this.savingPhotos = false;
                    if (!uploadError) window.showToast('Fotos salvas!', 'success');
                },

                // ── Histórico (lazy) ──
                historico: null,
                _hlLoaded: false,
                async loadHistorico() {
                    if (this._hlLoaded) return;
                    this._hlLoaded = true;
                    try {
                        const r = await fetch('/produtos/' + prodId + '/historico-json');
                        this.historico = r.ok ? await r.json() : [];
                    } catch { this.historico = []; }
                },
            };
        }
    </script>
}
