@model ProdutoDetailViewModel
@using System.Globalization
@using System.Text.Json
@{
    var ptBR = new CultureInfo("pt-BR");
    var p = Model.Produto;
    var fotosJson = JsonSerializer.Serialize(p.Fotos.Select(f => new { fotoId = f.FotoId.ToString(), url = f.Url }));

    // ── Integrity score ──
    var iFields = new (bool ok, string label, int pts)[]
    {
        (p.Fotos.Any(),                               "Foto",        20),
        (!string.IsNullOrWhiteSpace(p.DescricaoBase), "Descricao",   15),
        (p.CustoReferencia is > 0,                    "Custo",       15),
        (p.PrecoReferencia is > 0,                    "Preco",       15),
        (!string.IsNullOrWhiteSpace(p.CodigoBarras),  "Cod.Barras",  10),
        (p.Variacoes.Any(),                           "Variacoes",   10),
        (!string.IsNullOrWhiteSpace(p.Marca),         "Marca",        5),
        (p.Dimensoes != null,                         "Dimensoes",    5),
        (true,                                        "Nome",         3),
        (true,                                        "Categoria",    2),
    };
    var score = iFields.Where(f => f.ok).Sum(f => f.pts);
    var missing = iFields.Where(f => !f.ok).Select(f => f.label).ToList();
    var barCss = score >= 80 ? "bg-emerald-500" : score >= 50 ? "bg-amber-400" : "bg-red-500";
    var scoreCss = score >= 80 ? "text-emerald-600" : score >= 50 ? "text-amber-600" : "text-red-600";

    var statusBadge = p.StatusNome.ToLower() == "ativo" ? "badge-ok" : "badge-warn";
    var tipoBadge = p.Tipo switch { 1 => "Alimento", 2 => "Servico", _ => "Fisico" };

    var temPreco = p.PrecoReferencia is > 0;
    var temCusto = p.CustoReferencia is > 0;
    decimal margem = 0;
    if (temPreco && temCusto)
        margem = (p.PrecoReferencia!.Value - p.CustoReferencia!.Value) / p.PrecoReferencia.Value * 100;
}

@Html.AntiForgeryToken()

<div x-data="produtoHub()" x-init="init()" class="produto-detail-page">

    <!-- ═══ BACK + BREADCRUMB ═══ -->
    <div class="flex items-center gap-2 mb-4 text-sm text-slate-500">
        <a href="/produtos" class="hover:text-indigo-600 transition-colors inline-flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Produtos
        </a>
        <span class="text-slate-300">/</span>
        <span class="text-slate-700 font-medium truncate max-w-xs">@p.Nome</span>
    </div>

    <!-- ═══ HERO: GALLERY + PRODUCT INFO ═══ -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

        <!-- ── LEFT: IMAGE GALLERY ── -->
        <div class="space-y-3">
            <!-- Main image -->
            <div class="produto-gallery-card aspect-square bg-slate-50 rounded-2xl overflow-hidden border border-slate-200 shadow-sm relative group">
                <template x-if="photos.length > 0">
                    <img :src="mainPhoto" :key="mainPhoto" alt="@p.Nome"
                         class="w-full h-full object-contain transition-transform duration-300 group-hover:scale-105" />
                </template>
                <template x-if="photos.length === 0">
                    <div class="w-full h-full flex items-center justify-center flex-col gap-3 text-slate-300">
                        <svg class="w-20 h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        <p class="text-sm text-slate-400">Nenhuma foto cadastrada</p>
                        <button @@click="tab='fotos'" class="text-xs font-semibold text-indigo-600 hover:underline">
                            Adicionar fotos →
                        </button>
                    </div>
                </template>
                <!-- Photo counter -->
                <div x-show="photos.length > 1" class="absolute bottom-3 right-3 bg-black/60 text-white text-xs font-semibold px-2.5 py-1 rounded-full backdrop-blur-sm">
                    <span x-text="selectedPhotoIdx + 1"></span> / <span x-text="photos.length"></span>
                </div>
                <!-- Nav arrows -->
                <template x-if="photos.length > 1">
                    <div>
                        <button @@click="selectedPhotoIdx = (selectedPhotoIdx - 1 + photos.length) % photos.length"
                                class="absolute left-2 top-1/2 -translate-y-1/2 w-9 h-9 bg-black/40 hover:bg-black/60 text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all backdrop-blur-sm">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                        </button>
                        <button @@click="selectedPhotoIdx = (selectedPhotoIdx + 1) % photos.length"
                                class="absolute right-2 top-1/2 -translate-y-1/2 w-9 h-9 bg-black/40 hover:bg-black/60 text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all backdrop-blur-sm">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        </button>
                    </div>
                </template>
            </div>

            <!-- Thumbnails row -->
            <div x-show="photos.length > 1" class="flex gap-2 overflow-x-auto pb-1">
                <template x-for="(foto, idx) in photos" :key="foto.fotoId">
                    <button @@click="selectedPhotoIdx = idx"
                            class="w-16 h-16 flex-shrink-0 rounded-xl overflow-hidden border-2 transition-all"
                            :class="selectedPhotoIdx === idx ? 'border-indigo-500 ring-2 ring-indigo-200' : 'border-slate-200 hover:border-slate-300'">
                        <img :src="foto.url" class="w-full h-full object-cover"
                             onerror="this.onerror=null; this.style.display='none'; this.parentElement.classList.add('bg-slate-100');" />
                    </button>
                    </template>
            </div>
        </div>

        <!-- ── RIGHT: PRODUCT INFO ── -->
        <div class="space-y-5">
            <!-- Title + badges -->
            <div>
                <div class="flex items-center gap-2 mb-2 flex-wrap">
                    <span class="badge @statusBadge px-2.5 py-0.5 rounded-full text-xs font-semibold">@p.StatusNome</span>
                    <span class="produto-chip produto-chip--neutral text-[11px] bg-slate-100 text-slate-500 px-2.5 py-0.5 rounded-full font-medium">@tipoBadge</span>
                    @if (p.QuantidadeTotalEstoque == 0)
                    {
                        <span class="produto-chip produto-chip--danger text-[11px] bg-red-50 text-red-600 px-2.5 py-0.5 rounded-full font-semibold">Sem estoque</span>
                    }
                    else
                    {
                        <span class="produto-chip produto-chip--success text-[11px] bg-emerald-50 text-emerald-700 px-2.5 py-0.5 rounded-full font-semibold">@p.QuantidadeTotalEstoque un. em estoque</span>
                    }
                </div>
                <h1 class="text-2xl font-extrabold text-slate-900 leading-tight mb-1">@p.Nome</h1>
                @if (!string.IsNullOrEmpty(p.SkuBase))
                {
                    <p class="text-xs font-mono text-slate-400">SKU: @p.SkuBase</p>
                }
                @if (!string.IsNullOrEmpty(p.Marca))
                {
                    <p class="text-sm text-slate-500 mt-1">Marca: <span class="font-medium text-slate-700">@p.Marca</span></p>
                }
            </div>

            <!-- Price block -->
            @if (temPreco || temCusto)
            {
                <div class="produto-price-card bg-gradient-to-br from-slate-50 to-slate-100 rounded-2xl p-5 border border-slate-200">
                    @if (temPreco)
                    {
                        <div class="flex items-baseline gap-2 mb-1">
                            <span class="text-3xl font-extrabold text-slate-900">@p.PrecoReferencia!.Value.ToString("C", ptBR)</span>
                        </div>
                    }
                    @if (temCusto)
                    {
                        <div class="flex items-center gap-3 text-sm">
                            <span class="text-slate-500">Custo: <span class="font-semibold text-slate-700">@p.CustoReferencia!.Value.ToString("C", ptBR)</span></span>
                            @if (temPreco)
                            {
                                <span class="text-slate-300">|</span>
                                <span class="font-semibold @(margem < 10 ? "text-red-600" : margem < 30 ? "text-amber-600" : "text-emerald-600")">
                                    @margem.ToString("F1")% margem
                                </span>
                            }
                        </div>
                    }
                    @if (p.MargemEstimada.HasValue && !(temPreco && temCusto))
                    {
                        <p class="text-sm text-emerald-600 font-semibold mt-1">Margem estimada: @p.MargemEstimada.Value.ToString("F1")%</p>
                    }
                </div>
            }

            <!-- Description -->
            @if (!string.IsNullOrEmpty(p.DescricaoBase))
            {
                <div>
                    <p class="text-sm text-slate-600 leading-relaxed">@p.DescricaoBase</p>
                </div>
            }

            <!-- Details grid -->
            <div class="grid grid-cols-2 gap-3">
                @if (!string.IsNullOrEmpty(p.CodigoBarras))
                {
                    <div class="produto-meta-card bg-slate-50 rounded-xl p-3 border border-slate-100 col-span-2">
                        <p class="text-[11px] text-slate-400 font-medium mb-1.5">Codigo de barras</p>
                        <div class="flex items-center gap-3">
                            <svg id="barcode-svg" class="h-12"></svg>
                            <span class="text-sm font-mono text-slate-700">@p.CodigoBarras</span>
                        </div>
                    </div>
                }
                @if (p.ControlaValidade)
                {
                    <div class="produto-meta-card bg-slate-50 rounded-xl p-3 border border-slate-100">
                        <p class="text-[11px] text-slate-400 font-medium mb-0.5">Validade</p>
                        <p class="text-sm font-semibold text-emerald-600">Controlada</p>
                    </div>
                }
                @if (p.Dimensoes != null)
                {
                    <div class="produto-meta-card bg-slate-50 rounded-xl p-3 border border-slate-100">
                        <p class="text-[11px] text-slate-400 font-medium mb-0.5">Peso</p>
                        <p class="text-sm font-mono text-slate-700">@($"{p.Dimensoes.Peso:F3} kg")</p>
                    </div>
                    <div class="produto-meta-card bg-slate-50 rounded-xl p-3 border border-slate-100">
                        <p class="text-[11px] text-slate-400 font-medium mb-0.5">Dimensoes</p>
                        <p class="text-sm font-mono text-slate-700">@($"{p.Dimensoes.Largura:F1} x {p.Dimensoes.Altura:F1} x {p.Dimensoes.Comprimento:F1} cm")</p>
                    </div>
                }
            </div>

            <!-- Integrity bar -->
            <div class="produto-score-card bg-slate-50 rounded-xl p-3 border border-slate-100">
                <div class="flex items-center gap-2 mb-1">
                    <div class="flex-1 bg-slate-200 rounded-full h-2 overflow-hidden">
                        <div class="h-2 rounded-full @barCss transition-all" style="width: @score%"></div>
                    </div>
                    <span class="text-sm font-bold @scoreCss">@score%</span>
                </div>
                @if (missing.Any())
                {
                    <p class="text-[11px] text-slate-400">Falta: <span class="text-slate-500">@string.Join(", ", missing)</span></p>
                }
            </div>

            <!-- Action buttons -->
            <div class="flex flex-wrap gap-2">
                <a href="/produtos/@p.ProdutoId/editar"
                   class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition-colors shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Editar
                </a>
                <a href="/entradas/nova?produtoId=@p.ProdutoId"
                   class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-xl text-sm font-semibold hover:bg-emerald-100 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Entrada
                </a>
                <a href="/saidas/nova?produtoId=@p.ProdutoId"
                   class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-red-50 text-red-600 border border-red-200 rounded-xl text-sm font-semibold hover:bg-red-100 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
                    </svg>
                    Saida
                </a>
                <div x-data="{ open: false }" class="relative">
                    <button @@click="open = !open" @@click.away="open = false"
                            class="produto-kebab-btn p-2.5 border border-slate-200 text-slate-500 rounded-xl hover:bg-slate-50 transition-colors">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/>
                        </svg>
                    </button>
                    <div x-show="open" x-transition:enter.duration.100ms
                         class="produto-menu absolute right-0 top-full mt-1 w-48 bg-white rounded-xl shadow-xl shadow-slate-200/80 border border-slate-100 py-1 z-20">
                        <button @@click="open=false; showExcluir=true"
                                class="w-full flex items-center gap-2 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                            Excluir produto
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ TABS ═══ -->
    <div class="flex gap-0.5 border-b border-slate-200 mb-5">
        <button @@click="tab='variacoes'"
                :class="tab==='variacoes' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="px-4 py-2.5 text-sm transition-colors inline-flex items-center gap-1.5">
            Variacoes
            <span class="text-[11px] font-bold px-1.5 py-0.5 rounded-full"
                  :class="tab==='variacoes' ? 'bg-indigo-100 text-indigo-600' : 'bg-slate-100 text-slate-500'">@p.Variacoes.Count</span>
        </button>
        <button @@click="tab='fotos'"
                :class="tab==='fotos' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="px-4 py-2.5 text-sm transition-colors inline-flex items-center gap-1.5">
            Fotos
            <span class="text-[11px] font-bold px-1.5 py-0.5 rounded-full"
                  :class="tab==='fotos' ? 'bg-indigo-100 text-indigo-600' : 'bg-slate-100 text-slate-500'"
                  x-text="photos.filter(x=>!x.toDelete).length + pendingFiles.length"></span>
        </button>
        <button @@click="tab='estoque'"
                :class="tab==='estoque' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="px-4 py-2.5 text-sm transition-colors">Estoque</button>
        <button @@click="tab='historico'; loadHistorico()"
                :class="tab==='historico' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                class="px-4 py-2.5 text-sm transition-colors">Historico</button>
        @if (p.Caracteristicas.Any() || p.Embalagens.Any())
        {
            <button @@click="tab='detalhes'"
                    :class="tab==='detalhes' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                    class="px-4 py-2.5 text-sm transition-colors">Detalhes</button>
        }
    </div>

<!-- ═══ TAB: VARIACOES ═══ -->
<div x-show="tab==='variacoes'">
    <div class="ws">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-slate-800">Variacoes (@p.Variacoes.Count)</h3>
            <button @@click="showAddVariacao = !showAddVariacao"
                    class="text-xs font-semibold text-indigo-600 hover:bg-indigo-50 px-3 py-1.5 rounded-lg transition-colors">
                + Adicionar
            </button>
        </div>

        @if (p.Variacoes.Any())
        {
            <div class="space-y-1 mb-4">
                @foreach (var v in p.Variacoes)
                {
                    <div class="flex items-center justify-between py-3 border-b border-slate-50 last:border-0">
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="text-sm font-medium text-slate-800">@v.Nome</span>
                                @if (!string.IsNullOrEmpty(v.Sku))
                                {
                                    <span class="text-[11px] text-slate-400 font-mono">@v.Sku</span>
                                }
                                @if (!string.IsNullOrEmpty(v.Cor) || !string.IsNullOrEmpty(v.Tamanho))
                                {
                                    <span class="text-[11px] text-slate-400">@string.Join(" / ", new[] { v.Cor, v.Tamanho }.Where(x => !string.IsNullOrEmpty(x)))</span>
                                }
                                <span class="badge @(v.Ativa ? "badge-ok" : "badge-warn") px-1.5 py-0 rounded text-[10px] font-semibold">@(v.Ativa ? "Ativa" : "Inativa")</span>
                            </div>
                            <div class="flex items-center gap-3 mt-0.5">
                                <span class="text-xs @(v.QuantidadeEmEstoque == 0 ? "text-red-500 font-semibold" : v.QuantidadeEmEstoque < 5 ? "text-amber-600 font-semibold" : "text-slate-500")">
                                    @v.QuantidadeEmEstoque un.
                                </span>
                                @if (v.UltimaEntradaEm.HasValue)
                                {
                                    <span class="text-[11px] text-slate-400">ult. @v.UltimaEntradaEm.Value.ToString("dd/MM/yy")</span>
                                }
                                </div>
                            </div>
                            <form asp-action="RemoverVariacao" asp-controller="Produtos"
                                  asp-route-id="@p.ProdutoId" asp-route-vid="@v.VariacaoId" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" onclick="return confirm('Remover variacao @v.Nome?')"
                                        class="text-xs text-slate-300 hover:text-red-600 px-2 py-1 rounded hover:bg-red-50 transition-colors ml-2">x</button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-slate-400 mb-4">Nenhuma variacao cadastrada.</p>
            }

            <!-- Add variacao inline -->
            <div x-show="showAddVariacao" x-transition class="p-4 bg-slate-50 rounded-xl border border-slate-200">
                <p class="text-xs font-semibold text-slate-600 mb-2">Nova variacao</p>
                <form asp-action="AdicionarVariacao" asp-controller="Produtos" asp-route-id="@p.ProdutoId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="flex gap-2">
                        <input type="text" name="nome" x-ref="novaVarInput"
                               placeholder="Ex: M, Azul, P..." required
                               class="flex-1 px-3 py-2 text-sm border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300"/>
                        <input type="text" name="sku" placeholder="SKU"
                               class="w-24 px-3 py-2 text-sm font-mono border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300"/>
                        <button type="submit"
                                class="px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors">
                            OK
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ═══ TAB: FOTOS (auto-save) ═══ -->
    <div x-show="tab==='fotos'">
        <div class="ws">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-slate-800">Fotos do produto</h3>
                <span class="text-xs text-slate-400" x-text="photos.length + '/5'"></span>
            </div>

            <!-- Loading -->
            <div x-show="uploading" x-cloak class="flex items-center gap-2 mb-3 p-3 bg-indigo-50 border border-indigo-200 rounded-xl text-sm text-indigo-700">
                <span class="spinner w-4 h-4 border-indigo-500"></span>
                Enviando foto(s)...
            </div>

            <!-- Grid -->
            <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3 mb-4">
                <template x-for="foto in photos" :key="foto.fotoId">
                    <div class="relative group aspect-square rounded-xl overflow-hidden border-2 border-slate-200 hover:border-slate-300 transition-all">
                        <img :src="foto.url" class="w-full h-full object-cover"
                             onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                        <div class="w-full h-full items-center justify-center bg-slate-100 text-slate-400" style="display:none;">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <button type="button" @@click="deletePhoto(foto.fotoId)"
                                class="absolute top-1.5 right-1.5 w-7 h-7 bg-red-500/90 text-white rounded-full text-[11px] font-bold opacity-0 group-hover:opacity-100 flex items-center justify-center shadow-sm transition-all"
                                title="Remover foto">
                            x
                        </button>
                    </div>
                </template>

                <template x-if="photos.length < 5 && !uploading">
                    <button type="button" @@click="$refs.fileInputTab.click()"
                            class="aspect-square rounded-xl border-2 border-dashed border-slate-300 hover:border-indigo-400 hover:bg-indigo-50/50 flex flex-col items-center justify-center gap-1.5 text-slate-400 hover:text-indigo-500 transition-all cursor-pointer">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
                        </svg>
                        <span class="text-[11px] font-medium">Adicionar</span>
                    </button>
                </template>
            </div>

            <input type="file" x-ref="fileInputTab" accept="image/jpeg,image/png,image/webp" multiple class="hidden"
                   @@change="handlePhotoSelect($event)"/>

            <!-- Empty state -->
            <div x-show="photos.length===0 && !uploading" class="text-center py-10 text-slate-400">
                <svg class="w-10 h-10 mx-auto mb-2 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <p class="text-sm font-medium text-slate-500 mb-1">Nenhuma foto cadastrada</p>
                <p class="text-xs">Clique em "Adicionar" para enviar ate 5 fotos (JPEG, PNG, WebP — max. 5 MB cada)</p>
            </div>

            <!-- Erro -->
            <div x-show="photoError" x-cloak class="mt-3 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700" x-text="photoError"></div>
        </div>
    </div>

    <!-- ═══ TAB: ESTOQUE ═══ -->
    <div x-show="tab==='estoque'">
        <div class="ws">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-slate-800">Estoque por variacao</h3>
                <div class="flex items-center gap-2">
                    <span class="text-sm text-slate-500">Total:</span>
                    <span class="text-xl font-extrabold @(p.QuantidadeTotalEstoque == 0 ? "text-red-600" : "text-slate-900")">@p.QuantidadeTotalEstoque</span>
                    <span class="text-sm text-slate-400">un.</span>
                </div>
            </div>

            @if (p.Variacoes.Any())
            {
                <div class="overflow-x-auto">
                    <table class="tbl-full">
                        <thead>
                            <tr>
                                <th>Variacao</th>
                                <th>SKU</th>
                                <th class="text-center">Qtd</th>
                                <th class="text-center">Status</th>
                                <th>Ult. entrada</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in p.Variacoes)
                            {
                                <tr>
                                    <td>
                                        <div class="font-medium text-slate-800">@v.Nome</div>
                                        @if (!string.IsNullOrEmpty(v.Cor) || !string.IsNullOrEmpty(v.Tamanho))
                                        {
                                            <div class="text-xs text-slate-400">@string.Join(" / ", new[] { v.Cor, v.Tamanho }.Where(x => !string.IsNullOrEmpty(x)))</div>
                                        }
                                    </td>
                                    <td class="font-mono text-xs text-slate-500">@(v.Sku ?? "-")</td>
                                    <td class="text-center">
                                        <span class="text-lg font-extrabold @(v.QuantidadeEmEstoque == 0 ? "text-red-600" : v.QuantidadeEmEstoque < 5 ? "text-amber-600" : "text-slate-900")">
                                            @v.QuantidadeEmEstoque
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(v.Ativa ? "badge-ok" : "badge-warn") px-2 py-0.5 rounded-full text-xs font-semibold">
                                            @(v.Ativa ? "Ativa" : "Inativa")
                                        </span>
                                    </td>
                                    <td class="text-sm text-slate-500">@(v.UltimaEntradaEm?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td>
                                        <a href="/entradas/nova?produtoId=@p.ProdutoId&variacaoId=@v.VariacaoId"
                                           class="text-xs font-semibold text-emerald-600 px-2.5 py-1 border border-emerald-200 rounded-lg hover:bg-emerald-50 transition-colors whitespace-nowrap">
                                            + Entrada
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-10 text-slate-400">
                    <p class="text-sm mb-2">Nenhuma variacao cadastrada.</p>
                    <button @@click="tab='variacoes'; showAddVariacao=true; $nextTick(()=>$refs.novaVarInput?.focus())"
                            class="text-sm font-semibold text-indigo-600 hover:underline">
                        Adicionar variacao →
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- ═══ TAB: HISTORICO ═══ -->
    <div x-show="tab==='historico'">
        <div class="ws">
            <h3 class="font-bold text-slate-800 mb-4">Historico de movimentacoes</h3>

            <div x-show="historico===null" class="text-center py-10 text-slate-400 flex items-center justify-center gap-2">
                <span class="spinner"></span>
                <span class="text-sm">Carregando...</span>
            </div>

            <div x-show="historico!==null && historico.length===0" class="text-center py-10 text-slate-400">
                <svg class="w-10 h-10 mx-auto mb-2 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-sm font-medium text-slate-500 mb-3">Nenhum registro de movimentacao ainda.</p>
                <div class="flex gap-3 justify-center">
                    <a href="/entradas/nova?produtoId=@p.ProdutoId"
                       class="text-sm font-semibold text-emerald-600 px-4 py-2 border border-emerald-200 rounded-lg hover:bg-emerald-50 transition-colors">
                        Registrar primeira entrada →
                    </a>
                </div>
            </div>

            <div x-show="historico!==null && historico.length>0" class="overflow-x-auto">
                <table class="tbl-full">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Tipo</th>
                            <th class="text-center">Qtd</th>
                            <th class="text-right">Valor</th>
                            <th>Observacao</th>
                        </tr>
                    </thead>
                    <tbody>
                        <template x-for="(item, i) in historico" :key="i">
                            <tr>
                                <td class="text-sm text-slate-600 whitespace-nowrap"
                                    x-text="item.dataMovimentacao ? new Date(item.dataMovimentacao).toLocaleDateString('pt-BR') : '-'"></td>
                                <td>
                                    <span class="text-xs font-semibold px-2 py-0.5 rounded-full"
                                          :class="(item.natureza||'').toLowerCase().includes('entrada')
                                              ? 'bg-emerald-50 text-emerald-700'
                                              : 'bg-red-50 text-red-600'"
                                          x-text="item.natureza ?? '-'"></span>
                                </td>
                                <td class="text-center font-bold" x-text="item.quantidade ?? 0"></td>
                                <td class="text-right text-sm font-semibold"
                                    x-text="item.valorTotal!=null ? 'R$ '+Number(item.valorTotal).toFixed(2) : '-'"></td>
                                <td class="text-sm text-slate-500 max-w-xs truncate"
                                    x-text="item.observacoes ?? '-'"></td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ═══ TAB: DETALHES (Caracteristicas + Embalagens) ═══ -->
    @if (p.Caracteristicas.Any() || p.Embalagens.Any())
    {
        <div x-show="tab==='detalhes'">
            @if (p.Caracteristicas.Any())
            {
                <div class="ws mb-5">
                    <h3 class="font-bold text-slate-800 mb-3">Caracteristicas (@p.Caracteristicas.Count)</h3>
                    <div class="overflow-x-auto">
                        <table class="tbl-full">
                            <thead><tr><th>Nome</th><th>Descricao</th><th class="text-center">Qtd</th><th>Variacao</th></tr></thead>
                            <tbody>
                                @foreach (var c in p.Caracteristicas.OrderBy(x => x.OrdemExibicao))
                                {
                                    <tr>
                                        <td class="font-medium">@c.Nome</td>
                                        <td class="text-sm text-slate-500">@(c.Descricao ?? "-")</td>
                                        <td class="text-center text-sm">@(c.QuantidadeReferencia?.ToString() ?? "-")</td>
                                        <td class="text-sm text-slate-500">@(c.VariacaoPadrao ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @if (p.Embalagens.Any())
            {
                <div class="ws">
                    <h3 class="font-bold text-slate-800 mb-3">Embalagens (@p.Embalagens.Count)</h3>
                    <div class="overflow-x-auto">
                        <table class="tbl-full">
                            <thead><tr><th>Nome</th><th>Descricao</th><th>Dimensoes</th><th class="text-center">Padrao</th></tr></thead>
                            <tbody>
                                @foreach (var e in p.Embalagens)
                                {
                                    <tr>
                                        <td class="font-medium">@e.Nome</td>
                                        <td class="text-sm text-slate-500">@(e.Descricao ?? "-")</td>
                                        <td class="text-sm font-mono text-slate-500">
                                            @if (e.Dimensoes != null) { @($"{e.Dimensoes.Peso:F3}kg - {e.Dimensoes.Largura:F1}x{e.Dimensoes.Altura:F1}x{e.Dimensoes.Comprimento:F1} cm") }
                                            else { <text>-</text> }
                                        </td>
                                        <td class="text-center">
                                            @if (e.Padrao) { <span class="badge badge-ok px-2 py-0.5 rounded-full text-xs font-semibold">Sim</span> }
                                            else { <span class="text-sm text-slate-400">-</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    }

    <!-- ═══ MODAL: EXCLUIR ═══ -->
    <div x-show="showExcluir" x-cloak
         class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center"
         x-transition @@click.self="showExcluir=false">
        <div class="bg-white rounded-2xl shadow-2xl p-6 max-w-sm w-full mx-4">
            <h3 class="font-bold text-slate-900 text-lg mb-2">Excluir produto?</h3>
            <p class="text-slate-500 text-sm mb-3">
                Esta acao e irreversivel. O produto <strong>@p.Nome</strong> sera excluido permanentemente.
            </p>
            <div class="mb-4 p-3 bg-amber-50 border border-amber-200 rounded-lg text-xs text-amber-800">
                <strong>Atencao:</strong> se o produto possui estoque, e necessario zerar o estoque antes de exclui-lo.
            </div>
            <div class="flex gap-3 justify-end">
                <button @@click="showExcluir=false"
                        class="px-4 py-2 text-sm font-semibold border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
                    Cancelar
                </button>
                <form asp-action="Excluir" asp-controller="Produtos" asp-route-id="@p.ProdutoId" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="px-4 py-2 text-sm font-semibold bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors">
                        Confirmar exclusao
                    </button>
                </form>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    @if (!string.IsNullOrEmpty(p.CodigoBarras))
    {
        <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                try { JsBarcode('#barcode-svg', '@p.CodigoBarras', { format: 'CODE128', height: 40, displayValue: false, margin: 0 }); } catch(e) {}
            });
        </script>
    }
    <script>
        function produtoHub() {
            const initialPhotos = @Html.Raw(fotosJson);
            const prodId = '@p.ProdutoId';

            return {
                tab: 'variacoes',
                showAddVariacao: false,
                showExcluir: false,

                // ── Photo gallery ──
                selectedPhotoIdx: 0,
                get mainPhoto() {
                    if (this.photos.length === 0) return '';
                    const idx = Math.min(this.selectedPhotoIdx, this.photos.length - 1);
                    return this.photos[idx]?.url ?? '';
                },

                // ── Photos management ──
                photos: initialPhotos.map(f => ({ ...f, toDelete: false })),
                uploading: false,
                photoError: null,

                init() {
                    const t = new URLSearchParams(window.location.search).get('tab');
                    if (['variacoes','fotos','estoque','historico','detalhes'].includes(t)) {
                        this.tab = t;
                        if (t === 'historico') this.loadHistorico();
                    }
                },

                // ── Photo management (auto-save) ──
                async handlePhotoSelect(e) {
                    const token = document.querySelector('[name=__RequestVerificationToken]')?.value ?? '';
                    const available = 5 - this.photos.length;
                    const files = Array.from(e.target.files).slice(0, Math.max(0, available));
                    e.target.value = '';
                    if (files.length === 0) return;

                    this.uploading = true;
                    this.photoError = null;
                    for (const f of files) {
                        if (f.size > 5 * 1024 * 1024) { window.showToast('Imagem muito grande (max. 5 MB).', 'warning'); continue; }
                        if (!f.type.startsWith('image/')) continue;
                        const fd = new FormData();
                        fd.append('foto', f);
                        fd.append('__RequestVerificationToken', token);
                        try {
                            const r = await fetch(`/produtos/${prodId}/fotos/ajax`, { method: 'POST', body: fd });
                            const d = await r.json();
                            if (!d.ok) throw new Error(d.erro ?? 'Erro ao enviar');
                            if (d.fotoId && d.url) this.photos.push({ fotoId: d.fotoId, url: d.url, toDelete: false });
                        } catch (err) {
                            this.photoError = 'Erro ao enviar foto: ' + (err.message ?? 'tente novamente.');
                            window.showToast(this.photoError, 'error');
                        }
                    }
                    this.uploading = false;
                    if (!this.photoError) window.showToast('Foto(s) salva(s)!', 'success');
                },
                async deletePhoto(fotoId) {
                    if (!confirm('Remover esta foto?')) return;
                    const token = document.querySelector('[name=__RequestVerificationToken]')?.value ?? '';
                    const fd = new FormData();
                    fd.append('__RequestVerificationToken', token);
                    try {
                        const r = await fetch(`/produtos/${prodId}/fotos/${fotoId}/remover`, { method: 'POST', body: fd });
                        const d = await r.json();
                        if (!d.ok) throw new Error(d.erro ?? 'Erro');
                        this.photos = this.photos.filter(x => x.fotoId !== fotoId);
                        if (this.selectedPhotoIdx >= this.photos.length) this.selectedPhotoIdx = Math.max(0, this.photos.length - 1);
                        window.showToast('Foto removida.', 'success');
                    } catch (err) {
                        window.showToast('Erro ao remover foto.', 'error');
                    }
                },

                // ── Historico (lazy) ──
                historico: null,
                _hlLoaded: false,
                async loadHistorico() {
                    if (this._hlLoaded) return;
                    this._hlLoaded = true;
                    try {
                        const r = await fetch('/produtos/' + prodId + '/historico-json');
                        this.historico = r.ok ? await r.json() : [];
                    } catch { this.historico = []; }
                },
            };
        }
    </script>
}
