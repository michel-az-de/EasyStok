@model ProdutoFormViewModel
@using EasyStock.Web.Models.Api
@using System.Text.Json
@{
    var isEdit = !string.IsNullOrEmpty(Model.Id);
    var categorias = ViewBag.Categorias as List<CategoriaApi> ?? [];
    var roots = categorias.Where(c => c.CategoriaPaiId == null).ToList();
    var children = categorias.Where(c => c.CategoriaPaiId != null).ToLookup(c => c.CategoriaPaiId);
    var subcatJson = JsonSerializer.Serialize(categorias.Where(c => c.CategoriaPaiId != null).Select(c => new { id = c.Id, nome = c.Nome, categoriaPaiId = c.CategoriaPaiId }));
    var allCatsJson = JsonSerializer.Serialize(categorias.Select(c => new { id = c.Id, nome = c.Nome }));
    var existingPhotosJson = JsonSerializer.Serialize(Model.ExistingPhotos.Select(f => new { fotoId = f.FotoId, url = f.Url }));
    var formAction = isEdit ? Url.Action("Atualizar", "Produtos", new { id = Model.Id }) : Url.Action("Criar", "Produtos");
    var stepNames = new[] { "Essencial", "Fotos e Preços", "Detalhes", "Revisão" };
}

<div class="flex items-center gap-3 mb-6">
    <a href="@(isEdit ? $"/produtos/{Model.Id}" : "/produtos")"
       aria-label="Voltar"
       class="text-slate-400 hover:text-slate-600 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <div class="pg-hd">
        <h1>@ViewBag.Title</h1>
        <p>@(isEdit ? "Atualize as informações do produto" : "Cadastre um novo produto em poucos passos")</p>
    </div>
</div>

<form id="produto-form" action="@formAction" method="post" enctype="multipart/form-data" novalidate
      x-data="produtoForm()"
      @@submit.prevent="isEdit ? abrirModalConfirmacao() : submitForm()"
      class="max-w-3xl pb-24 sm:pb-8">
    @Html.AntiForgeryToken()
    @if (isEdit)
    {
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="Status" value="@Model.Status" />
    }

    <!-- ══════════════ STEPPER BAR ══════════════ -->
    <div class="ws mb-6 product-stepper-sticky">
        <div class="flex items-center">
            @for (int i = 0; i < stepNames.Length; i++)
            {
                var sn = i + 1;
                var last = i == stepNames.Length - 1;
                <div class="flex items-center @(last ? "" : "flex-1")">
                    <div class="step-circle cursor-pointer" :class="step > @sn ? 'done' : step === @sn ? 'active' : ''"
                         @@click="goToStep(@sn)">@sn</div>
                    <div class="ml-2 hidden sm:block">
                        <div class="text-xs font-semibold cursor-pointer" :class="step === @sn ? 'text-indigo-600' : 'text-slate-400'"
                             @@click="goToStep(@sn)">@stepNames[i]</div>
                    </div>
                    @* Mobile: mostrar nome da etapa ativa abaixo do círculo *@
                    <div x-show="step === @sn" class="ml-1 sm:hidden" x-cloak>
                        <div class="text-[10px] font-semibold text-indigo-600 leading-tight whitespace-nowrap">@stepNames[i]</div>
                    </div>
                    @if (!last)
                    {
                        <div class="step-connector flex-1 mx-3" :class="step > @sn ? 'step-connector--done' : ''"></div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ══════════════ STEP 1: ESSENCIAL ══════════════ -->
    <div x-show="step === 1" x-transition:enter.duration.200ms>
        <div class="ws premium-photo-section">
            <div class="section-hd premium-photo-section__head">
                <div class="section-hd-icon bg-indigo-50 text-indigo-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                </div>
                <h3 class="font-bold text-slate-800">Informações do produto</h3>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="sm:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Nome do produto *</label>
                    <input name="Nome" x-model="nome"
                           placeholder="Ex: Camiseta Basica Masculina Algodao"
                           minlength="3" maxlength="200"
                           @* Destaca borda vermelha quando usuario tentou avancar sem preencher (step1AttemptedAdvance true). *@
                           :class="step1AttemptedAdvance && (!nome || nome.trim().length < 3) ? 'w-full px-3 py-2.5 border border-red-400 ring-1 ring-red-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300' : 'w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300'" />
                    <span x-show="nome && nome.trim().length > 0 && nome.trim().length < 3" x-cloak
                          class="text-red-500 text-xs mt-1 block">O nome deve ter pelo menos 3 caracteres.</span>
                    <span x-show="step1AttemptedAdvance && !nome" x-cloak
                          class="text-red-500 text-xs mt-1 block">Nome é obrigatório.</span>
                    <span asp-validation-for="Nome" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Categoria *</label>
                    <div class="flex gap-2">
                        <select name="CategoriaId" x-model="categoriaId" x-ref="categoriaSelect"
                                @@change="subcategoriaId = ''"
                                :class="(step1AttemptedAdvance && !categoriaId ? 'border-red-400 ring-1 ring-red-200 focus:ring-red-300' : 'border-slate-300 focus:ring-indigo-300') + ' flex-1 px-3 py-2.5 border rounded-lg text-sm focus:outline-none focus:ring-2'">
                            <option value="">Selecione...</option>
                            @foreach (var cat in roots)
                            {
                                <option value="@cat.Id.ToString().ToLower()">@cat.Nome</option>
                                @foreach (var sub in children[cat.Id])
                                {
                                    <option value="@sub.Id.ToString().ToLower()">&nbsp;&nbsp;-- @sub.Nome</option>
                                }
                            }
                        </select>
                        <button type="button" @@click="novaCategoria.aberto = !novaCategoria.aberto"
                                class="shrink-0 px-3 py-2.5 text-sm font-semibold text-indigo-600 border border-indigo-200 rounded-lg hover:bg-indigo-50 transition-colors"
                                title="Criar nova categoria sem sair desta tela">+ Nova</button>
                    </div>
                    @if (!roots.Any())
                    {
                        <p x-show="!categoriaId" x-cloak class="text-xs text-amber-600 mt-1.5">
                            Nenhuma categoria ainda. Clique em <strong>+ Nova</strong> para criar a primeira sem sair daqui.
                        </p>
                    }
                    <div x-show="novaCategoria.aberto" x-cloak x-transition class="mt-2 flex gap-2 items-start">
                        <input type="text" x-model="novaCategoria.nome" maxlength="60"
                               placeholder="Nome da nova categoria"
                               @@keydown.enter.prevent="criarCategoriaInline()"
                               class="flex-1 px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        <button type="button" @@click="criarCategoriaInline()" :disabled="novaCategoria.salvando"
                                class="shrink-0 px-3 py-2 text-sm font-semibold bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 disabled:opacity-60">
                            <span x-show="!novaCategoria.salvando">Criar</span>
                            <span x-show="novaCategoria.salvando" x-cloak>Salvando...</span>
                        </button>
                        <button type="button" @@click="novaCategoria.aberto = false; novaCategoria.nome = ''"
                                class="shrink-0 px-2 py-2 text-sm text-slate-400 hover:text-slate-600" title="Cancelar">✕</button>
                    </div>
                    <span asp-validation-for="CategoriaId" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div x-show="subcategorias.length > 0" x-transition>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Subcategoria</label>
                    <select name="SubcategoriaId" x-model="subcategoriaId"
                            class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
                        <option value="">Nenhuma</option>
                        <template x-for="sub in subcategorias" :key="sub.id">
                            <option :value="sub.id" x-text="sub.nome"></option>
                        </template>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">SKU</label>
                    <div class="flex gap-2">
                        <div class="relative flex-1">
                            <input name="SkuBase" x-model="sku" placeholder="Ex: CAM-BAS-K7Q2"
                                   @@blur="checkSkuDisponivel()"
                                   :class="skuStatus === 'indisponivel' ? 'border-red-400 focus:ring-red-300' : skuStatus === 'disponivel' ? 'border-emerald-400 focus:ring-emerald-300' : ''"
                                   class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                            <span x-show="skuStatus === 'disponivel'" class="absolute right-3 top-1/2 -translate-y-1/2 text-emerald-600 text-xs font-semibold">&#10003; disponível</span>
                            <span x-show="skuStatus === 'indisponivel'" class="absolute right-3 top-1/2 -translate-y-1/2 text-red-500 text-xs font-semibold">&#10007; em uso</span>
                            <span x-show="skuStatus === 'verificando'" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs">...</span>
                            <span x-show="skuStatus === 'erro'" class="absolute right-3 top-1/2 -translate-y-1/2 text-amber-500 text-xs font-semibold">&#9888; verificar</span>
                        </div>
                        <button type="button" @@click="gerarSku()"
                                class="px-3 py-2.5 border border-slate-300 text-slate-600 text-xs rounded-lg hover:bg-slate-50 flex-shrink-0">
                            Gerar
                        </button>
                    </div>
                    @if (ViewData.ModelState["SkuBase"]?.Errors.Count > 0)
                    {
                        <p class="text-xs text-red-500 mt-1">@ViewData.ModelState["SkuBase"]!.Errors[0].ErrorMessage — clique "Preencher com IA" para gerar novo SKU.</p>
                    }
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Código de barras</label>
                    <div class="flex gap-2">
                        <input name="CodigoBarras" x-model="codigoBarras" placeholder="EAN-13"
                               x-effect="renderBarcode()"
                               @@blur="validarCodigoBarras()"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        <button type="button" @@click="gerarCodigoBarras()"
                                class="px-3 py-2.5 border border-slate-300 text-slate-600 text-xs rounded-lg hover:bg-slate-50 flex-shrink-0">
                            Gerar
                        </button>
                    </div>
                    <p x-show="eanAviso" x-text="eanAviso" class="text-xs text-amber-600 mt-1"></p>
                    <div x-show="codigoBarras && codigoBarras.length > 3" class="mt-2">
                        <svg id="product-barcode" class="max-w-full"></svg>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Marca</label>
                    <div class="relative">
                        <input name="Marca" x-model="marca"
                               @@input.debounce.250ms="buscarMarcas()"
                               @@focus="buscarMarcas()"
                               @@keydown.escape="marcaSugestoes = []"
                               autocomplete="off"
                               placeholder="Ex: Samsung, Nike, Nestlé..."
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        <ul x-show="marcaSugestoes.length > 0" x-cloak
                            class="absolute z-50 w-full bg-white border border-slate-200 rounded-lg shadow-lg mt-1 max-h-48 overflow-y-auto">
                            <template x-for="m in marcaSugestoes" :key="m">
                                <li @@click="selecionarMarca(m)"
                                    class="px-3 py-2 text-sm hover:bg-indigo-50 cursor-pointer" x-text="m"></li>
                            </template>
                        </ul>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Tipo</label>
                    <select name="Tipo" x-model.number="tipo" @@change="_tipoManuallySet = true"
                            class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
                        @if (Model.Tipo == 0) { <option value="0" selected>Físico</option> } else { <option value="0">Físico</option> }
                        @if (Model.Tipo == 1) { <option value="1" selected>Alimento</option> } else { <option value="1">Alimento</option> }
                        @if (Model.Tipo == 2) { <option value="2" selected>Serviço</option> } else { <option value="2">Serviço</option> }
                    </select>
                    <p x-show="tipoSugerido !== null && tipo !== tipoSugerido" x-cloak
                       class="text-xs text-indigo-500 mt-1 cursor-pointer hover:underline"
                       @@click="tipo = tipoSugerido; controlaValidade = (tipoSugerido === 1)">
                        <span x-text="tipoSugerido === 1 ? '💡 Sugestão: usar tipo Alimento para esta categoria' : ''"></span>
                    </p>
                </div>
                @* C2 (RDC 727/2022): novo campo TipoEmbalagem. Define se peso e
                   obrigatorio na etiqueta. Default Avulso (sem peso obrigatorio).
                   Embalado = produto pre-embalado, exige peso por unidade. *@
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Embalagem</label>
                    <select name="TipoEmbalagem"
                            class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
                        @{
                            var isAvulso = string.Equals(Model.TipoEmbalagem, "Avulso", StringComparison.OrdinalIgnoreCase) || string.IsNullOrEmpty(Model.TipoEmbalagem);
                            var isEmbalado = string.Equals(Model.TipoEmbalagem, "Embalado", StringComparison.OrdinalIgnoreCase);
                        }
                        <option value="Avulso" selected="@(isAvulso ? "selected" : null)">Avulso</option>
                        <option value="Embalado" selected="@(isEmbalado ? "selected" : null)">Embalado</option>
                    </select>
                    <p class="text-xs text-slate-500 mt-1">
                        <strong>Avulso</strong>: pão por kg, granel. <strong>Embalado</strong>: massa fresca, vácuo, pacote fechado (peso obrigatório RDC 727/2022).
                    </p>
                </div>
                <div class="sm:col-span-2">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="hidden" name="ControlaValidade" value="false" />
                        <input name="ControlaValidade" type="checkbox" value="true"
                               :checked="controlaValidade"
                               @@change="controlaValidade = $el.checked"
                               class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-300" />
                        <span class="text-sm text-slate-700">Controla validade</span>
                    </label>
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Descrição</label>
                    <textarea name="DescricaoBase" x-model="descricao" rows="3"
                              placeholder="Descreva o produto em poucas palavras..."
                              class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"></textarea>
                    <div class="flex items-center gap-3 mt-1.5">
                        <button type="button" :disabled="aiGenerating || !nome"
                                @@click="generateDescription()"
                                class="inline-flex items-center gap-1.5 text-xs text-indigo-600 hover:text-indigo-800 font-semibold disabled:opacity-40 disabled:cursor-not-allowed">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                            </svg>
                            <span x-show="!aiGenerating">Gerar com IA</span>
                            <span x-show="aiGenerating" x-cloak class="inline-flex items-center gap-1"><span class="spinner"></span> Gerando...</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Nav Step 1 -->
        <div class="flex items-center justify-between mt-4 gap-2 flex-wrap">
            <div class="flex items-center gap-2">
                <a href="@(isEdit ? $"/produtos/{Model.Id}" : "/produtos")"
                   class="px-5 py-2.5 border border-slate-300 text-slate-600 text-sm font-semibold rounded-lg hover:bg-slate-50 transition-colors">
                    Cancelar
                </a>
                @if (!isEdit)
                {
                    <button type="button" @@click="salvarRascunho()"
                            class="px-4 py-2.5 border border-slate-300 text-slate-500 text-xs font-semibold rounded-lg hover:bg-slate-50 transition-colors flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                        </svg>
                        Salvar rascunho
                    </button>
                }
            </div>
            <span class="text-xs text-slate-400 font-semibold hidden sm:block">Etapa 1 de 4</span>
            <div class="flex items-center gap-2">
                <button type="button" :disabled="autoFilling" @@click="confirmarAutoFill()"
                        class="px-4 py-2.5 border border-violet-200 text-violet-600 hover:bg-violet-50 text-xs font-semibold rounded-lg transition-colors disabled:opacity-40 disabled:cursor-not-allowed flex items-center gap-1.5">
                    <span x-show="!autoFilling" class="inline-flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                        Preencher auto
                    </span>
                    <span x-show="autoFilling" x-cloak class="inline-flex items-center gap-1"><span class="spinner"></span> Gerando...</span>
                </button>
                <button type="button" @@click="nextStep()"
                        class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-lg shadow-indigo-500/25">
                    Próximo &rarr;
                </button>
                <button x-show="isEdit" x-cloak type="submit" :disabled="saving"
                        class="px-6 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-lg shadow-emerald-500/25 disabled:opacity-50 flex items-center gap-2">
                    <template x-if="!saving"><span>Salvar alterações</span></template>
                    <template x-if="saving"><span class="inline-flex items-center gap-2"><span class="spinner"></span> Salvando...</span></template>
                </button>
            </div>
        </div>
    </div>

    <!-- ══════════════ STEP 2: FOTOS E PRECOS ══════════════ -->
    <div x-show="step === 2" x-transition:enter.duration.200ms>

        <!-- Fotos -->
        <div class="ws">
            <div class="section-hd">
                <div class="section-hd-icon bg-violet-50 text-violet-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                </div>
                <div>
                    <h3 class="font-bold text-slate-800">Fotos do produto</h3>
                    <p class="text-xs text-slate-400 mt-0.5">A primeira foto vira a capa do produto.</p>
                </div>
                <span class="premium-photo-counter ml-auto" x-text="totalPhotoCount + '/5'"></span>
            </div>

            <!-- Grid de previews (existentes + novas) -->
            <div x-show="totalPhotoCount > 0" x-transition class="mb-4">
                <div class="grid grid-cols-3 sm:grid-cols-5 gap-3">
                    <!-- Fotos existentes -->
                    <template x-for="(foto, idx) in existingPhotos" :key="'ex-' + foto.fotoId">
                        <div class="relative aspect-square rounded-xl overflow-hidden border-2 group"
                             :class="idx === 0 ? 'border-indigo-300 ring-2 ring-indigo-100' : 'border-slate-200'">
                            <img :src="foto.url" :alt="'Foto ' + (idx + 1)" loading="lazy" decoding="async" class="w-full h-full object-cover object-top" />
                            <span x-show="idx === 0"
                                  class="absolute top-1.5 left-1.5 bg-indigo-600 text-white text-[10px] font-bold px-2 py-0.5 rounded-full">Capa</span>
                            <span class="absolute bottom-1.5 left-1.5 text-[10px] font-semibold text-white bg-black/50 backdrop-blur px-1.5 py-0.5 rounded"
                                  x-text="'Foto ' + (idx + 1)"></span>
                            <!-- Botão remover (apenas em modo edição) -->
                            <template x-if="productId">
                                <button type="button" @@click="deleteExistingPhoto(foto.fotoId)"
                                        aria-label="Remover foto"
                                        class="absolute top-1.5 right-1.5 w-6 h-6 flex items-center justify-center bg-white/90 hover:bg-red-500 hover:text-white text-slate-500 rounded-full shadow-sm text-xs font-bold opacity-0 group-hover:opacity-100 transition-all">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                </button>
                            </template>
                        </div>
                    </template>
                    <!-- Previews de novas fotos -->
                    <template x-for="(url, idx) in previews" :key="'new-' + idx">
                        <div class="relative aspect-square rounded-xl overflow-hidden border-2 group"
                             :class="idx === 0 && existingPhotos.length === 0 ? 'border-indigo-300 ring-2 ring-indigo-100' : 'border-slate-200'">
                            <img :src="url" :alt="'Nova foto ' + (idx + 1)" loading="lazy" decoding="async" class="w-full h-full object-cover object-top" />
                            <span x-show="idx === 0 && existingPhotos.length === 0"
                                  class="absolute top-1.5 left-1.5 bg-indigo-600 text-white text-[10px] font-bold px-2 py-0.5 rounded-full">Capa</span>
                            <span class="absolute bottom-1.5 left-1.5 text-[10px] font-semibold text-white bg-black/50 backdrop-blur px-1.5 py-0.5 rounded"
                                  x-text="'Foto ' + (existingPhotos.length + idx + 1)"></span>
                            <button type="button" @@click="removePondFile(idx)"
                                    aria-label="Remover foto"
                                    class="absolute top-1.5 right-1.5 w-6 h-6 flex items-center justify-center bg-white/90 hover:bg-red-500 hover:text-white text-slate-500 rounded-full shadow-sm text-xs font-bold opacity-0 group-hover:opacity-100 transition-all">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                            </button>
                        </div>
                    </template>
                    <!-- Botão adicionar mais fotos (quando < 5) -->
                    <button x-show="totalPhotoCount < 5" :disabled="totalPhotoCount >= 5" type="button" @@click="_pond && _pond.browse()"
                            class="aspect-square rounded-xl border-2 border-dashed border-slate-200 bg-slate-50 hover:bg-slate-100 flex flex-col items-center justify-center gap-1 transition-colors cursor-pointer">
                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        <span class="text-[9px] text-slate-400 font-medium">Adicionar</span>
                    </button>
                </div>
                <p class="text-xs text-slate-400 mt-2">
                    Máx. 5 fotos · JPEG, PNG, WebP · 10 MB cada · A 1ª foto é a capa.
                    <span x-text="'(' + remainingPhotoSlots + (remainingPhotoSlots === 1 ? ' slot disponível)' : ' slots disponíveis)')"></span>
                </p>
            </div>

            <!-- Área de upload: slots visuais quando vazio -->
            <div x-show="totalPhotoCount === 0" x-cloak class="mb-4">
                <div class="grid grid-cols-5 gap-2">
                    <!-- Slot 1: Capa (destaque indigo, mesmo tamanho dos outros) -->
                    <button type="button" @@click="_pond && _pond.browse()"
                            class="aspect-square rounded-xl border-2 border-dashed border-indigo-300 bg-indigo-50/40 hover:bg-indigo-50 flex flex-col items-center justify-center gap-1 transition-colors cursor-pointer group">
                        <svg class="w-5 h-5 text-indigo-400 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        <span class="text-[9px] font-bold text-indigo-400 uppercase tracking-wide">Capa</span>
                    </button>
                    <!-- Slots 2-5 -->
                    <template x-for="n in [2,3,4,5]" :key="n">
                        <button type="button" @@click="_pond && _pond.browse()"
                                class="aspect-square rounded-xl border-2 border-dashed border-slate-200 bg-slate-50 hover:bg-slate-100 flex flex-col items-center justify-center gap-1 transition-colors cursor-pointer">
                            <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
                            <span class="text-[9px] text-slate-300 font-medium" x-text="'Foto ' + n"></span>
                        </button>
                    </template>
                </div>
                <p class="text-center text-xs text-slate-400 mt-3">Toque em qualquer slot para adicionar · JPEG, PNG, WebP · 10 MB</p>
            </div>

            <!-- FilePond: no DOM para funcionalidade, visualmente colapsado -->
            <div class="photo-upload-container" style="height:0;overflow:hidden;margin:0;padding:0;border:none;">
                <input type="file" x-ref="pondInput" />
            </div>
        </div>

        <!-- Overlay de progresso (Fase 2 do submit — upload de fotos) -->
        <div x-show="uploadPhase" x-cloak
             class="fixed inset-0 z-50 flex items-center justify-center bg-black/40">
            <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-sm space-y-3">
                <p class="text-sm font-semibold text-slate-800">Enviando fotos...</p>
                <template x-for="(qi, i) in uploadQueue" :key="i">
                    <div class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm"
                         :class="qi.status==='uploading' ? 'bg-indigo-50 text-indigo-700' :
                                 qi.status==='done' ? 'bg-emerald-50 text-emerald-700' :
                                 'bg-red-50 text-red-700'">
                        <svg x-show="qi.status==='uploading'" class="animate-spin h-4 w-4 flex-shrink-0" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                        </svg>
                        <span x-show="qi.status==='done'" class="text-emerald-600 font-bold flex-shrink-0">&#10003;</span>
                        <span x-show="qi.status==='error'" class="text-red-600 font-bold flex-shrink-0">&#10007;</span>
                        <span x-text="qi.name" class="truncate flex-1"></span>
                        <span x-show="qi.status==='error'" class="text-xs flex-shrink-0" x-text="qi.message"></span>
                    </div>
                </template>
            </div>
        </div>

        <!-- Preços -->
        <div class="ws mt-6">
            <div class="section-hd">
                <div class="section-hd-icon bg-emerald-50 text-emerald-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <h3 class="font-bold text-slate-800">Preços e margem</h3>
                    <p class="text-xs text-slate-400 mt-0.5">Preencha dois campos e o terceiro será calculado automaticamente.</p>
                </div>
            </div>
            <!-- Hidden inputs: valor vazio quando zero (ASP.NET trata como null para nullable decimal) -->
            <input type="hidden" name="CustoReferencia" :value="custo > 0 ? custo : ''" />
            <input type="hidden" name="PrecoReferencia" :value="preco > 0 ? preco : ''" />
            <input type="hidden" name="MargemEstimada" :value="margem > 0 ? margem : ''" />

            <div class="grid grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Custo</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs text-slate-400">R$</span>
                        <input type="text" inputmode="decimal" autocomplete="off"
                               x-effect="syncMoneyInput($el, custo, 2)"
                               @@input="custo = parseDecimal($el.value); onCustoInput()"
                               @@blur="$el.value = custo > 0 ? custo.toFixed(2).replace('.', ',') : ''"
                               :class="{ 'field-calculated': lastEdited === 'margem' && custo > 0 }"
                               class="w-full pl-9 pr-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Margem
                        <span class="inline-block ml-1 text-slate-300 cursor-help align-middle" title="% sobre o preço de venda — ex: custo R$8 com 30% → venda R$11,43">
                            <svg class="w-3.5 h-3.5 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        </span>
                    </label>
                    <div class="relative">
                        <input type="text" inputmode="decimal" autocomplete="off"
                               x-effect="syncMoneyInput($el, margem, 1)"
                               @@input="margem = parseDecimal($el.value); onMargemInput()"
                               @@blur="$el.value = margem > 0 ? margem.toFixed(1).replace('.', ',') : ''"
                               :class="{ 'field-calculated': (lastEdited === 'preco' || lastEdited === 'custo') && margem > 0 }"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-slate-400">%</span>
                    </div>
                    @* Margem positiva: indica saude (baixa/moderada/saudavel). Margem negativa
                       (preco abaixo do custo): alerta de prejuizo, antes ficava silenciosa. *@
                    <template x-if="margem !== null && margem !== 0">
                        <span class="text-xs mt-1 block font-medium"
                              :class="margem >= 100 ? 'text-red-600 font-bold' : margem < 0 ? 'text-red-600 font-bold' : margem < 10 ? 'text-red-500' : margem < 30 ? 'text-amber-500' : 'text-emerald-500'"
                              x-text="margem >= 100 ? '⚠ Margem inválida: deve ser menor que 100% (sobre preço de venda)' : margem < 0 ? '⚠ Prejuízo: preço abaixo do custo (' + margem.toFixed(1).replace('.', ',') + '%)' : margem < 10 ? 'Margem baixa' : margem < 30 ? 'Margem moderada' : 'Margem saudável'"></span>
                    </template>
                    <div x-show="margemSugestoes.length > 0" class="flex gap-2 mt-1 flex-wrap">
                        <template x-for="s in margemSugestoes" :key="s.pct">
                            <button type="button" @@click="aplicarMargem(s.pct)"
                                    class="px-2 py-1 text-xs rounded-full border border-indigo-200 text-indigo-600 hover:bg-indigo-50 transition-colors">
                                <span x-text="s.pct + '%'"></span>
                                <span class="text-slate-400 ml-1" x-text="'→ R$' + s.preco"></span>
                            </button>
                        </template>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Preço de venda</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs text-slate-400">R$</span>
                        <input type="text" inputmode="decimal" autocomplete="off"
                               x-effect="syncMoneyInput($el, preco, 2)"
                               @@input="preco = parseDecimal($el.value); onPrecoInput()"
                               @@blur="$el.value = preco > 0 ? preco.toFixed(2).replace('.', ',') : ''"
                               :class="{ 'field-calculated': lastEdited === 'margem' && preco > 0 }"
                               class="w-full pl-9 pr-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                </div>
            </div>
            <template x-if="lastEdited !== 'none' && (margem > 0 || preco > 0)">
                <p class="text-xs text-slate-400 mt-2 flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    Campos com borda verde foram calculados. Você pode editá-los.
                </p>
            </template>
        </div>

        <!-- Nav Step 2 -->
        <div class="flex items-center justify-between mt-4 gap-2 flex-wrap">
            <div class="flex items-center gap-2">
                <button type="button" @@click="prevStep()"
                        class="px-5 py-2.5 border border-slate-300 text-slate-600 text-sm font-semibold rounded-lg hover:bg-slate-50 transition-colors">
                    &larr; Voltar
                </button>
                @if (!isEdit)
                {
                    <button type="button" @@click="salvarRascunho()"
                            class="px-4 py-2.5 border border-slate-300 text-slate-500 text-xs font-semibold rounded-lg hover:bg-slate-50 transition-colors flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                        </svg>
                        Rascunho
                    </button>
                }
            </div>
            <span class="text-xs text-slate-400 font-semibold hidden sm:block">Etapa 2 de 4</span>
            <button type="button" @@click="nextStep()"
                    class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-lg shadow-indigo-500/25">
                Próximo &rarr;
            </button>
            <button x-show="isEdit" x-cloak type="submit" :disabled="saving"
                    class="px-6 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-lg shadow-emerald-500/25 disabled:opacity-50 flex items-center gap-2">
                <template x-if="!saving"><span>Salvar alterações</span></template>
                <template x-if="saving"><span class="inline-flex items-center gap-2"><span class="spinner"></span> Salvando...</span></template>
            </button>
        </div>
    </div>

    <!-- ══════════════ STEP 3: DETALHES (OPCIONAL) ══════════════ -->
    <div x-show="step === 3" x-transition:enter.duration.200ms>

        <div class="bg-indigo-50 border border-indigo-200 text-indigo-700 text-sm rounded-lg px-4 py-3 mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Etapa opcional — pule se não precisar agora. Você pode adicionar detalhes depois.
        </div>

        <!-- Limiares de estoque (overrides hierarquicos) -->
        <div class="ws mb-6" x-data="{ open: @(Model.QuantidadeMinima.HasValue || Model.QuantidadeCritica.HasValue ? "true" : "false") }">
            <button type="button" @@click="open = !open" class="w-full flex items-center justify-between cursor-pointer py-3">
                <div class="section-hd mb-0">
                    <div class="section-hd-icon bg-amber-50 text-amber-500">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-3L13.73 4c-.77-1.33-2.69-1.33-3.46 0L3.34 16c-.77 1.33.19 3 1.73 3z" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-slate-800">Limiares de estoque (opcional)</h3>
                </div>
                <svg class="w-5 h-5 text-slate-400 transition-transform" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </button>
            <div x-show="open" x-cloak>
                <p class="text-xs text-slate-500 mb-3 mt-1">
                    Sobrescrever os limiares vindos da categoria/loja. Deixe em branco para herdar.
                    Crítico precisa ser menor que mínimo (ex.: 50 / 10).
                </p>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="QuantidadeMinima" class="block text-sm font-semibold text-slate-700 mb-1.5">Quantidade mínima</label>
                        <input asp-for="QuantidadeMinima" type="number" min="0" max="9999" placeholder="Herdar"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        <span asp-validation-for="QuantidadeMinima" class="text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="QuantidadeCritica" class="block text-sm font-semibold text-slate-700 mb-1.5">Quantidade crítica</label>
                        <input asp-for="QuantidadeCritica" type="number" min="0" max="9999" placeholder="Herdar"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        <span asp-validation-for="QuantidadeCritica" class="text-xs text-red-600"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Dimensoes -->
        <div class="ws" x-data="{ open: @(Model.DimensoesPeso.HasValue || Model.DimensoesLargura.HasValue ? "true" : "false") }">
            <button type="button" @@click="open = !open" class="w-full flex items-center justify-between cursor-pointer py-3">
                <div class="section-hd mb-0">
                    <div class="section-hd-icon bg-sky-50 text-sky-500">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-slate-800">Dimensões e peso</h3>
                </div>
                <svg class="w-5 h-5 text-slate-400 transition-transform" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </button>
            <div x-show="open" x-transition class="mt-4">
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                    <div>
                        <label class="block text-xs text-slate-600 mb-1">Peso (kg)</label>
                        <input name="DimensoesPeso" type="number" step="0.001" min="0" value="@Model.DimensoesPeso"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                    <div>
                        <label class="block text-xs text-slate-600 mb-1">Largura (cm)</label>
                        <input name="DimensoesLargura" type="number" step="0.01" min="0" value="@Model.DimensoesLargura"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                    <div>
                        <label class="block text-xs text-slate-600 mb-1">Altura (cm)</label>
                        <input name="DimensoesAltura" type="number" step="0.01" min="0" value="@Model.DimensoesAltura"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                    <div>
                        <label class="block text-xs text-slate-600 mb-1">Comprimento (cm)</label>
                        <input name="DimensoesComprimento" type="number" step="0.01" min="0" value="@Model.DimensoesComprimento"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Variacoes -->
        <div class="ws">
            <div class="section-hd">
                <div class="section-hd-icon bg-amber-50 text-amber-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
                    </svg>
                </div>
                <h3 class="font-bold text-slate-800">Variações</h3>
                <span x-show="variacoes.length" class="text-xs text-slate-400 ml-auto" x-text="variacoes.length"></span>
            </div>
            <div class="space-y-3 mb-3">
                <template x-for="(v, i) in variacoes" :key="v._id || i">
                    <div class="border border-slate-200 rounded-lg p-3">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs font-semibold text-slate-500" x-text="'Variação ' + (i+1)"></span>
                            <button type="button" @@click="variacoes.splice(i, 1)"
                                    class="text-red-500 hover:text-red-700 text-xs font-semibold">Remover</button>
                        </div>
                        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                            <div>
                                <label :for="'var-nome-' + i" class="block text-xs text-slate-600 mb-1">Nome *</label>
                                <input type="text" :id="'var-nome-' + i" :name="'VariacoesRich[' + i + '].Nome'" x-model="v.nome" placeholder="Ex: P, M, G..."
                                       class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                            </div>
                            <div>
                                <label :for="'var-cor-' + i" class="block text-xs text-slate-600 mb-1">Cor</label>
                                <input type="text" :id="'var-cor-' + i" :name="'VariacoesRich[' + i + '].Cor'" x-model="v.cor" placeholder="Azul, Vermelho..."
                                       class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                            </div>
                            <div>
                                <label :for="'var-tam-' + i" class="block text-xs text-slate-600 mb-1">Tamanho</label>
                                <input type="text" :id="'var-tam-' + i" :name="'VariacoesRich[' + i + '].Tamanho'" x-model="v.tamanho" placeholder="P, M, G, 42..."
                                       class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                            </div>
                            <div>
