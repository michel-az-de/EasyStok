@model ProdutoFormViewModel
@{
    var isEdit = !string.IsNullOrEmpty(Model.Id);
}

<div class="flex items-center gap-3 mb-6">
    <a href="@(isEdit ? $"/produtos/{Model.Id}" : "/produtos")"
       class="text-slate-400 hover:text-slate-600 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <div class="pg-hd">
        <h1>@ViewBag.Title</h1>
        <p>@(isEdit ? "Atualize as informações do produto" : "Preencha os dados do novo produto")</p>
    </div>
</div>

@{
    var formAction = isEdit ? Url.Action("Atualizar", "Produtos", new { id = Model.Id }) : Url.Action("Criar", "Produtos");
}
<form action="@formAction" method="post" enctype="multipart/form-data"
      x-data="produtoForm()"
      class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    @Html.AntiForgeryToken()
    @if (isEdit)
    {
        <input type="hidden" asp-for="Id" />
    }

    <!-- Coluna principal -->
    <div class="lg:col-span-2 space-y-4">
        <div class="ws">
            <h3 class="font-bold text-slate-800 mb-4">Informações básicas</h3>

            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label asp-for="Nome" class="block text-sm font-semibold text-slate-700 mb-1.5">Nome *</label>
                    <input asp-for="Nome" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    <span asp-validation-for="Nome" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Sku" class="block text-sm font-semibold text-slate-700 mb-1.5">SKU *</label>
                    <input asp-for="Sku" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    <span asp-validation-for="Sku" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Emoji" class="block text-sm font-semibold text-slate-700 mb-1.5">Emoji</label>
                    <input asp-for="Emoji" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="📦" />
                </div>
                <div>
                    <label asp-for="Categoria" class="block text-sm font-semibold text-slate-700 mb-1.5">Categoria *</label>
                    <input asp-for="Categoria" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    <span asp-validation-for="Categoria" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Subcategoria" class="block text-sm font-semibold text-slate-700 mb-1.5">Subcategoria</label>
                    <input asp-for="Subcategoria" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                </div>
            </div>

            <div class="mt-4">
                <label asp-for="Descricao" class="block text-sm font-semibold text-slate-700 mb-1.5">Descrição</label>
                <textarea asp-for="Descricao" rows="3"
                          class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"></textarea>
            </div>
        </div>

        <div class="ws">
            <h3 class="font-bold text-slate-800 mb-4">Preços &amp; medidas</h3>
            <div class="grid grid-cols-3 gap-4">
                <div>
                    <label asp-for="Preco" class="block text-sm font-semibold text-slate-700 mb-1.5">Preço de venda *</label>
                    <input asp-for="Preco" type="number" step="0.01" min="0.01"
                           class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    <span asp-validation-for="Preco" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Custo" class="block text-sm font-semibold text-slate-700 mb-1.5">Custo</label>
                    <input asp-for="Custo" type="number" step="0.01" min="0"
                           class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                </div>
                <div>
                    <label asp-for="Peso" class="block text-sm font-semibold text-slate-700 mb-1.5">Peso (g)</label>
                    <input asp-for="Peso" type="number" min="0"
                           class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                </div>
            </div>
        </div>

        <!-- Variações -->
        <div class="ws">
            <h3 class="font-bold text-slate-800 mb-4">Variações</h3>
            <div class="space-y-2 mb-3">
                <template x-for="(v, i) in variacoes" :key="i">
                    <div class="flex items-center gap-2">
                        <input type="text" :name="'Variacoes[' + i + ']'" x-model="variacoes[i]"
                               placeholder="Nome da variação (ex: P, M, G, Azul...)"
                               class="flex-1 px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        <button type="button" @@click="variacoes.splice(i, 1)"
                                class="text-red-500 hover:text-red-700 p-1">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </template>
            </div>
            <button type="button" @@click="variacoes.push('')"
                    class="flex items-center gap-2 text-sm text-indigo-600 hover:text-indigo-800 font-semibold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Adicionar variação
            </button>
        </div>
    </div>

    <!-- Coluna lateral -->
    <div class="space-y-4">
        <div class="ws">
            <h3 class="font-bold text-slate-800 mb-4">Salvar produto</h3>
            <button type="submit"
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2.5 rounded-lg transition-colors text-sm mb-3">
                @(isEdit ? "Salvar alterações" : "Criar produto")
            </button>
            <a href="@(isEdit ? $"/produtos/{Model.Id}" : "/produtos")"
               class="w-full block text-center border border-slate-300 text-slate-700 font-semibold py-2.5 rounded-lg hover:bg-slate-50 transition-colors text-sm">
                Cancelar
            </a>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        function produtoForm() {
            return {
                variacoes: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Variacoes))
            };
        }
    </script>
}
