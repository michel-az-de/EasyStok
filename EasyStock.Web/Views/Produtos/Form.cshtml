                            <div>
                                <label :for="'var-desc-' + i" class="block text-xs text-slate-600 mb-1">Desc. comercial</label>
                                <input type="text" :id="'var-desc-' + i" :name="'VariacoesRich[' + i + '].DescricaoComercial'" x-model="v.descricaoComercial"
                                       class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                            </div>
                        </div>
                        <div class="mt-2">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="hidden" :name="'VariacoesRich[' + i + '].Ativa'" value="false" />
                                <input type="checkbox" :name="'VariacoesRich[' + i + '].Ativa'" :checked="v.ativa"
                                       @@change="v.ativa = $el.checked" value="true"
                                       class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-300" />
                                <span class="text-xs text-slate-600">Ativa</span>
                            </label>
                        </div>
                    </div>
                </template>
            </div>
            <button type="button" @@click="variacoes.push({_id:crypto.randomUUID(),nome:'',cor:'',tamanho:'',descricaoComercial:'',sku:'',codigoBarras:'',ativa:true})"
                    class="flex items-center gap-2 text-sm text-indigo-600 hover:text-indigo-800 font-semibold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                Adicionar variação
            </button>
        </div>

        <!-- Caracteristicas -->
        <div class="ws" x-data="{ open: @(Model.Caracteristicas.Any() ? "true" : "false") }">
            <button type="button" @@click="open = !open" class="w-full flex items-center justify-between cursor-pointer py-3">
                <div class="section-hd mb-0">
                    <div class="section-hd-icon bg-rose-50 text-rose-500">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-slate-800">Características</h3>
                    <span x-show="caracteristicas.length" class="text-xs text-slate-400 ml-2" x-text="caracteristicas.length"></span>
                </div>
                <svg class="w-5 h-5 text-slate-400 transition-transform" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </button>
            <div x-show="open" x-transition class="mt-4">
                <div class="space-y-3 mb-3">
                    <template x-for="(c, i) in caracteristicas" :key="c._id || i">
                        <div class="border border-slate-200 rounded-lg p-3">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-xs font-semibold text-slate-500" x-text="'Característica ' + (i+1)"></span>
                                <button type="button" @@click="caracteristicas.splice(i, 1)"
                                        class="text-red-500 hover:text-red-700 text-xs font-semibold">Remover</button>
                            </div>
                            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                                <div class="col-span-2">
                                    <label :for="'car-nome-' + i" class="block text-xs text-slate-600 mb-1">Nome *</label>
                                    <input type="text" :id="'car-nome-' + i" :name="'Caracteristicas[' + i + '].Nome'" x-model="c.nome" placeholder="Ex: Material, Voltagem..."
                                           class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                                </div>
                                <div>
                                    <label :for="'car-qtd-' + i" class="block text-xs text-slate-600 mb-1">Quantidade</label>
                                    <input type="number" :id="'car-qtd-' + i" :name="'Caracteristicas[' + i + '].QuantidadeReferencia'" x-model.number="c.quantidadeReferencia" min="0"
                                           class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                                </div>
                                <div>
                                    <label :for="'car-var-' + i" class="block text-xs text-slate-600 mb-1">Variação</label>
                                    <input type="text" :id="'car-var-' + i" :name="'Caracteristicas[' + i + '].VariacaoPadrao'" x-model="c.variacaoPadrao"
                                           class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                                </div>
                                <div class="col-span-2 sm:col-span-4">
                                    <label :for="'car-desc-' + i" class="block text-xs text-slate-600 mb-1">Descrição</label>
                                    <input type="text" :id="'car-desc-' + i" :name="'Caracteristicas[' + i + '].Descricao'" x-model="c.descricao"
                                           class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                                </div>
                            </div>
                            <input type="hidden" :name="'Caracteristicas[' + i + '].OrdemExibicao'" :value="i" />
                        </div>
                    </template>
                </div>
                <button type="button" @@click="caracteristicas.push({_id:crypto.randomUUID(),nome:'',descricao:'',quantidadeReferencia:null,variacaoPadrao:'',ordemExibicao:0})"
                        class="flex items-center gap-2 text-sm text-indigo-600 hover:text-indigo-800 font-semibold">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                    Adicionar característica
                </button>
            </div>
        </div>

        <!-- Embalagens -->
        <div class="ws" x-data="{ open: @(Model.Embalagens.Any() ? "true" : "false") }">
            <button type="button" @@click="open = !open" class="w-full flex items-center justify-between cursor-pointer py-3">
                <div class="section-hd mb-0">
                    <div class="section-hd-icon bg-teal-50 text-teal-500">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-slate-800">Embalagens</h3>
                    <span x-show="embalagens.length" class="text-xs text-slate-400 ml-2" x-text="embalagens.length"></span>
                </div>
                <svg class="w-5 h-5 text-slate-400 transition-transform" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </button>
            <div x-show="open" x-transition class="mt-4">
                <div class="space-y-3 mb-3">
                    <template x-for="(e, i) in embalagens" :key="e._id || i">
                        <div class="border border-slate-200 rounded-lg p-3">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-xs font-semibold text-slate-500" x-text="'Embalagem ' + (i+1)"></span>
                                <button type="button" @@click="embalagens.splice(i, 1)"
                                        class="text-red-500 hover:text-red-700 text-xs font-semibold">Remover</button>
                            </div>
                            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                                <div class="col-span-2">
                                    <label class="block text-xs text-slate-600 mb-1">Nome *</label>
                                    <input type="text" :name="'Embalagens[' + i + '].Nome'" x-model="e.nome" placeholder="Ex: Caixa individual..."
                                           class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                                </div>
                                <div>
                                    <label class="flex items-center gap-2 cursor-pointer mt-5">
                                        <input type="hidden" :name="'Embalagens[' + i + '].Padrao'" value="false" />
                                        <input type="checkbox" :name="'Embalagens[' + i + '].Padrao'" x-model="e.padrao" value="true"
                                               class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-300" />
                                        <span class="text-xs text-slate-600">Padrao</span>
                                    </label>
                                </div>
                                <div class="col-span-2 sm:col-span-3">
                                    <label class="block text-xs text-slate-600 mb-1">Descrição</label>
                                    <input type="text" :name="'Embalagens[' + i + '].Descricao'" x-model="e.descricao"
                                           class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                                </div>
                            </div>
                            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-3">
                                <div>
                                    <label class="block text-xs text-slate-600 mb-1">Peso (kg)</label>
                                    <input type="number" :name="'Embalagens[' + i + '].Peso'" x-model.number="e.peso" step="0.001" min="0"
                                           class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                                </div>
                                <div>
                                    <label class="block text-xs text-slate-600 mb-1">Largura (cm)</label>
                                    <input type="number" :name="'Embalagens[' + i + '].Largura'" x-model.number="e.largura" step="0.01" min="0"
                                           class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                                </div>
                                <div>
                                    <label class="block text-xs text-slate-600 mb-1">Altura (cm)</label>
                                    <input type="number" :name="'Embalagens[' + i + '].Altura'" x-model.number="e.altura" step="0.01" min="0"
                                           class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                                </div>
                                <div>
                                    <label class="block text-xs text-slate-600 mb-1">Comprimento (cm)</label>
                                    <input type="number" :name="'Embalagens[' + i + '].Comprimento'" x-model.number="e.comprimento" step="0.01" min="0"
                                           class="w-full px-2.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                                </div>
                            </div>
                        </div>
                    </template>
                </div>
                <button type="button" @@click="embalagens.push({_id:crypto.randomUUID(),nome:'',descricao:'',peso:null,largura:null,altura:null,comprimento:null,padrao:false})"
                        class="flex items-center gap-2 text-sm text-indigo-600 hover:text-indigo-800 font-semibold">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                    Adicionar embalagem
                </button>
            </div>
        </div>

        <!-- Nav Step 3 -->
        <div class="flex items-center justify-between mt-4 gap-2 flex-wrap">
            <div class="flex items-center gap-2">
                <button type="button" @@click="prevStep()"
                        class="px-5 py-2.5 border border-slate-300 text-slate-600 text-sm font-semibold rounded-lg hover:bg-slate-50 transition-colors">
                    &larr; Voltar
                </button>
                @if (!isEdit)
                {
                    <button type="button" @@click="salvarRascunho()"
                            class="px-4 py-2.5 border border-slate-300 text-slate-500 text-xs font-semibold rounded-lg hover:bg-slate-50 transition-colors flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                        </svg>
                        Rascunho
                    </button>
                }
            </div>
            <span class="text-xs text-slate-400 font-semibold hidden sm:block">Etapa 3 de 4</span>
            <button type="button" @@click="nextStep()"
                    class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-lg shadow-indigo-500/25">
                Revisar &rarr;
            </button>
            <button x-show="isEdit" x-cloak type="submit" :disabled="saving"
                    class="px-6 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-lg shadow-emerald-500/25 disabled:opacity-50 flex items-center gap-2">
                <template x-if="!saving"><span>Salvar alterações</span></template>
                <template x-if="saving"><span class="inline-flex items-center gap-2"><span class="spinner"></span> Salvando...</span></template>
            </button>
        </div>
    </div>

    <!-- ══════════════ STEP 4: REVISAO E-COMMERCE ══════════════ -->
    <div x-show="step === 4" x-transition:enter.duration.200ms>

        <!-- Banner CTA: sem foto -->
        <div x-show="totalPhotoCount === 0" x-cloak
             class="mb-4 flex items-center gap-3 bg-amber-50 border border-amber-200 rounded-xl px-4 py-3">
            <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-amber-800">Produto sem foto</p>
                <p class="text-xs text-amber-700">Produtos com foto têm muito mais chances de venda.</p>
            </div>
            <button type="button" @@click="step = 2"
                    class="flex-shrink-0 text-xs font-semibold text-amber-800 bg-amber-100 hover:bg-amber-200 px-3 py-2 rounded-lg transition-colors whitespace-nowrap">
                Adicionar foto →
            </button>
        </div>

        <!-- Product Card — layout e-commerce -->
        <div class="product-review-card bg-white rounded-2xl shadow-lg shadow-slate-200/60 overflow-hidden border border-slate-100">
            <div class="product-review-card__grid grid grid-cols-1 sm:grid-cols-[280px_1fr]">

                <!-- Foto principal (navegável) -->
                <div class="product-review-card__media relative bg-gradient-to-br from-slate-50 via-white to-indigo-50/30 flex items-center justify-center sm:min-h-[280px] min-h-[200px] overflow-hidden group cursor-pointer"
                     @@click="reviewLightbox = totalPhotoCount > 0">
                    <template x-if="totalPhotoCount > 0">
                        <img :src="reviewPhotoIdx < existingPhotos.length ? existingPhotos[reviewPhotoIdx].url : previews[reviewPhotoIdx - existingPhotos.length]"
                             class="w-full h-full object-cover object-top transition-transform duration-300 group-hover:scale-105" />
                    </template>
                    <div x-show="totalPhotoCount === 0" class="text-center p-6">
                        <svg class="w-12 h-12 mx-auto text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                        <p class="text-xs text-slate-300 mt-2">Sem foto</p>
                    </div>
                    <div x-show="totalPhotoCount > 1" x-cloak
                         class="absolute bottom-2 right-2 bg-black/60 backdrop-blur text-white text-[10px] font-semibold px-2 py-0.5 rounded-full"
                         x-text="(reviewPhotoIdx + 1) + '/' + totalPhotoCount"></div>
                </div>

                <!-- Info panel -->
                <div class="product-review-card__body p-5 sm:p-6 flex flex-col">
                    <!-- Tags -->
                    <div class="product-review-card__chips flex flex-wrap items-center gap-1.5 mb-2">
                        <span x-show="categoriaNome" x-cloak class="text-[11px] bg-indigo-50 text-indigo-600 px-2 py-0.5 rounded-full font-semibold" x-text="categoriaNome"></span>
                        <span x-show="marca" x-cloak class="text-[11px] bg-slate-100 text-slate-500 px-2 py-0.5 rounded-full" x-text="marca"></span>
                        <span class="text-[11px] bg-slate-50 text-slate-400 px-2 py-0.5 rounded-full"
                              x-text="tipo === 0 ? 'Físico' : tipo === 1 ? 'Alimento' : 'Serviço'"></span>
                    </div>

                    <!-- Nome -->
                    <h2 class="product-review-card__title text-xl sm:text-2xl font-extrabold text-slate-900 leading-tight" x-text="nome || 'Nome do produto'"></h2>

                    <!-- SKU -->
                    <div x-show="sku" x-cloak class="product-review-card__sku mt-1">
                        <span class="text-xs font-mono text-slate-400">SKU: </span>
                        <span class="text-xs font-mono text-slate-500 font-medium" x-text="sku"></span>
                    </div>

                    <!-- Descricao curta -->
                    <p class="text-sm text-slate-500 mt-3 line-clamp-2 flex-grow" x-text="descricao || 'Sem descrição'" :class="{ 'italic text-slate-300': !descricao }"></p>

                    <!-- Preco destaque -->
                    <div class="product-review-card__pricing mt-4 pt-4 border-t border-slate-100">
                        <div class="flex items-end gap-3 flex-wrap">
                            <span class="text-3xl font-black text-slate-900 tracking-tight"
                                  x-text="preco > 0 ? 'R$ ' + preco.toFixed(2).replace('.', ',') : 'Preço não definido'"
                                  :class="{ 'text-lg text-slate-300': preco <= 0 }"></span>
                            <span x-show="margemDerivada !== 0 && preco > 0" x-cloak
                                  :class="margemDerivada < 0 ? 'bg-red-100 text-red-700 ring-red-200' : margemDerivada < 10 ? 'bg-red-50 text-red-600 ring-red-100' : margemDerivada < 30 ? 'bg-amber-50 text-amber-600 ring-amber-100' : 'bg-emerald-50 text-emerald-600 ring-emerald-100'"
                                  class="text-xs font-bold px-2.5 py-1 rounded-full ring-1 mb-1"
                                  x-text="(margemDerivada < 0 ? '⚠ ' : '') + margemDerivada.toFixed(1).replace('.', ',') + '% margem'"></span>
                        </div>
                        <div x-show="custo > 0" x-cloak class="text-xs text-slate-400 mt-1" x-text="'Custo unitário: R$ ' + custo.toFixed(2).replace('.', ',')"></div>
                    </div>
                </div>
            </div>

            <!-- Thumbnails strip -->
            <div x-show="totalPhotoCount > 1" class="px-5 py-2 flex gap-2 overflow-x-auto border-t border-slate-100 bg-slate-50/30">
                <template x-for="(foto, idx) in existingPhotos" :key="'rt-ex-' + idx">
                    <img :src="foto.url" @@click.stop="reviewPhotoIdx = idx"
                         class="w-12 h-12 rounded-lg object-cover flex-shrink-0 border-2 cursor-pointer transition-all"
                         :class="reviewPhotoIdx === idx ? 'border-indigo-500 ring-2 ring-indigo-200' : 'border-slate-200 opacity-60 hover:opacity-100'" />
                </template>
                <template x-for="(url, idx) in previews" :key="'rt-nw-' + idx">
                    <img :src="url" @@click.stop="reviewPhotoIdx = existingPhotos.length + idx"
                         class="w-12 h-12 rounded-lg object-cover flex-shrink-0 border-2 cursor-pointer transition-all"
                         :class="reviewPhotoIdx === (existingPhotos.length + idx) ? 'border-indigo-500 ring-2 ring-indigo-200' : 'border-slate-200 opacity-60 hover:opacity-100'" />
                </template>
            </div>

            <!-- Details row -->
            <div class="product-review-card__meta border-t border-slate-100 px-5 sm:px-6 py-3 flex flex-wrap gap-4 text-xs text-slate-500 bg-slate-50/50">
                <div x-show="variacoes.filter(v => v.nome).length > 0" x-cloak class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                    <span x-text="variacoes.filter(v => v.nome).length + ' variação(ões)'"></span>
                </div>
                <div x-show="caracteristicas.filter(c => c.nome).length > 0" x-cloak class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-rose-400"></span>
                    <span x-text="caracteristicas.filter(c => c.nome).length + ' característica(s)'"></span>
                </div>
                <div x-show="embalagens.filter(e => e.nome).length > 0" x-cloak class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-teal-400"></span>
                    <span x-text="embalagens.filter(e => e.nome).length + ' embalagem(ns)'"></span>
                </div>
                <div x-show="controlaValidade" x-cloak class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-sky-400"></span>
                    <span>Controla validade</span>
                </div>
            </div>
        </div>

        <!-- Completion + Quick edit -->
        <div class="product-review-footer mt-4 bg-white rounded-xl border border-slate-100 p-4 flex flex-col sm:flex-row sm:items-center gap-4">
            <div class="flex-1">
                <div class="flex items-center gap-3 mb-1.5">
                    <div class="flex-1 bg-slate-100 rounded-full h-2 overflow-hidden">
                        <div class="h-2 rounded-full transition-all duration-500"
                             :class="completionPercent === 100 ? 'bg-emerald-500' : 'bg-indigo-500'"
                             :style="'width: ' + completionPercent + '%'"></div>
                    </div>
                    <span class="text-sm font-bold tabular-nums" :class="completionPercent === 100 ? 'text-emerald-600' : 'text-slate-400'" x-text="completionPercent + '%'"></span>
                </div>
                <div class="flex flex-wrap gap-2">
                    <span class="text-[10px] font-medium" :class="nome ? 'text-emerald-500' : 'text-slate-300'"><span x-text="nome ? '✓' : '○'"></span> Nome</span>
                    <span class="text-[10px] font-medium" :class="categoriaId ? 'text-emerald-500' : 'text-slate-300'"><span x-text="categoriaId ? '✓' : '○'"></span> Categoria</span>
                    <span class="text-[10px] font-medium" :class="custo > 0 ? 'text-emerald-500' : 'text-slate-300'"><span x-text="custo > 0 ? '✓' : '○'"></span> Custo</span>
                    <span class="text-[10px] font-medium" :class="preco > 0 ? 'text-emerald-500' : 'text-slate-300'"><span x-text="preco > 0 ? '✓' : '○'"></span> Preço</span>
                    <span class="text-[10px] font-medium" :class="descricao ? 'text-emerald-500' : 'text-slate-300'"><span x-text="descricao ? '✓' : '○'"></span> Desc</span>
                    <span class="text-[10px] font-medium" :class="(_pondFileCount + existingPhotos.length) > 0 ? 'text-emerald-500' : 'text-slate-300'"><span x-text="(_pondFileCount + existingPhotos.length) > 0 ? '✓' : '○'"></span> Foto</span>
                </div>
            </div>
            <div class="flex gap-2 flex-shrink-0">
                <button type="button" @@click="step = 1" class="text-[11px] text-indigo-600 hover:bg-indigo-50 font-semibold px-2.5 py-1 rounded-lg transition-colors">Editar</button>
                <button type="button" @@click="step = 2" class="text-[11px] text-indigo-600 hover:bg-indigo-50 font-semibold px-2.5 py-1 rounded-lg transition-colors">Fotos</button>
                <button type="button" @@click="step = 3" class="text-[11px] text-indigo-600 hover:bg-indigo-50 font-semibold px-2.5 py-1 rounded-lg transition-colors">Detalhes</button>
            </div>
        </div>

        <!-- CTA -->
        <div class="flex flex-col-reverse sm:flex-row justify-between gap-3 mt-5">
            <button type="button" @@click="prevStep()"
                    class="px-5 py-3 border border-slate-300 text-slate-600 text-sm font-semibold rounded-xl hover:bg-slate-50 transition-colors text-center">
                &larr; Voltar
            </button>
            @if (isEdit)
            {
                <button type="button"
                        @@click="abrirModalConfirmacao()"
                        :disabled="saving"
                        :class="{ 'opacity-50 cursor-not-allowed': saving }"
                        class="flex-1 sm:flex-initial px-10 py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-indigo-500/25 hover:shadow-xl hover:shadow-indigo-500/30 text-center">
                    <span x-show="!saving">Salvar alterações</span>
                    <span x-show="saving" x-cloak class="inline-flex items-center gap-2"><span class="spinner"></span> Salvando...</span>
                </button>
            }
            else
            {
                <button type="button"
                        @@click="submitForm()"
                        :disabled="saving"
                        :class="{ 'opacity-50 cursor-not-allowed': saving }"
                        class="flex-1 sm:flex-initial px-10 py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-indigo-500/25 hover:shadow-xl hover:shadow-indigo-500/30 text-center">
                    <span x-show="!saving">Criar produto</span>
                    <span x-show="saving" x-cloak class="inline-flex items-center gap-2"><span class="spinner"></span> Salvando...</span>
                </button>
            }
        </div>
    </div>

    <!-- Lightbox (review step 4) -->
    <div x-show="reviewLightbox" x-cloak x-transition.opacity
         class="fixed inset-0 z-50 bg-black/90 flex items-center justify-center"
         @@click.self="reviewLightbox = false" @@keydown.escape.window="reviewLightbox = false">
        <button @@click="reviewLightbox = false" class="absolute top-4 right-4 text-white/70 hover:text-white z-10">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <button x-show="totalPhotoCount > 1" @@click="reviewPhotoIdx = (reviewPhotoIdx - 1 + totalPhotoCount) % totalPhotoCount"
                class="absolute left-4 text-white/70 hover:text-white z-10">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <img x-show="totalPhotoCount > 0"
             :src="reviewPhotoIdx < existingPhotos.length ? existingPhotos[reviewPhotoIdx].url : previews[reviewPhotoIdx - existingPhotos.length]"
             class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" />
        <button x-show="totalPhotoCount > 1" @@click="reviewPhotoIdx = (reviewPhotoIdx + 1) % totalPhotoCount"
                class="absolute right-4 text-white/70 hover:text-white z-10">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </button>
        <div x-show="totalPhotoCount > 1" class="absolute bottom-4 text-white/60 text-sm" x-text="(reviewPhotoIdx + 1) + ' / ' + totalPhotoCount"></div>
    </div>

    @if (isEdit)
    {
        <!-- Modal de confirmacao de edicao com motivo/observacao -->
        <div x-show="showConfirmModal" x-cloak x-transition.opacity
             class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
             @@click.self="showConfirmModal = false" @@keydown.escape.window="if(showConfirmModal) showConfirmModal = false">
            <div class="bg-white rounded-xl p-6 w-full max-w-md shadow-xl mx-4" @@click.stop>
                <div class="flex items-center gap-3 mb-5">
                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center">
                        <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-slate-900">Confirmar alterações</h3>
                        <p class="text-xs text-slate-400">Descreva o motivo da alteração antes de salvar.</p>
                    </div>
                </div>

                <!-- Motivo -->
                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Motivo da alteração</label>
                    <select x-model="motivo" class="ui-select w-full">
                        <option value="">Selecione um motivo</option>
                        <option value="Cadastro incorreto">Cadastro incorreto</option>
                        <option value="Descrição errada">Descrição errada</option>
                        <option value="Preço ajustado">Preço ajustado</option>
                        <option value="Correção de dados">Correção de dados</option>
                        <option value="Atualização de informações">Atualização de informações</option>
                        <option value="Outro">Outro</option>
                    </select>
                </div>

                <!-- Motivo customizado -->
                <div x-show="motivo === 'Outro'" x-cloak class="mb-4">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Especifique o motivo</label>
                    <input type="text" x-model="motivoOutro" maxlength="100"
                           class="ui-field w-full" placeholder="Descreva o motivo..." />
                </div>

                <!-- Observacao -->
                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Observação <span class="text-slate-400 font-normal">(opcional)</span></label>
                    <textarea x-model="observacao" maxlength="500" rows="2"
                              class="ui-field w-full resize-none" placeholder="Nota sobre esta alteração..."></textarea>
                    <p class="text-[10px] text-slate-400 mt-0.5 text-right" x-text="observacao.length + '/500'"></p>
                </div>

                <!-- Observacao Interna do produto -->
                <div class="mb-5">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Observação interna do produto <span class="text-slate-400 font-normal">(persistente)</span></label>
                    <textarea x-model="observacaoInterna" maxlength="1000" rows="2"
                              class="ui-field w-full resize-none" placeholder="Notas internas que ficam salvas no produto..."></textarea>
                    <p class="text-[10px] text-slate-400 mt-0.5 text-right" x-text="observacaoInterna.length + '/1000'"></p>
                </div>

                <div class="flex justify-end gap-3">
                    <button type="button" @@click="showConfirmModal = false"
                            class="px-4 py-2.5 text-sm font-medium text-slate-600 border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
                        Cancelar
                    </button>
                    <button type="button" @@click="confirmarESalvar()"
                            :disabled="saving"
                            class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-bold rounded-lg transition-colors shadow-lg shadow-indigo-500/25 disabled:opacity-50">
                        <span x-show="!saving">Confirmar e salvar</span>
                        <span x-show="saving" x-cloak class="inline-flex items-center gap-1.5"><span class="spinner"></span> Salvando...</span>
                    </button>
                </div>
            </div>
        </div>
    }
</form>

@section Styles {
    <link href="https://unpkg.com/filepond@@^4/dist/filepond.min.css" rel="stylesheet" />
    <link href="https://unpkg.com/filepond-plugin-image-preview@@^4/dist/filepond-plugin-image-preview.min.css" rel="stylesheet" />
}

@section Scripts {
    <script src="https://unpkg.com/filepond-plugin-image-exif-orientation@@^1/dist/filepond-plugin-image-exif-orientation.min.js"></script>
    <script src="https://unpkg.com/filepond-plugin-image-preview@@^4/dist/filepond-plugin-image-preview.min.js"></script>
    <script src="https://unpkg.com/filepond-plugin-file-validate-type@@^1/dist/filepond-plugin-file-validate-type.min.js"></script>
    <script src="https://unpkg.com/filepond-plugin-file-validate-size@@^2/dist/filepond-plugin-file-validate-size.min.js"></script>
    <script src="https://unpkg.com/filepond@@^4/dist/filepond.min.js"></script>
    <script>
        FilePond.registerPlugin(
            FilePondPluginImageExifOrientation,
            FilePondPluginImagePreview,
            FilePondPluginFileValidateType,
            FilePondPluginFileValidateSize
        );
    </script>
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@@3.11.6/dist/JsBarcode.all.min.js"></script>
    <script>
        function produtoForm() {
            const todasSubcats = @Html.Raw(subcatJson);
            const allCats = @Html.Raw(allCatsJson);
            const isEdit = @(isEdit ? "true" : "false");

            return {
                isEdit,
                productId: '@(Model.Id ?? "")',

                // ── Confirmacao de edicao ──
                showConfirmModal: false,
                motivo: '',
                motivoOutro: '',
                observacao: '',
                observacaoInterna: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ObservacaoInterna ?? "")),

                abrirModalConfirmacao() {
                    if (!this.nome) { this.step = 1; window.showToast('Informe o nome do produto.', 'warning'); return; }
                    if (!this.categoriaId) { this.step = 1; window.showToast('Selecione uma categoria.', 'warning'); return; }
                    if (this.skuStatus === 'indisponivel') {
                        this.step = 1;
                        window.showToast('SKU já em uso. Altere antes de continuar.', 'warning');
                        return;
                    }
                    if (this.skuStatus === 'verificando') { window.showToast('Aguarde a verificação do SKU.', 'info'); return; }
                    this.showConfirmModal = true;
                },
                confirmarESalvar() {
                    this.showConfirmModal = false;
                    if (this.motivo === 'Outro' && this.motivoOutro.trim()) {
                        this.motivo = this.motivoOutro.trim();
                    }
                    this.submitForm();
                },

                // ── Wizard ──
                step: isEdit ? (parseInt(new URLSearchParams(location.search).get('step') ?? '1') || 1) : 1,
                maxStepReached: isEdit ? 4 : 1,
                // Liga ao clicar Proximo sem preencher — destaca borda vermelha nos campos
                // que estao em falta. Antes so toast aparecia (mensageria silenciosa que o
                // auditor reportou nao perceber).
                step1AttemptedAdvance: false,

                nextStep() {
                    if (this.step === 1 && !this.step1Valid) {
                        this.step1AttemptedAdvance = true;
                        console.warn('[Produto] nextStep bloqueado em step 1: nome="' + (this.nome || '') + '" categoriaId="' + (this.categoriaId || '') + '"');
                        if (!this.nome) window.showToast('Informe o nome do produto.', 'warning');
                        else window.showToast('Selecione uma categoria.', 'warning');
                        return;
                    }
                    // SKU em verificacao assincrona: aguardar resposta antes de avancar.
                    // Antes esse estado era silencioso e o usuario via "tela travada" se clicasse rapido.
                    if (this.step === 1 && this.skuStatus === 'verificando') {
                        window.showToast('Aguarde a verificação do SKU...', 'info');
                        return;
                    }
                    if (this.step === 1 && this.skuStatus === 'indisponivel') {
                        window.showToast('SKU em uso. Altere antes de continuar.', 'warning');
                        return;
                    }
                    if (this.step < 4) {
                        this.step1AttemptedAdvance = false;
                        this.step++;
                        this.maxStepReached = Math.max(this.maxStepReached, this.step);
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    }
                },
                prevStep() { if (this.step > 1) { this.step--; window.scrollTo({ top: 0, behavior: 'smooth' }); } },
                goToStep(n) { if (n >= 1 && n <= 4 && n <= this.maxStepReached) { this.step = n; window.scrollTo({ top: 0, behavior: 'smooth' }); } },

                get step1Valid() { return !!this.nome && !!this.categoriaId; },

                // ── Submit (duas fases: produto primeiro, fotos depois via AJAX) ──
                saving: false,
                uploadPhase: false,
                uploadQueue: [],
                async submitForm() {
                    if (!this.nome) { this.step = 1; window.showToast('Informe o nome do produto.', 'warning'); return; }
                    if (this.nome.trim().length < 3) { this.step = 1; window.showToast('O nome deve ter pelo menos 3 caracteres.', 'warning'); return; }
                    if (!this.categoriaId) { this.step = 1; window.showToast('Selecione uma categoria.', 'warning'); return; }
                    // No modo edição, se o SKU não foi alterado, ignorar status "indisponivel"
                    if (isEdit && this.sku === this._originalSku && this.skuStatus === 'indisponivel') {
                        this.skuStatus = '';
                    }
                    if (this.skuStatus === 'indisponivel') {
                        this.step = 1;
                        if (isEdit) {
                            window.showToast('SKU já em uso por outro produto. Altere o SKU manualmente.', 'warning');
                        } else {
                            window.showToast('SKU já em uso — gerando um novo automaticamente…', 'warning');
                            await this.gerarSku(true);
                            if (this.skuStatus === 'indisponivel') {
                                window.showToast('Não foi possível gerar um SKU único. Edite o campo SKU manualmente.', 'warning');
                            } else {
                                window.showToast('Novo SKU gerado. Revise e clique em Criar produto novamente.', 'success');
                            }
                        }
                        return;
                    }
                    if (this.skuStatus === 'verificando') { window.showToast('Aguarde a verificação do SKU.', 'info'); return; }
                    if (this.saving) return;

                    // Captura referência ao componente Alpine fora de closures para garantir acesso
                    const self = this;
                    self.saving = true;
                    console.log('[EasyStock] submitForm iniciado, action=', this.$el?.action);
                    try { sessionStorage.removeItem(this._draftKey); } catch(e) {}

                    // Belt-and-suspenders: reseta após 20s independente do que aconteça
                    const savingGuard = setTimeout(() => {
                        console.warn('[EasyStock] savingGuard disparado — resetando saving');
                        self.saving = false;
                        window.showToast('O servidor não respondeu. Tente novamente.', 'error');
                    }, 20000);

                    const form = document.getElementById('produto-form');
                    if (!form) {
                        console.error('[EasyStock] form#produto-form não encontrado');
                        clearTimeout(savingGuard);
                        self.saving = false;
                        return;
                    }
                    const fd = new FormData(form);
                    // Remover campos de arquivo — FilePond pode ter adicionado inputs hidden
                    fd.delete('fotos');
                    for (const key of [...fd.keys()]) {
                        if (key.startsWith('filepond')) fd.delete(key);
                    }

                    // Campos de auditoria (somente edicao)
                    if (this.isEdit) {
                        fd.set('Motivo', this.motivo || '');
                        fd.set('Observacao', this.observacao || '');
                        fd.set('ObservacaoInterna', this.observacaoInterna || '');
                    }

                    const abortCtrl = new AbortController();
                    const abortTimeout = setTimeout(() => {
                        console.warn('[EasyStock] AbortController disparado após 20s');
                        abortCtrl.abort();
                    }, 20000);

                    try {
                        console.log('[EasyStock] fetch iniciando para', form.action);
                        // === FASE 1: Criar/Atualizar produto (sem fotos) ===
                        const r = await fetch(form.action, {
                            method: 'POST',
                            body: fd,
                            redirect: 'follow',
                            headers: { 'X-Fetch': '1' },
                            signal: abortCtrl.signal
                        });
                        clearTimeout(abortTimeout);
                        console.log('[EasyStock] fetch respondeu: status=', r.status, 'redirected=', r.redirected, 'url=', r.url);

                        // Se o controller fez redirect (sucesso), r.redirected === true
                        // Se retornou JSON de erro (400), r.redirected === false e Content-Type é application/json
                        if (!r.redirected) {
                            let msg = 'Erro ao salvar. Verifique os campos e tente novamente.';
                            try {
                                const ct = r.headers.get('Content-Type') ?? '';
                                console.log('[EasyStock] erro sem redirect, Content-Type=', ct, 'status=', r.status);
                                if (ct.includes('application/json')) {
                                    const data = await r.json();
                                    if (data?.erro) msg = data.erro;
                                }
                            } catch (e) { console.error('[EasyStock] parse error response', e); }
                            window.showToast(msg, 'error');
                            return;
                        }

                        // === Sucesso: extrair productId ===
                        // Em edição já temos o ID; em criação, extraímos da URL de redirect
                        const redirectUrl = r.url;
                        const match = redirectUrl.match(/\/produtos\/([0-9a-f\-]{36})/i);
                        const productId = this.productId || (match ? match[1] : null);
                        console.log('[EasyStock] sucesso, redirectUrl=', redirectUrl, 'productId=', productId);

                        // Toast client-side (TempData é consumido pelo fetch redirect)
                        try {
                            sessionStorage.setItem('easystok_toast', JSON.stringify({
                                msg: this.productId ? 'Produto atualizado com sucesso!' : 'Produto criado com sucesso!',
                                type: 'success'
                            }));
                        } catch(e) {}

                        // === FASE 2: Upload de fotos via AJAX ===
                        const pondFiles = this._pond ? this._pond.getFiles().map(f => f.file).filter(Boolean) : [];
                        if (productId && pondFiles.length > 0) {
                            await this._uploadPhotosAfterSave(productId, pondFiles);
                        }

                        window.location.href = redirectUrl || '/produtos';
                    } catch (e) {
                        clearTimeout(abortTimeout);
                        console.error('[EasyStock] submitForm catch:', e.name, e.message);
                        if (e.name === 'AbortError') {
                            window.showToast('O servidor demorou para responder. Tente novamente.', 'error');
                        } else {
                            window.showToast('Erro de conexão ao salvar.', 'error');
                        }
                    } finally {
                        clearTimeout(savingGuard);
                        self.saving = false;
                        console.log('[EasyStock] finally executado, saving=false');
                    }
                },
                async _uploadPhotosAfterSave(productId, files) {
                    // Token CSRF: tenta meta tag e fallback para hidden input do form
                    const token = document.querySelector('meta[name="csrf-token"]')?.content
                               || document.querySelector('[name=__RequestVerificationToken]')?.value
                               || '';
                    this.uploadPhase = true;
                    this.uploadQueue = files.map(f => ({ name: f.name, status: 'uploading', message: '' }));

                    let successCount = 0;
                    for (let i = 0; i < files.length; i++) {
                        const uploadCtrl = new AbortController();
                        const uploadTimeout = setTimeout(() => uploadCtrl.abort(), 15000);
                        try {
                            const fd = new FormData();
                            fd.append('foto', files[i]);
                            fd.append('__RequestVerificationToken', token);
                            const resp = await fetch('/produtos/' + productId + '/fotos/ajax', { method: 'POST', body: fd, signal: uploadCtrl.signal });
                            clearTimeout(uploadTimeout);
                            if (!resp.ok) throw new Error('Servidor retornou status ' + resp.status);
                            const data = await resp.json();
                            if (!data.ok) throw new Error(data.erro || 'Erro no servidor');
                            this.uploadQueue[i].status = 'done';
                            successCount++;
                        } catch (err) {
                            clearTimeout(uploadTimeout);
                            this.uploadQueue[i].status = 'error';
                            this.uploadQueue[i].message = err.name === 'AbortError' ? 'Upload demorou demais' : err.message;
                            console.error('[EasyStock] Upload foto falhou:', err);
                        }
                        this.uploadQueue = [...this.uploadQueue]; // forçar reatividade Alpine
                    }

                    // Pausa para o usuário ver o resultado
                    await new Promise(resolve => setTimeout(resolve, 1200));
                    this.uploadPhase = false;

                    if (successCount < files.length) {
                        window.showToast((files.length - successCount) + ' foto(s) falharam. Adicione-as na página do produto.', 'warning');
                    }
                },

                // ── Marca autocomplete ──
                marcaSugestoes: [],
                async buscarMarcas() {
                    try {
                        const r = await fetch('/produtos/marcas-sugestoes?q=' + encodeURIComponent(this.marca || ''));
                        if (r.ok) this.marcaSugestoes = (await r.json()).filter(m => m !== this.marca);
                        else this.marcaSugestoes = [];
                    } catch (e) { console.error('[EasyStock]', e); this.marcaSugestoes = []; }
                },
                selecionarMarca(m) { this.marca = m; this.marcaSugestoes = []; },

                // ── Barcode ──
                renderBarcode() {
                    if (!this.codigoBarras || this.codigoBarras.length < 4) return;
                    try {
                        JsBarcode('#product-barcode', this.codigoBarras, {
                            format: 'CODE128',
                            height: 40,
                            fontSize: 12,
                            margin: 4,
                            displayValue: true
                        });
                    } catch (e) { console.error('[EasyStock]', e); }
                },
                gerarCodigoBarras() {
                    const ts = Date.now().toString().slice(-12).padStart(12, '0');
                    const digits = ts.split('').map(Number);
                    let checksum = 0;
                    for (let i = 0; i < 12; i++) checksum += digits[i] * (i % 2 === 0 ? 1 : 3);
                    const check = (10 - (checksum % 10)) % 10;
                    this.codigoBarras = ts + check;
                    this.eanAviso = '';
                },
                _buildSkuCandidate() {
                    const base = this.nome || '';
                    const words = base.trim().toUpperCase().split(/\s+/).filter(w => w.length > 0);
                    const parts = words.slice(0, 3).map(w => w.substring(0, 3).replace(/[^A-Z0-9]/g, ''));
                    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
                    let rnd = '';
                    for (let i = 0; i < 4; i++) rnd += chars[Math.floor(Math.random() * chars.length)];
                    const prefix = parts.filter(Boolean).join('-');
                    return prefix ? prefix + '-' + rnd : rnd;
                },
                async gerarSku(silent = false) {
                    const MAX = 3;
                    for (let attempt = 1; attempt <= MAX; attempt++) {
                        this.sku = this._buildSkuCandidate();
                        this.skuStatus = '';
                        await this.checkSkuDisponivel();
                        if (this.skuStatus !== 'indisponivel') break;
                        if (attempt === MAX) {
                            if (!silent) window.showToast('Não foi possível gerar um SKU único automaticamente. Edite manualmente.', 'warning');
                        }
                    }
                },
                _skuAbort: null,
                async checkSkuDisponivel() {
                    const sku = (this.sku || '').trim();
                    if (!sku) { this.skuStatus = ''; return; }
                    // Cancela requisição anterior se ainda estiver em andamento
                    if (this._skuAbort) { this._skuAbort.abort(); }
                    this._skuAbort = new AbortController();
                    this.skuStatus = 'verificando';
                    try {
                        const params = new URLSearchParams({ sku });
                        if (isEdit) params.set('ignoreProdutoId', '@Model.Id');
                        const res = await fetch(`/produtos/check-sku?${params}`, { signal: this._skuAbort.signal });
                        if (!res.ok) { this.skuStatus = 'erro'; return; }
                        const data = await res.json();
                        if (data.disponivel === null || data.disponivel === undefined) {
                            this.skuStatus = 'erro';
                            window.showToast(data.error || 'Não foi possível verificar o SKU. Confirme manualmente antes de salvar.', 'warning');
                        } else {
                            this.skuStatus = data.disponivel ? 'disponivel' : 'indisponivel';
                        }
                    } catch (e) {
                        if (e.name !== 'AbortError') this.skuStatus = 'erro';
                    }
                },
                validarCodigoBarras() {
                    const code = (this.codigoBarras || '').trim();
                    if (!code || code.length !== 13 || !/^\d{13}$/.test(code)) {
                        this.eanAviso = code.length > 0 && code.length !== 13
                            ? `EAN-13 deve ter 13 dígitos (atual: ${code.length})`
                            : '';
                        return;
                    }
                    const digits = code.split('').map(Number);
                    const sum = digits.slice(0, 12).reduce((acc, d, i) => acc + d * (i % 2 === 0 ? 1 : 3), 0);
                    const expected = (10 - (sum % 10)) % 10;
                    this.eanAviso = digits[12] !== expected
                        ? 'Dígito verificador inválido — verifique o código.'
                        : '';
                },

                // ── Draft persistence (sessionStorage) ──
                _draftKey: 'easystock_produto_draft_' + (isEdit ? 'edit_' + '@(Model.Id ?? "")' : 'new'),
                _clickHandler: null,

                init() {
                    // Restaurar rascunho manualmente (apenas novos produtos)
                    if (!isEdit) {
                        try {
                            const raw = sessionStorage.getItem(this._draftKey);
                            if (raw) {
                                const d = JSON.parse(raw);
                                if (d.nome) {
                                    const self = this;
                                    window.easyConfirm({
                                        titulo: 'Restaurar rascunho?',
                                        mensagem: 'Existe um rascunho salvo de um produto que você não concluiu. Deseja restaurar os dados?',
                                        textoBotao: 'Restaurar',
                                        classBotao: 'bg-indigo-600 hover:bg-indigo-700'
                                    }, () => self._applyDraft(d));
                                } else {
                                    sessionStorage.removeItem(this._draftKey);
                                }
                            }
                        } catch (e) { console.error('[EasyStock]', e); }
                    }

                    this._clickHandler = (e) => {
                        if (!e.target.closest('.relative')?.querySelector('input[name="Marca"]')) this.marcaSugestoes = [];
                    };
                    document.addEventListener('click', this._clickHandler);

                    // Auto-gerar SKU ao digitar nome (apenas novos produtos com SKU ainda vazio)
                    if (!isEdit) {
                        this.$watch('nome', (val) => {
                            if (!this.sku && val && val.length >= 3) {
                                clearTimeout(this._skuDebounce);
                                this._skuDebounce = setTimeout(() => {
                                    if (!this.sku) this.gerarSku(true);
                                }, 600);
                            }
                        });
                    }

                    // Auto-aplicar tipo "Alimento" quando categoria sugere
                    this.$watch('categoriaId', () => {
                        if (!this._tipoManuallySet && this.tipoSugerido !== null) {
                            this.tipo = this.tipoSugerido;
                            this.controlaValidade = (this.tipoSugerido === 1);
                        }
                    });

                    // Inicializar FilePond (guard contra dupla inicialização)
                    this.$nextTick(() => {
                        if (this._pond) return;
                        const maxNew = 5 - this.existingPhotos.length;
                        const self = this;
                        this._pond = FilePond.create(this.$refs.pondInput, {
                            allowMultiple: true,
                            maxFiles: maxNew,
                            acceptedFileTypes: ['image/jpeg', 'image/png', 'image/webp'],
                            maxFileSize: '10MB',
                            maxParallelUploads: 1,
                            imagePreviewHeight: 100,
                            imagePreviewMaxHeight: 120,
                            itemInsertLocation: 'after',
                            allowDrop: true,
                            allowBrowse: true,
                            allowPaste: false,
                            dropOnPage: false,
                            dropOnElement: true,
                            labelIdle: '<div style="padding:20px;text-align:center;touch-action:manipulation">'
                                + '<div style="font-size:32px;margin-bottom:8px">&#128247;</div>'
                                + '<div style="font-size:15px;font-weight:700;color:var(--text-primary)">Adicionar fotos</div>'
                                + '<div style="font-size:13px;color:var(--text-muted);margin-top:4px">Toque aqui ou <span class="filepond--label-action">selecione do dispositivo</span></div>'
                                + '</div>',
                            labelMaxFileSizeExceeded: 'Arquivo muito grande',
                            labelMaxFileSize: 'Maximo: {filesize}',
                            labelFileTypeNotAllowed: 'Tipo nao permitido',
                            fileValidateTypeLabelExpectedTypes: 'JPEG, PNG ou WebP',
                            labelFileProcessingComplete: 'Pronta',
                            labelTapToCancel: 'Toque para cancelar',
                            labelTapToRetry: 'Toque para tentar novamente',
                            labelTapToUndo: 'Toque para desfazer',
                            labelButtonRemoveItem: 'Remover',
                            credits: false,
                        });
                        const updatePondState = () => {
                            const files = self._pond.getFiles();
                            self._pondFileCount = files.length;
                            // Gerar previews locais para a step 4 (revisão)
                            self.previews.forEach(u => { try { URL.revokeObjectURL(u); } catch (e) { console.error('[EasyStock]', e); } });
                            self.previews = [];
                            files.forEach(f => {
                                if (f.file && f.file.type?.startsWith('image/')) {
                                    const url = URL.createObjectURL(f.file);
                                    self.previews.push(url);
                                }
                            });
                        };
                        this._pond.on('addfile', updatePondState);
                        this._pond.on('removefile', updatePondState);
                    });
                },
                destroy() {
                    if (this._pond) { this._pond.destroy(); this._pond = null; }
                    if (this._clickHandler) { document.removeEventListener('click', this._clickHandler); this._clickHandler = null; }
                    if (this._skuAbort) { this._skuAbort.abort(); this._skuAbort = null; }
                    this.previews.forEach(u => { try { URL.revokeObjectURL(u); } catch {} });
                },
                salvarRascunho() {
                    try {
                        sessionStorage.setItem(this._draftKey, JSON.stringify({
                            nome: this.nome, sku: this.sku, _originalSku: this._originalSku, marca: this.marca,
                            codigoBarras: this.codigoBarras,
                            descricao: this.descricao, categoriaId: this.categoriaId,
                            subcategoriaId: this.subcategoriaId, tipo: this.tipo,
                            preco: this.preco, custo: this.custo, margem: this.margem,
                            controlaValidade: this.controlaValidade, step: this.step,
                            maxStepReached: this.maxStepReached,
                            variacoes: this.variacoes, caracteristicas: this.caracteristicas,
                            embalagens: this.embalagens, savedAt: Date.now()
                        }));
                        window.showToast('Rascunho salvo!', 'success', 2000);
                    } catch (e) {
                        console.error('[EasyStock]', e);
                        window.showToast('Erro ao salvar rascunho.', 'error');
                    }
                },
                _applyDraft(d) {
                    if (d.nome) this.nome = d.nome;
                    if (d.sku) this.sku = d.sku;
                    if (d.marca) this.marca = d.marca;
                    if (d.codigoBarras) this.codigoBarras = d.codigoBarras;
                    if (d.descricao) this.descricao = d.descricao;
                    if (d.categoriaId) this.categoriaId = d.categoriaId;
                    if (d.subcategoriaId) this.subcategoriaId = d.subcategoriaId;
                    if (d.tipo !== undefined) this.tipo = d.tipo;
                    if (d.preco > 0) this.preco = d.preco;
                    if (d.custo > 0) this.custo = d.custo;
                    if (d.margem > 0) this.margem = d.margem;
                    if (d.controlaValidade) this.controlaValidade = d.controlaValidade;
                    if (d.step > 1) { this.step = d.step; this.maxStepReached = d.maxStepReached || d.step; }
                    if (d.variacoes?.length) this.variacoes = d.variacoes;
                    if (d.caracteristicas?.length) this.caracteristicas = d.caracteristicas;
                    if (d.embalagens?.length) this.embalagens = d.embalagens;
                    window.showToast('Rascunho restaurado.', 'info', 2000);
                },

                // ── Auto-fill ──
                autoFilling: false,
                confirmarAutoFill() {
                    if (!this.nome || !this.nome.trim()) {
                        window.showToast('Informe o nome do produto antes de preencher automaticamente.', 'error', 3000);
                        const inputNome = document.querySelector('input[name="Nome"]');
                        if (inputNome) inputNome.focus();
                        return;
                    }
                    const temDados = this.descricao || this.sku;
                    if (temDados) {
                        const self = this;
                        window.easyConfirm({
                            titulo: 'Preencher automaticamente?',
                            mensagem: 'O SKU será gerado e a descrição será reescrita com IA. Campos já preenchidos podem ser alterados. Deseja continuar?',
                            textoBotao: 'Preencher',
                            classBotao: 'bg-indigo-600 hover:bg-indigo-700'
                        }, () => self.autoFill());
                        return;
                    }
                    this.autoFill();
                },
                async autoFill() {
                    if (!this.nome) return;
                    let changed = [];

                    // Auto-gera SKU a partir do nome se estiver vazio
                    if (!this.sku) {
                        const words = this.nome.trim().toUpperCase().split(/\s+/).filter(w => w.length > 0);
                        const parts = words.slice(0, 3).map(w => w.substring(0, 3).replace(/[^A-Z0-9]/g, ''));
                        const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
                        let rnd = '';
                        for (let i = 0; i < 6; i++) rnd += chars[Math.floor(Math.random() * chars.length)];
                        this.sku = parts.filter(Boolean).join('-') + (parts.filter(Boolean).length ? '-' + rnd : rnd);
                        changed.push('SKU');
                    }

                    // Geração de descrição
                    if (this.productId) {
                        // Modo edição: usa endpoint existente com productId
                        if (!this.descricao) {
                            await this.generateDescription();
                            changed.push('Descrição');
                        }
                    } else if (!this.descricao) {
                        // Novo produto: chama /anuncios/completar-produto via SSE
                        changed.push('Descrição');
                        this.autoFilling = true;
                        window.showToast('Gerando descrição com IA...', 'info', 2000);
                        try {
                            const categoriaEl = document.querySelector('select[name="CategoriaId"]');
                            const categoriaNome = categoriaEl
                                ? (categoriaEl.options?.[categoriaEl.selectedIndex]?.text ?? '')
                                : '';
                            const params = new URLSearchParams({
                                nome: this.nome,
                                categoria: categoriaNome,
                                marca: this.marca ?? '',
                                instrucoes: ''
                            });
                            const resp = await fetch(`/anuncios/completar-produto?${params}`);
                            if (!resp.ok || !resp.body) throw new Error('Falha ao conectar com a IA.');
                            const reader = resp.body.getReader();
                            const decoder = new TextDecoder();
                            let buffer = '';
                            this.descricao = '';
                            while (true) {
                                const { value, done } = await reader.read();
                                if (done) break;
                                buffer += decoder.decode(value, { stream: true });
                                const lines = buffer.split('\n');
                                buffer = lines.pop() ?? '';
                                for (const line of lines) {
                                    if (!line.startsWith('data: ')) continue;
                                    const raw = line.slice(6).trim();
                                    if (raw === '[DONE]') break;
                                    try {
                                        const obj = JSON.parse(raw);
                                        if (obj.texto) this.descricao += obj.texto;
                                    } catch (e) { console.error('[EasyStock]', e); }
                                }
                            }
                        } catch (e) {
                            window.showToast('Erro ao gerar descrição: ' + e.message, 'error', 3000);
                            changed = changed.filter(c => c !== 'Descrição');
                        } finally {
                            this.autoFilling = false;
                        }
                    }

                    if (changed.length > 0 && !this.autoFilling) {
                        window.showToast('Preenchido: ' + changed.join(', '), 'success', 2500);
                    } else if (changed.length === 0) {
                        window.showToast('Campos já preenchidos. Nada alterado.', 'info', 2000);
                    }
                },

                // ── Fields ──
                nome: @Html.Raw(JsonSerializer.Serialize(Model.Nome ?? "")),
                descricao: @Html.Raw(JsonSerializer.Serialize(Model.DescricaoBase ?? "")),
