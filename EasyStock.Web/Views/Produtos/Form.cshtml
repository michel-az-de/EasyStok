@model ProdutoFormViewModel
@using EasyStock.Web.Models.Api
@using System.Text.Json
@{
    var isEdit = !string.IsNullOrEmpty(Model.Id);
    var categorias = ViewBag.Categorias as List<CategoriaApi> ?? [];
    var roots = categorias.Where(c => c.CategoriaPaiId == null).ToList();
    var children = categorias.Where(c => c.CategoriaPaiId != null).ToLookup(c => c.CategoriaPaiId);
    var subcatJson = JsonSerializer.Serialize(categorias.Where(c => c.CategoriaPaiId != null).Select(c => new { id = c.Id, nome = c.Nome, categoriaPaiId = c.CategoriaPaiId }));
    var allCatsJson = JsonSerializer.Serialize(categorias.Select(c => new { id = c.Id, nome = c.Nome }));
    var existingPhotosJson = JsonSerializer.Serialize(Model.ExistingPhotos.Select(f => new { fotoId = f.FotoId, url = f.Url }));
    var formAction = isEdit ? Url.Action("Atualizar", "Produtos", new { id = Model.Id }) : Url.Action("Criar", "Produtos");
    var stepNames = new[] { "Essencial", "Fotos e Precos", "Detalhes", "Revisao" };
}

<div class="flex items-center gap-3 mb-6">
    <a href="@(isEdit ? $"/produtos/{Model.Id}" : "/produtos")"
       class="text-slate-400 hover:text-slate-600 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <div class="pg-hd">
        <h1>@ViewBag.Title</h1>
        <p>@(isEdit ? "Atualize as informacoes do produto" : "Cadastre um novo produto em poucos passos")</p>
    </div>
</div>

<form action="@formAction" method="post" enctype="multipart/form-data" novalidate
      x-data="produtoForm()"
      @@submit.prevent="submitForm()"
      class="max-w-3xl">
    @Html.AntiForgeryToken()
    @if (isEdit)
    {
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="Status" value="@Model.Status" />
    }

    <!-- ══════════════ STEPPER BAR ══════════════ -->
    <div class="ws mb-6">
        <div class="flex items-center">
            @for (int i = 0; i < stepNames.Length; i++)
            {
                var sn = i + 1;
                var last = i == stepNames.Length - 1;
                <div class="flex items-center @(last ? "" : "flex-1")">
                    <div class="step-circle cursor-pointer" :class="step > @sn ? 'done' : step === @sn ? 'active' : ''"
                         @@click="goToStep(@sn)">@sn</div>
                    <div class="ml-2 hidden sm:block">
                        <div class="text-xs font-semibold cursor-pointer" :class="step === @sn ? 'text-indigo-600' : 'text-slate-400'"
                             @@click="goToStep(@sn)">@stepNames[i]</div>
                    </div>
                    @if (!last)
                    {
                        <div class="flex-1 mx-3 h-0.5" :class="step > @sn ? 'bg-indigo-500' : 'bg-slate-200'"></div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ══════════════ STEP 1: ESSENCIAL ══════════════ -->
    <div x-show="step === 1" x-transition:enter.duration.200ms>
        <div class="ws">
            <div class="section-hd">
                <div class="section-hd-icon bg-indigo-50 text-indigo-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                </div>
                <h3 class="font-bold text-slate-800">Informacoes do produto</h3>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="sm:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Nome do produto *</label>
                    <input name="Nome" x-model="nome"
                           placeholder="Ex: Camiseta Basica Masculina Algodao"
                           class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    <span asp-validation-for="Nome" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Categoria *</label>
                    @if (roots.Any())
                    {
                        <select name="CategoriaId" x-model="categoriaId"
                                @@change="subcategoriaId = ''"
                                class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
                            <option value="">Selecione...</option>
                            @foreach (var cat in roots)
                            {
                                <option value="@cat.Id.ToString().ToLower()">@cat.Nome</option>
                                @foreach (var sub in children[cat.Id])
                                {
                                    <option value="@sub.Id.ToString().ToLower()">&nbsp;&nbsp;-- @sub.Nome</option>
                                }
                            }
                        </select>
                    }
                    else
                    {
                        <input name="CategoriaId" x-model="categoriaId" placeholder="ID da categoria"
                               class="w-full px-3 py-2.5 border border-amber-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    }
                    <span asp-validation-for="CategoriaId" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div x-show="subcategorias.length > 0" x-transition>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Subcategoria</label>
                    <select name="SubcategoriaId" x-model="subcategoriaId"
                            class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
                        <option value="">Nenhuma</option>
                        <template x-for="sub in subcategorias" :key="sub.id">
                            <option :value="sub.id" x-text="sub.nome"></option>
                        </template>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">SKU</label>
                    <input name="SkuBase" x-model="sku" placeholder="Ex: CAM-BAS-001"
                           class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    @if (ViewData.ModelState["SkuBase"]?.Errors.Count > 0)
                    {
                        <p class="text-xs text-red-500 mt-1">@ViewData.ModelState["SkuBase"]!.Errors[0].ErrorMessage</p>
                    }
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Codigo de barras</label>
                    <input name="CodigoBarras" x-model="codigoBarras" placeholder="EAN-13"
                           class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Marca</label>
                    <input name="Marca" x-model="marca" placeholder="Ex: Nike, Samsung..."
                           class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Tipo</label>
                    <select name="Tipo" x-model.number="tipo"
                            class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
                        @if (Model.Tipo == 0) { <option value="0" selected>Fisico</option> } else { <option value="0">Fisico</option> }
                        @if (Model.Tipo == 1) { <option value="1" selected>Alimento</option> } else { <option value="1">Alimento</option> }
                        @if (Model.Tipo == 2) { <option value="2" selected>Servico</option> } else { <option value="2">Servico</option> }
                    </select>
                </div>
                <div class="sm:col-span-2">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="hidden" name="ControlaValidade" value="false" />
                        <input name="ControlaValidade" type="checkbox" value="true" @(Model.ControlaValidade ? "checked" : "")
                               @@change="controlaValidade = $el.checked"
                               class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-300" />
                        <span class="text-sm text-slate-700">Controla validade</span>
                    </label>
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Descricao</label>
                    <textarea name="DescricaoBase" x-model="descricao" rows="3"
                              placeholder="Descreva o produto em poucas palavras..."
                              class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"></textarea>
                    <div class="flex items-center gap-3 mt-1.5">
                        <button type="button" :disabled="aiGenerating || !nome || !productId"
                                @@click="generateDescription()"
                                :title="!productId ? 'Disponível após salvar o produto' : ''"
                                class="inline-flex items-center gap-1.5 text-xs text-indigo-600 hover:text-indigo-800 font-semibold disabled:opacity-40 disabled:cursor-not-allowed">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                            </svg>
                            <span x-show="!aiGenerating">Gerar com IA</span>
                            <span x-show="aiGenerating" x-cloak class="inline-flex items-center gap-1"><span class="spinner"></span> Gerando...</span>
                        </button>
                        <span x-show="!productId" class="text-[11px] text-slate-400 italic">IA disponível após salvar</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Nav Step 1 -->
        <div class="flex items-center justify-between mt-4 gap-2 flex-wrap">
            <div class="flex items-center gap-2">
                <a href="@(isEdit ? $"/produtos/{Model.Id}" : "/produtos")"
                   class="px-5 py-2.5 border border-slate-300 text-slate-600 text-sm font-semibold rounded-lg hover:bg-slate-50 transition-colors">
                    Cancelar
                </a>
                @if (!isEdit)
                {
                    <button type="button" x-show="hasDraft()" x-cloak
                            @@click="limparRascunho()"
                            class="px-4 py-2.5 border border-red-200 text-red-500 text-xs font-semibold rounded-lg hover:bg-red-50 transition-colors flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                        Limpar rascunho
                    </button>
                }
            </div>
            <div class="flex items-center gap-2">
                <button type="button" :disabled="!nome || autoFilling" @@click="autoFill()"
                        class="px-4 py-2.5 border border-violet-200 text-violet-600 hover:bg-violet-50 text-xs font-semibold rounded-lg transition-colors disabled:opacity-40 disabled:cursor-not-allowed flex items-center gap-1.5">
                    <span x-show="!autoFilling" class="inline-flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                        Preencher auto
                    </span>
                    <span x-show="autoFilling" x-cloak class="inline-flex items-center gap-1"><span class="spinner"></span> Gerando...</span>
                </button>
                <button type="button" @@click="nextStep()"
                        class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-lg shadow-indigo-500/25">
                    Proximo &rarr;
                </button>
            </div>
        </div>
    </div>

    <!-- ══════════════ STEP 2: FOTOS E PRECOS ══════════════ -->
    <div x-show="step === 2" x-transition:enter.duration.200ms>

        <!-- Fotos -->
        <div class="ws">
            <div class="section-hd">
                <div class="section-hd-icon bg-violet-50 text-violet-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                </div>
                <h3 class="font-bold text-slate-800">Fotos do produto</h3>
                <span class="text-xs text-slate-400 ml-auto" x-text="(existingPhotos.length + photoPreviews.length) + '/5'"></span>
            </div>

            <div x-show="existingPhotos.length > 0" x-transition class="grid grid-cols-4 sm:grid-cols-5 gap-2 mb-3">
                <template x-for="foto in existingPhotos" :key="foto.fotoId">
                    <div class="relative aspect-square rounded-lg overflow-hidden border border-slate-200">
                        <img :src="foto.url" class="w-full h-full object-cover" />
                    </div>
                </template>
            </div>

            <div x-show="(existingPhotos.length + photoPreviews.length) < 5"
                 @@dragover.prevent="$el.classList.add('drop-active')"
                 @@dragleave="$el.classList.remove('drop-active')"
                 @@drop.prevent="$el.classList.remove('drop-active'); handleDrop($event)"
                 @@click="$refs.fileInput.click()"
                 class="border-2 border-dashed border-slate-300 rounded-lg p-8 text-center cursor-pointer hover:border-indigo-300 transition-colors">
                <svg class="w-10 h-10 mx-auto text-slate-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                </svg>
                <p class="text-sm text-slate-500 font-medium">Arraste imagens ou clique para selecionar</p>
                <p class="text-xs text-slate-400 mt-1">JPEG, PNG ou WebP — Max. 5 MB cada</p>
            </div>
            <input type="file" name="fotos" x-ref="fileInput" accept="image/jpeg,image/png,image/webp" multiple class="hidden"
                   @@change="handleFileSelect($event)" />

            <div x-show="photoPreviews.length > 0" x-transition class="grid grid-cols-4 sm:grid-cols-5 gap-2 mt-3">
                <template x-for="(preview, i) in photoPreviews" :key="i">
                    <div class="relative aspect-square rounded-lg overflow-hidden border border-slate-200 group">
                        <img :src="preview" class="w-full h-full object-cover" />
                        <button type="button" @@click="removePhoto(i)"
                                class="absolute top-1 right-1 bg-red-500/90 hover:bg-red-600 text-white rounded-full w-5 h-5 text-xs flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">&times;</button>
                    </div>
                </template>
            </div>
        </div>

        <!-- Precos -->
        <div class="ws">
            <div class="section-hd">
                <div class="section-hd-icon bg-emerald-50 text-emerald-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <h3 class="font-bold text-slate-800">Precos e margem</h3>
            </div>
            <!-- Hidden inputs: enviam null quando valor é 0 (API exige PrecoReferencia > 0 se presente) -->
            <input type="hidden" name="CustoReferencia" :value="custo > 0 ? custo : ''" />
            <input type="hidden" name="PrecoReferencia" :value="preco > 0 ? preco : ''" />
            <input type="hidden" name="MargemEstimada" :value="margem > 0 ? margem : ''" />

            <div class="grid grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Custo</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs text-slate-400">R$</span>
                        <input type="number" step="0.01" min="0"
                               x-model.number="custo" @@input="onCustoInput()"
                               :class="{ 'field-calculated': lastEdited === 'margem' && custo > 0 }"
                               class="w-full pl-9 pr-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Margem</label>
                    <div class="relative">
                        <input type="number" step="0.1"
                               x-model.number="margem" @@input="onMargemInput()"
                               :class="{ 'field-calculated': (lastEdited === 'preco' || lastEdited === 'custo') && margem > 0 }"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-slate-400">%</span>
                    </div>
                    <template x-if="margem > 0">
                        <span class="text-xs mt-1 block font-medium"
                              :class="margem < 10 ? 'text-red-500' : margem < 30 ? 'text-amber-500' : 'text-emerald-500'"
                              x-text="margem < 10 ? 'Margem baixa' : margem < 30 ? 'Margem moderada' : 'Margem saudavel'"></span>
                    </template>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Preco venda</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs text-slate-400">R$</span>
                        <input type="number" step="0.01" min="0"
                               x-model.number="preco" @@input="onPrecoInput()"
                               :class="{ 'field-calculated': lastEdited === 'margem' && preco > 0 }"
                               class="w-full pl-9 pr-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                </div>
            </div>
            <template x-if="lastEdited !== 'none' && (margem > 0 || preco > 0)">
                <p class="text-xs text-slate-400 mt-2 flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    Campos com borda verde foram calculados. Voce pode edita-los.
                </p>
            </template>
        </div>

        <!-- Nav Step 2 -->
        <div class="flex justify-between mt-4">
            <button type="button" @@click="prevStep()"
                    class="px-5 py-2.5 border border-slate-300 text-slate-600 text-sm font-semibold rounded-lg hover:bg-slate-50 transition-colors">
                &larr; Voltar
            </button>
            <button type="button" @@click="nextStep()"
                    class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-lg shadow-indigo-500/25">
                Proximo &rarr;
            </button>
        </div>
    </div>

    <!-- ══════════════ STEP 3: DETALHES (OPCIONAL) ══════════════ -->
    <div x-show="step === 3" x-transition:enter.duration.200ms>

        <div class="bg-indigo-50 border border-indigo-200 text-indigo-700 text-sm rounded-lg px-4 py-3 mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Etapa opcional — pule se nao precisar agora. Voce pode adicionar detalhes depois.
        </div>

        <!-- Dimensoes -->
        <div class="ws" x-data="{ open: @(Model.DimensoesPeso.HasValue || Model.DimensoesLargura.HasValue ? "true" : "false") }">
            <button type="button" @@click="open = !open" class="w-full flex items-center justify-between">
                <div class="section-hd mb-0">
                    <div class="section-hd-icon bg-sky-50 text-sky-500">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-slate-800">Dimensoes e peso</h3>
                </div>
                <svg class="w-5 h-5 text-slate-400 transition-transform" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </button>
            <div x-show="open" x-transition class="mt-4">
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                    <div>
                        <label class="block text-xs text-slate-600 mb-1">Peso (kg)</label>
                        <input name="DimensoesPeso" type="number" step="0.001" min="0" value="@Model.DimensoesPeso"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
                    <div>
                        <label class="block text-xs text-slate-600 mb-1">Largura (cm)</label>
                        <input name="DimensoesLargura" type="number" step="0.01" min="0" value="@Model.DimensoesLargura"
                               class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    </div>
