                margem: @(Model.MargemEstimada?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
                lastEdited: 'none',

                parseDecimal(val) {
                    if (typeof val === 'number') return val;
                    if (val == null) return 0;
                    // aceita "1.234,56" (BR) e "1234.56" (en) — remove separadores de milhar e normaliza vírgula
                    let s = String(val).trim();
                    const lastComma = s.lastIndexOf(',');
                    const lastDot = s.lastIndexOf('.');
                    if (lastComma > -1 && lastComma > lastDot) {
                        // vírgula é o decimal → remove pontos (milhar)
                        s = s.replace(/\./g, '').replace(',', '.');
                    } else if (lastDot > -1 && lastComma > -1) {
                        // ponto é o decimal e vírgula é milhar
                        s = s.replace(/,/g, '');
                    } else {
                        // só vírgulas (ex: "12,5") ou só pontos
                        s = s.replace(',', '.');
                    }
                    const n = parseFloat(s);
                    return isFinite(n) ? n : 0;
                },
                // Sincroniza display do input com o estado reativo, sem sobrescrever enquanto o usuário digita.
                // Sempre acessa `value` para que o Alpine re-rastreie a dependência mesmo quando o input está focado.
                syncMoneyInput(el, value, decimals) {
                    const formatted = value > 0 ? value.toFixed(decimals).replace('.', ',') : '';
                    if (el !== document.activeElement && el.value !== formatted) {
                        el.value = formatted;
                    }
                },
                onPrecoInput() {
                    this.lastEdited = 'preco';
                    if (this.preco > 0 && this.custo > 0)
                        this.margem = +( ((this.preco - this.custo) / this.preco) * 100 ).toFixed(1);
                    else if (this.preco > 0 && this.margem > 0 && this.margem < 100)
                        this.custo = +( this.preco * (1 - this.margem / 100) ).toFixed(2);
                },
                onCustoInput() {
                    this.lastEdited = 'custo';
                    // Prioridade: se margem está definida, recalcula preço (preserva margem desejada pelo usuário).
                    // Caso contrário, recalcula margem a partir do preço existente.
                    if (this.custo > 0 && this.margem > 0 && this.margem < 100)
                        this.preco = +( this.custo / (1 - this.margem / 100) ).toFixed(2);
                    else if (this.preco > 0 && this.custo > 0)
                        this.margem = +( ((this.preco - this.custo) / this.preco) * 100 ).toFixed(1);
                },
                onMargemInput() {
                    this.lastEdited = 'margem';
                    // FIN-002: margem sobre PV nao pode atingir ou superar 100%
                    // (custo / (1 - 1.0) = divisao por zero; > 100% = preco negativo).
                    // Limpa o preco para sinalizar estado invalido e bloquear avanco/submit.
                    if (this.margem >= 100) {
                        this.preco = 0;
                        return;
                    }
                    if (this.custo > 0 && this.margem > 0)
                        this.preco = +( this.custo / (1 - this.margem / 100) ).toFixed(2);
                    else if (this.preco > 0 && this.margem > 0)
                        this.custo = +( this.preco * (1 - this.margem / 100) ).toFixed(2);
                },

                // FIN-001: margem derivada de preco e custo — valor real calculado, nao o
                // raw do input (quando usuario digita 150, o preco nao atualiza porem o
                // input mostra 150%; a derivada recalcula a margem real do preco calculado).
                // Usada na revisao para que o badge mostre 15% (real) e nao 150% (input).
                get margemDerivada() {
                    return (this.preco > 0 && this.custo > 0)
                        ? +(((this.preco - this.custo) / this.preco) * 100).toFixed(1)
                        : (this.margem ?? 0);
                },

                // ── Tipo sugerido baseado na categoria ──
                get tipoSugerido() {
                    const nome = (this.categoriaNome || '').toLowerCase();
                    const alimentoKeywords = ['aliment', 'comida', 'bebida', 'massa', 'doce', 'salgad', 'latic', 'carne', 'frut', 'verdur', 'legum', 'cereal', 'pão', 'padari', 'confeit', 'hortifruti', 'mercearia', 'grão', 'tempero', 'condiment', 'molho', 'sorvete', 'gelat', 'biscoito', 'bolacha', 'chocolate', 'café', 'chá', 'suco', 'refrigerant'];
                    if (alimentoKeywords.some(k => nome.includes(k))) return 1;
                    return null;
                },

                // ── Categories ──
                get subcategorias() {
                    if (!this.categoriaId) return [];
                    return todasSubcats.filter(s => s.categoriaPaiId.toLowerCase() === this.categoriaId);
                },
                get categoriaNome() {
                    if (!this.categoriaId) return '';
                    const cat = allCats.find(c => c.id.toLowerCase() === this.categoriaId);
                    return cat ? cat.nome : '';
                },
                // Cria categoria sem sair do form (issue 420): POST criar-json,
                // recarrega listar, injeta a option no select e seleciona. Reusa
                // o backend existente; nunca recarrega a pagina.
                async criarCategoriaInline() {
                    const nome = (this.novaCategoria.nome || '').trim();
                    if (nome.length < 2) { window.showToast('Informe o nome da categoria (minimo 2 letras).', 'warning'); return; }
                    this.novaCategoria.salvando = true;
                    try {
                        const token = document.querySelector('[name=__RequestVerificationToken]')?.value ?? '';
                        const resp = await fetch('/categorias/criar-json', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                            body: JSON.stringify({ nome })
                        });
                        const data = await resp.json().catch(() => ({}));
                        if (!resp.ok || !data.success) {
                            window.showToast(data?.error?.message || 'Nao foi possivel criar a categoria.', 'error');
                            return;
                        }
                        const lista = await (await fetch('/categorias/listar')).json();
                        const nova = lista.find(c => (c.nome || '').trim().toLowerCase() === nome.toLowerCase());
                        if (!nova) { window.showToast('Categoria criada. Recarregue a pagina para seleciona-la.', 'warning'); return; }
                        const novoId = String(nova.id).toLowerCase();
                        const sel = this.$refs.categoriaSelect;
                        if (sel && !Array.from(sel.options).some(o => o.value === novoId)) {
                            const opt = document.createElement('option');
                            opt.value = novoId;
                            opt.textContent = nova.nome;
                            sel.appendChild(opt);
                        }
                        if (!allCats.some(c => String(c.id).toLowerCase() === novoId)) allCats.push({ id: nova.id, nome: nova.nome });
                        this.categoriaId = novoId;
                        this.novaCategoria.nome = '';
                        this.novaCategoria.aberto = false;
                        window.showToast('Categoria "' + nova.nome + '" criada e selecionada.', 'success');
                    } catch (e) {
                        window.showToast('Erro ao criar categoria. Tente novamente.', 'error');
                    } finally {
                        this.novaCategoria.salvando = false;
                    }
                },

                // ── Photos (FilePond) ──
                _pond: null,
                _pondFileCount: 0,
                existingPhotos: @Html.Raw(existingPhotosJson),
get totalPhotoCount() {
    return this._pondFileCount + this.existingPhotos.length;
},
get remainingPhotoSlots() {
    return Math.max(0, 5 - this.totalPhotoCount);
},
previews: [],      // URLs de preview locais dos arquivos no FilePond
removePondFile(idx) {
    if (!this._pond) return;
    const files = this._pond.getFiles();
    if (files[idx]) {
        this._pond.removeFile(files[idx].id);
    }
},
async deleteExistingPhoto(fotoId) {
    if (!this.productId) return;
    const self = this;
    window.easyConfirm({
        titulo: 'Remover foto do produto?',
        mensagem: 'Esta ação não pode ser desfeita.',
        textoBotao: 'Remover',
        classBotao: 'bg-red-600 hover:bg-red-700'
    }, () => self._doDeletePhoto(fotoId));
},
async _doDeletePhoto(fotoId) {
    try {
        const token = document.querySelector('[name=__RequestVerificationToken]')?.value ?? '';
        const resp = await fetch(`/produtos/${this.productId}/fotos/${fotoId}/remover`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `__RequestVerificationToken=${encodeURIComponent(token)}`
        });
        const data = await resp.json();
        if (data.ok) {
            this.existingPhotos = this.existingPhotos.filter(f => f.fotoId !== fotoId);
            window.showToast('Foto removida.', 'success');
        } else {
            window.showToast(data.erro || 'Erro ao remover foto.', 'error');
        }
    } catch (e) {
        console.error('[EasyStock] deleteExistingPhoto:', e);
        window.showToast('Erro de conexão ao remover foto.', 'error');
    }
},

                // ── AI ──
                aiGenerating: false,
                async generateDescription() {
                    if (this.aiGenerating || !this.nome) return;
                    this.aiGenerating = true;
                    try {
                        let res;
                        if (this.productId) {
                            // Produto já salvo: usa endpoint com contexto completo
                            const params = new URLSearchParams({
                                produtoId: this.productId, canal: 'descricao', tom: 'profissional',
                                foco: 'beneficios',
                                contexto: 'Gere apenas uma descricao comercial curta e objetiva (2-3 frases) para usar no cadastro do produto. Nao use listas. Nao use titulo.'
                            });
                            res = await fetch('/anuncios/gerar?' + params.toString());
                        } else {
                            // Novo produto: usa endpoint de completar com dados do formulário
                            const params = new URLSearchParams({
                                nome: this.nome,
                                categoria: this.categoriaNome ?? '',
                                marca: this.marca ?? '',
                                instrucoes: 'Gere apenas uma descricao comercial curta e objetiva (2-3 frases). Nao use listas. Nao use titulo.'
                            });
                            res = await fetch('/anuncios/completar-produto?' + params.toString());
                        }
                        if (!res || !res.ok || !res.body) throw new Error('Resposta inválida');
                        const reader = res.body.getReader();
                        const decoder = new TextDecoder();
                        this.descricao = '';
                        while (true) {
                            const { done, value } = await reader.read();
                            if (done) break;
                            const text = decoder.decode(value, { stream: true });
                            for (const line of text.split('\n')) {
                                if (!line.startsWith('data: ')) continue;
                                const chunk = line.slice(6).trim();
                                if (chunk === '[DONE]') continue;
                                try {
                                    const json = JSON.parse(chunk);
                                    if (json.texto) this.descricao += json.texto;
                                    else if (json.error) throw new Error(json.error);
                                } catch (e) {
                                    if (!chunk.startsWith('{')) this.descricao += chunk;
                                }
                            }
                        }
                    } catch (e) { console.error('[EasyStock]', e); window.showToast('Erro ao gerar descrição com IA.', 'error'); }
                    this.aiGenerating = false;
                },

                // ── Margem sugestoes ──
                get margemSugestoes() {
                    if (!this.custo || this.custo <= 0) return [];
                    // Fórmula: margem sobre preço de venda → preço = custo / (1 - pct/100)
                    return [30, 50, 80].map(pct => ({
                        pct,
                        preco: (this.custo / (1 - pct / 100)).toFixed(2).replace('.', ',')
                    }));
                },
                aplicarMargem(pct) {
                    if (pct >= 100) return;
                    this.margem = pct;
                    if (this.custo > 0) this.preco = parseFloat((this.custo / (1 - pct / 100)).toFixed(2));
                },

                // ── Completion (mesmos critérios ponderados da página do produto) ──
                get completionPercent() {
                    const fotos = this._pondFileCount + this.existingPhotos.length;
                    const fields = [
                        { ok: fotos > 0,              pts: 20 },
                        { ok: !!this.descricao,        pts: 15 },
                        { ok: this.custo > 0,          pts: 15 },
                        { ok: this.preco > 0,          pts: 15 },
                        { ok: !!this.codigoBarras,     pts: 10 },
                        { ok: this.variacoes.length > 0, pts: 10 },
                        { ok: !!this.marca,            pts:  5 },
                        { ok: false,                   pts:  5 }, // Dimensoes: não avaliado no wizard
                        { ok: true,                    pts:  3 }, // Nome: sempre preenchido ao chegar na revisão
                        { ok: !!this.categoriaId,      pts:  2 },
                    ];
                    return fields.filter(f => f.ok).reduce((s, f) => s + f.pts, 0);
                },
            };
        }
    </script>
}
