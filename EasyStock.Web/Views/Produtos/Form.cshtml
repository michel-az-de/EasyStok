                    <span class="text-[10px] font-medium" :class="categoriaId ? 'text-emerald-500' : 'text-slate-300'"><span x-text="categoriaId ? '✓' : '○'"></span> Categoria</span>
                    <span class="text-[10px] font-medium" :class="custo > 0 ? 'text-emerald-500' : 'text-slate-300'"><span x-text="custo > 0 ? '✓' : '○'"></span> Custo</span>
                    <span class="text-[10px] font-medium" :class="preco > 0 ? 'text-emerald-500' : 'text-slate-300'"><span x-text="preco > 0 ? '✓' : '○'"></span> Preco</span>
                    <span class="text-[10px] font-medium" :class="descricao ? 'text-emerald-500' : 'text-slate-300'"><span x-text="descricao ? '✓' : '○'"></span> Desc</span>
                    <span class="text-[10px] font-medium" :class="(photoPreviews.length + existingPhotos.length) > 0 ? 'text-emerald-500' : 'text-slate-300'"><span x-text="(photoPreviews.length + existingPhotos.length) > 0 ? '✓' : '○'"></span> Foto</span>
                </div>
            </div>
            <div class="flex gap-2 flex-shrink-0">
                <button type="button" @@click="step = 1" class="text-[11px] text-indigo-600 hover:bg-indigo-50 font-semibold px-2.5 py-1 rounded-lg transition-colors">Editar</button>
                <button type="button" @@click="step = 2" class="text-[11px] text-indigo-600 hover:bg-indigo-50 font-semibold px-2.5 py-1 rounded-lg transition-colors">Fotos</button>
                <button type="button" @@click="step = 3" class="text-[11px] text-indigo-600 hover:bg-indigo-50 font-semibold px-2.5 py-1 rounded-lg transition-colors">Detalhes</button>
            </div>
        </div>

        <!-- CTA -->
        <div class="flex flex-col-reverse sm:flex-row justify-between gap-3 mt-5">
            <button type="button" @@click="prevStep()"
                    class="px-5 py-3 border border-slate-300 text-slate-600 text-sm font-semibold rounded-xl hover:bg-slate-50 transition-colors text-center">
                &larr; Voltar
            </button>
            <button type="submit"
                    :disabled="saving"
                    :class="{ 'opacity-50 cursor-not-allowed': saving }"
                    class="flex-1 sm:flex-initial px-10 py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-indigo-500/25 hover:shadow-xl hover:shadow-indigo-500/30 text-center">
                <span x-show="!saving">@(isEdit ? "Salvar alteracoes" : "Criar produto")</span>
                <span x-show="saving" x-cloak class="inline-flex items-center gap-2"><span class="spinner"></span> Salvando...</span>
            </button>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        function produtoForm() {
            const todasSubcats = @Html.Raw(subcatJson);
            const allCats = @Html.Raw(allCatsJson);
            const isEdit = @(isEdit ? "true" : "false");

            return {
                isEdit,
                productId: '@(Model.Id ?? "")',

                // ── Wizard ──
                step: 1,
                maxStepReached: isEdit ? 4 : 1,

                nextStep() {
                    if (this.step === 1 && !this.step1Valid) {
                        if (!this.nome) window.showToast('Informe o nome do produto.', 'warning');
                        else window.showToast('Selecione uma categoria.', 'warning');
                        return;
                    }
                    if (this.step < 4) {
                        this.step++;
                        this.maxStepReached = Math.max(this.maxStepReached, this.step);
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    }
                },
                prevStep() { if (this.step > 1) { this.step--; window.scrollTo({ top: 0, behavior: 'smooth' }); } },
                goToStep(n) { if (n >= 1 && n <= 4 && n <= this.maxStepReached) { this.step = n; window.scrollTo({ top: 0, behavior: 'smooth' }); } },

                get step1Valid() { return !!this.nome && !!this.categoriaId; },

                // ── Submit ──
                saving: false,
                submitForm() {
                    if (!this.nome) { this.step = 1; window.showToast('Informe o nome do produto.', 'warning'); return; }
                    if (!this.categoriaId) { this.step = 1; window.showToast('Selecione uma categoria.', 'warning'); return; }
                    this.saving = true;
                    this._clearDraft();
                    this.$nextTick(() => this.$el.submit());
                },

                // ── Draft persistence (sessionStorage) ──
                _draftKey: 'easystock_produto_draft' + (isEdit ? '_edit' : '_new'),
                _draftTimer: null,
                init() {
                    if (!isEdit) this._restoreDraft();
                    const save = () => { clearTimeout(this._draftTimer); this._draftTimer = setTimeout(() => this._saveDraft(), 500); };
                    for (const f of ['nome','sku','marca','descricao','categoriaId','codigoBarras','preco','custo','margem','step'])
                        this.$watch(f, save);
                },
                _saveDraft() {
                    try {
                        sessionStorage.setItem(this._draftKey, JSON.stringify({
                            nome: this.nome, sku: this.sku, marca: this.marca,
                            codigoBarras: this.codigoBarras,
                            descricao: this.descricao, categoriaId: this.categoriaId,
                            subcategoriaId: this.subcategoriaId, tipo: this.tipo,
                            preco: this.preco, custo: this.custo, margem: this.margem,
                            controlaValidade: this.controlaValidade, step: this.step,
                            maxStepReached: this.maxStepReached,
                            variacoes: this.variacoes, caracteristicas: this.caracteristicas,
                            embalagens: this.embalagens
                        }));
                    } catch {}
                },
                _restoreDraft() {
                    try {
                        const raw = sessionStorage.getItem(this._draftKey);
                        if (!raw) return;
                        const d = JSON.parse(raw);
                        if (d.nome) this.nome = d.nome;
                        if (d.sku) this.sku = d.sku;
                        if (d.marca) this.marca = d.marca;
                        if (d.codigoBarras) this.codigoBarras = d.codigoBarras;
                        if (d.descricao) this.descricao = d.descricao;
                        if (d.categoriaId) this.categoriaId = d.categoriaId;
                        if (d.subcategoriaId) this.subcategoriaId = d.subcategoriaId;
                        if (d.tipo !== undefined) this.tipo = d.tipo;
                        if (d.preco > 0) this.preco = d.preco;
                        if (d.custo > 0) this.custo = d.custo;
                        if (d.margem > 0) this.margem = d.margem;
                        if (d.controlaValidade) this.controlaValidade = d.controlaValidade;
                        if (d.step > 1) { this.step = d.step; this.maxStepReached = d.maxStepReached || d.step; }
                        if (d.variacoes?.length) this.variacoes = d.variacoes;
                        if (d.caracteristicas?.length) this.caracteristicas = d.caracteristicas;
                        if (d.embalagens?.length) this.embalagens = d.embalagens;
                        window.showToast('Rascunho restaurado.', 'info', 2000);
                    } catch {}
                },
                _clearDraft() {
                    try { sessionStorage.removeItem(this._draftKey); } catch {}
                },
                hasDraft() {
                    try { return !!sessionStorage.getItem(this._draftKey); } catch { return false; }
                },
                limparRascunho() {
                    if (!confirm('Limpar rascunho e começar do zero?')) return;
                    this._clearDraft();
                    window.location.reload();
                },

                // ── Auto-fill ──
                autoFilling: false,
                async autoFill() {
                    if (!this.nome) return;
                    let changed = [];

                    // Auto-gera SKU a partir do nome se estiver vazio
                    if (!this.sku) {
                        const words = this.nome.trim().toUpperCase().split(/\s+/).filter(w => w.length > 0);
                        const parts = words.slice(0, 3).map(w => w.substring(0, 3).replace(/[^A-Z0-9]/g, ''));
                        const suffix = String(Date.now()).slice(-5);
                        this.sku = parts.filter(Boolean).join('-') + (parts.filter(Boolean).length ? '-' + suffix : suffix);
                        changed.push('SKU');
                    }

                    // Geração de descrição
                    if (this.productId) {
                        // Modo edição: usa endpoint existente com productId
                        if (!this.descricao) {
                            this.generateDescription();
                            changed.push('Descrição');
                        }
                    } else if (!this.descricao) {
                        // Novo produto: chama /anuncios/completar-produto via SSE
                        changed.push('Descrição');
                        this.autoFilling = true;
                        window.showToast('Gerando descrição com IA...', 'info', 2000);
                        try {
                            const categoriaEl = document.querySelector('select[name="CategoriaId"]');
                            const categoriaNome = categoriaEl
                                ? (categoriaEl.options?.[categoriaEl.selectedIndex]?.text ?? '')
                                : '';
                            const params = new URLSearchParams({
                                nome: this.nome,
                                categoria: categoriaNome,
                                marca: this.marca ?? '',
                                instrucoes: ''
                            });
                            const resp = await fetch(`/anuncios/completar-produto?${params}`);
                            if (!resp.ok || !resp.body) throw new Error('Falha ao conectar com a IA.');
                            const reader = resp.body.getReader();
                            const decoder = new TextDecoder();
                            let buffer = '';
                            this.descricao = '';
                            while (true) {
                                const { value, done } = await reader.read();
                                if (done) break;
                                buffer += decoder.decode(value, { stream: true });
                                const lines = buffer.split('\n');
                                buffer = lines.pop() ?? '';
                                for (const line of lines) {
                                    if (!line.startsWith('data: ')) continue;
                                    const raw = line.slice(6).trim();
                                    if (raw === '[DONE]') break;
                                    try {
                                        const obj = JSON.parse(raw);
                                        if (obj.texto) this.descricao += obj.texto;
                                    } catch {}
                                }
                            }
                        } catch (e) {
                            window.showToast('Erro ao gerar descrição: ' + e.message, 'error', 3000);
                            changed = changed.filter(c => c !== 'Descrição');
                        } finally {
                            this.autoFilling = false;
                        }
                    }

                    if (changed.length > 0 && !this.autoFilling) {
                        window.showToast('Preenchido: ' + changed.join(', '), 'success', 2500);
                    } else if (changed.length === 0) {
                        window.showToast('Campos já preenchidos. Nada alterado.', 'info', 2000);
                    }
                },

                // ── Fields ──
                nome: @Html.Raw(JsonSerializer.Serialize(Model.Nome ?? "")),
                descricao: @Html.Raw(JsonSerializer.Serialize(Model.DescricaoBase ?? "")),
                marca: @Html.Raw(JsonSerializer.Serialize(Model.Marca ?? "")),
                sku: @Html.Raw(JsonSerializer.Serialize(Model.SkuBase ?? "")),
                codigoBarras: @Html.Raw(JsonSerializer.Serialize(Model.CodigoBarras ?? "")),
                tipo: @Model.Tipo,
                controlaValidade: @(Model.ControlaValidade ? "true" : "false"),

                categoriaId: '@(Model.CategoriaId == Guid.Empty ? "" : Model.CategoriaId.ToString().ToLower())',
                subcategoriaId: '@(Model.SubcategoriaId?.ToString().ToLower() ?? "")',

                variacoes: @Html.Raw(JsonSerializer.Serialize(Model.VariacoesRich.Select(v => new {
                    nome = v.Nome ?? "", cor = v.Cor ?? "", tamanho = v.Tamanho ?? "",
                    descricaoComercial = v.DescricaoComercial ?? "", sku = v.Sku ?? "",
                    codigoBarras = v.CodigoBarras ?? "", ativa = v.Ativa
                }))),
                caracteristicas: @Html.Raw(JsonSerializer.Serialize(Model.Caracteristicas.Select(c => new {
                    nome = c.Nome ?? "", descricao = c.Descricao ?? "",
                    quantidadeReferencia = c.QuantidadeReferencia,
                    variacaoPadrao = c.VariacaoPadrao ?? "", ordemExibicao = c.OrdemExibicao
                }))),
                embalagens: @Html.Raw(JsonSerializer.Serialize(Model.Embalagens.Select(e => new {
                    nome = e.Nome ?? "", descricao = e.Descricao ?? "",
                    peso = e.Peso, largura = e.Largura, altura = e.Altura,
                    comprimento = e.Comprimento, padrao = e.Padrao
                }))),

                // ── Pricing ──
                preco: @(Model.PrecoReferencia?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
                custo: @(Model.CustoReferencia?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
                margem: @(Model.MargemEstimada?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
                lastEdited: 'none',

                onPrecoInput() {
                    this.lastEdited = 'preco';
                    if (this.preco > 0 && this.custo > 0)
                        this.margem = +( ((this.preco - this.custo) / this.preco) * 100 ).toFixed(1);
                    else if (this.preco > 0 && this.margem > 0 && this.margem < 100)
                        this.custo = +( this.preco * (1 - this.margem / 100) ).toFixed(2);
                },
                onCustoInput() {
                    this.lastEdited = 'custo';
                    if (this.preco > 0 && this.custo > 0)
                        this.margem = +( ((this.preco - this.custo) / this.preco) * 100 ).toFixed(1);
                    else if (this.custo > 0 && this.margem > 0 && this.margem < 100)
                        this.preco = +( this.custo / (1 - this.margem / 100) ).toFixed(2);
                },
                onMargemInput() {
                    this.lastEdited = 'margem';
                    if (this.custo > 0 && this.margem > 0 && this.margem < 100)
                        this.preco = +( this.custo / (1 - this.margem / 100) ).toFixed(2);
                    else if (this.preco > 0 && this.margem > 0 && this.margem < 100)
                        this.custo = +( this.preco * (1 - this.margem / 100) ).toFixed(2);
                },

                // ── Categories ──
                get subcategorias() {
                    if (!this.categoriaId) return [];
                    return todasSubcats.filter(s => s.categoriaPaiId.toLowerCase() === this.categoriaId);
                },
                get categoriaNome() {
                    if (!this.categoriaId) return '';
                    const cat = allCats.find(c => c.id.toLowerCase() === this.categoriaId);
                    return cat ? cat.nome : '';
                },

                // ── Photos ──
                photoFiles: [],
                photoPreviews: [],
                existingPhotos: @Html.Raw(existingPhotosJson),

                handleFileSelect(e) { this.addPhotos(e.target.files); e.target.value = ''; },
                handleDrop(e) { this.addPhotos(e.dataTransfer.files); },
                addPhotos(files) {
                    const maxNew = 5 - this.existingPhotos.length - this.photoFiles.length;
                    for (const file of Array.from(files).slice(0, Math.max(0, maxNew))) {
                        if (file.size > 5 * 1024 * 1024) continue;
                        if (!file.type.startsWith('image/')) continue;
                        this.photoFiles.push(file);
                        this.photoPreviews.push(URL.createObjectURL(file));
                    }
                    this._syncFileInput();
                },
                removePhoto(i) {
                    URL.revokeObjectURL(this.photoPreviews[i]);
                    this.photoFiles.splice(i, 1);
                    this.photoPreviews.splice(i, 1);
                    this._syncFileInput();
                },
                _syncFileInput() {
                    try {
                        const dt = new DataTransfer();
                        this.photoFiles.forEach(f => dt.items.add(f));
                        this.$refs.fileInput.files = dt.files;
                    } catch (e) { /* DataTransfer fallback */ }
                },

                // ── AI ──
                aiGenerating: false,
                async generateDescription() {
                    if (this.aiGenerating || !this.productId) return;
                    this.aiGenerating = true;
                    try {
                        const params = new URLSearchParams({
                            produtoId: this.productId, canal: 'descricao', tom: 'profissional',
                            foco: 'beneficios',
                            contexto: 'Gere apenas uma descricao comercial curta e objetiva (2-3 frases) para usar no cadastro do produto. Nao use listas. Nao use titulo.'
                        });
                        const res = await fetch('/anuncios/gerar?' + params.toString());
                        if (!res.ok) throw new Error();
                        const reader = res.body.getReader();
                        const decoder = new TextDecoder();
                        this.descricao = '';
                        while (true) {
                            const { done, value } = await reader.read();
                            if (done) break;
                            const text = decoder.decode(value);
                            for (const line of text.split('\n')) {
                                if (line.startsWith('data: ')) this.descricao += line.slice(6);
                            }
                        }
                    } catch { /* silently fail */ }
                    this.aiGenerating = false;
                },

                // ── Completion ──
                get completionPercent() {
                    const fields = [!!this.nome, !!this.categoriaId, this.preco > 0, this.custo > 0, !!this.descricao, (this.photoPreviews.length + this.existingPhotos.length) > 0];
                    return Math.round(fields.filter(Boolean).length / fields.length * 100);
                },
            };
        }
    </script>
}
