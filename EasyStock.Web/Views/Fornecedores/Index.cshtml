@model FornecedoresListViewModel
@{
    ViewBag.Title = "Fornecedores";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Fornecedores</h1>
        <p>Gerencie seus fornecedores e pedidos de compra</p>
    </div>
    <div class="flex gap-3">
        <button type="button" x-data
                @@click="$dispatch('open-modal', 'novo-fornecedor')"
                class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
            + Novo Fornecedor
        </button>
    </div>
</div>

<!-- Filtros -->
<div class="ws mb-6">
    <form method="get" class="flex gap-3 flex-wrap items-center">
        <div class="supplier-search-group flex flex-1 min-w-48 gap-3">
        <input type="text" name="search" value="@Model.Search" placeholder="Buscar fornecedor..."
               class="ui-field flex-1 min-w-48" />
        <button type="submit" class="ui-secondary-btn px-4 py-2 bg-slate-100 border border-slate-300 rounded-lg text-sm hover:bg-slate-200">
            Buscar
        </button>
        </div>
        <div class="flex gap-2">
            @foreach (var (val, label) in new[] { ("", "Todos"), ("ativo", "Ativos"), ("inativo", "Inativos") })
            {
                var isActive = Model.FiltroStatus == val || (val == "" && Model.FiltroStatus == null);
                <a href="@Url.Action("Index", "Fornecedores", new { search = Model.Search, status = val == "" ? null : val })"
                   class="px-3 py-2 rounded-lg text-sm font-medium @(isActive ? "app-primary-btn bg-indigo-600 text-white" : "ui-secondary-btn bg-white border border-slate-300 text-slate-700 hover:bg-slate-50")">
                    @label
                </a>
            }
        </div>
    </form>
</div>

<!-- Lista -->
<div class="ws">
    @if (!Model.Items.Any())
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIcon", "🏭" },
            { "EmptyTitle", "Nenhum fornecedor cadastrado" },
            { "EmptyDescription", "Adicione seu primeiro fornecedor para organizar suas compras." },
            { "EmptyCta", "+ Novo Fornecedor" },
            { "EmptyCtaModal", "novo-fornecedor" }
        })
    }
    else
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Tipo</th>
                    <th>Lead (dias)</th>
                    <th>Categorias</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model.Items)
                {
                    <tr>
                        <td>
                            <div class="font-medium text-slate-900">@f.Nome</div>
                            @if (!string.IsNullOrEmpty(f.Email))
                            {
                                <div class="text-xs text-slate-500">@f.Email</div>
                            }
                        </td>
                        <td class="text-slate-600 text-sm capitalize">@f.Tipo</td>
                        <td class="text-slate-600">@(f.LeadTimeEstimadoDias?.ToString() ?? "—")</td>
                        <td class="text-slate-500 text-sm">@f.Categoria</td>
                        <td>
                            <span class="px-2 py-0.5 rounded-full text-xs font-medium @(f.Status == "ativo" ? "bg-green-100 text-green-700" : "bg-slate-100 text-slate-600")">
                                @(string.IsNullOrWhiteSpace(f.Status) ? "—" : char.ToUpperInvariant(f.Status[0]) + f.Status[1..].ToLowerInvariant())
                            </span>
                        </td>
                        <td>
                            <a asp-action="Detail" asp-controller="Fornecedores" asp-route-id="@f.Id"
                               class="text-sm text-indigo-600 hover:text-indigo-700">Ver</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>

<!-- Modal novo fornecedor -->
<div x-data="criarFornecedorModal()" @@open-modal.window="if ($event.detail === 'novo-fornecedor') open = true"
     x-show="open" x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
     @@click.self="open = false" @@keydown.escape.window="open = false">
    <div class="ui-modal supplier-modal bg-white rounded-xl shadow-xl w-full max-w-3xl p-0 overflow-y-auto max-h-[92vh]">
        <div class="supplier-modal__header">
            <h2 class="text-lg font-semibold text-slate-900">Novo Fornecedor</h2>
            <p class="text-sm text-slate-500 mt-1">Cadastre um parceiro com dados essenciais, contato e condições comerciais em um único fluxo.</p>
        </div>
        <div x-show="erroMsg" x-cloak class="mx-6 mt-5 mb-0 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700" x-text="erroMsg"></div>
        @Html.AntiForgeryToken()
        <div class="supplier-form grid grid-cols-2 gap-3 mb-0">
            <div class="col-span-2">
                <label class="block text-sm font-medium text-slate-700 mb-1">Nome *</label>
                <input type="text" x-model="form.nome" required @@input="erroMsg = ''"
                       class="ui-field w-full text-sm" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">CNPJ/CPF</label>
                <input type="text" x-model="form.documento" x-mask:doc inputmode="numeric" class="ui-field w-full text-sm" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Responsável</label>
                <input type="text" x-model="form.contato" class="ui-field w-full text-sm" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
                <input type="email" x-model="form.email" class="ui-field w-full text-sm" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Telefone</label>
                <input type="text" x-model="form.telefone" x-mask:phone inputmode="numeric" autocomplete="tel" class="ui-field w-full text-sm" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Tipo *</label>
                <select x-model="form.tipo" required class="ui-select w-full text-sm">
                    <option value="nacional">Nacional</option>
                    <option value="importado">Importado</option>
                    <option value="dropshipping">Dropshipping</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Lead Time (dias)</label>
                <input type="number" x-model.number="form.leadTimeEstimadoDias" min="0"
                       class="ui-field w-full text-sm" />
            </div>
            <div class="col-span-2">
                <label class="block text-sm font-medium text-slate-700 mb-1">Categorias</label>
                <input type="text" x-model="form.categoria" placeholder="Ex: eletrônicos, roupas..."
                       class="ui-field w-full text-sm" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Site</label>
                <input type="url" x-model="form.siteUrl" placeholder="https://..."
                       class="ui-field w-full text-sm" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Pedido Mínimo</label>
                <input type="text" x-model="form.pedidoMinimo" placeholder="Ex: R$ 500 ou 10 un"
                       class="ui-field w-full text-sm" />
            </div>
            <div class="col-span-2">
                <label class="block text-sm font-medium text-slate-700 mb-1">Frete Padrão</label>
                <input type="text" x-model="form.fretePadrao" placeholder="Ex: R$ 50 ou grátis acima de R$ 500"
                       class="ui-field w-full text-sm" />
            </div>
            <div class="col-span-2">
                <label class="block text-sm font-medium text-slate-700 mb-1">Observações</label>
                <textarea x-model="form.observacoes" rows="2"
                          class="ui-textarea w-full text-sm"></textarea>
            </div>
        </div>
        <div class="supplier-modal__footer flex justify-end gap-3 pt-3 border-t">
            <button type="button" @@click="open = false"
                    class="ui-secondary-btn px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                Cancelar
            </button>
            <button type="button" @@click="submitForm()" :disabled="loading || !form.nome.trim()"
                    :class="{ 'opacity-50 cursor-not-allowed': loading || !form.nome.trim() }"
                    class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                <span x-show="!loading">Criar Fornecedor</span>
                <span x-show="loading" x-cloak class="flex items-center gap-2"><span class="spinner"></span> Salvando...</span>
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
function criarFornecedorModal() {
    return {
        open: false,
        loading: false,
        erroMsg: '',
        form: {
            nome: '', documento: '', contato: '', email: '', telefone: '',
            tipo: 'nacional', leadTimeEstimadoDias: 7, categoria: '',
            siteUrl: '', pedidoMinimo: '', fretePadrao: '', observacoes: ''
        },
        async submitForm() {
            if (!this.form.nome.trim()) { this.erroMsg = 'Nome é obrigatório.'; return; }
            this.loading = true;
            this.erroMsg = '';
            try {
                const token = document.querySelector('[name=__RequestVerificationToken]')?.value;
                const res = await fetch('/fornecedores/json', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify(this.form)
                });
                // Lê o corpo como texto pra tolerar respostas vazias ou HTML (ex: página
                // de erro do StatusCodePages quando antiforgery/auth falha).
                const raw = await res.text();
                let data = null;
                try { data = raw ? JSON.parse(raw) : null; } catch { /* ignora — resposta não-JSON */ }
                if (res.ok && data && data.success) {
                    window.location.href = '/fornecedores/' + data.id;
                    return;
                }
                if (data && data.errorMessage) {
                    this.erroMsg = data.errorMessage;
                } else if (res.status === 400 || res.status === 403) {
                    this.erroMsg = 'Sessão expirada ou token inválido. Recarregue a página e tente novamente.';
                } else if (res.status === 401) {
                    this.erroMsg = 'Sessão expirada. Faça login novamente.';
                } else {
                    this.erroMsg = `Erro ao criar fornecedor (HTTP ${res.status}). Tente novamente.`;
                }
            } catch {
                this.erroMsg = 'Não foi possível conectar ao servidor. Verifique sua conexão.';
            } finally {
                this.loading = false;
            }
        }
    };
}
</script>
}
