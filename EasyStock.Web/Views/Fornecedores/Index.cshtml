@model FornecedoresListViewModel
@{
    ViewBag.Title = "Fornecedores";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6 flex-wrap gap-3">
    <div class="pg-hd">
        <h1>Fornecedores</h1>
        <p>
            @Model.Items.Count @(Model.Items.Count == 1 ? "fornecedor listado" : "fornecedores listados") · gerencie cadastros e pedidos de compra
        </p>
    </div>
    <div class="flex gap-3 flex-wrap">
        <button type="button" x-data
                @@click="$dispatch('open-modal', 'novo-fornecedor')"
                class="app-primary-btn inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Novo fornecedor
        </button>
    </div>
</div>

<!-- Filtros -->
<div class="ws mb-6">
    <form method="get" class="flex gap-3 flex-wrap items-center" role="search" aria-label="Filtrar fornecedores">
        <div class="supplier-search-group flex flex-1 min-w-48 gap-3">
        <input type="search" name="search" value="@Model.Search" placeholder="Buscar por nome, e-mail, CNPJ/CPF ou categoria…"
               aria-label="Buscar fornecedor"
               class="ui-field flex-1 min-w-48" />
        <button type="submit" class="btn btn-secondary btn-sm">Buscar</button>
        </div>
        <div class="filter-tab-group">
            @foreach (var (val, label) in new[] { ("", "Todos"), ("ativo", "Ativos"), ("inativo", "Inativos") })
            {
                var isActive = Model.FiltroStatus == val || (val == "" && Model.FiltroStatus == null);
                <a href="@Url.Action("Index", "Fornecedores", new { search = Model.Search, status = val == "" ? null : val })"
                   class="filter-tab @(isActive ? "active" : "")">@label</a>
            }
        </div>
    </form>
</div>

<!-- Lista -->
<div class="ws">
    @if (!Model.Items.Any())
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIconName", "truck" },
            { "EmptyTitle", "Nenhum fornecedor cadastrado" },
            { "EmptyDescription", "Adicione seu primeiro fornecedor para organizar suas compras." },
            { "EmptyCta", "+ Novo Fornecedor" },
            { "EmptyCtaModal", "novo-fornecedor" }
        })
    }
    else
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Tipo</th>
                    <th>Lead (dias)</th>
                    <th>Categorias</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model.Items)
                {
                    <tr>
                        <td>
                            <div class="font-medium text-slate-900">@f.Nome</div>
                            @if (!string.IsNullOrEmpty(f.Email))
                            {
                                <div class="text-xs text-slate-500">@f.Email</div>
                            }
                        </td>
                        <td class="text-slate-600 text-sm capitalize">@f.Tipo</td>
                        <td class="text-slate-600">@(f.LeadTimeEstimadoDias?.ToString() ?? "—")</td>
                        <td class="text-slate-500 text-sm">@f.Categoria</td>
                        <td>
                            @{ var ativo = f.Status == "ativo"; }
                            <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-xs font-medium ring-1
                                        @(ativo ? "bg-emerald-50 text-emerald-800 ring-emerald-200" : "bg-slate-50 text-slate-600 ring-slate-200")">
                                <span class="w-1.5 h-1.5 rounded-full @(ativo ? "bg-emerald-500" : "bg-slate-400")"></span>
                                @(string.IsNullOrWhiteSpace(f.Status) ? "—" : char.ToUpperInvariant(f.Status[0]) + f.Status[1..].ToLowerInvariant())
                            </span>
                        </td>
                        <td class="text-right">
                            <a asp-action="Detail" asp-controller="Fornecedores" asp-route-id="@f.Id"
                               class="text-sm font-medium text-indigo-600 hover:text-indigo-700">Abrir →</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>

<!-- Modal: novo fornecedor -->
<div x-data="formModal({
        id: 'novo-fornecedor',
        endpoint: '/fornecedores/json',
        redirect: '/fornecedores/{id}',
        requireField: 'nome',
        requireMessage: 'Informe o nome do fornecedor.',
        initialForm: {
            nome: '', documento: '', contato: '', email: '', telefone: '',
            tipo: 'nacional', leadTimeEstimadoDias: 7, categoria: '',
            siteUrl: '', pedidoMinimo: '', fretePadrao: '', observacoes: ''
        }
     })"
     x-show="open" x-cloak
     x-transition:leave="transition duration-100 ease-in"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     @@keydown.window="handleKeydown($event)"
     @@click.self="close()"
     class="fm-overlay"
     role="dialog" aria-modal="true" aria-labelledby="fm-fornecedor-title">
    @* BUG-05: backdrop do overlay aparece opaco e instantaneo (sem fade), e a animacao
       de entrada fica no painel via x-show — antes o x-transition do painel era inerte
       (sem x-show proprio) e o fade do overlay deixava o texto do fundo vazar. *@
    <form x-ref="panel" class="fm-panel" x-show="open"
          @@submit.prevent="submit()"
          x-transition:enter="transition duration-150 ease-out"
          x-transition:enter-start="opacity-0 scale-95"
          x-transition:enter-end="opacity-100 scale-100">
        <header class="fm-header">
            <div>
                <h2 id="fm-fornecedor-title" class="fm-header__title">Novo fornecedor</h2>
                <p class="fm-header__subtitle">Comece com o essencial. Condições comerciais e categorias você completa depois.</p>
            </div>
            <button type="button" class="fm-close" aria-label="Fechar" @@click="close()">✕</button>
        </header>

        <div class="fm-body">
            <div x-show="erroMsg" x-cloak class="fm-error" x-text="erroMsg" role="alert"></div>
            @Html.AntiForgeryToken()

            <fieldset class="fm-section">
                <legend class="fm-section__legend">Identificação</legend>
                <div class="fm-grid">
                    <div class="fm-field fm-col-2">
                        <label class="fm-field__label" for="forn-nome">
                            Nome do fornecedor<span class="fm-field__required" aria-hidden="true">*</span>
                        </label>
                        <input id="forn-nome" type="text" x-model="form.nome" required
                               placeholder="Ex: Distribuidora Sul Ltda"
                               @@input="erroMsg = ''"
                               class="ui-field w-full text-sm" />
                    </div>
                    <div class="fm-field">
                        <label class="fm-field__label" for="forn-doc">CNPJ ou CPF</label>
                        <input id="forn-doc" type="text" x-model="form.documento" x-mask:doc
                               inputmode="numeric" placeholder="00.000.000/0000-00"
                               data-validate-doc
                               class="ui-field w-full text-sm" />
                    </div>
                    <div class="fm-field">
                        <label class="fm-field__label" for="forn-tipo">
                            Origem<span class="fm-field__required" aria-hidden="true">*</span>
                        </label>
                        <select id="forn-tipo" x-model="form.tipo" required class="ui-select w-full text-sm">
                            <option value="nacional">Nacional</option>
                            <option value="importado">Importado</option>
                            <option value="dropshipping">Dropshipping</option>
                        </select>
                    </div>
                </div>
            </fieldset>

            <fieldset class="fm-section">
                <legend class="fm-section__legend">Contato</legend>
                <div class="fm-grid">
                    <div class="fm-field">
                        <label class="fm-field__label" for="forn-resp">Pessoa de contato</label>
                        <input id="forn-resp" type="text" x-model="form.contato"
                               placeholder="Ex: Marina Silva"
                               class="ui-field w-full text-sm" />
                    </div>
                    <div class="fm-field">
                        <label class="fm-field__label" for="forn-tel">Telefone / WhatsApp</label>
                        <input id="forn-tel" type="text" x-model="form.telefone" x-mask:phone
                               inputmode="numeric" autocomplete="tel" placeholder="(11) 99999-9999"
                               data-validate-phone
                               class="ui-field w-full text-sm" />
                    </div>
                    <div class="fm-field">
                        <label class="fm-field__label" for="forn-email">E-mail</label>
                        <input id="forn-email" type="email" x-model="form.email"
                               placeholder="contato@fornecedor.com.br"
                               class="ui-field w-full text-sm" />
                    </div>
                    <div class="fm-field">
                        <label class="fm-field__label" for="forn-site">Site</label>
                        <input id="forn-site" type="url" x-model="form.siteUrl"
                               placeholder="https://..."
                               class="ui-field w-full text-sm" />
                    </div>
                </div>
            </fieldset>

            <div class="fm-advanced">
                <button type="button" class="fm-advanced__toggle"
                        :aria-expanded="advancedOpen ? 'true' : 'false'"
                        aria-controls="forn-advanced"
                        @@click="advancedOpen = !advancedOpen">
                    <span class="fm-advanced__chevron" aria-hidden="true">›</span>
                    <span x-text="advancedOpen ? 'Ocultar condições comerciais' : 'Adicionar condições comerciais'"></span>
                </button>
                <div id="forn-advanced" x-show="advancedOpen" x-cloak
                     x-transition:enter="transition duration-100 ease-out"
                     x-transition:enter-start="opacity-0 -translate-y-1"
                     x-transition:enter-end="opacity-100 translate-y-0">
                    <div class="fm-grid">
                        <div class="fm-field">
                            <label class="fm-field__label" for="forn-lead">Prazo de entrega (dias)</label>
                            <input id="forn-lead" type="number" x-model.number="form.leadTimeEstimadoDias" min="0"
                                   class="ui-field w-full text-sm" />
                            <span class="fm-field__hint">Tempo médio entre pedido e recebimento</span>
                        </div>
                        <div class="fm-field">
                            <label class="fm-field__label" for="forn-cat">Categorias</label>
                            <input id="forn-cat" type="text" x-model="form.categoria"
                                   placeholder="eletrônicos, roupas..."
                                   class="ui-field w-full text-sm" />
                            <span class="fm-field__hint">Separe por vírgula</span>
                        </div>
                        <div class="fm-field">
                            <label class="fm-field__label" for="forn-min">Pedido mínimo</label>
                            <input id="forn-min" type="text" x-model="form.pedidoMinimo"
                                   placeholder="R$ 500 ou 10 un"
                                   class="ui-field w-full text-sm" />
                        </div>
                        <div class="fm-field">
                            <label class="fm-field__label" for="forn-frete">Frete padrão</label>
                            <input id="forn-frete" type="text" x-model="form.fretePadrao"
                                   placeholder="R$ 50 ou grátis acima de R$ 500"
                                   class="ui-field w-full text-sm" />
                        </div>
                        <div class="fm-field fm-col-2">
                            <label class="fm-field__label" for="forn-obs">Observações</label>
                            <textarea id="forn-obs" x-model="form.observacoes" rows="2"
                                      placeholder="Forma de pagamento preferida, prazos especiais..."
                                      class="ui-textarea w-full text-sm"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="fm-footer">
            <span class="fm-footer__hint">
                Pressione <kbd class="px-1.5 py-0.5 rounded border border-slate-300 bg-slate-50 text-[11px] font-mono text-slate-600">Enter</kbd> para salvar
            </span>
            <button type="button" @@click="close()"
                    class="ui-secondary-btn px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                Cancelar
            </button>
            <button type="submit" :disabled="loading || isInvalid()"
                    :class="{ 'opacity-50 cursor-not-allowed': loading || isInvalid() }"
                    class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700">
                <span x-show="!loading">Salvar fornecedor</span>
                <span x-show="loading" x-cloak class="flex items-center gap-2">
                    <span class="spinner"></span> Salvando…
                </span>
            </button>
        </footer>
    </form>
</div>
