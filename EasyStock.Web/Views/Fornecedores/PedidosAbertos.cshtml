@model PedidosAbertosViewModel
@{
    ViewBag.Title = "Pedidos em Aberto";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
        <a asp-action="Index" asp-controller="Fornecedores" class="text-slate-400 hover:text-slate-600" aria-label="Voltar para fornecedores">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
        </a>
        <h1 class="text-2xl font-bold text-slate-900">Pedidos em Aberto</h1>
        @if (Model.TotalPedidos > 0)
        {
            <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">
                @Model.TotalPedidos
            </span>
        }
    </div>
    <button type="button" x-data @@click="$dispatch('open-modal', 'novo-pedido')"
            class="app-primary-btn">
        + Novo Pedido
    </button>
</div>

@if (Model.TotalPedidos > 0)
{
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div class="ws">
            <div class="text-sm text-slate-500">Total de pedidos</div>
            <div class="text-2xl font-bold text-slate-900">@Model.TotalPedidos</div>
        </div>
        <div class="ws">
            <div class="text-sm text-slate-500">Valor total estimado</div>
            <div class="text-2xl font-bold text-slate-900">R$ @Model.ValorTotal.ToString("N2")</div>
        </div>
    </div>

    <div class="ws">
        <div class="overflow-x-auto">
            <table class="tbl-full">
                <thead>
                    <tr>
                        <th>Fornecedor</th>
                        <th>Data Pedido</th>
                        <th>Previsão Entrega</th>
                        <th>Valor</th>
                        <th>Status</th>
                        <th>Canal</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ped in Model.Pedidos)
                    {
                        <tr x-data="{ confirmCancel: false, confirmReceber: false, tracking: '' }">
                            <td>
                                <a asp-action="Detail" asp-controller="Fornecedores" asp-route-id="@ped.FornecedorId"
                                   class="font-medium text-indigo-600 hover:text-indigo-700">
                                    @ped.FornecedorNome
                                </a>
                            </td>
                            <td class="text-slate-600">@ped.DataPedido.ToString("dd/MM/yyyy")</td>
                            <td class="text-slate-600">
                                @if (ped.PrevisaoEntrega.HasValue)
                                {
                                    var previsao = ped.PrevisaoEntrega.Value;
                                    var atrasado = previsao.Date < DateTime.Today && ped.Status != 3;
                                    <span class="@(atrasado ? "text-red-600 font-medium" : "")">
                                        @previsao.ToString("dd/MM/yyyy")
                                        @if (atrasado)
                                        {
                                            <span class="text-xs ml-1">(atrasado)</span>
                                        }
                                    </span>
                                }
                                else
                                {
                                    <span>&mdash;</span>
                                }
                            </td>
                            <td class="text-slate-600">R$ @((ped.ValorEstimado ?? 0).ToString("N2"))</td>
                            <td>
                                <span class="px-2 py-0.5 rounded-full text-xs font-medium @ped.StatusCssClass">
                                    @ped.StatusLabel
                                </span>
                            </td>
                            <td class="text-slate-500 text-sm">@(ped.Canal ?? "-")</td>
                            <td>
                                <div class="flex items-center gap-2">
                                    @if (ped.Status == 1 || ped.Status == 2)
                                    {
                                        <button type="button" @@click="confirmReceber = true"
                                                class="grid-action-btn grid-action-btn--success">
                                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                            </svg>
                                            Recebido
                                        </button>
                                        <button type="button" @@click="confirmCancel = true"
                                                class="grid-action-btn grid-action-btn--danger">
                                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                            </svg>
                                            Cancelar
                                        </button>
                                    }
                                    <a asp-action="Detail" asp-controller="Fornecedores" asp-route-id="@ped.FornecedorId"
                                       class="grid-action-btn grid-action-btn--primary">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                        </svg>
                                        Ver
                                    </a>
                                </div>

                                <div x-show="confirmReceber" x-cloak
                                     class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/55 px-4"
                                     @@click.self="confirmReceber = false">
                                    <div class="ui-modal pedido-action-modal w-full max-w-md overflow-hidden">
                                        <div class="pedido-action-modal__header">
                                            <span class="pedido-action-modal__eyebrow">Recebimento</span>
                                            <h3 class="text-lg font-semibold text-slate-900">Confirmar recebimento</h3>
                                            <p class="text-sm text-slate-600">
                                                Finalize a chegada do pedido de <strong>@ped.FornecedorNome</strong> e registre o rastreio, se existir.
                                            </p>
                                        </div>
                                        <div class="pedido-action-modal__body">
                                            <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-2">Código de rastreio</label>
                                            <input type="text" x-model="tracking" placeholder="Ex: BR123456789"
                                                   class="ui-field mb-4" />
                                            <div class="pedido-action-modal__footer">
                                                <button type="button" @@click="confirmReceber = false"
                                                        class="ui-secondary-btn">Voltar</button>
                                                <form asp-action="ReceberPedido" asp-controller="Fornecedores"
                                                      asp-route-id="@ped.PedidoId" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="tracking" :value="tracking" />
                                                    <button type="submit" class="app-primary-btn app-primary-btn--success">
                                                        Confirmar recebimento
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div x-show="confirmCancel" x-cloak
                                     class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/55 px-4"
                                     @@click.self="confirmCancel = false">
                                    <div class="ui-modal pedido-action-modal pedido-action-modal--danger w-full max-w-md overflow-hidden">
                                        <div class="pedido-action-modal__header">
                                            <span class="pedido-action-modal__eyebrow">Cancelamento</span>
                                            <h3 class="text-lg font-semibold text-slate-900">Cancelar pedido</h3>
                                            <p class="text-sm text-slate-600">
                                                O pedido de <strong>@ped.FornecedorNome</strong> será encerrado e essa ação não poderá ser desfeita.
                                            </p>
                                        </div>
                                        <div class="pedido-action-modal__footer pedido-action-modal__footer--compact">
                                            <button type="button" @@click="confirmCancel = false"
                                                    class="ui-secondary-btn">
                                                Voltar
                                            </button>
                                            <form asp-action="CancelarPedido" asp-controller="Fornecedores"
                                                  asp-route-id="@ped.PedidoId" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="pedido-danger-btn">
                                                    Confirmar cancelamento
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="ws">
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIllustration", "chart" },
            { "EmptyTitle", "Nenhum pedido em aberto" },
            { "EmptyDescription", "Todos os pedidos foram concluídos. Crie um novo pedido quando precisar." },
            { "EmptyCta", "Novo pedido" },
            { "EmptyCtaModal", "novo-pedido" }
        })
    </div>
}

<div x-data="{ open: false }" @@open-modal.window="open = ($event.detail === 'novo-pedido')"
     x-show="open" x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/55 px-4"
     @@click.self="open = false">
    <div class="ui-modal pedido-modal w-full max-w-3xl overflow-y-auto max-h-[92vh]">
        <div class="pedido-modal__header">
            <span class="pedido-modal__eyebrow">Compra assistida</span>
            <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                <div>
                    <h2 class="text-xl font-semibold text-slate-900">Novo pedido de compra</h2>
                    <p class="mt-2 max-w-2xl text-sm text-slate-600">
                        Registre o pedido com contexto comercial, previsão e observações para acompanhar melhor a entrega e o recebimento.
                    </p>
                </div>
                <div class="pedido-modal__chips">
                    <span>Mais contexto</span>
                    <span>Melhor follow-up</span>
                    <span>Pronto para mobile</span>
                </div>
            </div>
        </div>
        <form asp-action="CriarPedido" asp-controller="Fornecedores" method="post" x-data="{ loading: false }" @@submit="loading = true">
            @Html.AntiForgeryToken()
            <div class="pedido-form grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-2">Fornecedor *</label>
                    <select name="fornecedorId" required class="ui-select" id="select-fornecedor-pedido">
                        <option value="">Selecione...</option>
                        @foreach (var f in Model.Fornecedores)
                        {
                            <option value="@f.Id">@f.Nome</option>
                        }
                    </select>
                    <p class="mt-2 text-xs text-slate-500">Escolha o parceiro que vai receber este pedido para manter o histórico centralizado.</p>
                </div>
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-2">Data do pedido *</label>
                    <input type="date" name="dataPedido" required
                           value="@DateTime.Today.ToString("yyyy-MM-dd")"
                           class="ui-field" />
                </div>
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-2">Previsão de entrega</label>
                    <input type="date" name="previsaoEntrega"
                           class="ui-field" />
                </div>
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-2">Valor estimado (R$)</label>
                    <input type="number" name="valorEstimado" min="0" step="0.01" placeholder="0,00"
                           class="ui-field" />
                </div>
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-2">Canal</label>
                    <input type="text" name="canal" placeholder="Ex: WhatsApp, Site, Telefone"
                           class="ui-field" />
                </div>
                <div class="col-span-2">
                    <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-2">Observações</label>
                    <textarea name="observacoes" rows="3" placeholder="Ex: prazo combinado, itens esperados, condição de frete ou detalhes do contato"
                              class="ui-textarea"></textarea>
                </div>
            </div>
            <div class="pedido-modal__footer flex justify-end gap-3 border-t">
                <button type="button" @@click="open = false"
                        class="ui-secondary-btn">
                    Cancelar
                </button>
                <button type="submit"
                        :disabled="loading" :class="{ 'opacity-50 cursor-not-allowed': loading }"
                        class="app-primary-btn">
                    <span x-show="!loading">Criar Pedido</span>
                    <span x-show="loading" x-cloak class="flex items-center gap-2"><span class="spinner"></span> Salvando...</span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        const params = new URLSearchParams(location.search);
        if (params.get('novo') === '1') {
            const fornId = params.get('fornecedorId');
            document.addEventListener('alpine:init', () => {}, { once: true });
            // Dispatch after Alpine has initialised the modal
            setTimeout(() => {
                const sel = document.getElementById('select-fornecedor-pedido');
                if (sel && fornId) sel.value = fornId;
                window.dispatchEvent(new CustomEvent('open-modal', { detail: 'novo-pedido' }));
            }, 50);
        }
    })();
</script>
}
