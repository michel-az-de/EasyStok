@model PedidosAbertosViewModel
@{
    ViewBag.Title = "Pedidos em Aberto";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
        <a asp-action="Index" asp-controller="Fornecedores" class="text-gray-400 hover:text-gray-600">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Pedidos em Aberto</h1>
        <span class="px-2 py-0.5 bg-yellow-100 text-yellow-700 rounded-full text-sm font-medium">
            @Model.TotalPedidos
        </span>
    </div>
</div>

@if (!Model.Pedidos.Any())
{
    <div class="ws text-center py-16 text-gray-400">
        <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        <p class="text-sm">Nenhum pedido em aberto</p>
    </div>
}
else
{
    <div class="space-y-4">
        @foreach (var ped in Model.Pedidos)
        {
            <div class="ws" x-data="{ receberOpen: false }">
                <div class="flex items-start justify-between mb-3">
                    <div>
                        <div class="font-semibold text-gray-900">
                            @(ped.Fornecedor?.Nome ?? ped.FornId)
                        </div>
                        <div class="text-sm text-gray-500">
                            Pedido em @ped.Data.ToString("dd/MM/yyyy")
                            @if (ped.Previsao.HasValue)
                            {
                                <span> · Previsão: @ped.Previsao.Value.ToString("dd/MM/yyyy")</span>
                            }
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="px-2 py-0.5 rounded-full text-xs font-medium @(ped.Status == "em_transito" ? "bg-blue-100 text-blue-700" : "bg-yellow-100 text-yellow-700")">
                            @ped.Status.Replace("_", " ")
                        </span>
                        <span class="font-semibold text-gray-900">R$ @ped.Valor.ToString("N2")</span>
                    </div>
                </div>

                @if (ped.Itens.Any())
                {
                    <div class="border-t pt-3 mt-3">
                        <table class="w-full text-sm">
                            <tbody>
                                @foreach (var item in ped.Itens)
                                {
                                    <tr>
                                        <td class="py-1 text-gray-700">@item.Nome</td>
                                        <td class="py-1 text-gray-500 text-right">@item.Qty un.</td>
                                        <td class="py-1 text-gray-500 text-right">R$ @item.Custo.ToString("N2")/un</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="flex justify-end gap-3 mt-3 pt-3 border-t">
                    <form asp-action="CancelarPedido" asp-controller="Fornecedores"
                          asp-route-fornId="@ped.FornId" asp-route-pedId="@ped.Id"
                          method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="px-3 py-1.5 text-sm text-red-600 border border-red-200 rounded-lg hover:bg-red-50">
                            Cancelar
                        </button>
                    </form>
                    <button type="button" @@click="receberOpen = true"
                            class="px-4 py-1.5 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700">
                        Marcar como Recebido
                    </button>
                </div>

                <!-- Modal Receber -->
                <div x-show="receberOpen" x-cloak
                     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                     @@click.self="receberOpen = false">
                    <div class="bg-white rounded-xl p-6 w-80 shadow-xl">
                        <h3 class="font-semibold text-gray-900 mb-3">Confirmar Recebimento</h3>
                        <form asp-action="ReceberPedido" asp-controller="Fornecedores"
                              asp-route-fornId="@ped.FornId" asp-route-pedId="@ped.Id"
                              method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-4">
                                <label class="block text-sm text-gray-600 mb-1">Observação (opcional)</label>
                                <textarea name="obs" rows="2"
                                          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"></textarea>
                            </div>
                            <div class="flex justify-end gap-3">
                                <button type="button" @@click="receberOpen = false"
                                        class="px-3 py-1.5 text-sm border rounded-lg hover:bg-gray-50">
                                    Cancelar
                                </button>
                                <button type="submit"
                                        class="px-4 py-1.5 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700">
                                    Confirmar
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
