@model PedidosAbertosViewModel
@{
    ViewBag.Title = "Pedidos em Aberto";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
        <a asp-action="Index" asp-controller="Fornecedores" class="text-gray-400 hover:text-gray-600">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Pedidos em Aberto</h1>
        @if (Model.TotalPedidos > 0)
        {
            <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">
                @Model.TotalPedidos
            </span>
        }
    </div>
    <button type="button" x-data @@click="$dispatch('open-modal', 'novo-pedido')"
            class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
        + Novo Pedido
    </button>
</div>

@if (Model.TotalPedidos > 0)
{
    <!-- Resumo -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div class="ws">
            <div class="text-sm text-gray-500">Total de pedidos</div>
            <div class="text-2xl font-bold text-gray-900">@Model.TotalPedidos</div>
        </div>
        <div class="ws">
            <div class="text-sm text-gray-500">Valor total estimado</div>
            <div class="text-2xl font-bold text-gray-900">R$ @Model.ValorTotal.ToString("N2")</div>
        </div>
    </div>

    <!-- Tabela -->
    <div class="ws">
        <table class="tbl-full">
            <thead>
                <tr>
                    <th>Fornecedor</th>
                    <th>Data Pedido</th>
                    <th>Previsão Entrega</th>
                    <th>Valor</th>
                    <th>Status</th>
                    <th>Canal</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ped in Model.Pedidos)
                {
                    <tr x-data="{ confirmCancel: false }">
                        <td>
                            <a asp-action="Detail" asp-controller="Fornecedores" asp-route-id="@ped.FornecedorId"
                               class="font-medium text-indigo-600 hover:text-indigo-700">
                                @ped.FornecedorNome
                            </a>
                        </td>
                        <td class="text-gray-600">@ped.DataPedido.ToString("dd/MM/yyyy")</td>
                        <td class="text-gray-600">
                            @if (ped.PrevisaoEntrega.HasValue)
                            {
                                var previsao = ped.PrevisaoEntrega.Value;
                                var atrasado = previsao.Date < DateTime.Today && ped.Status != 3;
                                <span class="@(atrasado ? "text-red-600 font-medium" : "")">
                                    @previsao.ToString("dd/MM/yyyy")
                                    @if (atrasado)
                                    {
                                        <span class="text-xs ml-1">(atrasado)</span>
                                    }
                                </span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                        <td class="text-gray-600">R$ @((ped.ValorEstimado ?? 0).ToString("N2"))</td>
                        <td>
                            <span class="px-2 py-0.5 rounded-full text-xs font-medium @ped.StatusCssClass">
                                @ped.StatusLabel
                            </span>
                        </td>
                        <td class="text-gray-500 text-sm">@(ped.Canal ?? "—")</td>
                        <td>
                            <div class="flex items-center gap-2">
                                @if (ped.Status == 1 || ped.Status == 2)
                                {
                                    <form asp-action="ReceberPedido" asp-controller="Fornecedores"
                                          asp-route-id="@ped.PedidoId" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="text-xs text-emerald-600 hover:text-emerald-700 font-medium">
                                            Recebido
                                        </button>
                                    </form>
                                    <button type="button" @@click="confirmCancel = true"
                                            class="text-xs text-red-500 hover:text-red-700">
                                        Cancelar
                                    </button>
                                }
                                <a asp-action="Detail" asp-controller="Fornecedores" asp-route-id="@ped.FornecedorId"
                                   class="text-xs text-indigo-600 hover:text-indigo-700">Ver</a>
                            </div>

                            <!-- Confirmar cancelamento -->
                            <div x-show="confirmCancel" x-cloak
                                 class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                                 @@click.self="confirmCancel = false">
                                <div class="bg-white rounded-xl p-6 w-80 shadow-xl">
                                    <h3 class="font-semibold text-gray-900 mb-2">Cancelar pedido</h3>
                                    <p class="text-sm text-gray-600 mb-4">
                                        Cancelar pedido de <strong>@ped.FornecedorNome</strong>? Esta ação não pode ser desfeita.
                                    </p>
                                    <div class="flex justify-end gap-3">
                                        <button type="button" @@click="confirmCancel = false"
                                                class="px-3 py-1.5 text-sm border rounded-lg hover:bg-gray-50">
                                            Voltar
                                        </button>
                                        <form asp-action="CancelarPedido" asp-controller="Fornecedores"
                                              asp-route-id="@ped.PedidoId" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="px-3 py-1.5 bg-red-600 text-white text-sm rounded-lg hover:bg-red-700">
                                                Confirmar cancelamento
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="ws text-center py-16 text-gray-400">
        <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-sm font-medium text-gray-500 mb-1">Nenhum pedido em aberto</p>
        <p class="text-xs text-gray-400">Crie um novo pedido para um fornecedor.</p>
        <button type="button" x-data @@click="$dispatch('open-modal', 'novo-pedido')"
                class="mt-4 inline-block px-4 py-2 text-sm text-indigo-600 border border-indigo-200 rounded-lg hover:bg-indigo-50">
            + Novo Pedido
        </button>
    </div>
}

<!-- Modal Novo Pedido -->
<div x-data="{ open: false }" @@open-modal.window="open = ($event.detail === 'novo-pedido')"
     x-show="open" x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
     @@click.self="open = false">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Novo Pedido de Compra</h2>
        <form asp-action="CriarPedido" asp-controller="Fornecedores" method="post">
            @Html.AntiForgeryToken()
            <div class="space-y-3 mb-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Fornecedor *</label>
                    <select name="fornecedorId" required
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                        <option value="">Selecione...</option>
                        @foreach (var f in Model.Fornecedores)
                        {
                            <option value="@f.Id">@f.Nome</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Data do Pedido *</label>
                    <input type="date" name="dataPedido" required
                           value="@DateTime.Today.ToString("yyyy-MM-dd")"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Previsão de Entrega</label>
                    <input type="date" name="previsaoEntrega"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Valor Estimado (R$)</label>
                    <input type="number" name="valorEstimado" min="0" step="0.01" placeholder="0,00"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Canal</label>
                    <input type="text" name="canal" placeholder="Ex: WhatsApp, Site, Telefone"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Observações</label>
                    <textarea name="observacoes" rows="2" placeholder="Opcional"
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"></textarea>
                </div>
            </div>
            <div class="flex justify-end gap-3">
                <button type="button" @@click="open = false"
                        class="px-4 py-2 text-sm text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50">
                    Cancelar
                </button>
                <button type="submit"
                        class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                    Criar Pedido
                </button>
            </div>
        </form>
    </div>
</div>
