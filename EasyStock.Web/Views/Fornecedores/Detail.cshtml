@model FornecedorDetailViewModel
@{
    ViewBag.Title = Model.Fornecedor.Nome;
    Layout = "_Layout";
}

<div class="flex items-center gap-3 mb-6">
    <a asp-action="Index" asp-controller="Fornecedores" class="text-slate-400 hover:text-slate-600" aria-label="Voltar para fornecedores">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <h1 class="text-2xl font-bold text-slate-900">@Model.Fornecedor.Nome</h1>
    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-xs font-medium ring-1
                @(Model.Fornecedor.Ativo ? "bg-emerald-50 text-emerald-800 ring-emerald-200" : "bg-slate-50 text-slate-600 ring-slate-200")">
        <span class="w-1.5 h-1.5 rounded-full @(Model.Fornecedor.Ativo ? "bg-emerald-500" : "bg-slate-400")"></span>
        @Model.Fornecedor.Status
    </span>
    <div class="ml-auto">
        <a href="/fornecedores/pedidos-abertos?novo=1&fornecedorId=@Model.Fornecedor.Id"
           class="inline-flex items-center gap-1.5 px-3.5 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Novo pedido
        </a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Dados cadastrais -->
    <div class="lg:col-span-1 space-y-4">
        <div class="ws" x-data="{ editando: false }">
            <div class="flex items-center justify-between mb-4">
                <h2 class="font-semibold text-slate-900">Dados Cadastrais</h2>
                <button type="button" @@click="editando = !editando"
                        class="text-sm text-indigo-600 hover:text-indigo-700">
                    <span x-text="editando ? 'Cancelar' : 'Editar'"></span>
                </button>
            </div>

            <div x-show="!editando">
                <dl class="space-y-3 text-sm">
                    @if (!string.IsNullOrEmpty(Model.Fornecedor.Documento))
                    {
                        <div><dt class="text-slate-500">CNPJ/CPF</dt><dd class="font-medium">@Model.Fornecedor.Documento</dd></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Fornecedor.Contato))
                    {
                        <div><dt class="text-slate-500">Responsável</dt><dd class="font-medium">@Model.Fornecedor.Contato</dd></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Fornecedor.Email))
                    {
                        <div><dt class="text-slate-500">Email</dt><dd class="font-medium">@Model.Fornecedor.Email</dd></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Fornecedor.Telefone))
                    {
                        <div><dt class="text-slate-500">Telefone</dt><dd class="font-medium">@Model.Fornecedor.Telefone</dd></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Fornecedor.Tipo))
                    {
                        <div><dt class="text-slate-500">Tipo</dt><dd class="font-medium capitalize">@Model.Fornecedor.Tipo</dd></div>
                    }
                    @if (Model.Fornecedor.LeadTimeEstimadoDias.HasValue)
                    {
                        <div><dt class="text-slate-500">Lead Time</dt><dd class="font-medium">@Model.Fornecedor.LeadTimeEstimadoDias dias</dd></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Fornecedor.Categoria))
                    {
                        <div><dt class="text-slate-500">Categorias</dt><dd class="font-medium">@Model.Fornecedor.Categoria</dd></div>
                    }
                </dl>
            </div>

            <form asp-action="Editar" asp-controller="Fornecedores" asp-route-id="@Model.Fornecedor.Id"
                  method="post" x-show="editando" x-cloak>
                @Html.AntiForgeryToken()
                <div class="space-y-3">
                    <div>
                        <label for="forn-edit-nome" class="block text-xs text-slate-500 mb-1">Nome *</label>
                        <input id="forn-edit-nome" type="text" name="nome" value="@Model.Fornecedor.Nome" required aria-required="true"
                               class="w-full border border-slate-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <div>
                        <label for="forn-edit-documento" class="block text-xs text-slate-500 mb-1">CNPJ/CPF</label>
                        <input id="forn-edit-documento" type="text" name="documento" value="@Model.Fornecedor.Documento"
                               data-mask="doc" inputmode="numeric"
                               class="w-full border border-slate-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <div>
                        <label for="forn-edit-contato" class="block text-xs text-slate-500 mb-1">Responsável</label>
                        <input id="forn-edit-contato" type="text" name="contato" value="@Model.Fornecedor.Contato"
                               class="w-full border border-slate-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <div>
                        <label for="forn-edit-email" class="block text-xs text-slate-500 mb-1">Email</label>
                        <input id="forn-edit-email" type="email" name="email" value="@Model.Fornecedor.Email"
                               class="w-full border border-slate-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <div>
                        <label for="forn-edit-telefone" class="block text-xs text-slate-500 mb-1">Telefone</label>
                        <input id="forn-edit-telefone" type="text" name="telefone" value="@Model.Fornecedor.Telefone"
                               data-mask="phone" inputmode="numeric" autocomplete="tel"
                               class="w-full border border-slate-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <div>
                        <label for="forn-edit-tipo" class="block text-xs text-slate-500 mb-1">Tipo</label>
                        <select id="forn-edit-tipo" name="tipo" class="w-full border border-slate-300 rounded px-2 py-1.5 text-sm">
                            <option value="" selected="@(string.IsNullOrEmpty(Model.Fornecedor.Tipo))">Selecione...</option>
                            @{
                                var tipoOpts = new[] { "nacional", "importado", "dropshipping" };
                                foreach (var opt in tipoOpts)
                                {
                                    <option value="@opt" selected="@(Model.Fornecedor.Tipo == opt)">@opt</option>
                                }
                            }
                        </select>
                    </div>
                    <div>
                        <label for="forn-edit-lead" class="block text-xs text-slate-500 mb-1">Lead Time (dias)</label>
                        <input id="forn-edit-lead" type="number" name="leadTimeEstimadoDias" value="@Model.Fornecedor.LeadTimeEstimadoDias"
                               class="w-full border border-slate-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <div>
                        <label for="forn-edit-categoria" class="block text-xs text-slate-500 mb-1">Categorias</label>
                        <input id="forn-edit-categoria" type="text" name="categoria" value="@Model.Fornecedor.Categoria"
                               class="w-full border border-slate-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <div>
                        <label for="forn-edit-site" class="block text-xs text-slate-500 mb-1">Site</label>
                        <input id="forn-edit-site" type="url" name="siteUrl" value="@Model.Fornecedor.SiteUrl" placeholder="https://"
                               class="w-full border border-slate-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <div>
                        <label for="forn-edit-pedido-minimo" class="block text-xs text-slate-500 mb-1">Pedido Mínimo</label>
                        <input id="forn-edit-pedido-minimo" type="text" name="pedidoMinimo" value="@Model.Fornecedor.PedidoMinimo"
                               class="w-full border border-slate-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <div>
                        <label for="forn-edit-frete" class="block text-xs text-slate-500 mb-1">Frete Padrão</label>
                        <input id="forn-edit-frete" type="text" name="fretePadrao" value="@Model.Fornecedor.FretePadrao"
                               class="w-full border border-slate-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <div>
                        <label for="forn-edit-observacoes" class="block text-xs text-slate-500 mb-1">Observações</label>
                        <textarea id="forn-edit-observacoes" name="observacoes" rows="2"
                                  class="w-full border border-slate-300 rounded px-2 py-1.5 text-sm">@Model.Fornecedor.Observacoes</textarea>
                    </div>
                    <button type="submit" x-data="{ loading: false }" @@click="loading = true"
                            :disabled="loading" :class="{ 'opacity-50 cursor-not-allowed': loading }"
                            class="w-full py-1.5 bg-indigo-600 text-white text-sm rounded hover:bg-indigo-700">
                        <span x-show="!loading">Salvar</span>
                        <span x-show="loading" x-cloak class="flex items-center justify-center gap-2"><span class="spinner"></span> Salvando...</span>
                    </button>
                </div>
            </form>
        </div>

        <!-- KPIs -->
        <div class="ws">
            <h2 class="font-semibold text-slate-900 mb-3">Resumo</h2>
            @if (Model.QuantidadePedidos == 0)
            {
                <p class="text-sm text-slate-400 text-center py-4">Nenhum pedido registrado ainda.</p>
            }
            else
            {
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-slate-500">Total gasto</span>
                        <span class="font-semibold text-slate-900">R$ @Model.TotalGasto.ToString("N2")</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-500">Lead médio real</span>
                        <span class="font-semibold text-slate-900">
                            @(Model.LeadRealMedio.HasValue ? $"{Model.LeadRealMedio:N0} dias" : "—")
                        </span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-500">Total de pedidos</span>
                        <span class="font-semibold text-slate-900">@Model.QuantidadePedidos</span>
                    </div>
                </div>
            }
        </div>

        <!-- Excluir -->
        <div class="ws" x-data="{ confirm: false }">
            <button type="button" @@click="confirm = true"
                    class="w-full py-2 text-sm text-red-600 border border-red-200 rounded-lg hover:bg-red-50">
                Desativar Fornecedor
            </button>
            <div x-show="confirm" x-cloak
                 class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                 @@click.self="confirm = false">
                <div class="bg-white rounded-xl p-6 w-80 shadow-xl">
                    <h3 class="font-semibold text-slate-900 mb-2">Confirmar desativação</h3>
                    <p class="text-sm text-slate-600 mb-4">O fornecedor será marcado como inativo.</p>
                    <div class="flex justify-end gap-3">
                        <button type="button" @@click="confirm = false"
                                class="px-3 py-1.5 text-sm border rounded-lg hover:bg-slate-50">Cancelar</button>
                        <form asp-action="Excluir" asp-controller="Fornecedores"
                              asp-route-id="@Model.Fornecedor.Id" method="post"
                              x-data="{ loading: false }" @@submit="loading = true">
                            @Html.AntiForgeryToken()
                            <button type="submit" :disabled="loading" :class="{ 'opacity-50 cursor-not-allowed': loading }"
                                    class="px-3 py-1.5 text-sm bg-red-600 text-white rounded-lg hover:bg-red-700">
                                <span x-show="!loading">Desativar</span>
                                <span x-show="loading" x-cloak class="flex items-center gap-2"><span class="spinner"></span> Desativando...</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Histórico -->
    <div class="lg:col-span-2 space-y-4">
        @if (Model.Historico.Any())
        {
            <div class="ws">
                <h2 class="font-semibold text-slate-900 mb-4">Histórico de Pedidos</h2>
                <div class="overflow-x-auto">
                <table class="tbl-full">
                    <thead>
                        <tr><th>Data</th><th>Previsão</th><th>Valor</th><th>Status</th><th>Obs</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var ped in Model.Historico)
                        {
                            <tr>
                                <td>@ped.DataPedido.ToString("dd/MM/yyyy")</td>
                                <td>@(ped.PrevisaoEntrega?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>R$ @((ped.ValorEstimado ?? 0).ToString("N2"))</td>
                                <td>
                                    <span class="px-2 py-0.5 rounded-full text-xs font-medium @ped.StatusCssClass">
                                        @ped.StatusLabel
                                    </span>
                                </td>                                <td class="text-slate-500 text-sm">@(ped.Observacoes ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            </div>
        }
        else
        {
            <div class="ws text-center py-12 text-slate-400">
                <div class="text-4xl mb-3">📦</div>
                <p class="text-sm font-medium text-slate-500">Nenhum pedido registrado</p>
                <p class="text-xs mt-1 text-slate-400">O histórico de pedidos aparece aqui quando pedidos forem criados para este fornecedor.</p>
            </div>
        }

        <!-- Onda P4 — Histórico de alterações cadastrais -->
        <div class="ws" x-data="{ expanded: false }">
            <div class="flex items-center justify-between mb-2">
                <h2 class="font-semibold text-slate-900">Histórico de Alterações <span class="text-xs text-slate-400 font-normal">(@Model.Alteracoes.Count)</span></h2>
                @if (Model.Alteracoes.Count > 10)
                {
                    <button type="button" @@click="expanded = !expanded" class="text-sm text-indigo-600 hover:text-indigo-700">
                        <span x-text="expanded ? 'Mostrar menos' : 'Ver tudo'"></span>
                    </button>
                }
            </div>
            @if (!Model.Alteracoes.Any())
            {
                <p class="text-sm text-slate-500">Nenhuma alteração registrada ainda. Quando alguém editar dados cadastrais, o diff aparece aqui.</p>
            }
            else
            {
                <ul class="divide-y divide-slate-100">
                @{
                    var visiveis = Model.Alteracoes;
                }
                @for (int idx = 0; idx < visiveis.Count; idx++)
                {
                    var a = visiveis[idx];
                    var classeOculta = idx >= 10 ? "alt-extra" : "";
                    <li class="py-2 text-sm @classeOculta" @(idx >= 10 ? "x-show=\"expanded\" x-cloak" : "")>
                        <div class="flex items-center gap-2 flex-wrap">
                            <span class="text-xs text-slate-400 font-mono">@a.AlteradoEm.ToLocalTime().ToString("dd/MM HH:mm")</span>
                            <span class="font-medium text-slate-900">@a.Campo</span>
                            <span class="text-xs px-1.5 py-0.5 bg-slate-100 text-slate-600 rounded">@(a.Origem ?? "?")</span>
                        </div>
                        <div class="text-xs text-slate-600 ml-2">
                            <span class="line-through text-slate-400">@(a.ValorAntigo ?? "—")</span>
                            <span class="mx-1">→</span>
                            <span class="font-medium">@(a.ValorNovo ?? "—")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(a.AlteradoPorNome))
                        {
                            <div class="text-xs text-slate-400 ml-2">por @a.AlteradoPorNome</div>
                        }
                    </li>
                }
                </ul>
            }
        </div>
    </div>
</div>
