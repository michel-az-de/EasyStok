@model FornecedorDetailViewModel
@{
    ViewBag.Title = Model.Fornecedor.Nome;
    Layout = "_Layout";
}

<div class="flex items-center gap-3 mb-6">
    <a asp-action="Index" asp-controller="Fornecedores" class="text-gray-400 hover:text-gray-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <h1 class="text-2xl font-bold text-gray-900">@Model.Fornecedor.Nome</h1>
    <span class="px-2 py-0.5 rounded-full text-xs font-medium @(Model.Fornecedor.Status == "ativo" ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-600")">
        @Model.Fornecedor.Status
    </span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Dados cadastrais -->
    <div class="lg:col-span-1 space-y-4">
        <div class="ws" x-data="{ editando: false }">
            <div class="flex items-center justify-between mb-4">
                <h2 class="font-semibold text-gray-900">Dados Cadastrais</h2>
                <button type="button" @@click="editando = !editando"
                        class="text-sm text-indigo-600 hover:text-indigo-700">
                    <span x-text="editando ? 'Cancelar' : 'Editar'"></span>
                </button>
            </div>

            <div x-show="!editando">
                <dl class="space-y-3 text-sm">
                    @if (!string.IsNullOrEmpty(Model.Fornecedor.Cnpj))
                    {
                        <div><dt class="text-gray-500">CNPJ/CPF</dt><dd class="font-medium">@Model.Fornecedor.Cnpj</dd></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Fornecedor.Resp))
                    {
                        <div><dt class="text-gray-500">Responsável</dt><dd class="font-medium">@Model.Fornecedor.Resp</dd></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Fornecedor.Email))
                    {
                        <div><dt class="text-gray-500">Email</dt><dd class="font-medium">@Model.Fornecedor.Email</dd></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Fornecedor.Tel))
                    {
                        <div><dt class="text-gray-500">Telefone</dt><dd class="font-medium">@Model.Fornecedor.Tel</dd></div>
                    }
                    <div><dt class="text-gray-500">Tipo</dt><dd class="font-medium capitalize">@Model.Fornecedor.Tipo</dd></div>
                    <div><dt class="text-gray-500">Prazo de entrega</dt><dd class="font-medium">@Model.Fornecedor.Lead dias</dd></div>
                    <div><dt class="text-gray-500">Pagamento</dt><dd class="font-medium">@Model.Fornecedor.Pgto</dd></div>
                    <div><dt class="text-gray-500">Categorias</dt><dd class="font-medium">@Model.Fornecedor.Cats</dd></div>
                </dl>
            </div>

            <form asp-action="Editar" asp-controller="Fornecedores" asp-route-id="@Model.Fornecedor.Id"
                  method="post" x-show="editando" x-cloak>
                @Html.AntiForgeryToken()
                <div class="space-y-3">
                    <div>
                        <label class="block text-xs text-gray-500 mb-1">Nome</label>
                        <input type="text" name="nome" value="@Model.Fornecedor.Nome"
                               class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <div>
                        <label class="block text-xs text-gray-500 mb-1">Email</label>
                        <input type="email" name="email" value="@Model.Fornecedor.Email"
                               class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <div>
                        <label class="block text-xs text-gray-500 mb-1">Prazo de entrega (dias)</label>
                        <input type="number" name="lead" value="@Model.Fornecedor.Lead"
                               class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm" />
                    </div>
                    <input type="hidden" name="cnpj" value="@Model.Fornecedor.Cnpj" />
                    <input type="hidden" name="resp" value="@Model.Fornecedor.Resp" />
                    <input type="hidden" name="tel" value="@Model.Fornecedor.Tel" />
                    <input type="hidden" name="pgto" value="@Model.Fornecedor.Pgto" />
                    <input type="hidden" name="tipo" value="@Model.Fornecedor.Tipo" />
                    <input type="hidden" name="cats" value="@Model.Fornecedor.Cats" />
                    <button type="submit"
                            class="w-full py-1.5 bg-indigo-600 text-white text-sm rounded hover:bg-indigo-700">
                        Salvar
                    </button>
                </div>
            </form>
        </div>

        <!-- KPIs -->
        <div class="ws">
            <h2 class="font-semibold text-gray-900 mb-3">Resumo</h2>
            <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                    <span class="text-gray-500">Total gasto</span>
                    <span class="font-semibold text-gray-900">R$ @Model.TotalGasto.ToString("N2")</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-500">Prazo médio real</span>
                    <span class="font-semibold text-gray-900">@Model.LeadRealMedio dias</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-500">Pedidos abertos</span>
                    <span class="font-semibold text-gray-900">@Model.PedidosAbertos.Count</span>
                </div>
            </div>
        </div>

        <!-- Excluir -->
        <div class="ws" x-data="{ confirm: false }">
            <button type="button" @@click="confirm = true"
                    class="w-full py-2 text-sm text-red-600 border border-red-200 rounded-lg hover:bg-red-50">
                Excluir Fornecedor
            </button>
            <div x-show="confirm" x-cloak
                 class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                 @@click.self="confirm = false">
                <div class="bg-white rounded-xl p-6 w-80 shadow-xl">
                    <h3 class="font-semibold text-gray-900 mb-2">Confirmar exclusão</h3>
                    <p class="text-sm text-gray-600 mb-4">Esta ação não pode ser desfeita.</p>
                    <div class="flex justify-end gap-3">
                        <button type="button" @@click="confirm = false"
                                class="px-3 py-1.5 text-sm border rounded-lg hover:bg-gray-50">Cancelar</button>
                        <form asp-action="Excluir" asp-controller="Fornecedores"
                              asp-route-id="@Model.Fornecedor.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="px-3 py-1.5 text-sm bg-red-600 text-white rounded-lg hover:bg-red-700">
                                Excluir
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pedidos em aberto + histórico -->
    <div class="lg:col-span-2 space-y-4">
        @if (Model.PedidosAbertos.Any())
        {
            <div class="ws">
                <h2 class="font-semibold text-gray-900 mb-4">Pedidos em Aberto</h2>
                <table class="tbl-full">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Previsão</th>
                            <th>Valor</th>
                            <th>Status</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ped in Model.PedidosAbertos)
                        {
                            <tr>
                                <td>@ped.Data.ToString("dd/MM/yyyy")</td>
                                <td>@(ped.Previsao?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>R$ @ped.Valor.ToString("N2")</td>
                                <td>
                                    <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">
                                        @ped.Status
                                    </span>
                                </td>
                                <td>
                                    <form asp-action="ReceberPedido" asp-controller="Fornecedores"
                                          asp-route-fornId="@Model.Fornecedor.Id" asp-route-pedId="@ped.Id"
                                          method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="text-xs text-green-600 hover:text-green-700 font-medium">
                                            Receber
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.Historico.Any())
        {
            <div class="ws">
                <h2 class="font-semibold text-gray-900 mb-4">Histórico de Pedidos</h2>
                <table class="tbl-full">
                    <thead>
                        <tr><th>Data</th><th>Valor</th><th>Status</th><th>Obs</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var ped in Model.Historico)
                        {
                            <tr>
                                <td>@ped.Data.ToString("dd/MM/yyyy")</td>
                                <td>R$ @ped.Valor.ToString("N2")</td>
                                <td><span class="px-2 py-0.5 rounded-full text-xs bg-gray-100 text-gray-600">@ped.Status</span></td>
                                <td class="text-gray-500 text-sm">@(ped.Obs ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (!Model.PedidosAbertos.Any() && !Model.Historico.Any())
        {
            <div class="ws text-center py-12 text-gray-400">
                <div class="text-4xl mb-2">📋</div>
                <p class="text-sm font-medium text-gray-500">Nenhum pedido registrado</p>
                <p class="text-xs mt-1">Os pedidos feitos a este fornecedor aparecerão aqui.</p>
            </div>
        }
    </div>
</div>
