@model CaixaOperacaoViewModel
@{
    ViewBag.Title = "Caixa";
    Layout = "_Layout";
    var d = Model.Dia;
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Caixa do dia</h1>
        <p>@(Model.DataSelecionada.ToString("dd/MM/yyyy"))</p>
    </div>
    <div class="flex gap-3">
        <a href="/caixa-mobile" class="ui-secondary-btn px-4 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50">📱 Lançamentos do app</a>
        <a href="/caixa/historico" class="ui-secondary-btn px-4 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50">📚 Histórico</a>
    </div>
</div>

@if (d == null)
{
    <div class="ws"><p class="text-slate-500">Não foi possível carregar o caixa do dia.</p></div>
}
else
{
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
        <div class="ws">
            <h3 class="text-sm font-semibold text-slate-500 mb-1">Saldo esperado</h3>
            <div class="text-2xl font-bold text-slate-900">@d.SaldoEsperado.ToString("C")</div>
            <div class="text-xs text-slate-500 mt-1">
                @(d.Fechado ? "Caixa fechado" : (d.Aberto ? "Caixa aberto" : "Caixa não aberto"))
            </div>
        </div>
        <div class="ws">
            <h3 class="text-sm font-semibold text-slate-500 mb-1">Vendas + pagamentos</h3>
            <div class="text-2xl font-bold text-green-600">@((d.TotalVendas + d.TotalPagamentosPedidos).ToString("C"))</div>
            <div class="text-xs text-slate-500 mt-1">Vendas: @d.TotalVendas.ToString("C") · Pagamentos: @d.TotalPagamentosPedidos.ToString("C")</div>
        </div>
        <div class="ws">
            <h3 class="text-sm font-semibold text-slate-500 mb-1">Entradas/saídas extras</h3>
            <div class="text-2xl font-bold text-slate-900">@((d.TotalEntradasExtras - d.TotalSaidasExtras).ToString("C"))</div>
            <div class="text-xs text-slate-500 mt-1">Entradas: +@d.TotalEntradasExtras.ToString("C") · Saídas: -@d.TotalSaidasExtras.ToString("C")</div>
        </div>
    </div>

    <!-- Ações: abrir/fechar/lançar -->
    <div class="ws mb-6">
        <div class="flex flex-wrap gap-3 items-center">
            @if (!d.Aberto && !d.Fechado)
            {
                <form asp-action="Abrir" asp-controller="Caixa" method="post" class="flex gap-2 items-center" x-data>
                    @Html.AntiForgeryToken()
                    <input type="number" step="0.01" min="0" name="saldoInicial" placeholder="Saldo inicial" required class="ui-field text-sm" />
                    <input type="text" name="observacoes" placeholder="Obs (opcional)" class="ui-field text-sm" />
                    <button type="submit" class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                        🔓 Abrir caixa
                    </button>
                </form>
            }
            @if (d.Aberto && !d.Fechado)
            {
                <button type="button" x-data @@click="$dispatch('open-modal', 'lancar-mov')"
                        class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                    + Lançar entrada/saída
                </button>
                <form asp-action="Fechar" asp-controller="Caixa" method="post" class="flex gap-2 items-center"
                      onsubmit="return confirm('Fechar caixa do dia? Saldo final: @d.SaldoEsperado.ToString("C")');">
                    @Html.AntiForgeryToken()
                    <input type="text" name="observacoes" placeholder="Obs do fechamento (opcional)" class="ui-field text-sm" />
                    <button type="submit" class="ui-secondary-btn px-4 py-2 bg-white border border-amber-300 text-amber-700 text-sm font-medium rounded-lg hover:bg-amber-50">
                        🔒 Fechar caixa
                    </button>
                </form>
            }
            @if (d.Fechado && d.Fechamento != null)
            {
                <span class="text-sm text-slate-600">
                    Fechado em @d.Fechamento.FechadoEm.ToLocalTime():dd/MM HH:mm
                    @if (!string.IsNullOrEmpty(d.Fechamento.FechadoPorNome)) { <span class="text-slate-400">por @d.Fechamento.FechadoPorNome</span> }
                    · Saldo final: <strong>@d.Fechamento.SaldoFinal.ToString("C")</strong>
                </span>
            }
        </div>
    </div>

    <!-- Lista de movimentos -->
    <div class="ws">
        <h2 class="font-semibold text-slate-900 mb-4">Movimentos do dia (@d.Movimentos.Count)</h2>
        @if (!d.Movimentos.Any())
        {
            <p class="text-sm text-slate-500">Nenhum movimento registrado ainda.</p>
        }
        else
        {
            <div class="overflow-x-auto">
            <table class="tbl-full">
                <thead><tr><th>Hora</th><th>Tipo</th><th>Valor</th><th>Descrição</th><th>Categoria</th><th>Origem</th><th></th></tr></thead>
                <tbody>
                @foreach (var m in d.Movimentos)
                {
                    string tipoBadge = m.Tipo switch
                    {
                        "abertura"   => "bg-blue-100 text-blue-700",
                        "fechamento" => "bg-slate-100 text-slate-600",
                        "entrada"    => "bg-green-100 text-green-700",
                        "saida"      => "bg-red-100 text-red-700",
                        _            => "bg-slate-100 text-slate-600"
                    };
                    <tr>
                        <td class="text-xs text-slate-500">@m.DataMovimento.ToLocalTime().ToString("HH:mm")</td>
                        <td><span class="px-2 py-0.5 rounded-full text-xs font-medium @tipoBadge">@m.Tipo</span></td>
                        <td class="font-medium @(m.Tipo == "saida" ? "text-red-700" : "text-slate-900")">
                            @(m.Tipo == "saida" ? "-" : "+")@m.Valor.ToString("C")
                        </td>
                        <td class="text-sm text-slate-600">@(m.Descricao ?? "—")</td>
                        <td class="text-xs text-slate-500">@(m.Categoria ?? "—")</td>
                        <td class="text-xs text-slate-500">@(m.Origem ?? "—") @if (!string.IsNullOrEmpty(m.RegistradoPorNome)) { <div class="text-slate-400">@m.RegistradoPorNome</div> }</td>
                        <td>
                            @if (m.Tipo != "abertura" && m.Tipo != "fechamento" && !d.Fechado)
                            {
                                <form asp-action="Estornar" asp-controller="Caixa" asp-route-id="@m.Id" method="post" onsubmit="return confirm('Estornar este movimento?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-xs text-red-600 hover:text-red-700">Estornar</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            </div>
        }
    </div>

    <!-- Modal lançar entrada/saída -->
    <div x-data="lancamentoCaixaModal()" @@open-modal.window="if ($event.detail === 'lancar-mov') open = true"
         x-show="open" x-cloak
         class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
         @@click.self="open = false" @@keydown.escape.window="open = false">
        <div class="ui-modal bg-white rounded-xl shadow-xl w-full max-w-xl p-6">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Lançar entrada/saída</h2>
            <form asp-action="RegistrarMovimento" asp-controller="Caixa" method="post" class="space-y-3">
                @Html.AntiForgeryToken()
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Tipo *</label>
                        <select name="tipo" required class="ui-select w-full text-sm">
                            <option value="entrada">Entrada (recebimento)</option>
                            <option value="saida">Saída (despesa, sangria)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Valor *</label>
                        <input type="number" name="valor" step="0.01" min="0.01" required class="ui-field w-full text-sm" />
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Descrição</label>
                        <input type="text" name="descricao" class="ui-field w-full text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Método</label>
                        <select name="metodo" class="ui-select w-full text-sm">
                            <option value="">—</option>
                            <option value="dinheiro">Dinheiro</option>
                            <option value="pix">PIX</option>
                            <option value="credito">Crédito</option>
                            <option value="debito">Débito</option>
                            <option value="transferencia">Transferência</option>
                            <option value="outro">Outro</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Categoria</label>
                        <input type="text" name="categoria" placeholder="Ex: embalagem, sangria" class="ui-field w-full text-sm" />
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Referência</label>
                        <input type="text" name="referencia" placeholder="txid, NSU, n° NF" class="ui-field w-full text-sm" />
                    </div>
                </div>
                <div class="flex justify-end gap-3 pt-3 border-t">
                    <button type="button" @@click="open = false" class="ui-secondary-btn px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">Cancelar</button>
                    <button type="submit" class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">Registrar</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
function lancamentoCaixaModal() { return { open: false }; }
</script>
}
