@model CaixaOperacaoViewModel
@{
    ViewBag.Title = "Caixa";
    Layout = "_Layout";
    var d = Model.Dia;
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Caixa do dia</h1>
        <p>@(Model.DataSelecionada.ToString("dd/MM/yyyy"))</p>
    </div>
    <div class="flex gap-3">
        <a href="/caixa-mobile" class="ui-secondary-btn px-4 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50">📱 Lançamentos do app</a>
        <a href="/caixa/historico" class="ui-secondary-btn px-4 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50">📚 Histórico</a>
    </div>
</div>

@if (d == null)
{
    var isLojaIssue = string.Equals(Model.ErrorCode, "EMPRESA_INVALIDA", StringComparison.OrdinalIgnoreCase)
                      || string.Equals(Model.ErrorCode, "LOJA_NAO_SELECIONADA", StringComparison.OrdinalIgnoreCase)
                      || string.IsNullOrEmpty(ViewBag.LojaAtualId as string);
    var isAuthIssue = string.Equals(Model.ErrorCode, "UNAUTHORIZED", StringComparison.OrdinalIgnoreCase)
                      || string.Equals(Model.ErrorCode, "TOKEN_EXPIRED", StringComparison.OrdinalIgnoreCase)
                      || string.Equals(Model.ErrorCode, "AUTH_TOKEN_EXPIRED", StringComparison.OrdinalIgnoreCase);
    // Auto-retry só pra falha transitória (rede/timeout/5xx). Loja/auth precisam de ação humana.
    var canAutoRetry = !isLojaIssue && !isAuthIssue;

    <div class="ws bg-red-50 border border-red-200 rounded-xl p-8 text-center"
         x-data="caixaAutoRetry(@(canAutoRetry ? "true" : "false"))" x-init="start()">
        <svg class="w-12 h-12 mx-auto text-red-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <p class="text-red-700 font-semibold text-base">Não foi possível carregar o caixa do dia.</p>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <p class="text-sm text-red-600 mt-1">@Model.ErrorMessage</p>
        }

        @if (isLojaIssue)
        {
            <p class="text-sm text-slate-600 mt-3 max-w-md mx-auto">
                Selecione uma loja no seletor do topo da página antes de acessar o caixa.
            </p>
        }
        else if (isAuthIssue)
        {
            <p class="text-sm text-slate-600 mt-3 max-w-md mx-auto">
                Sua sessão expirou. Faça login novamente para continuar.
            </p>
        }
        else
        {
            <p class="text-sm text-slate-600 mt-3 max-w-md mx-auto">
                Tentaremos automaticamente novamente. Se o problema persistir, contate o suporte.
            </p>
            <p x-show="enabled && !exhausted" x-cloak
               class="text-xs text-slate-500 mt-2">
                <span x-show="retrying">Tentando novamente…</span>
                <span x-show="!retrying">
                    Tentativa <span x-text="attempts + 1"></span> de <span x-text="maxAttempts"></span>
                    em <span x-text="countdown" class="font-semibold"></span>s
                </span>
            </p>
            <p x-show="exhausted" x-cloak class="text-xs text-amber-600 mt-2 font-medium">
                Tentativas automáticas esgotadas. Use o botão abaixo para tentar manualmente.
            </p>
        }

        <div class="flex justify-center gap-3 mt-5 flex-wrap">
            <button type="button" @@click="retryNow()"
                    class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 inline-flex items-center gap-2">
                <svg class="w-4 h-4" :class="retrying && 'animate-spin'" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Tentar agora
            </button>
            @if (canAutoRetry)
            {
                <button type="button" x-show="enabled && !exhausted" @@click="cancel()"
                        class="ui-secondary-btn px-4 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50">
                    Cancelar tentativas automáticas
                </button>
            }
            @if (isAuthIssue)
            {
                <a href="/auth/login" class="ui-secondary-btn px-4 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50">
                    Ir para login
                </a>
            }
            else
            {
                <a href="/caixa/historico" class="ui-secondary-btn px-4 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50">
                    Ver histórico de fechamentos
                </a>
            }
        </div>
    </div>
}
else
{
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
        <div class="ws">
            <h3 class="text-sm font-semibold text-slate-500 mb-1">Saldo esperado</h3>
            <div class="text-2xl font-bold text-slate-900">@d.SaldoEsperado.ToString("C")</div>
            <div class="text-xs text-slate-500 mt-1">
                @(d.Fechado ? "Caixa fechado" : (d.Aberto ? "Caixa aberto" : "Caixa não aberto"))
            </div>
        </div>
        <div class="ws">
            <h3 class="text-sm font-semibold text-slate-500 mb-1">Vendas + pagamentos</h3>
            <div class="text-2xl font-bold text-green-600">@((d.TotalVendas + d.TotalPagamentosPedidos).ToString("C"))</div>
            <div class="text-xs text-slate-500 mt-1">Vendas: @d.TotalVendas.ToString("C") · Pagamentos: @d.TotalPagamentosPedidos.ToString("C")</div>
        </div>
        <div class="ws">
            <h3 class="text-sm font-semibold text-slate-500 mb-1">Entradas/saídas extras</h3>
            <div class="text-2xl font-bold text-slate-900">@((d.TotalEntradasExtras - d.TotalSaidasExtras).ToString("C"))</div>
            <div class="text-xs text-slate-500 mt-1">Entradas: +@d.TotalEntradasExtras.ToString("C") · Saídas: -@d.TotalSaidasExtras.ToString("C")</div>
        </div>
    </div>

    <!-- Ações: abrir/fechar/lançar -->
    <div class="ws mb-6">
        <div class="flex flex-wrap gap-3 items-center">
            @if (!d.Aberto && !d.Fechado)
            {
                <form asp-action="Abrir" asp-controller="Caixa" method="post" data-validate class="flex gap-2 items-center" x-data>
                    @Html.AntiForgeryToken()
                    <input type="number" step="0.01" min="0" name="saldoInicial" placeholder="Saldo inicial" required
                           aria-label="Saldo inicial do caixa"
                           data-error-message="Informe um saldo inicial válido (use 0 se não houver caixa físico)."
                           class="ui-field text-sm" />
                    <input type="text" name="observacoes" placeholder="Obs (opcional)" maxlength="200" aria-label="Observações" class="ui-field text-sm" />
                    <button type="submit" class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                        🔓 Abrir caixa
                    </button>
                </form>
            }
            @if (d.Aberto && !d.Fechado)
            {
                <button type="button" x-data @@click="$dispatch('open-modal', 'lancar-mov')"
                        class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                    + Lançar entrada/saída
                </button>
                <form asp-action="Fechar" asp-controller="Caixa" method="post" class="flex gap-2 items-center"
                      data-confirm='@($"{{\"titulo\":\"Fechar caixa do dia?\",\"mensagem\":\"Saldo final: {d.SaldoEsperado.ToString("C")}. Esta acao nao pode ser desfeita.\",\"textoBotao\":\"Fechar caixa\",\"classBotao\":\"bg-amber-600 hover:bg-amber-700\"}}")'>
                    @Html.AntiForgeryToken()
                    <input type="text" name="observacoes" placeholder="Obs do fechamento (opcional)" aria-label="Observações do fechamento" class="ui-field text-sm" />
                    <button type="submit" class="ui-secondary-btn px-4 py-2 bg-white border border-amber-300 text-amber-700 text-sm font-medium rounded-lg hover:bg-amber-50">
                        🔒 Fechar caixa
                    </button>
                </form>
            }
            @if (d.Fechado && d.Fechamento != null)
            {
                <span class="text-sm text-slate-600">
                    Fechado em @d.Fechamento.FechadoEm.ToLocalTime().ToString("dd/MM HH:mm")
                    @if (!string.IsNullOrEmpty(d.Fechamento.FechadoPorNome)) { <span class="text-slate-400">por @d.Fechamento.FechadoPorNome</span> }
                    · Saldo final: <strong>@d.Fechamento.SaldoFinal.ToString("C")</strong>
                </span>
            }
        </div>
    </div>

    <!-- Lista de movimentos -->
    <div class="ws">
        <h2 class="font-semibold text-slate-900 mb-4">Movimentos do dia (@d.Movimentos.Count)</h2>
        @if (!d.Movimentos.Any())
        {
            <p class="text-sm text-slate-500">Nenhum movimento registrado ainda.</p>
        }
        else
        {
            <div class="overflow-x-auto">
            <table class="tbl-full">
                <thead><tr><th>Hora</th><th>Tipo</th><th>Valor</th><th>Descrição</th><th>Categoria</th><th>Origem</th><th></th></tr></thead>
                <tbody>
                @foreach (var m in d.Movimentos)
                {
                    string tipoBadge = m.Tipo switch
                    {
                        "abertura"   => "bg-blue-100 text-blue-700",
                        "fechamento" => "bg-slate-100 text-slate-600",
                        "entrada"    => "bg-green-100 text-green-700",
                        "saida"      => "bg-red-100 text-red-700",
                        _            => "bg-slate-100 text-slate-600"
                    };
                    <tr>
                        <td class="text-xs text-slate-500">@m.DataMovimento.ToLocalTime().ToString("HH:mm")</td>
                        <td><span class="px-2 py-0.5 rounded-full text-xs font-medium @tipoBadge">@m.Tipo</span></td>
                        <td class="font-medium @(m.Tipo == "saida" ? "text-red-700" : "text-slate-900")">
                            @(m.Tipo == "saida" ? "-" : "+")@m.Valor.ToString("C")
                        </td>
                        <td class="text-sm text-slate-600">@(m.Descricao ?? "—")</td>
                        <td class="text-xs text-slate-500">@(m.Categoria ?? "—")</td>
                        <td class="text-xs text-slate-500">@(m.Origem ?? "—") @if (!string.IsNullOrEmpty(m.RegistradoPorNome)) { <div class="text-slate-400">@m.RegistradoPorNome</div> }</td>
                        <td>
                            @if (m.Tipo != "abertura" && m.Tipo != "fechamento" && !d.Fechado)
                            {
                                <form asp-action="Estornar" asp-controller="Caixa" asp-route-id="@m.Id" method="post" data-confirm='{"titulo":"Estornar movimento?","mensagem":"O valor sera revertido no fluxo do dia.","textoBotao":"Estornar","classBotao":"bg-red-600 hover:bg-red-700"}'>
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-xs text-red-600 hover:text-red-700">Estornar</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            </div>
        }
    </div>

    <!-- Modal lançar entrada/saída -->
    <div x-data="lancamentoCaixaModal()" @@open-modal.window="if ($event.detail === 'lancar-mov') open = true"
         x-show="open" x-cloak
         class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
         @@click.self="open = false" @@keydown.escape.window="open = false">
        <div class="ui-modal bg-white rounded-xl shadow-xl w-full max-w-xl p-6">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Lançar entrada/saída</h2>
            <form asp-action="RegistrarMovimento" asp-controller="Caixa" method="post" data-validate class="space-y-3">
                @Html.AntiForgeryToken()
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Tipo *</label>
                        <select name="tipo" required class="ui-select w-full text-sm">
                            <option value="entrada">Entrada (recebimento)</option>
                            <option value="saida">Saída (despesa, sangria)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Valor *</label>
                        <input type="number" name="valor" step="0.01" min="0.01" required
                               data-error-message="Informe um valor maior que zero."
                               class="ui-field w-full text-sm" />
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Descrição</label>
                        <input type="text" name="descricao" class="ui-field w-full text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Método</label>
                        <select name="metodo" class="ui-select w-full text-sm">
                            <option value="">—</option>
                            <option value="dinheiro">Dinheiro</option>
                            <option value="pix">PIX</option>
                            <option value="credito">Crédito</option>
                            <option value="debito">Débito</option>
                            <option value="transferencia">Transferência</option>
                            <option value="outro">Outro</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Categoria</label>
                        <input type="text" name="categoria" placeholder="Ex: embalagem, sangria" class="ui-field w-full text-sm" />
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Referência</label>
                        <input type="text" name="referencia" placeholder="txid, NSU, n° NF" class="ui-field w-full text-sm" />
                    </div>
                </div>
                <div class="flex justify-end gap-3 pt-3 border-t">
                    <button type="button" @@click="open = false" class="ui-secondary-btn px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">Cancelar</button>
                    <button type="submit" class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">Registrar</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
function lancamentoCaixaModal() { return { open: false }; }

// Auto-retry exponencial pra falhas transitórias na carga do Caixa.
// 3 tentativas com backoff (5s, 10s, 20s); usuário pode cancelar ou disparar agora.
function caixaAutoRetry(enabled) {
    return {
        enabled: enabled,
        attempts: 0,
        maxAttempts: 3,
        delays: [5, 10, 20],
        countdown: 0,
        retrying: false,
        exhausted: false,
        _tickHandle: null,

        start() {
            if (!this.enabled) return;
            this.scheduleNext();
        },
        scheduleNext() {
            if (this.attempts >= this.maxAttempts) {
                this.exhausted = true;
                return;
            }
            this.countdown = this.delays[this.attempts] || 30;
            clearInterval(this._tickHandle);
            this._tickHandle = setInterval(() => {
                this.countdown -= 1;
                if (this.countdown <= 0) {
                    clearInterval(this._tickHandle);
                    this.retryNow();
                }
            }, 1000);
        },
        async retryNow() {
            if (this.retrying) return;
            clearInterval(this._tickHandle);
            this.retrying = true;
            this.attempts += 1;
            try {
                // HEAD na própria URL — se o servidor responder OK, recarrega de vez.
                // Se ainda falhar, agenda próxima tentativa.
                const r = await fetch(window.location.pathname + window.location.search, {
                    method: 'GET',
                    headers: { 'X-Probe': '1' },
                    credentials: 'same-origin',
                    cache: 'no-store'
                });
                if (r.ok) {
                    window.location.reload();
                    return;
                }
                // não-OK do servidor → conta como falha, segue tentando
                this.retrying = false;
                this.scheduleNext();
            } catch (e) {
                this.retrying = false;
                this.scheduleNext();
            }
        },
        cancel() {
            clearInterval(this._tickHandle);
            this.enabled = false;
            this.exhausted = true;
        }
    };
}
</script>
}
