@model CaixaOperacaoViewModel
@{
    ViewBag.Title = "Caixa";
    Layout = "_Layout";
    var d = Model.Dia;
}

@{
    var statusCaixa = Model.Dia is null ? "indisponivel"
                    : Model.Dia.Fechado ? "fechado"
                    : Model.Dia.Aberto  ? "aberto"
                                        : "fechado-pendente";
}
<div class="flex items-center justify-between mb-6 flex-wrap gap-3">
    <div class="pg-hd">
        <h1 class="flex items-center gap-3">
            Caixa do dia
            @{ var caixaStatus = StatusHelper.Resolve(statusCaixa); }
            <span class="badge @caixaStatus.BadgeClass">
                <span class="dot"></span> @caixaStatus.Label
            </span>
        </h1>
        <p>@(Model.DataSelecionada.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR")))</p>
    </div>
    <div class="flex gap-3">
        <a href="/caixa-mobile" class="btn-outline-dark inline-flex items-center gap-2">
            <es-icon name="phone" class="es-icon--sm"></es-icon> Lançamentos do app
        </a>
        <a href="/caixa/historico" class="btn-outline-dark inline-flex items-center gap-2">
            <es-icon name="history" class="es-icon--sm"></es-icon> Histórico
        </a>
    </div>
</div>

@if (d == null)
{
    var isLojaIssue = string.Equals(Model.ErrorCode, "EMPRESA_INVALIDA", StringComparison.OrdinalIgnoreCase)
                      || string.Equals(Model.ErrorCode, "LOJA_NAO_SELECIONADA", StringComparison.OrdinalIgnoreCase)
                      || string.IsNullOrEmpty(ViewBag.LojaAtualId as string);
    var isAuthIssue = string.Equals(Model.ErrorCode, "UNAUTHORIZED", StringComparison.OrdinalIgnoreCase)
                      || string.Equals(Model.ErrorCode, "TOKEN_EXPIRED", StringComparison.OrdinalIgnoreCase)
                      || string.Equals(Model.ErrorCode, "AUTH_TOKEN_EXPIRED", StringComparison.OrdinalIgnoreCase);
    // Auto-retry só pra falha transitória (rede/timeout/5xx). Loja/auth precisam de ação humana.
    var canAutoRetry = !isLojaIssue && !isAuthIssue;

    <div class="ws bg-red-50 border border-red-200 rounded-xl p-8 text-center"
         x-data="caixaAutoRetry(@(canAutoRetry ? "true" : "false"))" x-init="start()">
        <svg class="w-12 h-12 mx-auto text-red-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <p class="text-red-700 font-semibold text-base">Não foi possível carregar o caixa do dia.</p>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <p class="text-sm text-red-600 mt-1">@Model.ErrorMessage</p>
        }

        @if (isLojaIssue)
        {
            <p class="text-sm text-slate-600 mt-3 max-w-md mx-auto">
                Selecione uma loja no seletor do topo da página antes de acessar o caixa.
            </p>
        }
        else if (isAuthIssue)
        {
            <p class="text-sm text-slate-600 mt-3 max-w-md mx-auto">
                Sua sessão expirou. Faça login novamente para continuar.
            </p>
        }
        else
        {
            <p class="text-sm text-slate-600 mt-3 max-w-md mx-auto">
                Tentaremos automaticamente novamente. Se o problema persistir, contate o suporte.
            </p>
            <p x-show="enabled && !exhausted" x-cloak
               class="text-xs text-slate-500 mt-2">
                <span x-show="retrying">Tentando novamente…</span>
                <span x-show="!retrying">
                    Tentativa <span x-text="attempts + 1"></span> de <span x-text="maxAttempts"></span>
                    em <span x-text="countdown" class="font-semibold"></span>s
                </span>
            </p>
            <p x-show="exhausted" x-cloak class="text-xs text-amber-600 mt-2 font-medium">
                Tentativas automáticas esgotadas. Use o botão abaixo para tentar manualmente.
            </p>
        }

        <div class="flex justify-center gap-3 mt-5 flex-wrap">
            <button type="button" @@click="retryNow()"
                    class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 inline-flex items-center gap-2">
                <svg class="w-4 h-4" :class="retrying && 'animate-spin'" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Tentar agora
            </button>
            @if (canAutoRetry)
            {
                <button type="button" x-show="enabled && !exhausted" @@click="cancel()"
                        class="btn-outline-dark">
                    Cancelar tentativas automáticas
                </button>
            }
            @if (isAuthIssue)
            {
                <a href="/auth/login" class="btn-outline-dark">
                    Ir para login
                </a>
            }
            else
            {
                <a href="/caixa/historico" class="btn-outline-dark">
                    Ver histórico de fechamentos
                </a>
                <a href="/configuracoes#suporte" class="btn-outline-dark">
                    Falar com suporte
                </a>
            }
        </div>
    </div>
}
else
{
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
        <div class="ws">
            <h3 class="text-sm font-semibold text-slate-500 mb-1">Saldo esperado</h3>
            <div class="text-2xl font-bold text-slate-900 tabular-nums">@d.SaldoEsperado.AsMoney()</div>
            <div class="text-xs text-slate-500 mt-1">
                @(d.Fechado ? "Caixa fechado" : (d.Aberto ? "Caixa aberto" : "Caixa não aberto"))
            </div>
        </div>
        <div class="ws">
            <h3 class="text-sm font-semibold text-slate-500 mb-1">Vendas + pagamentos</h3>
            <div class="text-2xl font-bold text-green-600 tabular-nums">@((d.TotalVendas + d.TotalPagamentosPedidos).AsMoney())</div>
            <div class="text-xs text-slate-500 mt-1 tabular-nums">Vendas: @d.TotalVendas.AsMoney() · Pagamentos: @d.TotalPagamentosPedidos.AsMoney()</div>
        </div>
        <div class="ws">
            <h3 class="text-sm font-semibold text-slate-500 mb-1">Entradas/saídas extras</h3>
            <div class="text-2xl font-bold text-slate-900 tabular-nums">@((d.TotalEntradasExtras - d.TotalSaidasExtras).AsMoney())</div>
            <div class="text-xs text-slate-500 mt-1 tabular-nums">Entradas: +@d.TotalEntradasExtras.AsMoney() · Saídas: −@d.TotalSaidasExtras.AsMoney()</div>
        </div>
    </div>

    <!-- Ações: abrir/fechar/lançar -->
    <div class="ws mb-6">
        <div class="flex flex-wrap gap-3 items-center">
            @if (!d.Aberto && !d.Fechado)
            {
                <button type="button" x-data @@click="$dispatch('open-modal', 'abrir-caixa')"
                        class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                    🔓 Abrir caixa do dia
                </button>
                <span class="text-sm text-slate-500">Comece informando o saldo inicial em dinheiro.</span>
            }
            @if (d.Aberto && !d.Fechado)
            {
                <button type="button" x-data @@click="$dispatch('open-modal', 'lancar-mov')"
                        class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                    + Lançar entrada/saída
                </button>
                <button type="button" x-data @@click="$dispatch('open-modal', 'fechar-caixa')"
                        class="btn-warn-dark inline-flex items-center gap-2">
                    <es-icon name="lock" class="es-icon--sm"></es-icon> Fechar caixa
                </button>
            }
            @if (d.Fechado && d.Fechamento != null)
            {
                <span class="text-sm text-slate-600">
                    Fechado em @d.Fechamento.FechadoEm.ToLocalTime().AsDateTime()
                    @if (!string.IsNullOrEmpty(d.Fechamento.FechadoPorNome)) { <span class="text-slate-400">por @d.Fechamento.FechadoPorNome</span> }
                    · Saldo final: <strong class="tabular-nums">@d.Fechamento.SaldoFinal.AsMoney()</strong>
                </span>
            }
        </div>
    </div>

    <!-- Lista de movimentos -->
    <div class="ws">
        <h2 class="font-semibold text-slate-900 mb-4">Movimentos do dia (@d.Movimentos.Count)</h2>
        @if (!d.Movimentos.Any())
        {
            <p class="text-sm text-slate-500">Nenhum movimento registrado ainda.</p>
        }
        else
        {
            <div class="overflow-x-auto">
            <table class="tbl-full">
                <thead><tr><th>Hora</th><th>Tipo</th><th>Valor</th><th>Descrição</th><th>Categoria</th><th>Origem</th><th></th></tr></thead>
                <tbody>
                @foreach (var m in d.Movimentos)
                {
                    string tipoBadge = m.Tipo switch
                    {
                        "abertura"   => "bg-blue-100 text-blue-700",
                        "fechamento" => "bg-slate-100 text-slate-600",
                        "entrada"    => "bg-green-100 text-green-700",
                        "saida"      => "bg-red-100 text-red-700",
                        _            => "bg-slate-100 text-slate-600"
                    };
                    <tr>
                        <td class="text-xs text-slate-500">@m.DataMovimento.ToLocalTime().ToString("HH:mm")</td>
                        <td><span class="px-2 py-0.5 rounded-full text-xs font-medium @tipoBadge">@m.Tipo</span></td>
                        <td class="font-medium @(m.Tipo == "saida" ? "text-red-700" : "text-slate-900")">
                            @(m.Tipo == "saida" ? "−" : "+")@m.Valor.AsMoney()
                        </td>
                        <td class="text-sm text-slate-600">@(m.Descricao ?? "—")</td>
                        <td class="text-xs text-slate-500">@(m.Categoria ?? "—")</td>
                        <td class="text-xs text-slate-500">@(m.Origem ?? "—") @if (!string.IsNullOrEmpty(m.RegistradoPorNome)) { <div class="text-slate-400">@m.RegistradoPorNome</div> }</td>
                        <td>
                            @if (m.Tipo != "abertura" && m.Tipo != "fechamento" && !d.Fechado)
                            {
                                <form asp-action="Estornar" asp-controller="Caixa" asp-route-id="@m.Id" method="post" data-confirm='{"titulo":"Estornar movimento?","mensagem":"O valor será revertido no fluxo do dia.","textoBotao":"Estornar","classBotao":"bg-red-600 hover:bg-red-700"}'>
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-xs text-slate-400 hover:text-red-600" aria-label="Estornar movimento">Estornar</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            </div>
        }
    </div>

    @* Modais movidos para o final do arquivo (após if/else completo). *@
}

@* ===== Modais de Caixa (fora do if/else para sempre serem renderizados quando aplicável) ===== *@

@if (d != null && !d.Aberto && !d.Fechado)
{
    <!-- Modal: abrir caixa -->
    <div x-data="abrirCaixaModal()"
         x-show="open" x-cloak
         x-transition:enter="transition duration-150 ease-out"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         @@keydown.escape.window="close()"
         @@click.self="close()"
         class="fm-overlay"
         role="dialog" aria-modal="true" aria-labelledby="fm-abrir-title">
        <form x-ref="panel" class="fm-panel" style="max-width: 540px"
              method="post" action="/caixa/abrir" data-validate
              x-transition:enter="transition duration-150 ease-out"
              x-transition:enter-start="opacity-0 scale-95"
              x-transition:enter-end="opacity-100 scale-100">
            @Html.AntiForgeryToken()
            <header class="fm-header">
                <div>
                    <h2 id="fm-abrir-title" class="fm-header__title">Abrir caixa do dia</h2>
                    <p class="fm-header__subtitle">Informe o saldo em dinheiro físico que está no caixa para começar.</p>
                </div>
                <button type="button" class="fm-close" aria-label="Fechar" @@click="close()">✕</button>
            </header>
            <div class="fm-body">
                <fieldset class="fm-section">
                    <div class="fm-grid">
                        <div class="fm-field fm-col-2">
                            <label class="fm-field__label" for="abrir-saldo">
                                Saldo inicial em dinheiro<span class="fm-field__required" aria-hidden="true">*</span>
                            </label>
                            <input id="abrir-saldo" type="number" name="saldoInicial" step="0.01" min="0" required
                                   placeholder="0,00"
                                   data-error-message="Informe um saldo inicial igual ou maior que zero."
                                   class="ui-field w-full text-sm" />
                            <span class="fm-field__hint">Use 0 se não há caixa físico (só registros eletrônicos)</span>
                        </div>
                        <div class="fm-field fm-col-2">
                            <label class="fm-field__label" for="abrir-obs">Observações</label>
                            <input id="abrir-obs" type="text" name="observacoes" maxlength="200"
                                   placeholder="Ex: troco do dia anterior, conferência..."
                                   class="ui-field w-full text-sm" />
                        </div>
                    </div>
                </fieldset>
            </div>
            <footer class="fm-footer">
                <button type="button" @@click="close()"
                        class="ui-secondary-btn px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                    Cancelar
                </button>
                <button type="submit"
                        class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                    🔓 Abrir caixa
                </button>
            </footer>
        </form>
    </div>
}

@if (d != null && d.Aberto && !d.Fechado)
{
    <!-- Modal: lançar entrada/saída -->
    <div x-data="lancamentoCaixaModal()"
         x-show="open" x-cloak
         x-transition:enter="transition duration-150 ease-out"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         @@keydown.escape.window="close()"
         @@click.self="close()"
         class="fm-overlay"
         role="dialog" aria-modal="true" aria-labelledby="fm-mov-title">
        <form x-ref="panel" class="fm-panel" style="max-width: 640px"
              method="post" action="/caixa/movimentos" data-validate
              x-transition:enter="transition duration-150 ease-out"
              x-transition:enter-start="opacity-0 scale-95"
              x-transition:enter-end="opacity-100 scale-100">
            @Html.AntiForgeryToken()
            <header class="fm-header">
                <div>
                    <h2 id="fm-mov-title" class="fm-header__title">Registrar movimento</h2>
                    <p class="fm-header__subtitle">Entradas extras (vendas, recebimentos) ou saídas (despesas, sangrias) que afetam o saldo do caixa.</p>
                </div>
                <button type="button" class="fm-close" aria-label="Fechar" @@click="close()">✕</button>
            </header>
            <div class="fm-body">
                <!-- Tabs entrada / saída -->
                <div class="ped-tabs" role="tablist">
                    <button type="button" role="tab" class="ped-tab"
                            :class="{ 'ped-tab--active': tipo === 'entrada' }"
                            :aria-selected="tipo === 'entrada'"
                            @@click="tipo = 'entrada'">
                        ➕ Entrada
                    </button>
                    <button type="button" role="tab" class="ped-tab"
                            :class="{ 'ped-tab--active': tipo === 'saida' }"
                            :aria-selected="tipo === 'saida'"
                            @@click="tipo = 'saida'">
                        ➖ Saída
                    </button>
                </div>
                <input type="hidden" name="tipo" :value="tipo" />

                <fieldset class="fm-section">
                    <div class="fm-grid">
                        <div class="fm-field">
                            <label class="fm-field__label" for="mov-valor">
                                Valor<span class="fm-field__required" aria-hidden="true">*</span>
                            </label>
                            <input id="mov-valor" type="number" name="valor" step="0.01" min="0.01" required
                                   placeholder="0,00"
                                   data-error-message="Informe um valor maior que zero."
                                   class="ui-field w-full text-sm text-right" />
                        </div>
                        <div class="fm-field">
                            <label class="fm-field__label" for="mov-metodo">Método<span x-show="tipo === 'saida'" x-cloak class="fm-field__required" aria-hidden="true">*</span></label>
                            <select id="mov-metodo" name="metodo" :required="tipo === 'saida'" class="ui-select w-full text-sm">
                                <option value="">— Selecionar —</option>
                                <option value="dinheiro">Dinheiro</option>
                                <option value="pix">PIX</option>
                                <option value="credito">Crédito</option>
                                <option value="debito">Débito</option>
                                <option value="transferencia">Transferência</option>
                                <option value="outro">Outro</option>
                            </select>
                        </div>
                        <div class="fm-field fm-col-2">
                            <label class="fm-field__label" for="mov-desc">Descrição<span x-show="tipo === 'saida'" x-cloak class="fm-field__required" aria-hidden="true">*</span></label>
                            <input id="mov-desc" type="text" name="descricao"
                                   :required="tipo === 'saida'"
                                   :placeholder="tipo === 'entrada' ? 'Ex: venda balcão, recebimento de cliente' : 'Ex: pagamento embalagem, sangria, troco'"
                                   class="ui-field w-full text-sm" />
                        </div>
                        <div class="fm-field">
                            <label class="fm-field__label" for="mov-cat">Categoria</label>
                            <input id="mov-cat" type="text" name="categoria"
                                   :placeholder="tipo === 'entrada' ? 'venda, devolução' : 'embalagem, sangria, fornecedor'"
                                   class="ui-field w-full text-sm" />
                        </div>
                        <div class="fm-field">
                            <label class="fm-field__label" for="mov-ref">Referência</label>
                            <input id="mov-ref" type="text" name="referencia"
                                   placeholder="txid, NSU, nº NF"
                                   class="ui-field w-full text-sm" />
                        </div>
                    </div>
                </fieldset>
            </div>
            <footer class="fm-footer">
                <button type="button" @@click="close()"
                        class="ui-secondary-btn px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                    Cancelar
                </button>
                <button type="submit"
                        :class="tipo === 'saida' ? 'bg-red-600 hover:bg-red-700' : 'bg-indigo-600 hover:bg-indigo-700'"
                        class="app-primary-btn px-4 py-2 text-white text-sm font-medium rounded-lg">
                    <span x-show="tipo === 'entrada'">Registrar entrada</span>
                    <span x-show="tipo === 'saida'">Registrar saída</span>
                </button>
            </footer>
        </form>
    </div>

    <!-- Modal: fechar caixa -->
    <div x-data="fecharCaixaModal()"
         x-show="open" x-cloak
         x-transition:enter="transition duration-150 ease-out"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         @@keydown.escape.window="close()"
         @@click.self="close()"
         class="fm-overlay"
         role="alertdialog" aria-modal="true" aria-labelledby="fm-fechar-title">
        <form x-ref="panel" class="fm-panel" style="max-width: 540px"
              method="post" action="/caixa/fechar"
              x-transition:enter="transition duration-150 ease-out"
              x-transition:enter-start="opacity-0 scale-95"
              x-transition:enter-end="opacity-100 scale-100">
            @Html.AntiForgeryToken()
            <header class="fm-header">
                <div>
                    <h2 id="fm-fechar-title" class="fm-header__title">Fechar caixa do dia?</h2>
                    <p class="fm-header__subtitle">Após o fechamento, novos lançamentos vão pro caixa de amanhã. Esta ação não pode ser desfeita.</p>
                </div>
                <button type="button" class="fm-close" aria-label="Fechar" @@click="close()">✕</button>
            </header>
            <div class="fm-body">
                <div class="caixa-fechar-resumo">
                    <div class="caixa-fechar-resumo__item">
                        <span class="text-xs text-slate-500 uppercase tracking-wider">Saldo final esperado</span>
                        <span class="caixa-fechar-resumo__valor tabular-nums">@d.SaldoEsperado.AsMoney()</span>
                    </div>
                    <div class="caixa-fechar-resumo__split">
                        <div>
                            <span class="text-xs text-slate-500">Vendas + pagamentos</span>
                            <strong class="text-green-700 block tabular-nums">+@((d.TotalVendas + d.TotalPagamentosPedidos).AsMoney())</strong>
                        </div>
                        <div>
                            <span class="text-xs text-slate-500">Entradas extras</span>
                            <strong class="text-green-700 block tabular-nums">+@d.TotalEntradasExtras.AsMoney()</strong>
                        </div>
                        <div>
                            <span class="text-xs text-slate-500">Saídas extras</span>
                            <strong class="text-red-700 block tabular-nums">−@d.TotalSaidasExtras.AsMoney()</strong>
                        </div>
                    </div>
                </div>

                <fieldset class="fm-section" style="margin-top: 16px">
                    <div class="fm-field fm-col-2">
                        <label class="fm-field__label" for="fechar-obs">Observações do fechamento</label>
                        <textarea id="fechar-obs" name="observacoes" rows="2"
                                  placeholder="Ex: diferença de troco, conferência..."
                                  class="ui-textarea w-full text-sm"></textarea>
                        <span class="fm-field__hint">Fica registrado no histórico do dia</span>
                    </div>
                </fieldset>
            </div>
            <footer class="fm-footer">
                <button type="button" @@click="close()"
                        class="ui-secondary-btn px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                    Voltar
                </button>
                <button type="submit"
                        class="px-4 py-2 bg-amber-600 text-white text-sm font-medium rounded-lg hover:bg-amber-700">
                    🔒 Sim, fechar caixa
                </button>
            </footer>
        </form>
    </div>
}

@section Scripts {
<script>
function _caixaModalBase(eventId) {
    return {
        open: false,
        _previousFocus: null,
        init() {
            window.addEventListener('open-modal', (e) => {
                if (e.detail !== eventId) return;
                this._previousFocus = document.activeElement;
                this.open = true;
                this.$nextTick(() => {
                    const el = this.$refs.panel?.querySelector('input:not([type=hidden]), select, textarea');
                    if (el) el.focus();
                });
            });
            this.$watch('open', (v) => {
                document.body.style.overflow = v ? 'hidden' : '';
                if (!v && this._previousFocus) this._previousFocus.focus?.();
            });
        },
        close() { this.open = false; }
    };
}

function abrirCaixaModal()       { return _caixaModalBase('abrir-caixa'); }
function fecharCaixaModal()      { return _caixaModalBase('fechar-caixa'); }
