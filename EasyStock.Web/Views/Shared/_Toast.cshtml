@{
    var toastRaw = TempData["Toast"] as string;
    string? toastType = null;
    string? toastMsg = null;
    if (!string.IsNullOrEmpty(toastRaw))
    {
        var parts = toastRaw.Split('|', 2);
        toastType = parts[0];
        toastMsg = parts.Length > 1 ? parts[1] : parts[0];
    }
}

@if (!string.IsNullOrEmpty(toastMsg))
{
    var bgClass = toastType switch
    {
        "success" => "bg-emerald-600",
        "error" => "bg-red-600",
        "warning" => "bg-amber-500",
        _ => "bg-blue-600"
    };
    var icon = toastType switch
    {
        "success" => "✓",
        "error" => "✕",
        "warning" => "⚠",
        _ => "ℹ"
    };

    <div x-cloak
         x-data="{ show: true }"
         x-show="show"
         x-init="setTimeout(() => show = false, @(toastType == "error" ? "6000" : "3000"))"
         x-transition:leave="transition ease-in duration-300"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 translate-y-2"
         role="@(toastType == "error" ? "alert" : "status")"
         aria-live="@(toastType == "error" ? "assertive" : "polite")"
         class="fixed bottom-6 left-6 z-[9999] flex items-center gap-3 @bgClass text-white px-4 py-3 rounded-xl shadow-xl min-w-[280px] max-w-sm">
        <span class="text-lg font-bold">@icon</span>
        <span class="text-sm font-medium">@toastMsg</span>
        <button @@click="show = false" class="ml-auto opacity-70 hover:opacity-100 text-lg leading-none">&times;</button>
    </div>
}
