@{
    var toastRaw = TempData["Toast"] as string;
}
@if (!string.IsNullOrEmpty(toastRaw))
{
    var parts          = toastRaw.Split('|', 4);
    var toastType      = parts[0];
    var toastMsg       = parts.Length > 1 ? parts[1] : toastRaw;
    var undoUrl        = parts.Length > 2 && !string.IsNullOrEmpty(parts[2]) ? parts[2] : null;
    var correlationId  = parts.Length > 3 && !string.IsNullOrEmpty(parts[3]) ? parts[3] : null;

    // C3 (2026-05-16): undoUrl so vale para tipos success/success-undo.
    // Antes, qualquer tipo (inclusive error) podia receber undoUrl e o
    // botao Desfazer aparecia indevidamente. Tipos error/warning/info perdem
    // capacidade de undo (auditoria mostrou que nenhum call-site usa hoje).
    var isUndoable = !string.IsNullOrEmpty(undoUrl)
                     && (toastType == "success" || toastType == "success-undo");
    var effectiveType = isUndoable ? "success-undo" : toastType;

    if (isUndoable)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                if (!window.showToast) return;
                function __undoToast() {
                    var form = document.createElement('form');
                    form.method = 'POST';
                    form.action = @Json.Serialize(undoUrl);
                    var tok = document.querySelector('[name="__RequestVerificationToken"]');
                    if (tok) {
                        var inp = document.createElement('input');
                        inp.type = 'hidden';
                        inp.name = '__RequestVerificationToken';
                        inp.value = tok.value;
                        form.appendChild(inp);
                    }
                    document.body.appendChild(form);
                    form.submit();
                }
                window.showToast(@Json.Serialize(toastMsg), @Json.Serialize(effectiveType), 5000, __undoToast);
            }, { once: true });
        </script>
    }
    else
    {
        @* Detecta caso onde undoUrl veio mas tipo nao e undoable - log no console pra triagem. *@
        @if (!string.IsNullOrEmpty(undoUrl))
        {
            <script>
                console.warn('[toast] undoUrl ignorado em tipo "@toastType". Para acao reversivel use type=success ou success-undo.');
            </script>
        }
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                if (window.showToast) {
                    window.showToast(@Json.Serialize(toastMsg), @Json.Serialize(toastType)@(correlationId is not null ? $", {{ correlationId: {Json.Serialize(correlationId)} }}" : ""));
                }
            }, { once: true });
        </script>
    }
}
