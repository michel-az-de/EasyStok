@{
    var toastRaw = TempData["Toast"] as string;
}
@if (!string.IsNullOrEmpty(toastRaw))
{
    var sep      = toastRaw.IndexOf('|');
    var toastType = sep >= 0 ? toastRaw[..sep] : toastRaw;
    var toastMsg  = sep >= 0 ? toastRaw[(sep + 1)..] : toastRaw;
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.showToast) {
                window.showToast(@Json.Serialize(toastMsg), @Json.Serialize(toastType));
            }
        }, { once: true });
    </script>
}
