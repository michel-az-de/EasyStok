@{
    var usuarioNome = ViewBag.UsuarioNome as string ?? "Usuário";
    var iniciais = string.Join("", (usuarioNome).Split(' ').Take(2).Select(p => p.Length > 0 ? p[0].ToString().ToUpper() : ""));
    if (string.IsNullOrEmpty(iniciais)) iniciais = "U";
}

<header class="bg-white border-b border-slate-200 px-4 py-3 flex items-center gap-2 sm:gap-3 flex-shrink-0">
    <!-- Hamburger (mobile only) -->
    <button @@click="sidebarOpen = !sidebarOpen"
            class="lg:hidden p-2 text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-colors flex-shrink-0">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
    </button>

    <!-- Page title (mobile only) -->
    <div class="flex-1 lg:hidden min-w-0">
        <span class="text-sm font-semibold text-slate-800 truncate block">@(ViewBag.Title as string ?? "EasyStock")</span>
    </div>

    <!-- Busca global -->
    <div x-data="buscaUnificada()"
         @@keydown.window.ctrl.k.prevent="abrir()"
         @@keydown.window.slash.prevent="if(!document.activeElement || document.activeElement.tagName === 'BODY') abrir()"
         class="contents">

        <!-- Desktop: full search bar -->
        <div class="hidden lg:block flex-1">
            <button @@click="abrir()"
                    class="flex items-center gap-2 px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-400 hover:bg-white hover:border-slate-300 transition-colors w-full max-w-xs">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
                </svg>
                <span class="flex-1 text-left truncate">Buscar...</span>
                <kbd class="inline-flex items-center gap-1 px-1.5 py-0.5 text-xs bg-slate-100 border border-slate-200 rounded text-slate-400">Ctrl K</kbd>
            </button>
        </div>

        <!-- Mobile: icon-only search -->
        <button @@click="abrir()"
                class="lg:hidden p-2 text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-colors flex-shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
            </svg>
        </button>

        <!-- Command palette overlay -->
        <div x-show="aberto" x-cloak
             class="fixed inset-0 z-[100] flex items-start justify-center pt-[8vh] px-4"
             @@keydown.escape.window="fechar()">
            <!-- Backdrop -->
            <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm" @@click="fechar()"></div>

            <!-- Painel -->
            <div class="relative w-full max-w-xl bg-white rounded-2xl shadow-2xl border border-slate-200 overflow-hidden"
                 @@keydown.arrow-down.prevent="mover(1)" @@keydown.arrow-up.prevent="mover(-1)"
                 @@keydown.enter.prevent="selecionar()">
                <!-- Input -->
                <div class="flex items-center gap-3 px-4 py-3 border-b border-slate-100">
                    <svg class="w-5 h-5 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
                    </svg>
                    <input type="text" placeholder="Buscar produto, SKU, código, fornecedor..."
                           x-ref="input"
                           x-model="query"
                           @@input.debounce.300ms="buscar()"
                           class="flex-1 text-sm text-slate-800 placeholder-slate-400 bg-transparent border-none outline-none" />
                    <div x-show="carregando" class="w-4 h-4 border-2 border-indigo-400 border-t-transparent rounded-full animate-spin flex-shrink-0"></div>
                    <kbd class="flex-shrink-0 text-xs text-slate-400 bg-slate-100 px-1.5 py-0.5 rounded border border-slate-200">Esc</kbd>
                </div>

                <!-- Resultados -->
                <div class="max-h-[60vh] overflow-y-auto py-1">
                    <template x-if="results.length > 0">
                        <div>
                            <template x-for="(item, idx) in results" :key="item.id + '-' + item.tipo">
                                <a :href="linkItem(item)"
                                   :class="idx === activeIdx ? 'bg-indigo-50' : 'hover:bg-slate-50'"
                                   class="flex items-start gap-3 px-4 py-2.5 transition-colors cursor-pointer group"
                                   @@mouseenter="activeIdx = idx"
                                   @@click="fechar()">
                                    <!-- Badge tipo -->
                                    <span :class="badgeClasse(item.tipo)"
                                          class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide flex-shrink-0 mt-0.5"
                                          x-text="badgeLabel(item.tipo)"></span>
                                    <!-- Conteúdo -->
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center gap-2">
                                            <span class="text-sm font-medium text-slate-900 truncate" x-text="item.titulo"></span>
                                            <template x-if="item.sku">
                                                <span class="text-xs text-slate-400 font-mono flex-shrink-0" x-text="item.sku"></span>
                                            </template>
                                        </div>
                                        <div class="flex items-center gap-2 mt-0.5">
                                            <span x-show="item.subtitulo" class="text-xs text-slate-500 truncate" x-text="item.subtitulo"></span>
                                            <template x-if="item.quantidadeAtual !== null && item.quantidadeAtual !== undefined">
                                                <span :class="statusClasse(item.status)"
                                                      class="text-xs font-medium flex-shrink-0"
                                                      x-text="item.quantidadeAtual + ' un.'"></span>
                                            </template>
                                            <span x-show="item.fornecedorNome" class="text-xs text-slate-400 flex-shrink-0" x-text="item.fornecedorNome"></span>
                                        </div>
                                    </div>
                                    <!-- Ações rápidas para estoque -->
                                    <template x-if="item.tipo === 'ItemEstoque'">
                                        <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0">
                                            <a :href="'/entradas/nova?produtoId=' + item.produtoId"
                                               @@click.stop
                                               class="text-xs px-2 py-1 bg-emerald-50 text-emerald-700 rounded hover:bg-emerald-100 transition-colors">
                                                Entrada
                                            </a>
                                            <a :href="'/saidas/nova?produtoId=' + item.produtoId"
                                               @@click.stop
                                               class="text-xs px-2 py-1 bg-rose-50 text-rose-700 rounded hover:bg-rose-100 transition-colors">
                                                Saída
                                            </a>
                                        </div>
                                    </template>
                                </a>
                            </template>
                        </div>
                    </template>

                    <!-- Estado vazio -->
                    <div x-show="semResultados && !carregando && query.length >= 2"
                         class="px-4 py-8 text-center">
                        <div class="text-slate-300 mb-2">
                            <svg class="w-10 h-10 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
                            </svg>
                        </div>
                        <p class="text-sm text-slate-400">Nenhum resultado para <strong x-text="query" class="text-slate-600"></strong></p>
                        <p class="text-xs text-slate-300 mt-1">Tente por nome, SKU, código interno ou fornecedor</p>
                    </div>

                    <!-- Estado inicial -->
                    <div x-show="results.length === 0 && !semResultados && !carregando"
                         class="px-4 py-4 text-xs text-slate-400 text-center">
                        Digite pelo menos 2 caracteres para buscar
                    </div>
                </div>

                <!-- Rodapé dicas -->
                <div class="border-t border-slate-100 px-4 py-2 flex items-center gap-4 text-xs text-slate-400">
                    <span><kbd class="bg-slate-100 px-1 rounded border border-slate-200">↑↓</kbd> navegar</span>
                    <span><kbd class="bg-slate-100 px-1 rounded border border-slate-200">Enter</kbd> abrir</span>
                    <span><kbd class="bg-slate-100 px-1 rounded border border-slate-200">Esc</kbd> fechar</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        function buscaUnificada() {
            return {
                aberto: false,
                query: '',
                results: [],
                semResultados: false,
                carregando: false,
                activeIdx: 0,

                abrir() {
                    this.aberto = true;
                    this.$nextTick(() => this.$refs.input && this.$refs.input.focus());
                },
                fechar() {
                    this.aberto = false;
                    this.query = '';
                    this.results = [];
                    this.semResultados = false;
                    this.activeIdx = 0;
                },
                mover(dir) {
                    if (this.results.length === 0) return;
                    this.activeIdx = (this.activeIdx + dir + this.results.length) % this.results.length;
                },
                selecionar() {
                    if (this.results.length === 0) return;
                    const item = this.results[this.activeIdx];
                    if (item) window.location.href = this.linkItem(item);
                },
                async buscar() {
                    const q = this.query.trim();
                    if (q.length < 2) { this.results = []; this.semResultados = false; return; }
                    this.carregando = true;
                    try {
                        const r = await fetch('/busca?q=' + encodeURIComponent(q) + '&limit=15');
                        if (!r.ok) return;
                        const data = await r.json();
                        this.results = Array.isArray(data) ? data : [];
                        this.semResultados = this.results.length === 0;
                        this.activeIdx = 0;
                    } catch {
                        this.results = [];
                    } finally {
                        this.carregando = false;
                    }
                },
                linkItem(item) {
                    switch (item.tipo) {
                        case 'Produto': return '/produtos/' + item.produtoId;
                        case 'Variacao': return '/produtos/' + item.produtoId;
                        case 'ItemEstoque': return '/estoque';
                        case 'Fornecedor': return '/fornecedores/' + item.id;
                        default: return '/produtos/' + item.produtoId;
                    }
                },
                badgeLabel(tipo) {
                    return { Produto: 'Produto', Variacao: 'Variação', ItemEstoque: 'Estoque', Fornecedor: 'Fornecedor' }[tipo] || tipo;
                },
                badgeClasse(tipo) {
                    return {
                        Produto: 'bg-indigo-100 text-indigo-700',
                        Variacao: 'bg-violet-100 text-violet-700',
                        ItemEstoque: 'bg-emerald-100 text-emerald-700',
                        Fornecedor: 'bg-amber-100 text-amber-700'
                    }[tipo] || 'bg-slate-100 text-slate-600';
                },
                statusClasse(status) {
                    return {
                        'Ok': 'text-emerald-600',
                        'Warn': 'text-amber-600',
                        'Critical': 'text-red-600',
                        'Slow': 'text-slate-500',
                        'Vencido': 'text-red-700',
                        'Bloqueado': 'text-slate-400'
                    }[status] || 'text-slate-500';
                }
            };
        }
    </script>

    <div class="relative">
        <button type="button"
                onclick="window.EasyStockTheme && window.EasyStockTheme.toggle()"
                class="theme-toggle-btn flex items-center gap-2 px-3 py-2 bg-white/85 border border-slate-200 rounded-lg text-sm text-slate-600 hover:text-slate-900 hover:border-slate-300 transition-colors"
                title="Alternar tema">
            <span class="theme-icon-light" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v2.25m0 13.5V21m9-9h-2.25M5.25 12H3m15.364 6.364-1.591-1.591M7.227 7.227 5.636 5.636m12.728 0-1.591 1.591M7.227 16.773l-1.591 1.591M12 16a4 4 0 100-8 4 4 0 000 8z" />
                </svg>
            </span>
            <span class="theme-icon-dark hidden" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 1012 21a8.96 8.96 0 008.354-5.646z" />
                </svg>
            </span>
            <span class="hidden md:inline theme-toggle-label">Tema escuro</span>
        </button>
    </div>

    <!-- Ação rápida (desktop only) -->
    <div x-data="{ open: false }" class="relative hidden lg:block">
        <button @@click="open = !open"
                class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            <span class="hidden sm:inline">Ação rápida</span>
        </button>
        <div x-show="open" @@click.outside="open = false"
             class="absolute right-0 mt-2 w-52 bg-white rounded-xl shadow-xl border border-slate-200 py-1 z-50">
            <a href="/entradas/nova" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>📥</span> Nova entrada
            </a>
            <a href="/saidas/nova" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>📤</span> Nova saída
            </a>
            <a href="/entradas/reposicao" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>🔄</span> Repor estoque
            </a>
            <a href="/estoque" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>📦</span> Ver estoque
            </a>
            <div class="border-t border-slate-100 my-1"></div>
            <a href="/anuncios" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>🤖</span> Gerar anúncio com IA
            </a>
            <a href="/analytics/movimentacoes" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>📊</span> Ver movimentações
            </a>
        </div>
    </div>

    <!-- Notificações Dropdown -->
    <div x-data="notifDropdown()" class="relative">
        <button @@click="toggle()" class="relative p-2 text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-colors">
            <svg id="notif-bell-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            <span id="topbar-notif-badge" class="hidden absolute -top-1 -right-1 bg-red-500 text-white text-[10px] font-bold rounded-full min-w-[18px] h-[18px] px-1 flex items-center justify-center leading-none"></span>
        </button>

        <div x-show="open" @@click.outside="open = false" x-cloak x-transition
             class="absolute right-0 mt-2 w-96 max-h-[480px] bg-white rounded-xl shadow-2xl border border-slate-200 z-50 flex flex-col">
            <!-- Header -->
            <div class="flex items-center justify-between px-4 py-3 border-b border-slate-100">
                <div class="flex items-center gap-2">
                    <span class="font-semibold text-slate-900 text-sm">Notificações</span>
                    <template x-if="resumo && resumo.totalNaoLidas > 0">
                        <span class="px-1.5 py-0.5 bg-red-100 text-red-600 rounded-full text-xs font-medium" x-text="resumo.totalNaoLidas"></span>
                    </template>
                </div>
                <template x-if="resumo && resumo.criticas > 0">
                    <span class="px-1.5 py-0.5 bg-red-600 text-white rounded-full text-xs font-bold" x-text="resumo.criticas + ' crítica' + (resumo.criticas > 1 ? 's' : '')"></span>
                </template>
            </div>

            <!-- Items -->
            <div class="overflow-y-auto flex-1">
                <template x-if="loading">
                    <div class="px-4 py-8 text-center text-slate-400 text-sm">Carregando...</div>
                </template>
                <template x-if="!loading && items.length === 0">
                    <div class="px-4 py-8 text-center text-slate-400">
                        <svg class="w-8 h-8 mx-auto mb-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        <p class="text-sm">Nenhuma notificação pendente</p>
                    </div>
                </template>
                <template x-for="n in items" :key="n.id">
                    <div class="px-4 py-3 border-b border-slate-50 hover:bg-slate-50 transition-colors"
                         :class="severidadeBorder(n.severidade)">
                        <div class="flex items-start gap-3">
                            <div class="flex-shrink-0 mt-0.5" x-html="severidadeIcon(n.severidade)"></div>
                            <div class="flex-1 min-w-0">
                                <div class="text-sm font-medium text-slate-900 truncate" x-text="n.titulo"></div>
                                <div class="text-xs text-slate-500 mt-0.5 line-clamp-2" x-text="n.mensagem"></div>
                                <div class="flex items-center gap-2 mt-1.5">
                                    <a :href="acaoUrl(n)" class="text-xs text-indigo-600 hover:text-indigo-700 font-medium" x-text="acaoLabel(n)"></a>
                                    <span class="text-slate-300">|</span>
                                    <button @@click.stop="marcarLida(n.id)" class="text-xs text-slate-400 hover:text-slate-600">Marcar lida</button>
                                    <span class="text-xs text-slate-300 ml-auto" x-text="tempoRelativo(n.criadaEm || n.createdAt)"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </template>
            </div>

            <!-- Footer -->
            <a href="/notificacoes" class="block px-4 py-2.5 text-center text-sm text-indigo-600 font-medium hover:bg-indigo-50 border-t border-slate-100 rounded-b-xl transition-colors">
                Ver todas as notificações
            </a>
        </div>
    </div>
    <script>
        function notifDropdown() {
            return {
                open: false,
                loading: false,
                items: [],
                resumo: null,
                async toggle() {
                    this.open = !this.open;
                    if (this.open && this.items.length === 0) await this.load();
                },
                async load() {
                    this.loading = true;
                    try {
                        const [rItems, rResumo] = await Promise.all([
                            fetch('/notificacoes/recentes').then(r => r.json()),
                            fetch('/notificacoes/resumo').then(r => r.json())
                        ]);
                        this.items = Array.isArray(rItems) ? rItems : [];
                        this.resumo = rResumo;
                    } catch { this.items = []; }
                    this.loading = false;
                },
                async marcarLida(id) {
                    try {
                        await fetch('/notificacoes/' + id + '/lida-ajax', { method: 'POST' });
                        this.items = this.items.filter(n => n.id !== id);
                        if (this.resumo) this.resumo.totalNaoLidas = Math.max(0, (this.resumo.totalNaoLidas || 0) - 1);
                        const badge = document.getElementById('topbar-notif-badge');
                        if (badge) {
                            const c = this.resumo?.totalNaoLidas || 0;
                            if (c > 0) { badge.textContent = c > 99 ? '99+' : c; }
                            else { badge.classList.add('hidden'); }
                        }
                    } catch {}
                },
                severidadeBorder(s) {
                    const m = { Critica: 'border-l-4 border-red-500', Alta: 'border-l-4 border-orange-500', Media: 'border-l-4 border-yellow-400', Informativa: 'border-l-4 border-slate-300' };
                    return m[s] || m.Media;
                },
                severidadeIcon(s) {
                    const icons = {
                        Critica: '<svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>',
                        Alta: '<svg class="w-4 h-4 text-orange-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>',
                        Media: '<svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>',
                        Informativa: '<svg class="w-4 h-4 text-slate-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>'
                    };
                    return icons[s] || icons.Media;
                },
                acaoUrl(n) {
                    const t = n.tipoAlerta || n.tipo;
                    const ref = n.referenciaId;
                    const map = {
                        EstoqueCritico: '/estoque?item=' + ref,
                        ProdutoVencido: '/estoque?item=' + ref,
                        ValidadeProxima: '/estoque?item=' + ref,
                        ProdutoParado: '/estoque?item=' + ref,
                        ReposicaoSugerida: '/entradas/reposicao?item=' + ref,
                        PedidoAtrasado: '/fornecedores',
                        PedidoRecebido: '/fornecedores'
                    };
                    return map[t] || '/estoque';
                },
                acaoLabel(n) {
                    const t = n.tipoAlerta || n.tipo;
                    const map = {
                        EstoqueCritico: 'Ver no estoque',
                        ProdutoVencido: 'Ver no estoque',
                        ValidadeProxima: 'Ver validade',
                        ProdutoParado: 'Ver item',
                        ReposicaoSugerida: 'Repor estoque',
                        PedidoAtrasado: 'Ver pedido',
                        PedidoRecebido: 'Ver pedido'
                    };
                    return map[t] || 'Ver detalhes';
                },
                tempoRelativo(dt) {
                    if (!dt) return '';
                    const diff = (Date.now() - new Date(dt).getTime()) / 1000;
                    if (diff < 60) return 'agora';
                    if (diff < 3600) return Math.floor(diff / 60) + 'min';
                    if (diff < 86400) return Math.floor(diff / 3600) + 'h';
                    return Math.floor(diff / 86400) + 'd';
                }
            };
        }

        window.EasyStockTheme = {
            async toggle() {
                const current = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
                const next = current === 'dark' ? 'light' : 'dark';
                await this.apply(next, true);
            },
            async apply(theme, persist) {
                const normalized = theme === 'dark' ? 'dark' : 'light';
                document.documentElement.dataset.theme = normalized;
                document.documentElement.classList.toggle('theme-dark', normalized === 'dark');
                document.body.classList.toggle('theme-dark', normalized === 'dark');
                localStorage.setItem('easystock-theme', normalized);
                this.refreshToggle(normalized);

                if (!persist) return;

                const token = document.querySelector('meta[name=\"csrf-token\"]')?.getAttribute('content');
                const form = new URLSearchParams();
                form.append('theme', normalized);

                try {
                    await fetch('/auth/theme', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                            'RequestVerificationToken': token || ''
                        },
                        body: form.toString()
                    });
                } catch { }
            },
            refreshToggle(theme) {
                const isDark = theme === 'dark';
                document.querySelectorAll('.theme-icon-light').forEach(el => el.classList.toggle('hidden', isDark));
                document.querySelectorAll('.theme-icon-dark').forEach(el => el.classList.toggle('hidden', !isDark));
                document.querySelectorAll('.theme-toggle-label').forEach(el => el.textContent = isDark ? 'Tema claro' : 'Tema escuro');
            },
            init() {
                const active = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
                this.refreshToggle(active);
            }
        };

        document.addEventListener('DOMContentLoaded', () => window.EasyStockTheme.init());
    </script>

    <!-- Avatar / usuário -->
    <div x-data="{ open: false }" class="relative">
        <button @@click="open = !open"
                class="flex items-center gap-2 p-1 rounded-lg hover:bg-slate-100 transition-colors">
            <div class="w-8 h-8 bg-indigo-600 text-white rounded-full flex items-center justify-center text-xs font-bold">
                @iniciais
            </div>
            <div class="text-left hidden sm:block">
                <div class="text-sm font-semibold text-slate-800 leading-tight">@usuarioNome</div>
            </div>
            <svg class="hidden sm:block w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
        </button>
        <div x-show="open" @@click.outside="open = false"
             class="absolute right-0 mt-2 w-44 bg-white rounded-xl shadow-xl border border-slate-200 py-1 z-50">
            <div class="px-4 py-2 text-xs text-slate-400 border-b border-slate-100">@usuarioNome</div>
            <form asp-controller="Auth" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full flex items-center gap-2 px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                    Sair
                </button>
            </form>
        </div>
    </div>
</header>
