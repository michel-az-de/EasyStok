@{
    var usuarioNome = ViewBag.UsuarioNome as string ?? "Usuário";
    var iniciais = string.Join("", (usuarioNome).Split(' ').Take(2).Select(p => p.Length > 0 ? p[0].ToString().ToUpper() : ""));
    if (string.IsNullOrEmpty(iniciais)) iniciais = "U";
}

<header class="bg-white border-b border-slate-200 px-4 py-3 flex items-center gap-3 flex-shrink-0">
    <!-- Hamburger (mobile only) -->
    <button @@click="sidebarOpen = !sidebarOpen"
            class="lg:hidden p-2 text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-colors flex-shrink-0">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
    </button>

    <!-- Busca global (trigger) -->
    <div class="flex-1" x-data="buscaUnificada()" @@keydown.window.ctrl.k.prevent="abrir()" @@keydown.window.slash.prevent="if(!document.activeElement || document.activeElement.tagName === 'BODY') abrir()">
        <!-- Trigger button -->
        <button @@click="abrir()"
                class="flex items-center gap-2 px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-400 hover:bg-white hover:border-slate-300 transition-colors w-full max-w-xs">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
            </svg>
            <span class="flex-1 text-left truncate hidden sm:block">Buscar...</span>
            <kbd class="hidden sm:inline-flex items-center gap-1 px-1.5 py-0.5 text-xs bg-slate-100 border border-slate-200 rounded text-slate-400">Ctrl K</kbd>
        </button>

        <!-- Command palette overlay -->
        <div x-show="aberto" x-cloak
             class="fixed inset-0 z-[100] flex items-start justify-center pt-[8vh] px-4"
             @@keydown.escape.window="fechar()">
            <!-- Backdrop -->
            <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm" @@click="fechar()"></div>

            <!-- Painel -->
            <div class="relative w-full max-w-xl bg-white rounded-2xl shadow-2xl border border-slate-200 overflow-hidden"
                 @@keydown.arrow-down.prevent="mover(1)" @@keydown.arrow-up.prevent="mover(-1)"
                 @@keydown.enter.prevent="selecionar()">
                <!-- Input -->
                <div class="flex items-center gap-3 px-4 py-3 border-b border-slate-100">
                    <svg class="w-5 h-5 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
                    </svg>
                    <input type="text" placeholder="Buscar produto, SKU, código, fornecedor..."
                           x-ref="input"
                           x-model="query"
                           @@input.debounce.300ms="buscar()"
                           class="flex-1 text-sm text-slate-800 placeholder-slate-400 bg-transparent border-none outline-none" />
                    <div x-show="carregando" class="w-4 h-4 border-2 border-indigo-400 border-t-transparent rounded-full animate-spin flex-shrink-0"></div>
                    <kbd class="flex-shrink-0 text-xs text-slate-400 bg-slate-100 px-1.5 py-0.5 rounded border border-slate-200">Esc</kbd>
                </div>

                <!-- Resultados -->
                <div class="max-h-[60vh] overflow-y-auto py-1">
                    <template x-if="results.length > 0">
                        <div>
                            <template x-for="(item, idx) in results" :key="item.id + '-' + item.tipo">
                                <a :href="linkItem(item)"
                                   :class="idx === activeIdx ? 'bg-indigo-50' : 'hover:bg-slate-50'"
                                   class="flex items-start gap-3 px-4 py-2.5 transition-colors cursor-pointer group"
                                   @@mouseenter="activeIdx = idx"
                                   @@click="fechar()">
                                    <!-- Badge tipo -->
                                    <span :class="badgeClasse(item.tipo)"
                                          class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide flex-shrink-0 mt-0.5"
                                          x-text="badgeLabel(item.tipo)"></span>
                                    <!-- Conteúdo -->
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center gap-2">
                                            <span class="text-sm font-medium text-slate-900 truncate" x-text="item.titulo"></span>
                                            <template x-if="item.sku">
                                                <span class="text-xs text-slate-400 font-mono flex-shrink-0" x-text="item.sku"></span>
                                            </template>
                                        </div>
                                        <div class="flex items-center gap-2 mt-0.5">
                                            <span x-show="item.subtitulo" class="text-xs text-slate-500 truncate" x-text="item.subtitulo"></span>
                                            <template x-if="item.quantidadeAtual !== null && item.quantidadeAtual !== undefined">
                                                <span :class="statusClasse(item.status)"
                                                      class="text-xs font-medium flex-shrink-0"
                                                      x-text="item.quantidadeAtual + ' un.'"></span>
                                            </template>
                                            <span x-show="item.fornecedorNome" class="text-xs text-slate-400 flex-shrink-0" x-text="item.fornecedorNome"></span>
                                        </div>
                                    </div>
                                    <!-- Ações rápidas para estoque -->
                                    <template x-if="item.tipo === 'ItemEstoque'">
                                        <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0">
                                            <a :href="'/entradas/nova?produtoId=' + item.produtoId"
                                               @@click.stop
                                               class="text-xs px-2 py-1 bg-emerald-50 text-emerald-700 rounded hover:bg-emerald-100 transition-colors">
                                                Entrada
                                            </a>
                                            <a :href="'/saidas/nova?produtoId=' + item.produtoId"
                                               @@click.stop
                                               class="text-xs px-2 py-1 bg-rose-50 text-rose-700 rounded hover:bg-rose-100 transition-colors">
                                                Saída
                                            </a>
                                        </div>
                                    </template>
                                </a>
                            </template>
                        </div>
                    </template>

                    <!-- Estado vazio -->
                    <div x-show="semResultados && !carregando && query.length >= 2"
                         class="px-4 py-8 text-center">
                        <div class="text-slate-300 mb-2">
                            <svg class="w-10 h-10 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
                            </svg>
                        </div>
                        <p class="text-sm text-slate-400">Nenhum resultado para <strong x-text="query" class="text-slate-600"></strong></p>
                        <p class="text-xs text-slate-300 mt-1">Tente por nome, SKU, código interno ou fornecedor</p>
                    </div>

                    <!-- Estado inicial -->
                    <div x-show="results.length === 0 && !semResultados && !carregando"
                         class="px-4 py-4 text-xs text-slate-400 text-center">
                        Digite pelo menos 2 caracteres para buscar
                    </div>
                </div>

                <!-- Rodapé dicas -->
                <div class="border-t border-slate-100 px-4 py-2 flex items-center gap-4 text-xs text-slate-400">
                    <span><kbd class="bg-slate-100 px-1 rounded border border-slate-200">↑↓</kbd> navegar</span>
                    <span><kbd class="bg-slate-100 px-1 rounded border border-slate-200">Enter</kbd> abrir</span>
                    <span><kbd class="bg-slate-100 px-1 rounded border border-slate-200">Esc</kbd> fechar</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        function buscaUnificada() {
            return {
                aberto: false,
                query: '',
                results: [],
                semResultados: false,
                carregando: false,
                activeIdx: 0,

                abrir() {
                    this.aberto = true;
                    this.$nextTick(() => this.$refs.input && this.$refs.input.focus());
                },
                fechar() {
                    this.aberto = false;
                    this.query = '';
                    this.results = [];
                    this.semResultados = false;
                    this.activeIdx = 0;
                },
                mover(dir) {
                    if (this.results.length === 0) return;
                    this.activeIdx = (this.activeIdx + dir + this.results.length) % this.results.length;
                },
                selecionar() {
                    if (this.results.length === 0) return;
                    const item = this.results[this.activeIdx];
                    if (item) window.location.href = this.linkItem(item);
                },
                async buscar() {
                    const q = this.query.trim();
                    if (q.length < 2) { this.results = []; this.semResultados = false; return; }
                    this.carregando = true;
                    try {
                        const r = await fetch('/busca?q=' + encodeURIComponent(q) + '&limit=15');
                        if (!r.ok) return;
                        const data = await r.json();
                        this.results = Array.isArray(data) ? data : [];
                        this.semResultados = this.results.length === 0;
                        this.activeIdx = 0;
                    } catch {
                        this.results = [];
                    } finally {
                        this.carregando = false;
                    }
                },
                linkItem(item) {
                    switch (item.tipo) {
                        case 'Produto': return '/produtos/' + item.produtoId;
                        case 'Variacao': return '/produtos/' + item.produtoId;
                        case 'ItemEstoque': return '/estoque';
                        case 'Fornecedor': return '/fornecedores/' + item.id;
                        default: return '/produtos/' + item.produtoId;
                    }
                },
                badgeLabel(tipo) {
                    return { Produto: 'Produto', Variacao: 'Variação', ItemEstoque: 'Estoque', Fornecedor: 'Fornecedor' }[tipo] || tipo;
                },
                badgeClasse(tipo) {
                    return {
                        Produto: 'bg-indigo-100 text-indigo-700',
                        Variacao: 'bg-violet-100 text-violet-700',
                        ItemEstoque: 'bg-emerald-100 text-emerald-700',
                        Fornecedor: 'bg-amber-100 text-amber-700'
                    }[tipo] || 'bg-slate-100 text-slate-600';
                },
                statusClasse(status) {
                    return {
                        'Ok': 'text-emerald-600',
                        'Warn': 'text-amber-600',
                        'Critical': 'text-red-600',
                        'Slow': 'text-slate-500',
                        'Vencido': 'text-red-700',
                        'Bloqueado': 'text-slate-400'
                    }[status] || 'text-slate-500';
                }
            };
        }
    </script>

    <!-- Ação rápida -->
    <div x-data="{ open: false }" class="relative">
        <button @@click="open = !open"
                class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            <span class="hidden sm:inline">Ação rápida</span>
        </button>
        <div x-show="open" @@click.outside="open = false"
             class="absolute right-0 mt-2 w-52 bg-white rounded-xl shadow-xl border border-slate-200 py-1 z-50">
            <a href="/entradas/nova" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>📥</span> Nova entrada
            </a>
            <a href="/saidas/nova" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>📤</span> Nova saída
            </a>
            <a href="/entradas/reposicao" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>🔄</span> Repor estoque
            </a>
            <a href="/estoque" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>📦</span> Ver estoque
            </a>
            <div class="border-t border-slate-100 my-1"></div>
            <a href="/anuncios" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>🤖</span> Gerar anúncio com IA
            </a>
            <a href="/analytics/movimentacoes" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>📊</span> Ver movimentações
            </a>
        </div>
    </div>

    <!-- Notificações -->
    <a href="/notificacoes" class="relative p-2 text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
        </svg>
        <span id="topbar-notif-badge" class="hidden absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold rounded-full w-4 h-4 flex items-center justify-center"></span>
    </a>

    <!-- Avatar / usuário -->
    <div x-data="{ open: false }" class="relative">
        <button @@click="open = !open"
                class="flex items-center gap-2 p-1 rounded-lg hover:bg-slate-100 transition-colors">
            <div class="w-8 h-8 bg-indigo-600 text-white rounded-full flex items-center justify-center text-xs font-bold">
                @iniciais
            </div>
            <div class="text-left hidden sm:block">
                <div class="text-sm font-semibold text-slate-800 leading-tight">@usuarioNome</div>
            </div>
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
        </button>
        <div x-show="open" @@click.outside="open = false"
             class="absolute right-0 mt-2 w-44 bg-white rounded-xl shadow-xl border border-slate-200 py-1 z-50">
            <div class="px-4 py-2 text-xs text-slate-400 border-b border-slate-100">@usuarioNome</div>
            <form asp-controller="Auth" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full flex items-center gap-2 px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                    Sair
                </button>
            </form>
        </div>
    </div>
</header>
