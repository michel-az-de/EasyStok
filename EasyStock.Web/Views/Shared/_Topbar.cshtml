@{
    var usuarioNome = ViewBag.UsuarioNome as string ?? "Usuário";
    var iniciais = string.Join("", (usuarioNome).Split(' ').Take(2).Select(p => p.Length > 0 ? p[0].ToString().ToUpper() : ""));
    if (string.IsNullOrEmpty(iniciais)) iniciais = "U";
}

<header class="bg-white border-b border-slate-200 px-4 py-3 flex items-center gap-3 flex-shrink-0">
    <!-- Hamburger (mobile only) -->
    <button @@click="sidebarOpen = !sidebarOpen"
            class="lg:hidden p-2 text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-colors flex-shrink-0">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
    </button>

    <!-- Busca global -->
    <div class="flex-1 max-w-md hidden sm:block" x-data="topbarSearch()" @@click.outside="results = []">
        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
            </svg>
            <input type="text" placeholder="Buscar produto ou SKU..."
                   x-model="query" @@input.debounce.300ms="search()"
                   @@keydown.escape="results = []; query = ''"
                   class="w-full pl-9 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-600 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:bg-white" />
            <!-- Dropdown resultados -->
            <div x-show="results.length > 0" x-cloak
                 class="absolute top-full left-0 right-0 mt-1 bg-white rounded-xl shadow-xl border border-slate-200 py-1 z-50 max-h-80 overflow-y-auto">
                <template x-for="item in results" :key="item.id">
                    <a :href="'/produtos/' + item.id"
                       class="flex items-center gap-3 px-4 py-2.5 hover:bg-slate-50 transition-colors"
                       @@click="results = []">
                        <div class="flex-1 min-w-0">
                            <div class="text-sm font-medium text-slate-900 truncate" x-text="item.nome"></div>
                            <div class="text-xs text-slate-400" x-text="item.sku"></div>
                        </div>
                        <span class="text-xs text-slate-400 flex-shrink-0" x-text="item.categoria || ''"></span>
                    </a>
                </template>
                <div x-show="noResults" class="px-4 py-3 text-sm text-slate-400 text-center">
                    Nenhum produto encontrado.
                </div>
            </div>
        </div>
    </div>
    <script>
        function topbarSearch() {
            return {
                query: '',
                results: [],
                noResults: false,
                _timeout: null,
                async search() {
                    const q = this.query.trim();
                    if (q.length < 2) { this.results = []; this.noResults = false; return; }
                    try {
                        const r = await fetch('/produtos/buscar?q=' + encodeURIComponent(q) + '&limit=8');
                        if (!r.ok) return;
                        const data = await r.json();
                        this.results = Array.isArray(data) ? data : [];
                        this.noResults = this.results.length === 0;
                    } catch { this.results = []; this.noResults = false; }
                }
            };
        }
    </script>

    <!-- Ação rápida -->
    <div x-data="{ open: false }" class="relative">
        <button @@click="open = !open"
                class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Ação rápida
        </button>
        <div x-show="open" @@click.outside="open = false"
             class="absolute right-0 mt-2 w-52 bg-white rounded-xl shadow-xl border border-slate-200 py-1 z-50">
            <a href="/entradas/nova" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>📥</span> Nova entrada
            </a>
            <a href="/saidas/nova" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>📤</span> Nova saída
            </a>
            <a href="/entradas/reposicao" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>🔄</span> Repor estoque
            </a>
            <a href="/estoque" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>📦</span> Ver estoque
            </a>
            <div class="border-t border-slate-100 my-1"></div>
            <a href="/anuncios" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>🤖</span> Gerar anúncio com IA
            </a>
            <a href="/analytics/movimentacoes" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                <span>📊</span> Ver movimentações
            </a>
        </div>
    </div>

    <!-- Notificacoes Dropdown -->
    <div x-data="notifDropdown()" class="relative">
        <button @@click="toggle()" class="relative p-2 text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            <span id="topbar-notif-badge" class="hidden absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold rounded-full w-4 h-4 flex items-center justify-center"></span>
        </button>

        <div x-show="open" @@click.outside="open = false" x-cloak x-transition
             class="absolute right-0 mt-2 w-96 max-h-[480px] bg-white rounded-xl shadow-2xl border border-slate-200 z-50 flex flex-col">
            <!-- Header -->
            <div class="flex items-center justify-between px-4 py-3 border-b border-slate-100">
                <div class="flex items-center gap-2">
                    <span class="font-semibold text-slate-900 text-sm">Notificacoes</span>
                    <template x-if="resumo && resumo.totalNaoLidas > 0">
                        <span class="px-1.5 py-0.5 bg-red-100 text-red-600 rounded-full text-xs font-medium" x-text="resumo.totalNaoLidas"></span>
                    </template>
                </div>
                <template x-if="resumo && resumo.criticas > 0">
                    <span class="px-1.5 py-0.5 bg-red-600 text-white rounded-full text-xs font-bold" x-text="resumo.criticas + ' critica' + (resumo.criticas > 1 ? 's' : '')"></span>
                </template>
            </div>

            <!-- Items -->
            <div class="overflow-y-auto flex-1">
                <template x-if="loading">
                    <div class="px-4 py-8 text-center text-slate-400 text-sm">Carregando...</div>
                </template>
                <template x-if="!loading && items.length === 0">
                    <div class="px-4 py-8 text-center text-slate-400">
                        <svg class="w-8 h-8 mx-auto mb-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        <p class="text-sm">Nenhuma notificacao pendente</p>
                    </div>
                </template>
                <template x-for="n in items" :key="n.id">
                    <div class="px-4 py-3 border-b border-slate-50 hover:bg-slate-50 transition-colors"
                         :class="severidadeBorder(n.severidade)">
                        <div class="flex items-start gap-3">
                            <div class="flex-shrink-0 mt-0.5" x-html="severidadeIcon(n.severidade)"></div>
                            <div class="flex-1 min-w-0">
                                <div class="text-sm font-medium text-slate-900 truncate" x-text="n.titulo"></div>
                                <div class="text-xs text-slate-500 mt-0.5 line-clamp-2" x-text="n.mensagem"></div>
                                <div class="flex items-center gap-2 mt-1.5">
                                    <a :href="acaoUrl(n)" class="text-xs text-indigo-600 hover:text-indigo-700 font-medium" x-text="acaoLabel(n)"></a>
                                    <span class="text-slate-300">|</span>
                                    <button @@click.stop="marcarLida(n.id)" class="text-xs text-slate-400 hover:text-slate-600">Marcar lida</button>
                                    <span class="text-xs text-slate-300 ml-auto" x-text="tempoRelativo(n.criadaEm || n.createdAt)"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </template>
            </div>

            <!-- Footer -->
            <a href="/notificacoes" class="block px-4 py-2.5 text-center text-sm text-indigo-600 font-medium hover:bg-indigo-50 border-t border-slate-100 rounded-b-xl transition-colors">
                Ver todas as notificacoes
            </a>
        </div>
    </div>
    <script>
        function notifDropdown() {
            return {
                open: false,
                loading: false,
                items: [],
                resumo: null,
                async toggle() {
                    this.open = !this.open;
                    if (this.open && this.items.length === 0) await this.load();
                },
                async load() {
                    this.loading = true;
                    try {
                        const [rItems, rResumo] = await Promise.all([
                            fetch('/notificacoes/recentes').then(r => r.json()),
                            fetch('/notificacoes/resumo').then(r => r.json())
                        ]);
                        this.items = Array.isArray(rItems) ? rItems : [];
                        this.resumo = rResumo;
                    } catch { this.items = []; }
                    this.loading = false;
                },
                async marcarLida(id) {
                    try {
                        await fetch('/notificacoes/' + id + '/lida-ajax', { method: 'POST' });
                        this.items = this.items.filter(n => n.id !== id);
                        if (this.resumo) this.resumo.totalNaoLidas = Math.max(0, (this.resumo.totalNaoLidas || 0) - 1);
                        const badge = document.getElementById('topbar-notif-badge');
                        if (badge) {
                            const c = this.resumo?.totalNaoLidas || 0;
                            if (c > 0) { badge.textContent = c > 99 ? '99+' : c; }
                            else { badge.classList.add('hidden'); }
                        }
                    } catch {}
                },
                severidadeBorder(s) {
                    const m = { Critica: 'border-l-4 border-red-500', Alta: 'border-l-4 border-orange-500', Media: 'border-l-4 border-yellow-400', Informativa: 'border-l-4 border-slate-300' };
                    return m[s] || m.Media;
                },
                severidadeIcon(s) {
                    const icons = {
                        Critica: '<svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>',
                        Alta: '<svg class="w-4 h-4 text-orange-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>',
                        Media: '<svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>',
                        Informativa: '<svg class="w-4 h-4 text-slate-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>'
                    };
                    return icons[s] || icons.Media;
                },
                acaoUrl(n) {
                    const t = n.tipoAlerta || n.tipo;
                    const ref = n.referenciaId;
                    const map = {
                        EstoqueCritico: '/estoque?item=' + ref,
                        ProdutoVencido: '/estoque?item=' + ref,
                        ValidadeProxima: '/estoque?item=' + ref,
                        ProdutoParado: '/estoque?item=' + ref,
                        ReposicaoSugerida: '/entradas/reposicao?item=' + ref,
                        PedidoAtrasado: '/fornecedores',
                        PedidoRecebido: '/fornecedores'
                    };
                    return map[t] || '/estoque';
                },
                acaoLabel(n) {
                    const t = n.tipoAlerta || n.tipo;
                    const map = {
                        EstoqueCritico: 'Ver no estoque',
                        ProdutoVencido: 'Ver no estoque',
                        ValidadeProxima: 'Ver validade',
                        ProdutoParado: 'Ver item',
                        ReposicaoSugerida: 'Repor estoque',
                        PedidoAtrasado: 'Ver pedido',
                        PedidoRecebido: 'Ver pedido'
                    };
                    return map[t] || 'Ver detalhes';
                },
                tempoRelativo(dt) {
                    if (!dt) return '';
                    const diff = (Date.now() - new Date(dt).getTime()) / 1000;
                    if (diff < 60) return 'agora';
                    if (diff < 3600) return Math.floor(diff / 60) + 'min';
                    if (diff < 86400) return Math.floor(diff / 3600) + 'h';
                    return Math.floor(diff / 86400) + 'd';
                }
            };
        }
    </script>

    <!-- Avatar / usuário -->
    <div x-data="{ open: false }" class="relative">
        <button @@click="open = !open"
                class="flex items-center gap-2 p-1 rounded-lg hover:bg-slate-100 transition-colors">
            <div class="w-8 h-8 bg-indigo-600 text-white rounded-full flex items-center justify-center text-xs font-bold">
                @iniciais
            </div>
            <div class="text-left hidden sm:block">
                <div class="text-sm font-semibold text-slate-800 leading-tight">@usuarioNome</div>
            </div>
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
        </button>
        <div x-show="open" @@click.outside="open = false"
             class="absolute right-0 mt-2 w-44 bg-white rounded-xl shadow-xl border border-slate-200 py-1 z-50">
            <div class="px-4 py-2 text-xs text-slate-400 border-b border-slate-100">@usuarioNome</div>
            <form asp-controller="Auth" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full flex items-center gap-2 px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                    Sair
                </button>
            </form>
        </div>
    </div>
</header>
