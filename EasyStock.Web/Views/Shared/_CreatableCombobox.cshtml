@*
    Combobox com busca + criação inline + limpar (extensão T2.1).
    Parâmetros:
        Name          — nome do campo hidden no form (obrigatório)
        Items         — IEnumerable<{value, label}> (obrigatório)
        Value         — valor selecionado inicial (opcional)
        Placeholder   — placeholder do input (opcional)
        Required      — bool, marca campo como obrigatório na validação client-side
        CreateUrl     — endpoint POST para criação rápida (ex: "/financeiro/categorias/criar-rapido")
        CreatePayload — campos extras no POST (ex: new { tipo = "Despesa" })
        CreateLabel   — prefixo do botão criar, padrão "Criar"
        AllowClear    — bool, exibe botão × para limpar a seleção

    Uso:
        <partial name="_CreatableCombobox" model='new {
            Name         = "categoriaFinanceiraId",
            Items        = Model.Categorias.Select(c => new { value = c.Id, label = c.Nome }),
            Required     = true,
            CreateUrl    = "/financeiro/categorias/criar-rapido",
            CreatePayload= new { tipo = "Despesa" }
        }' />
*@
@model dynamic
@{
    string name = Model.Name as string ?? "combobox";
    object? value = null; try { value = Model.Value; } catch { }
    string? placeholder = null; try { placeholder = Model.Placeholder as string; } catch { }
    bool required = false; try { required = (bool)Model.Required; } catch { }
    string? createUrl = null; try { createUrl = Model.CreateUrl as string; } catch { }
    object? createPayload = null; try { createPayload = Model.CreatePayload; } catch { }
    string createLabel = "Criar";
    try { var cl = Model.CreateLabel as string; if (!string.IsNullOrWhiteSpace(cl)) createLabel = cl; } catch { }
    bool allowClear = false; try { allowClear = (bool)Model.AllowClear; } catch { }

    var itemsJson    = System.Text.Json.JsonSerializer.Serialize(Model.Items);
    var valueJson    = System.Text.Json.JsonSerializer.Serialize(value);
    var payloadJson  = createPayload != null
        ? System.Text.Json.JsonSerializer.Serialize(createPayload)
        : "{}";
    var phEsc        = (placeholder ?? "Selecionar...").Replace("\"", "&quot;");
    var createUrlEsc = (createUrl ?? "").Replace("\"", "&quot;");
    var createLblEsc = createLabel.Replace("\"", "&quot;");
}
<div class="combobox" x-data='combobox({ items: @Html.Raw(itemsJson), value: @Html.Raw(valueJson), name: "@name", placeholder: "@phEsc", createUrl: "@createUrlEsc", createPayload: @Html.Raw(payloadJson), createLabel: "@createLblEsc", allowClear: @(allowClear ? "true" : "false") })'>
    <input type="text" class="combobox-input"
           role="combobox" aria-autocomplete="list" :aria-expanded="open"
           :aria-controls="$id('cbx-list')"
           x-model="query"
           @@input="onInput()" @@focus="onFocus()" @@blur="onBlur()"
           @@keydown="onKey($event)"
           placeholder="@phEsc" />

    @* Caret: esconde quando há seleção E allowClear está ligado (o × aparece no lugar) *@
    @if (allowClear)
    {
        <span class="combobox-caret" aria-hidden="true" x-show="!selected">▾</span>
        <button type="button" class="combobox-clear" x-show="selected" x-cloak
                @@click="clear()" aria-label="Limpar seleção">×</button>
    }
    else
    {
        <span class="combobox-caret" aria-hidden="true">▾</span>
    }

    @* BUG-07: o valor real (selecionado) vive no hidden; data-required aqui faz o
       form-validate.js contar a categoria vazia como inválida (antes era pulada). *@
    <input type="hidden" name="@name" :value="selected ?? ''" @(required ? "data-required=\"true\"" : "") />

    <div class="combobox-listbox" role="listbox" :id="$id('cbx-list')" x-show="open" x-cloak>
        <template x-for="(item, idx) in filtered" :key="item.value">
            <div class="combobox-option"
                 role="option"
                 :aria-selected="String(item.value) === String(selected)"
                 :data-active="idx === activeIdx"
                 @@mousedown.prevent="pick(item)"
                 x-text="item.label"></div>
        </template>

        <div class="combobox-empty" x-show="filtered.length === 0 && !showCreate()">Nenhum resultado</div>

        @if (!string.IsNullOrEmpty(createUrl))
        {
            <div class="combobox-create"
                 x-show="showCreate()"
                 :data-active="activeIdx === filtered.length"
                 @@mousedown.prevent="create()">
                <span x-show="!creating" x-text="`+ @createLblEsc &quot;${query.trim()}&quot;`"></span>
                <span x-show="creating">Criando…</span>
            </div>
            <div class="combobox-error" x-show="createError" x-cloak x-text="createError"></div>
        }
    </div>
</div>
