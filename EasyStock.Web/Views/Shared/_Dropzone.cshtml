@*
    File upload com dropzone (T2.7). Usa Alpine inline.
    Params: Name, Accept (default "image/*"), Multiple (bool).
*@
@model dynamic
@{
    string name = "files"; try { name = (Model.Name as string) ?? "files"; } catch { }
    string accept = "image/*"; try { accept = (Model.Accept as string) ?? "image/*"; } catch { }
    bool multiple = true; try { multiple = (bool)Model.Multiple; } catch { }
}
<div x-data="{
        files: [],
        dragover: false,
        onSelect(e) { this.add(e.target.files); },
        onDrop(e) { this.dragover = false; this.add(e.dataTransfer.files); },
        add(list) {
            for (const f of list) { if (f.type.startsWith('image/')) f.preview = URL.createObjectURL(f); this.files.push(f); }
            this._syncInput();
        },
        remove(i) { this.files.splice(i, 1); this._syncInput(); },
        _syncInput() {
            const dt = new DataTransfer();
            for (const f of this.files) dt.items.add(f);
            this.$refs.input.files = dt.files;
        }
     }">
    <label class="dropzone block"
           :data-dragover="dragover"
           @@dragover.prevent="dragover=true"
           @@dragleave="dragover=false"
           @@drop.prevent="onDrop($event)">
        <input type="file" name="@name" @(multiple ? "multiple" : "") accept="@accept"
               x-ref="input" class="sr-only" @@change="onSelect($event)" />
        <div class="text-sm">
            <strong class="block">Solte arquivos aqui</strong>
            <span class="text-xs">ou clique para escolher</span>
        </div>
    </label>
    <div class="dropzone-preview" x-show="files.length > 0" x-cloak>
        <template x-for="(f, i) in files" :key="i">
            <div class="relative">
                <img x-show="f.preview" :src="f.preview" :alt="f.name" />
                <button type="button" @@click="remove(i)" aria-label="Remover"
                        class="absolute top-1 right-1 bg-black/60 text-white rounded-full w-5 h-5 text-xs leading-none">×</button>
            </div>
        </template>
    </div>
</div>
