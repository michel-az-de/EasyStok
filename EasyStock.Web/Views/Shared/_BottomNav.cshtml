@{
    var activeItem = ViewBag.ActiveMenuItem as string ?? "";
}

<div x-data="{ moreOpen: false }" class="lg:hidden">

    @* Backdrop *@
    <div x-show="moreOpen"
         x-transition:enter="transition-opacity ease-linear duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition-opacity ease-linear duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @@click="moreOpen = false"
         class="sheet-overlay fixed inset-0 bg-black/40 z-40"
         x-cloak></div>

    @* Action sheet *@
    <div x-show="moreOpen"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-full"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 translate-y-full"
         class="quick-actions-sheet fixed inset-x-0 bottom-0 z-50 bg-white rounded-t-2xl shadow-2xl pb-safe"
         x-cloak>

        @* Handle *@
        <div class="flex justify-center pt-3 pb-1">
            <div class="sheet-handle w-10 h-1 bg-slate-200 rounded-full"></div>
        </div>

        <div class="px-4 pb-6 pt-2">
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3 px-1">Ações rápidas</p>

            <div class="grid grid-cols-3 gap-2.5">
                <a href="/entradas/nova" @@click="moreOpen = false"
                   class="quick-action-item flex flex-col items-center gap-2 p-3.5 rounded-2xl bg-emerald-50 text-emerald-700 active:scale-95 transition-transform">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    <span class="text-xs font-semibold leading-tight text-center">Nova entrada</span>
                </a>

                <a href="/saidas/nova" @@click="moreOpen = false"
                   class="quick-action-item flex flex-col items-center gap-2 p-3.5 rounded-2xl bg-rose-50 text-rose-700 active:scale-95 transition-transform">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 20H4m16-8H4m8-8H4" />
                    </svg>
                    <span class="text-xs font-semibold leading-tight text-center">Nova saída</span>
                </a>

                <a href="/entradas/reposicao" @@click="moreOpen = false"
                   class="quick-action-item flex flex-col items-center gap-2 p-3.5 rounded-2xl bg-indigo-50 text-indigo-700 active:scale-95 transition-transform">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                    <span class="text-xs font-semibold leading-tight text-center">Reposição</span>
                </a>

                <a href="/fornecedores" @@click="moreOpen = false"
                   class="quick-action-item flex flex-col items-center gap-2 p-3.5 rounded-2xl bg-amber-50 text-amber-700 active:scale-95 transition-transform">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span class="text-xs font-semibold leading-tight text-center">Fornecedores</span>
                </a>

                <a href="/estoque" @@click="moreOpen = false"
                   class="quick-action-item flex flex-col items-center gap-2 p-3.5 rounded-2xl bg-slate-50 text-slate-700 active:scale-95 transition-transform">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    <span class="text-xs font-semibold leading-tight text-center">Estoque</span>
                </a>

                <a href="/notificacoes" @@click="moreOpen = false"
                   class="quick-action-item flex flex-col items-center gap-2 p-3.5 rounded-2xl bg-slate-50 text-slate-700 active:scale-95 transition-transform relative">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                    </svg>
                    <span class="text-xs font-semibold leading-tight text-center">Notificações</span>
                </a>
            </div>

            <div class="mt-4 border-t border-slate-100 pt-3 space-y-1">
                <a href="/analytics" @@click="moreOpen = false"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-slate-50 text-slate-700 text-sm font-medium active:bg-slate-100">
                    <svg class="w-5 h-5 text-indigo-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                    Análises &amp; IA
                </a>
                <a href="/anuncios" @@click="moreOpen = false"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-slate-50 text-slate-700 text-sm font-medium active:bg-slate-100">
                    <svg class="w-5 h-5 text-violet-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
                    </svg>
                    Anúncios com IA
                </a>
                <a href="/configuracoes" @@click="moreOpen = false"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-slate-50 text-slate-700 text-sm font-medium active:bg-slate-100">
                    <svg class="w-5 h-5 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Configurações
                </a>
            </div>
        </div>
    </div>

    @* Bottom nav bar *@
    <nav class="bottom-nav">
        <a href="/dashboard"
           class="bottom-nav-item @(activeItem == "Dashboard" ? "bottom-nav-item--active" : "")">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span>Início</span>
        </a>

        <a href="/produtos"
           class="bottom-nav-item @(activeItem == "Produtos" ? "bottom-nav-item--active" : "")">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            <span>Produtos</span>
        </a>

        <a href="/entradas/historico"
           class="bottom-nav-item @(activeItem is "Entradas" or "EntradasNova" or "EntradasHistorico" or "EntradasReposicao" ? "bottom-nav-item--active" : "")">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            <span>Entradas</span>
        </a>

        <a href="/saidas/historico"
           class="bottom-nav-item @(activeItem is "Saidas" or "SaidasHistorico" ? "bottom-nav-item--active" : "")">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 20H4m16-8H4m8-8H4" />
            </svg>
            <span>Saídas</span>
        </a>

        <button @@click="moreOpen = !moreOpen"
                class="bottom-nav-item bottom-nav-item--fab"
                :class="moreOpen ? 'bottom-nav-item--fab-open' : ''">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            <span x-text="moreOpen ? 'Fechar' : 'Mais'"></span>
        </button>
    </nav>
</div>
