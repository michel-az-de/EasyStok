@*
    Banner persistente de status do trial. Renderiza vazio no SSR
    e popula via /api/assinatura no client. Some quando trial nao
    ativo OU quando ja tem plano pago.
*@
<div id="trial-banner" class="hidden" data-trial-banner>
    <div class="px-4 py-2 text-sm flex items-center justify-between gap-3" data-trial-bar
         style="background-color: var(--accent-soft, var(--orange-50)); border-bottom: 1px solid var(--border-soft); color: var(--text-primary);">
        <span data-trial-msg></span>
        <a href="/assinatura" class="font-semibold underline whitespace-nowrap">Assinar agora</a>
    </div>
</div>
<script>
(function(){
    var el = document.getElementById('trial-banner');
    if (!el) return;
    function render(json){
        if (!json || !json.data) return;
        var d = json.data;
        if (!d.trialAtivo) return;
        if (d.dataFim && new Date(d.dataFim) >= new Date()) return; // ja tem plano pago vigente
        var fim = d.trialFim ? new Date(d.trialFim) : null;
        if (!fim) return;
        var dias = Math.max(0, Math.ceil((fim - new Date()) / 86400000));
        var msg = el.querySelector('[data-trial-msg]');
        if (msg) {
            if (dias === 0) msg.innerHTML = '<strong>Último dia de teste grátis.</strong> Assine hoje pra não perder o acesso amanhã.';
            else if (dias === 1) msg.innerHTML = '<strong>Falta 1 dia</strong> de teste grátis. Garanta sua assinatura e não pare a operação.';
            else msg.innerHTML = '<strong>Seu teste grátis termina em ' + dias + ' dias.</strong> Garanta sua assinatura e não pare a operação.';
        }
        // Urgência nos últimos 3 dias: barra âmbar mais forte que o laranja-suave padrão.
        var bar = el.querySelector('[data-trial-bar]');
        if (bar && dias <= 3) {
            bar.style.backgroundColor = 'var(--warn-50)';
            bar.style.borderBottomColor = 'var(--warn-200)';
        }
        el.classList.remove('hidden');
    }
    // BUG-23: cacheia /api/assinatura por 10min em sessionStorage. Sem isso, cada
    // navegacao (full-page MVC) refazia o fetch -> dezenas de chamadas identicas.
    try {
        var cached = sessionStorage.getItem('es_assinatura');
        if (cached) {
            var p = JSON.parse(cached);
            if (p && p.t && (Date.now() - p.t) < 600000) { render(p.v); return; }
        }
    } catch (e) { /* sessionStorage indisponivel: segue pro fetch */ }
    esFetch('/api/assinatura', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
        .then(function(r){ return r.ok ? r.json() : null; })
        .then(function(json){
            try { sessionStorage.setItem('es_assinatura', JSON.stringify({ t: Date.now(), v: json })); } catch (e) {}
            render(json);
        })
        .catch(function(){ /* silencia */ });
})();
</script>
