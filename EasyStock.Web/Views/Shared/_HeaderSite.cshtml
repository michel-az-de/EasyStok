@model EasyStock.Web.Services.MarketingOptions
@{
    var current = Context.Request.Path.Value?.TrimEnd('/').ToLowerInvariant() ?? string.Empty;
    string activeClass(string path) =>
        string.Equals(current, path.TrimEnd('/'), StringComparison.OrdinalIgnoreCase)
            ? "site-nav-link site-nav-link--active"
            : "site-nav-link";
}
<header class="site-top">
    <div class="site-container site-top-inner">
        <a href="/" class="site-logo" aria-label="EasyStok inicial">
            <svg class="site-logo-mark" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M32 6 L56 18 L32 30 L8 18 Z" fill="#E85814" />
                <path d="M8 18 L32 30 L32 58 L8 46 Z" fill="#0E2A6E" />
                <path d="M56 18 L32 30 L32 58 L56 46 Z" fill="#06143A" />
            </svg>
            <span class="site-logo-word"><span class="site-logo-easy">Easy</span><span class="site-logo-stok">Stok</span></span>
        </a>

        <nav class="site-nav" aria-label="Principal">
            <a href="/" class="@activeClass("")">Produto</a>
            <a href="/precos" class="@activeClass("/precos")">Precos</a>
            <a href="/app" class="@activeClass("/app")">No celular</a>
            <a href="/contato" class="@activeClass("/contato")">Contato</a>
        </nav>

        <div class="site-top-cta">
            <a href="/auth/login" class="btn btn-secondary btn-sm site-top-login">Entrar</a>
            <a href="/auth/registrar?origem=teste-gratis" class="btn btn-primary btn-sm site-top-cta-primary">Testar gratis</a>
            <button type="button" class="site-burger" aria-label="Abrir menu" aria-controls="site-mobile-nav" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
        </div>
    </div>

    <div id="site-mobile-nav" class="site-mobile-nav" hidden>
        <a href="/">Produto</a>
        <a href="/precos">Precos</a>
        <a href="/app">No celular</a>
        <a href="/contato">Contato</a>
        <hr />
        <a href="/auth/login">Entrar</a>
        <a href="/auth/registrar?origem=teste-gratis" class="btn btn-primary">Testar gratis</a>
    </div>
</header>
