@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var theme = (ViewBag.UserTheme as string)?.ToLowerInvariant() == "dark" ? "dark" : "light";
    var antiForgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full @(theme == "dark" ? "theme-dark" : string.Empty)" data-theme="@theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@ViewBag.Title — EasyStok</title>
    <meta name="csrf-token" content="@antiForgeryToken" />
    <script>
        (function () {
            const stored = localStorage.getItem('easystock-theme');
            const serverTheme = '@theme';
            const theme = stored === 'dark' || stored === 'light' ? stored : serverTheme;
            document.documentElement.dataset.theme = theme;
            document.documentElement.classList.toggle('theme-dark', theme === 'dark');
        })();
    </script>
    @* Alpine self-hosted (mesma origem) — sem CDN/SRI. O jsDelivr era bloqueado pelo
       firewall corporativo E os hashes SRI antigos estavam errados; ambos matavam o
       Alpine -> interatividade inteira inerte. Vendored de alpinejs@3.14.9 (core). *@
    <script defer src="~/js/vendor/alpine/alpine.js" asp-append-version="true"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.dist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/form-validation.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mobile.css" media="(max-width: 768px)" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/print.css" media="print" asp-append-version="true" />
    <style>
        /* Previne flash de dropdowns antes do Alpine.js inicializar */
        .app-dropdown { display: none; }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body class="app-body h-full font-[Inter] antialiased @(theme == "dark" ? "theme-dark" : string.Empty)" style="background-color:var(--app-bg);background-image:var(--app-bg-image);color:var(--text-primary);">
    <a href="#app-main" class="skip-link">Pular para o conteúdo</a>

    @* C1 (2026-05-16): aviso para viewports <320px (split-screen extremo).
       CSS em mobile.css mostra este div e esconde o resto. Atributo `hidden`
       e fallback default — mobile.css carrega com media="(max-width: 768px)",
       sem ele em desktop largo o div renderiza display:block default do browser. *@
    <div class="viewport-too-narrow-warning" hidden role="alert" aria-live="assertive">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
        </svg>
        <h2 class="text-base font-semibold">Tela muito estreita</h2>
        <p class="text-sm opacity-80">Gire o aparelho ou abra em tela maior (mínimo 320px).</p>
    </div>

    <div x-data="{ sidebarOpen: false }" class="flex h-screen overflow-hidden">
        <div x-show="sidebarOpen" x-cloak
             x-transition:enter="transition-opacity ease-linear duration-200"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition-opacity ease-linear duration-200"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             @@click="sidebarOpen = false"
             class="fixed inset-0 bg-black/50 z-40 lg:hidden"></div>
        @await Html.PartialAsync("_Sidebar")
        <div class="flex flex-col flex-1 overflow-hidden min-w-0">
            @await Html.PartialAsync("_Topbar")
            <main id="app-main" class="app-main flex-1 overflow-y-auto p-4 lg:p-6 pb-28 lg:pb-6" tabindex="-1">
                @await Html.PartialAsync("_Toast")
                @await Html.PartialAsync("_TrialBanner")
                @RenderBody()
            </main>
        </div>
    </div>

    @* Bottom nav: outside flex wrapper so it sits above everything *@
    @await Html.PartialAsync("_BottomNav")

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.js"></script>
    <script src="~/js/combobox.js" asp-append-version="true"></script>
    <script src="~/js/keybindings.js" asp-append-version="true"></script>
    <script src="~/js/shortcuts.js" asp-append-version="true"></script>
    <script src="~/js/scanner.js" asp-append-version="true"></script>
    <script src="~/js/confirm.js" asp-append-version="true"></script>
    <script src="~/js/nav-progress.js" asp-append-version="true"></script>
    <script src="~/js/format.js" asp-append-version="true"></script>
    <script src="~/js/toast.js" asp-append-version="true"></script>
    <script src="~/js/api.js" asp-append-version="true"></script>
    <script src="~/js/locale.js" asp-append-version="true"></script>
    <script src="~/js/masks.js" asp-append-version="true"></script>
    <script src="~/js/form-guard.js" asp-append-version="true"></script>
    <script src="~/js/form-submit.js" asp-append-version="true"></script>
    <script src="~/js/form-validate.js" asp-append-version="true"></script>
    <script src="~/js/form-modal.js" asp-append-version="true"></script>
    <script src="~/js/bulk.js" asp-append-version="true"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script src="~/js/command-palette.js" asp-append-version="true"></script>
    <script src="~/js/row-nav.js" asp-append-version="true"></script>
    <script>
        // Topbar scroll state binding (depende de .app-main e .app-topbar no DOM).
        (function () {
            function bindTopbarScrollState() {
                var scroller = document.querySelector('.app-main');
                var topbar = document.querySelector('.app-topbar');
                if (!scroller || !topbar) return;
                var sync = function () {
                    topbar.classList.toggle('app-topbar--scrolled', scroller.scrollTop > 20);
                };
                sync();
                scroller.addEventListener('scroll', sync, { passive: true });
            }
            document.addEventListener('DOMContentLoaded', bindTopbarScrollState);
            window.addEventListener('pageshow', bindTopbarScrollState);
        })();
    </script>
    @RenderSection("Scripts", required: false)
    <partial name="_ConfirmModal" />
    <partial name="_Cheatsheet" />
    <partial name="_BarcodeScannerModal" />
    <partial name="_CommandPalette" />
</body>
</html>
