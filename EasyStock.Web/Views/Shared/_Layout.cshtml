@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var theme = (ViewBag.UserTheme as string)?.ToLowerInvariant() == "dark" ? "dark" : "light";
    var antiForgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full @(theme == "dark" ? "theme-dark" : string.Empty)" data-theme="@theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@ViewBag.Title — EasyStock</title>
    <meta name="csrf-token" content="@antiForgeryToken" />
    <script>
        (function () {
            const stored = localStorage.getItem('easystock-theme');
            const serverTheme = '@theme';
            const theme = stored === 'dark' || stored === 'light' ? stored : serverTheme;
            document.documentElement.dataset.theme = theme;
            document.documentElement.classList.toggle('theme-dark', theme === 'dark');
        })();
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.dist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mobile.css" media="(max-width: 768px)" asp-append-version="true" />
    <style>
        /* Previne flash de dropdowns antes do Alpine.js inicializar */
        .app-dropdown { display: none; }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body class="app-body h-full font-[Inter] text-slate-900 antialiased @(theme == "dark" ? "theme-dark" : string.Empty)" style="background-color:var(--app-bg);background-image:var(--app-bg-image);">
    <a href="#app-main" class="skip-link">Pular para o conteúdo</a>
    <div x-data="{ sidebarOpen: false }" class="flex h-screen overflow-hidden">
        <div x-show="sidebarOpen" x-cloak
             x-transition:enter="transition-opacity ease-linear duration-200"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition-opacity ease-linear duration-200"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             @@click="sidebarOpen = false"
             class="fixed inset-0 bg-black/50 z-40 lg:hidden"></div>
        @await Html.PartialAsync("_Sidebar")
        <div class="flex flex-col flex-1 overflow-hidden min-w-0">
            @await Html.PartialAsync("_Topbar")
            <main id="app-main" class="app-main flex-1 overflow-y-auto p-4 lg:p-6 pb-24 lg:pb-6" tabindex="-1">
                @await Html.PartialAsync("_Toast")
                @RenderBody()
            </main>
        </div>
    </div>

    @* Bottom nav: outside flex wrapper so it sits above everything *@
    @await Html.PartialAsync("_BottomNav")

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.js"></script>
    <script src="~/js/toast.js" asp-append-version="true"></script>
    <script src="~/js/api.js" asp-append-version="true"></script>
    <script src="~/js/locale.js" asp-append-version="true"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script>
        // Topbar scroll state binding (depende de .app-main e .app-topbar no DOM).
        (function () {
            function bindTopbarScrollState() {
                var scroller = document.querySelector('.app-main');
                var topbar = document.querySelector('.app-topbar');
                if (!scroller || !topbar) return;
                var sync = function () {
                    topbar.classList.toggle('app-topbar--scrolled', scroller.scrollTop > 20);
                };
                sync();
                scroller.addEventListener('scroll', sync, { passive: true });
            }
            document.addEventListener('DOMContentLoaded', bindTopbarScrollState);
            window.addEventListener('pageshow', bindTopbarScrollState);
        })();
    </script>
    @RenderSection("Scripts", required: false)
    <partial name="_ConfirmModal" />
</body>
</html>
