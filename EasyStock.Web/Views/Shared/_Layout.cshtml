@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var theme = (ViewBag.UserTheme as string)?.ToLowerInvariant() == "dark" ? "dark" : "light";
    var antiForgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full @(theme == "dark" ? "theme-dark" : string.Empty)" data-theme="@theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@ViewBag.Title — EasyStock</title>
    <meta name="csrf-token" content="@antiForgeryToken" />
    <script>
        (function () {
            const stored = localStorage.getItem('easystock-theme');
            const serverTheme = '@theme';
            const theme = stored === 'dark' || stored === 'light' ? stored : serverTheme;
            document.documentElement.dataset.theme = theme;
            document.documentElement.classList.toggle('theme-dark', theme === 'dark');
        })();
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#6366F1',
                        'primary-hover': '#4F46E5',
                        'primary-light': '#EEF2FF',
                        sidebar: '#0F172A',
                        'sidebar-text': '#94A3B8',
                        'sidebar-active': '#818CF8',
                        surface: '#FFFFFF',
                        border: '#E2E8F0'
                    }
                }
            }
        }
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/app.css" />
    <link rel="stylesheet" href="~/css/mobile.css" media="(max-width: 768px)" />
    @RenderSection("Styles", required: false)
</head>
<body class="app-body h-full font-[Inter] text-slate-900 antialiased @(theme == "dark" ? "theme-dark" : string.Empty)" style="background-color:var(--app-bg);background-image:var(--app-bg-image);">
    <div x-data="{ sidebarOpen: false }" class="flex h-screen overflow-hidden">
        <div x-show="sidebarOpen"
             x-transition:enter="transition-opacity ease-linear duration-200"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition-opacity ease-linear duration-200"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             @@click="sidebarOpen = false"
             class="fixed inset-0 bg-black/50 z-40 lg:hidden" x-cloak></div>
        @await Html.PartialAsync("_Sidebar")
        <div class="flex flex-col flex-1 overflow-hidden min-w-0">
            @await Html.PartialAsync("_Topbar")
            <main class="app-main flex-1 overflow-y-auto p-4 lg:p-6 pb-24 lg:pb-6">
                @await Html.PartialAsync("_Toast")
                @RenderBody()
            </main>
        </div>
    </div>

    @* Bottom nav: outside flex wrapper so it sits above everything *@
    @await Html.PartialAsync("_BottomNav")

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.js"></script>
    <script src="~/js/toast.js"></script>
    <script>
        (function () {
            function bindTopbarScrollState() {
                var scroller = document.querySelector('.app-main');
                var topbar = document.querySelector('.app-topbar');
                if (!scroller || !topbar) return;

                var sync = function () {
                    topbar.classList.toggle('app-topbar--scrolled', scroller.scrollTop > 20);
                };

                sync();
                scroller.addEventListener('scroll', sync, { passive: true });
            }

            document.addEventListener('DOMContentLoaded', bindTopbarScrollState);
            window.addEventListener('pageshow', bindTopbarScrollState);
        })();
    </script>
    <script>
        /* ── Decimal separator normalizer (BR locale: vírgula → ponto) ──
           Intercepts comma keypresses on number inputs and converts to period,
           allowing Brazilian users to type "10,50" and get "10.50".
        ── */
        document.addEventListener('keydown', function (e) {
            if ((e.key === ',' || e.key === 'Decimal') && e.target.tagName === 'INPUT') {
                var t = e.target;
                if (t.type === 'number' || t.inputMode === 'decimal' || t.inputMode === 'numeric') {
                    e.preventDefault();
                    // For type=text/decimal inputs, insert a period at cursor position
                    if (t.type !== 'number') {
                        var s = t.selectionStart, end = t.selectionEnd;
                        t.value = t.value.slice(0, s) + '.' + t.value.slice(end);
                        t.setSelectionRange(s + 1, s + 1);
                        t.dispatchEvent(new Event('input', { bubbles: true }));
                    }
                    // For type=number, only block the comma (browsers natively reject it)
                }
            }
        }, true);
    </script>
    <script>
        /* ── Notification polling ──────────────────────────────────────
           Polls /notificacoes/resumo every 45s.
           - Updates badge counters on first poll
           - On count increase: shakes bell, shows push toast for criticals
        ─────────────────────────────────────────────────────────────── */
        (function () {
            var lastCount    = -1;
            var lastCritical = 0;
            var INTERVAL     = 45000;

            function updateBadge(id, count) {
                var el = document.getElementById(id);
                if (!el) return;
                if (count > 0) {
                    el.textContent = count > 99 ? '99+' : String(count);
                    el.classList.remove('hidden');
                } else {
                    el.classList.add('hidden');
                }
            }

            function shakeBell() {
                var bell = document.getElementById('notif-bell-icon');
                if (!bell) return;
                bell.classList.remove('bell-shake');
                void bell.offsetWidth; // force reflow
                bell.classList.add('bell-shake');
                setTimeout(function () { bell.classList.remove('bell-shake'); }, 800);
            }

            async function poll() {
                if (document.hidden) return;
                try {
                    var r = await fetch('/notificacoes/resumo');
                    if (!r.ok) return;
                    var data = await r.json();
                    var count    = data.totalNaoLidas ?? 0;
                    var critical = data.criticas      ?? 0;

                    updateBadge('topbar-notif-badge', count);
                    updateBadge('notif-badge',        count);

                    // Expor resumo para reutilização (ex: dropdown de notificações)
                    window.__notifResumo = { data: data, ts: Date.now() };

                    if (lastCount === -1) {
                        lastCount    = count;
                        lastCritical = critical;
                        return;
                    }

                    if (count > lastCount) {
                        shakeBell();
                        var delta = count - lastCount;
                        if (critical > lastCritical) {
                            var dc = critical - lastCritical;
                            window.showToast && window.showToast(
                                dc + ' nova' + (dc > 1 ? 's' : '') + ' notificação' + (dc > 1 ? 'ões' : '') + ' crítica' + (dc > 1 ? 's' : ''),
                                'error'
                            );
                        } else {
                            window.showToast && window.showToast(
                                delta + ' nova' + (delta > 1 ? 's' : '') + ' notificação' + (delta > 1 ? 'ões' : ''),
                                'info'
                            );
                        }
                    }

                    lastCount    = count;
                    lastCritical = critical;
                } catch (e) { /* silent */ }
            }

            var timerId = null;
            function startPolling() { if (!timerId) timerId = setInterval(poll, INTERVAL); }
            function stopPolling()  { clearInterval(timerId); timerId = null; }

            document.addEventListener('visibilitychange', function () {
                if (document.hidden) { stopPolling(); }
                else { poll(); startPolling(); }
            });

            document.addEventListener('DOMContentLoaded', function () {
                poll();
                startPolling();
            });
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
