@{
    var lojaNome = ViewBag.LojaAtualNome as string ?? "Selecionar loja";
    var lojaEmoji = ViewBag.LojaAtualEmoji as string;
    var hasLojaEmoji = !string.IsNullOrWhiteSpace(lojaEmoji);
}

<aside class="app-sidebar fixed inset-y-0 left-0 z-50 w-60 flex flex-col flex-shrink-0
              transition-transform duration-300 ease-in-out
              lg:relative lg:inset-auto lg:z-auto lg:translate-x-0"
       aria-label="Navegação principal"
       :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'">

    <!-- Logo -->
    <div class="px-5 py-4 flex items-center gap-2.5 border-b border-white/5 justify-between">
        <partial name="_LogoEasyStock" model='new { Size = 28, Variant = "inverted" }' />
        <!-- Rail toggle (desktop): recolhe o menu para ~64px (so icones). -->
        <button type="button" data-rail-toggle
                aria-label="Recolher ou expandir o menu"
                title="Recolher / expandir menu"
                class="es-rail-toggle hidden lg:inline-flex p-2 text-slate-400 hover:text-white transition-colors rounded focus:outline-none focus:ring-2 focus:ring-navy-500">
            <es-icon name="panel-left" class="w-4 h-4"></es-icon>
        </button>
        <!-- Close button (mobile only) -->
        <button @@click="sidebarOpen = false"
                aria-label="Fechar menu"
                class="lg:hidden p-2 text-slate-400 hover:text-white transition-colors rounded focus:outline-none focus:ring-2 focus:ring-navy-500">
            <es-icon name="x" class="w-5 h-5"></es-icon>
        </button>
    </div>

    <!-- Seletor de Loja -->
    <div class="px-3 py-2.5 border-b border-white/5"
         x-data="{ open: false, lojaSwitchClick($event) { if (window.EasyFormGuard && window.EasyFormGuard.hasDirtyForm && window.EasyFormGuard.hasDirtyForm()) { $event.preventDefault(); var href = $event.currentTarget.getAttribute('href'); window.easyConfirm({ titulo: 'Trocar de loja?', mensagem: 'Voce tem alteracoes nao salvas no formulario atual. Trocar de loja vai descartar essas alteracoes.', textoBotao: 'Trocar mesmo assim', classBotao: 'bg-amber-600 hover:bg-amber-700' }, function () { window.location.href = href; }); } } }">
        <button @@click="open = !open"
                class="app-store-trigger w-full flex items-center gap-2.5 px-3 py-2 rounded-lg hover:bg-white/5 transition-colors text-left focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-navy-500">
            @if (hasLojaEmoji)
            {
                <span class="text-lg leading-none" aria-hidden="true">@lojaEmoji</span>
            }
            else
            {
                <es-icon name="store" class="es-icon--sm" style="color: var(--text-muted);"></es-icon>
            }
            <div class="flex-1 min-w-0">
                <div class="text-white font-semibold truncate" style="font-size: 0.875rem;">@lojaNome</div>
                @* Antes var(--text-muted) ficava quase invisivel em fundo navy escuro
                   (contraste < 3:1, falhava WCAG AA). text-slate-400 da ~7:1 — passa AA. *@
                <div class="text-slate-400" style="font-size: 0.6875rem;">Loja selecionada</div>
            </div>
            <es-icon name="chevron-down" class="w-3.5 h-3.5 flex-shrink-0" style="color: var(--text-muted);"></es-icon>
        </button>
        <div x-show="open" x-cloak @@click.outside="open = false"
             class="app-sidebar-menu mt-1 bg-slate-800 rounded-lg border border-white/10 overflow-hidden shadow-xl">
            <a href="/auth/selecionar-loja" @@click="lojaSwitchClick($event)"
               class="flex items-center gap-2 px-3 py-2 text-xs text-slate-300 hover:bg-white/5 transition-colors">
                <es-icon name="refresh-cw" class="es-icon--sm"></es-icon>
                <span>Trocar loja</span>
            </a>
        </div>
    </div>

    @* Navegação (ADR-0032): estrutura, favoritos (Meu dia), grupos e badges renderizados
       no servidor pelo <es-sidebar> (EsSidebarTagHelper). A interatividade (pin/accordion
       exclusivo/rail/reorder) entra na fatia 7. *@
    <div class="sidebar-nav-wrap flex-1 min-h-0 relative">
        <es-sidebar></es-sidebar>
        <div class="sidebar-scroll-hint" aria-hidden="true"></div>
    </div>

    <!-- Footer -->
    <div class="px-4 py-3 border-t border-white/5 flex items-center justify-between">
        <div>
            <div class="text-[11px] text-slate-600 font-semibold">EasyStok @(ViewBag.AppVersion as string ?? "v1.0")</div>
            <div class="text-[10px] text-slate-700">Gestão inteligente de estoque</div>
        </div>
    </div>
</aside>

<script src="~/js/estoque.js" defer></script>
