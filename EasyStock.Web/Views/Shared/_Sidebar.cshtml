@{
    var activeItem = ViewBag.ActiveMenuItem as string ?? "";
    var lojaNome = ViewBag.LojaAtualNome as string ?? "Selecionar loja";
    var lojaEmoji = ViewBag.LojaAtualEmoji as string ?? "🏪";
}

<aside class="fixed inset-y-0 left-0 z-50 w-64 bg-sidebar flex flex-col overflow-y-auto flex-shrink-0
              transition-transform duration-300 ease-in-out
              lg:relative lg:inset-auto lg:z-auto lg:translate-x-0"
       :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'">
    <!-- Logo -->
    <div class="px-5 py-5 border-b border-slate-700/50">
        <div class="flex items-center gap-2">
            <span class="text-2xl">📦</span>
            <span class="text-white font-extrabold text-lg tracking-tight">EasyStock</span>
        </div>
    </div>

    <!-- Seletor de Loja -->
    <div class="px-3 py-3 border-b border-slate-700/50" x-data="{ open: false }">
        <button @@click="open = !open"
                class="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-left hover:bg-slate-700/50 transition-colors">
            <span class="text-xl">@lojaEmoji</span>
            <div class="flex-1 min-w-0">
                <div class="text-white text-sm font-semibold truncate">@lojaNome</div>
                <div class="text-slate-400 text-xs">Loja ativa</div>
            </div>
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
        </button>
        <div x-show="open" @@click.outside="open = false"
             class="mt-1 bg-slate-800 rounded-lg border border-slate-700 overflow-hidden shadow-xl">
            <a href="/auth/selecionar-loja" class="flex items-center gap-2 px-3 py-2 text-sm text-slate-300 hover:bg-slate-700 transition-colors">
                <span>🔄</span> Trocar loja
            </a>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 overflow-y-auto py-3 px-2 space-y-0.5">
        <!-- Principal -->
        <div class="nav-section">Principal</div>
        <a href="/dashboard" class="ni @(activeItem == "Dashboard" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Dashboard
        </a>

        <!-- Catálogo -->
        <div class="nav-section mt-3">Catálogo</div>
        <a href="/produtos" class="ni @(activeItem == "Produtos" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            Produtos
        </a>
        <a href="/fornecedores" class="ni @(activeItem == "Fornecedores" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Fornecedores
        </a>
        <a href="/categorias" class="ni @(activeItem == "Categorias" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
            </svg>
            Categorias
        </a>

        <!-- Estoque -->
        <div class="nav-section mt-3">Estoque</div>
        <a href="/estoque" class="ni @(activeItem == "Estoque" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            Todos os itens
        </a>
        <!-- Categorias dinâmicas -->
        <div id="cat-nav"></div>

        <!-- Movimentações -->
        <div class="nav-section mt-3">Movimentações</div>
        <a href="/entradas/historico" class="ni @(activeItem == "Entradas" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Entradas
        </a>
        <a href="/entradas/nova" class="ni-sub @(activeItem == "EntradasNova" ? "active" : "")">Nova entrada</a>
        <a href="/entradas/reposicao" class="ni-sub @(activeItem == "EntradasReposicao" ? "active" : "")">Reposição rápida</a>
        <a href="/entradas/historico" class="ni-sub @(activeItem == "EntradasHistorico" ? "active" : "")">Histórico</a>

        <a href="/saidas" class="ni @(activeItem == "Saidas" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 20H4m16-8H4m8-8H4" />
            </svg>
            Saídas
        </a>
        <a href="/saidas/historico" class="ni-sub @(activeItem == "SaidasHistorico" ? "active" : "")">Histórico</a>
        <a href="/analytics/movimentacoes" class="ni @(activeItem == "Movimentacoes" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Movimentações
        </a>

        <!-- Inteligência -->
        <div class="nav-section mt-3">Inteligência</div>
        <a href="/analytics" class="ni @(activeItem == "Analytics" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Análises &amp; IA
        </a>
        <a href="/inteligencia" class="ni @(activeItem == "Inteligencia" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Inteligência Operacional
        </a>
        <a href="/anuncios" class="ni @(activeItem == "Anuncios" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
            </svg>
            Anúncios com IA
        </a>

        <!-- Gestão -->
        <div class="nav-section mt-3">Gestão</div>
        <a href="/usuarios" class="ni @(activeItem == "Usuarios" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            Usuários
        </a>
        <a href="/lojas" class="ni @(activeItem == "Lojas" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            Lojas
        </a>
        <a href="/assinatura" class="ni @(activeItem == "Assinatura" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
            Assinatura
        </a>
        <a href="/notificacoes" class="ni relative @(activeItem == "Notificacoes" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            Notificações
            <span id="notif-badge" class="hidden ml-auto bg-red-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center"></span>
        </a>
        <a href="/configuracoes" class="ni @(activeItem == "Configuracoes" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Configurações
        </a>
        <a href="/diagnostico" class="ni @(activeItem == "Diagnostico" ? "active" : "")">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Diagnóstico
        </a>
    </nav>
</aside>

<script src="~/js/estoque.js" defer></script>
