@{
    var activeItem = ViewBag.ActiveMenuItem as string ?? "";
    var lojaNome = ViewBag.LojaAtualNome as string ?? "Selecionar loja";
    var lojaEmoji = ViewBag.LojaAtualEmoji as string;
    var hasLojaEmoji = !string.IsNullOrWhiteSpace(lojaEmoji);
}

<aside class="app-sidebar fixed inset-y-0 left-0 z-50 w-60 flex flex-col flex-shrink-0
              transition-transform duration-300 ease-in-out
              lg:relative lg:inset-auto lg:z-auto lg:translate-x-0"
       role="navigation" aria-label="Navegação principal"
       :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'">

    <!-- Logo -->
    <div class="px-5 py-4 flex items-center gap-2.5 border-b border-white/5 justify-between">
        <partial name="_LogoEasyStock" model='new { Size = 28, Variant = "inverted" }' />
        <!-- Close button (mobile only) -->
        <button @@click="sidebarOpen = false"
                aria-label="Fechar menu"
                class="lg:hidden p-2 text-slate-400 hover:text-white transition-colors rounded focus:outline-none focus:ring-2 focus:ring-navy-500">
            <es-icon name="x" class="w-5 h-5"></es-icon>
        </button>
    </div>

    <!-- Seletor de Loja -->
    <div class="px-3 py-2.5 border-b border-white/5"
         x-data="{ open: false, lojaSwitchClick($event) { if (window.EasyFormGuard && window.EasyFormGuard.hasDirtyForm && window.EasyFormGuard.hasDirtyForm()) { $event.preventDefault(); var href = $event.currentTarget.getAttribute('href'); window.easyConfirm({ titulo: 'Trocar de loja?', mensagem: 'Voce tem alteracoes nao salvas no formulario atual. Trocar de loja vai descartar essas alteracoes.', textoBotao: 'Trocar mesmo assim', classBotao: 'bg-amber-600 hover:bg-amber-700' }, function () { window.location.href = href; }); } } }">
        <button @@click="open = !open"
                class="app-store-trigger w-full flex items-center gap-2.5 px-3 py-2 rounded-lg hover:bg-white/5 transition-colors text-left focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-navy-500">
            @if (hasLojaEmoji)
            {
                <span class="text-lg leading-none" aria-hidden="true">@lojaEmoji</span>
            }
            else
            {
                <es-icon name="store" class="es-icon--sm" style="color: var(--text-muted);"></es-icon>
            }
            <div class="flex-1 min-w-0">
                <div class="text-white font-semibold truncate" style="font-size: 0.875rem;">@lojaNome</div>
                <div style="color: var(--text-muted); font-size: 0.6875rem;">Loja ativa</div>
            </div>
            <es-icon name="chevron-down" class="w-3.5 h-3.5 flex-shrink-0" style="color: var(--text-muted);"></es-icon>
        </button>
        <div x-show="open" x-cloak @@click.outside="open = false"
             class="app-sidebar-menu mt-1 bg-slate-800 rounded-lg border border-white/10 overflow-hidden shadow-xl">
            <a href="/auth/selecionar-loja" @@click="lojaSwitchClick($event)"
               class="flex items-center gap-2 px-3 py-2 text-xs text-slate-300 hover:bg-white/5 transition-colors">
                <es-icon name="refresh-cw" class="es-icon--sm"></es-icon>
                <span>Trocar loja</span>
            </a>
        </div>
    </div>

    <!-- Navegação -->
    <div class="sidebar-nav-wrap flex-1 min-h-0 relative">
    <nav class="sidebar-nav flex-1 overflow-y-auto py-3 px-2.5 space-y-0.5">

        <a href="/dashboard" class="ni @(activeItem == "Dashboard" ? "active" : "")">
            <es-icon name="layout-dashboard" class="w-4 h-4 flex-shrink-0"></es-icon>
            Dashboard
        </a>

        <div class="nav-sep"></div>

        <a href="/produtos" class="ni @(activeItem == "Produtos" ? "active" : "")">
            <es-icon name="package" class="w-4 h-4 flex-shrink-0"></es-icon>
            Produtos
        </a>
        <a href="/estoque" class="ni @(activeItem == "Estoque" ? "active" : "")">
            <es-icon name="clipboard-list" class="w-4 h-4 flex-shrink-0"></es-icon>
            Estoque
        </a>
        <a href="/fornecedores" class="ni @(activeItem is "Fornecedores" or "PedidosAbertos" ? "active" : "")">
            <es-icon name="truck" class="w-4 h-4 flex-shrink-0"></es-icon>
            Fornecedores
        </a>
        <a href="/clientes" class="ni @(activeItem is "Clientes" or "ClientesMobile" ? "active" : "")">
            <es-icon name="users" class="w-4 h-4 flex-shrink-0"></es-icon>
            Clientes
        </a>
        <a href="/pedidos" class="ni @(activeItem is "Pedidos" or "PedidosMobile" ? "active" : "")">
            <es-icon name="shopping-cart" class="w-4 h-4 flex-shrink-0"></es-icon>
            Pedidos
        </a>
        <a href="/caixa" class="ni @(activeItem is "Caixa" or "CaixaMobile" ? "active" : "")">
            <es-icon name="wallet" class="w-4 h-4 flex-shrink-0"></es-icon>
            Caixa
        </a>
        <a href="/lotes" class="ni @(activeItem is "Lotes" or "LotesMobile" ? "active" : "")">
            <es-icon name="layers" class="w-4 h-4 flex-shrink-0"></es-icon>
            Lotes
        </a>
        <a href="/listas-compras" class="ni @(activeItem == "ListasCompras" ? "active" : "")">
            <es-icon name="list-checks" class="w-4 h-4 flex-shrink-0"></es-icon>
            Compras
        </a>
        <a href="/categorias" class="ni @(activeItem == "Categorias" ? "active" : "")">
            <es-icon name="tag" class="w-4 h-4 flex-shrink-0"></es-icon>
            Categorias
        </a>

        <div class="nav-sep"></div>

        <a href="/entradas/historico" class="ni @(activeItem is "Entradas" or "EntradasNova" or "EntradasHistorico" or "EntradasReposicao" ? "active" : "")">
            <es-icon name="arrow-down-to-line" class="w-4 h-4 flex-shrink-0"></es-icon>
            Entradas
        </a>
        <a href="/saidas/historico" class="ni @(activeItem is "Saidas" or "SaidasNova" or "SaidasHistorico" ? "active" : "")">
            <es-icon name="arrow-up-from-line" class="w-4 h-4 flex-shrink-0"></es-icon>
            Saídas
        </a>

        <div class="nav-sep"></div>

        <a href="/analytics" class="ni @(activeItem is "Analytics" or "Movimentacoes" or "Inteligencia" or "InteligenciaLojas" ? "active" : "")">
            <es-icon name="bar-chart-3" class="w-4 h-4 flex-shrink-0"></es-icon>
            Análises &amp; IA
        </a>
        <a href="/anuncios" class="ni @(activeItem == "Anuncios" ? "active" : "")">
            <es-icon name="sparkles" class="w-4 h-4 flex-shrink-0"></es-icon>
            Anúncios com IA
        </a>

        <div class="nav-sep"></div>

        <a href="/dispositivos" class="ni @(activeItem is "Dispositivos" or "ProdutosMobile" or "Operacao" ? "active" : "")">
            <es-icon name="monitor" class="w-4 h-4 flex-shrink-0"></es-icon>
            Dispositivos
        </a>

        <div class="nav-sep"></div>

        <a href="/usuarios" class="ni @(activeItem == "Usuarios" ? "active" : "")">
            <es-icon name="user-cog" class="w-4 h-4 flex-shrink-0"></es-icon>
            Usuários
        </a>
        <a href="/configuracoes" class="ni @(activeItem is "Configuracoes" or "Lojas" or "Assinatura" or "Notificacoes" ? "active" : "")">
            <es-icon name="settings" class="w-4 h-4 flex-shrink-0"></es-icon>
            Configurações
        </a>

    </nav>
    <div class="sidebar-scroll-hint" aria-hidden="true"></div>
    </div>

    <!-- Footer -->
    <div class="px-4 py-3 border-t border-white/5 flex items-center justify-between">
        <div>
            <div class="text-[11px] text-slate-600 font-semibold">EasyStock @(ViewBag.AppVersion as string ?? "v1.0")</div>
            <div class="text-[10px] text-slate-700">Gestão inteligente de estoque</div>
        </div>
        <a href="/diagnostico" title="Diagnóstico"
           class="flex flex-col items-center gap-0.5 p-1.5 rounded-lg hover:bg-white/5 transition-colors @(activeItem == "Diagnostico" ? "text-orange-400" : "text-slate-500")">
            <es-icon name="shield-check" class="w-4 h-4"></es-icon>
            <span class="text-[9px] leading-none">Diagnóstico</span>
        </a>
    </div>
</aside>

<script src="~/js/estoque.js" defer></script>
