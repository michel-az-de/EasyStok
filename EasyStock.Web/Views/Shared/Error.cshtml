@{
    ViewBag.Title = "Erro";
    Layout = "_Layout";
}

<div class="ws max-w-lg mx-auto mt-10 text-center">
    <div class="text-5xl mb-4">⚠️</div>
    <h1 class="text-xl font-bold text-slate-900 mb-2">Algo deu errado</h1>
    <p class="text-slate-500 text-sm mb-6">Não foi possível concluir sua solicitação. Se o problema persistir, entre em contato com o suporte.</p>
    <a href="/dashboard" class="inline-block px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors">
        Voltar ao início
    </a>
</div>
