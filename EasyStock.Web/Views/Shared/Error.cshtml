@{
    ViewBag.Title = "Erro";
    Layout = "_Layout";
}

<div class="ws max-w-lg mx-auto mt-16 text-center">
    <div class="text-7xl font-extrabold text-slate-200 mb-2">500</div>
    <h1 class="text-xl font-bold text-slate-900 mb-2">Algo deu errado</h1>
    <p class="text-slate-500 text-sm mb-6">Não foi possível concluir sua solicitação. Se o problema persistir, entre em contato com o suporte.</p>
    <div class="flex items-center justify-center gap-3">
        <a href="/dashboard" class="px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors">
            Voltar ao início
        </a>
        <button onclick="history.back()" class="px-4 py-2 text-sm text-slate-600 border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
            Voltar
        </button>
    </div>
</div>
