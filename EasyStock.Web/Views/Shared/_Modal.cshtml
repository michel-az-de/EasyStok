@*
    Modal generic (T2.13). Tamanhos: sm | md | lg | full.
    Uso:
        <div x-data="{ open: false }">
          <button @click="open = true" class="btn btn-primary">Abrir</button>
          <partial name="_Modal" model='new { Size = "md", Title = "Confirmar ação", BodyHtml = "<p>...</p>" }' />
        </div>
    Para conteúdo dinâmico, copie o markup deste partial e ajuste no contexto.
*@
@model dynamic
@{
    string size = "md"; try { size = (Model.Size as string) ?? "md"; } catch { }
    string? title = null; try { title = Model.Title as string; } catch { }
    string? bodyHtml = null; try { bodyHtml = Model.BodyHtml as string; } catch { }
    string? footerHtml = null; try { footerHtml = Model.FooterHtml as string; } catch { }
}
<div class="modal-backdrop" x-show="open" x-cloak @@keydown.escape.window="open=false" @@click.self="open=false" role="dialog" aria-modal="true" :aria-labelledby="$id('modal-title')">
    <div class="modal-panel modal-@size">
        @if (!string.IsNullOrEmpty(title))
        {
            <div class="modal-header">
                <h3 :id="$id('modal-title')" class="text-base font-semibold m-0">@title</h3>
                <button type="button" class="btn btn-ghost btn-sm" aria-label="Fechar" @@click="open=false">✕</button>
            </div>
        }
        <div class="modal-body">@Html.Raw(bodyHtml)</div>
        @if (!string.IsNullOrEmpty(footerHtml))
        {
            <div class="modal-footer">@Html.Raw(footerHtml)</div>
        }
    </div>
</div>
