@*
    Wrapper de campo de formulário: label (acima) + input slot + helper text + erro inline.
    API publica preservada — campos existentes (<input class="ui-field" />) continuam funcionando direto.
    Use este partial em forms novos para garantir layout consistente.

    Exemplo:
    <partial name="_FormField" model='new {
        Label = "E-mail",
        For = "Email",
        Required = true,
        Helper = "Usamos para login e notificacoes",
        Error = ViewData.ModelState["Email"]?.Errors.FirstOrDefault()?.ErrorMessage,
        InputHtml = "<input class=\"ui-field\" id=\"Email\" name=\"Email\" type=\"email\" required />"
    }' />
*@
@model dynamic
@{
    // Acesso defensivo a um modelo anonimo dinamico: chamadores podem omitir
    // qualquer propriedade. Sem try/catch, Model.<ausente> lanca RuntimeBinderException
    // e derruba a view inteira (o storybook /dev/components quebrava em Model.Error).
    // Mesmo padrao defensivo do _Modal.cshtml.
    string? label = null;      try { label = Model.Label as string; } catch { }
    string? forId = null;      try { forId = Model.For as string; } catch { }
    if (string.IsNullOrEmpty(forId)) { try { forId = Model.Id as string; } catch { } }
    bool required = false;     try { required = Model.Required != null && (bool)Model.Required; } catch { }
    string? helperText = null; try { helperText = Model.Helper as string; } catch { }
    string? error = null;      try { error = Model.Error as string; } catch { }
    string? inputHtml = null;  try { inputHtml = Model.InputHtml as string; } catch { }
    var hasError = !string.IsNullOrEmpty(error);
}
<div class="ui-form-field@(hasError ? " ui-form-field--error" : "")">
    @if (!string.IsNullOrEmpty(label))
    {
        <label for="@forId" class="ui-form-field__label">
            @label
            @if (required)
            {
                <span class="ui-form-field__required" aria-hidden="true">*</span>
            }
        </label>
    }
    <div class="ui-form-field__input">
        @Html.Raw(inputHtml)
    </div>
    @if (hasError)
    {
        <p class="ui-form-field__error" role="alert">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <span>@error</span>
        </p>
    }
    else if (!string.IsNullOrEmpty(helperText))
    {
        <p class="ui-form-field__helper">@helperText</p>
    }
</div>
