@model ClientesListViewModel
@{
    ViewBag.Title = "Clientes";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Clientes</h1>
        <p>Gerencie seus clientes e o histórico de pedidos</p>
    </div>
    <div class="flex gap-3">
        <a href="/clientes-mobile"
           class="ui-secondary-btn px-4 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50">
            📱 Clientes do app
        </a>
        <button type="button" x-data
                @@click="$dispatch('open-modal', 'novo-cliente')"
                class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
            + Novo Cliente
        </button>
    </div>
</div>

<!-- Filtros -->
<div class="ws mb-6">
    <form method="get" class="flex gap-3 flex-wrap items-center" role="search" aria-label="Filtrar clientes">
        <div class="flex flex-1 min-w-48 gap-3">
            <input type="search" name="search" value="@Model.Search" placeholder="Buscar por nome, telefone, documento, e-mail ou apt..."
                   aria-label="Buscar cliente"
                   class="ui-field flex-1 min-w-48" />
            <button type="submit" class="ui-secondary-btn px-4 py-2 bg-slate-100 border border-slate-300 rounded-lg text-sm hover:bg-slate-200">
                Buscar
            </button>
        </div>
        <div class="flex gap-2">
            @foreach (var (val, label) in new[] { ("", "Todos"), ("ativo", "Ativos"), ("inativo", "Inativos") })
            {
                var isActive = Model.FiltroStatus == val || (val == "" && Model.FiltroStatus == null);
                <a href="@Url.Action("Index", "Clientes", new { search = Model.Search, status = val == "" ? null : val })"
                   class="px-3 py-2 rounded-lg text-sm font-medium @(isActive ? "app-primary-btn bg-indigo-600 text-white" : "ui-secondary-btn bg-white border border-slate-300 text-slate-700 hover:bg-slate-50")">
                    @label
                </a>
            }
        </div>
    </form>
</div>

<!-- Lista -->
<div class="ws">
    @if (!Model.Items.Any())
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIcon", "👤" },
            { "EmptyTitle", "Nenhum cliente cadastrado ainda" },
            { "EmptyDescription", "Cadastre o primeiro cliente para começar a registrar pedidos e acompanhar o histórico de compras." },
            { "EmptyCta", "Cadastrar primeiro cliente" },
            { "EmptyCtaModal", "novo-cliente" }
        })
    }
    else
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Apt</th>
                    <th>Telefone</th>
                    <th>Documento</th>
                    <th>Pedidos</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Items)
                {
                    <tr>
                        <td>
                            <div class="font-medium text-slate-900">@c.Nome</div>
                            @if (!string.IsNullOrEmpty(c.Email))
                            {
                                <div class="text-xs text-slate-500">@c.Email</div>
                            }
                        </td>
                        <td class="text-slate-600 text-sm">@(c.Apt ?? "—")</td>
                        <td class="text-slate-600">@(c.Telefone ?? "—")</td>
                        <td class="text-slate-500 text-sm">@(c.Documento ?? "—")</td>
                        <td class="text-slate-600 text-sm">
                            @c.OrderCount
                            @if (c.LastOrderAt.HasValue)
                            {
                                <span class="text-xs text-slate-400 block">último: @c.LastOrderAt.Value.ToLocalTime().ToString("dd/MM/yy")</span>
                            }
                        </td>
                        <td>
                            <span class="px-2 py-0.5 rounded-full text-xs font-medium @(c.Ativo ? "bg-green-100 text-green-700" : "bg-slate-100 text-slate-600")">
                                @(c.Ativo ? "Ativo" : "Inativo")
                            </span>
                        </td>
                        <td>
                            <a asp-action="Detail" asp-controller="Clientes" asp-route-id="@c.Id"
                               class="text-sm text-indigo-600 hover:text-indigo-700">Ver</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>

<!-- Modal: novo cliente -->
<div x-data="formModal({
        id: 'novo-cliente',
        endpoint: '/clientes/json',
        redirect: '/clientes/{id}',
        requireField: 'nome',
        requireMessage: 'Informe o nome do cliente.',
        initialForm: { nome: '', apt: '', endereco: '', telefone: '', email: '', documento: '', observacoes: '' }
     })"
     x-show="open" x-cloak
     x-transition:enter="transition duration-150 ease-out"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition duration-100 ease-in"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     @@keydown.window="handleKeydown($event)"
     @@click.self="close()"
     class="fm-overlay"
     role="dialog" aria-modal="true" aria-labelledby="fm-cliente-title">
    <form x-ref="panel" class="fm-panel"
          @@submit.prevent="submit()"
          x-transition:enter="transition duration-150 ease-out"
          x-transition:enter-start="opacity-0 scale-95"
          x-transition:enter-end="opacity-100 scale-100">
        <header class="fm-header">
            <div>
                <h2 id="fm-cliente-title" class="fm-header__title">Novo cliente</h2>
                <p class="fm-header__subtitle">Só o essencial agora. Endereços e documentos extras você adiciona depois na tela do cliente.</p>
            </div>
            <button type="button" class="fm-close" aria-label="Fechar" @@click="close()">✕</button>
        </header>

        <div class="fm-body">
            <div x-show="erroMsg" x-cloak class="fm-error" x-text="erroMsg" role="alert"></div>
            @Html.AntiForgeryToken()

            <fieldset class="fm-section">
                <legend class="fm-section__legend">Identificação</legend>
                <div class="fm-grid">
                    <div class="fm-field fm-col-2">
                        <label class="fm-field__label" for="cli-nome">
                            Nome completo<span class="fm-field__required" aria-hidden="true">*</span>
                        </label>
                        <input id="cli-nome" type="text" x-model="form.nome" required
                               placeholder="Ex: Ana Beatriz Costa"
                               @@input="erroMsg = ''"
                               class="ui-field w-full text-sm" />
                    </div>
                    <div class="fm-field fm-col-2">
                        <label class="fm-field__label" for="cli-doc">CPF ou CNPJ</label>
                        <input id="cli-doc" type="text" x-model="form.documento" x-mask:doc
                               inputmode="numeric" placeholder="000.000.000-00"
                               class="ui-field w-full text-sm" />
                        <span class="fm-field__hint">Para emissão de nota fiscal</span>
                    </div>
                </div>
            </fieldset>

            <fieldset class="fm-section">
                <legend class="fm-section__legend">Contato e localização</legend>
                <div class="fm-grid">
                    <div class="fm-field">
                        <label class="fm-field__label" for="cli-tel">Telefone / WhatsApp</label>
                        <input id="cli-tel" type="text" x-model="form.telefone" x-mask:phone
                               inputmode="numeric" autocomplete="tel" placeholder="(11) 99999-9999"
                               class="ui-field w-full text-sm" />
                    </div>
                    <div class="fm-field">
                        <label class="fm-field__label" for="cli-email">E-mail</label>
                        <input id="cli-email" type="email" x-model="form.email"
                               placeholder="cliente@email.com"
                               class="ui-field w-full text-sm" />
                    </div>
                    <div class="fm-field fm-col-2">
                        <label class="fm-field__label" for="cli-end">Endereço</label>
                        <input id="cli-end" type="text" x-model="form.endereco"
                               placeholder="Rua, número, bairro"
                               class="ui-field w-full text-sm" />
                    </div>
                    <div class="fm-field fm-col-2">
                        <label class="fm-field__label" for="cli-apt">Apartamento / Unidade</label>
                        <input id="cli-apt" type="text" x-model="form.apt"
                               placeholder="Ex: 304B, Bloco 2"
                               class="ui-field w-full text-sm" />
                        <span class="fm-field__hint">Se entregar em condomínio</span>
                    </div>
                </div>
            </fieldset>

            <div class="fm-advanced">
                <button type="button" class="fm-advanced__toggle"
                        :aria-expanded="advancedOpen ? 'true' : 'false'"
                        aria-controls="cli-advanced"
                        @@click="advancedOpen = !advancedOpen">
                    <span class="fm-advanced__chevron" aria-hidden="true">›</span>
                    <span x-text="advancedOpen ? 'Ocultar observações' : 'Adicionar observações'"></span>
                </button>
                <div id="cli-advanced" x-show="advancedOpen" x-cloak
                     x-transition:enter="transition duration-100 ease-out"
                     x-transition:enter-start="opacity-0 -translate-y-1"
                     x-transition:enter-end="opacity-100 translate-y-0">
                    <div class="fm-grid">
                        <div class="fm-field fm-col-2">
                            <label class="fm-field__label" for="cli-obs">Observações</label>
                            <textarea id="cli-obs" x-model="form.observacoes" rows="3"
                                      placeholder="Preferências, restrições, alergias..."
                                      class="ui-textarea w-full text-sm"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="fm-footer">
            <span class="fm-footer__hint">Pressione Enter para salvar</span>
            <button type="button" @@click="close()"
                    class="ui-secondary-btn px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                Cancelar
            </button>
            <button type="submit" :disabled="loading || isInvalid()"
                    :class="{ 'opacity-50 cursor-not-allowed': loading || isInvalid() }"
                    class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                <span x-show="!loading">Cadastrar cliente</span>
                <span x-show="loading" x-cloak class="flex items-center gap-2">
                    <span class="spinner"></span> Salvando…
                </span>
            </button>
        </footer>
    </form>
</div>
