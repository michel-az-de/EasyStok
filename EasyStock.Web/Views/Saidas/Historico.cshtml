@model SaidasHistoricoViewModel
@{
    ViewBag.Title = "Histórico de Saídas";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Histórico de Saídas</h1>
        <p>@Model.TotalRegistros @(Model.TotalRegistros == 1 ? "saída registrada" : "saídas registradas")</p>
    </div>
    <div class="flex items-center gap-2">
        <a href="/saidas/exportar-csv?periodoInicio=@Model.PeriodoInicio&periodoFim=@Model.PeriodoFim"
           class="flex items-center gap-1.5 text-sm text-slate-600 border border-slate-300 hover:bg-slate-50 px-3 py-2 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Exportar CSV
        </a>
        <a asp-action="Nova" asp-controller="Saidas"
           class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
            + Registrar Saída
        </a>
    </div>
</div>

<!-- KPI chips -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="ws text-center">
        <div class="text-2xl font-bold text-slate-900">@Model.TotalRegistros</div>
        <div class="text-xs text-slate-500 mt-1">Total de registros</div>
    </div>
    <div class="ws text-center">
        <div class="text-2xl font-bold text-blue-600">@Model.TotalUnidades</div>
        <div class="text-xs text-slate-500 mt-1">Unidades saídas</div>
    </div>
    <div class="ws text-center">
        <div class="text-2xl font-bold text-green-600">R$ @Model.ReceitaTotal.ToString("N2")</div>
        <div class="text-xs text-slate-500 mt-1">Receita total</div>
    </div>
    <div class="ws text-center">
        <div class="text-2xl font-bold text-red-500">@Model.TotalPerdas</div>
        <div class="text-xs text-slate-500 mt-1">Perdas / Ajustes</div>
    </div>
</div>

<!-- Filtros -->
<form method="get" class="ws mb-6">
    @if (!string.IsNullOrEmpty(Model.FiltroNatureza))
    {
        <input type="hidden" name="natureza" value="@Model.FiltroNatureza" />
    }
    <div class="flex flex-wrap gap-3 items-end">
        <!-- Pill filters por natureza -->
        <div class="flex gap-2 flex-wrap">
            @{
                var naturezas = new[] {
                    ("", "Todas"), ("venda", "Vendas"), ("perda", "Perdas"), ("prejuizo", "Prejuízos"),
                    ("doacao", "Doações"), ("uso_interno", "Uso Interno"), ("devolucao", "Devoluções"), ("ajuste", "Ajustes")
                };
            }
            @foreach (var (val, label) in naturezas)
            {
                var isActive = Model.FiltroNatureza == val || (val == "" && Model.FiltroNatureza == null);
                <a href="@Url.Action("Historico", "Saidas", new { natureza = val == "" ? null : val, de = Model.PeriodoInicio, ate = Model.PeriodoFim })"
                   class="px-3 py-1.5 rounded-full text-sm font-medium @(isActive ? "bg-indigo-600 text-white" : "bg-white border border-slate-300 text-slate-700 hover:bg-slate-50")">
                    @label
                </a>
            }
        </div>
        @* BUG 10: input type="date" não aceita componente de hora, então o valor
           passado pelo controller é truncado em yyyy-MM-dd. O Substring(0, 10)
           garante que, se algum período antigo ainda tiver "T23:59:59", o input
           continua exibindo a parte de data. *@
        <!-- Date range -->
        <div class="flex flex-wrap gap-2 items-center ml-auto">
            <input type="date" name="de" value="@(Model.PeriodoInicio is { Length: >= 10 } d ? d[..10] : Model.PeriodoInicio)"
                   class="border border-slate-300 rounded-lg px-3 py-1.5 text-sm" />
            <span class="text-slate-400 text-sm">a</span>
            <input type="date" name="ate" value="@(Model.PeriodoFim is { Length: >= 10 } a ? a[..10] : Model.PeriodoFim)"
                   class="border border-slate-300 rounded-lg px-3 py-1.5 text-sm" />
            <button type="submit"
                    class="px-4 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors">
                Filtrar
            </button>
        </div>
    </div>
</form>

<!-- Tabela -->
<div class="ws">
    @if (!Model.Itens.Any())
    {
        <div class="text-center py-12 text-slate-400">
            <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
            </svg>
            <p class="text-sm">Nenhuma saída encontrada</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead>
                <tr>
                    <th>Produto</th>
                    <th>Natureza</th>
                    <th>Qtd</th>
                    <th>Valor</th>
                    <th>Data</th>
                    <th>Documento</th>
                    <th>Descrição</th>
                    <th title="Quem registrou / De onde">Auditoria</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Itens)
                {
                    var isEstornada = s.EstornadaEm.HasValue;
                    var isEstorno = s.Natureza?.Equals("Estorno", StringComparison.OrdinalIgnoreCase) == true;
                    <tr class="@(isEstornada ? "opacity-50" : "")">
                        <td>
                            <div class="font-medium text-slate-900 @(isEstornada ? "line-through" : "")">@(s.Produto?.Nome ?? s.ProdutoId)</div>
                            @if (s.ProdutoVariacao != null)
                            {
                                <div class="text-xs text-slate-500">@s.ProdutoVariacao.Nome</div>
                            }
                        </td>
                        <td>
                            @{
                                var naturezaColor = s.Natureza?.ToLower() switch {
                                    "venda" => "badge-ok",
                                    "perda" or "prejuizo" => "badge-critical",
                                    "devolucao" or "devolução" => "badge-slow",
                                    "doacao" or "doação" => "badge-warn",
                                    "usointerno" => "badge-warn",
                                    "estorno" => "badge-slow",
                                    "ajuste" => "badge-warn",
                                    _ => "badge-warn"
                                };
                                var naturezaLabel = s.Natureza?.ToLower() switch {
                                    "usointerno" => "Uso Interno",
                                    "devolucao" => "Devolução",
                                    "doacao" => "Doação",
                                    "prejuizo" => "Prejuízo",
                                    _ => s.Natureza
                                };
                            }
                            <span class="badge @naturezaColor">
                                @naturezaLabel
                            </span>
                            @if (isEstornada)
                            {
                                <span class="badge badge-slow text-xs ml-1">Estornada</span>
                            }
                        </td>
                        <td class="font-medium @(isEstornada ? "line-through" : "")">@s.Qty</td>
                        <td>
                            @if (s.Custo.HasValue)
                            {
                                <span class="@(isEstornada ? "line-through" : "")">R$ @s.Custo.Value.ToString("N2")</span>
                            }
                            else
                            {
                                <span class="text-slate-400">—</span>
                            }
                        </td>
                        <td class="text-slate-600">@s.DataMovimentacao.ToString("dd/MM/yyyy")</td>
                        <td class="text-slate-500 text-sm">@(s.DocumentoReferencia ?? "—")</td>
                        <td class="text-slate-500 text-sm">
                            @if (s.Descricao?.StartsWith("DIVERGENCIA_SYNC") == true)
                            {
                                <span class="text-xs text-slate-400"
                                      title="@(User.IsInRole("Admin") ? s.Descricao : null)">
                                    Sync automático
                                </span>
                            }
                            else
                            {
                                <span>@(s.Descricao ?? "—")</span>
                            }
                        </td>
                        <td class="text-xs text-slate-500">
                            @if (!string.IsNullOrEmpty(s.UsuarioId) || !string.IsNullOrEmpty(s.Ip) || !string.IsNullOrEmpty(s.MotivoEstorno))
                            {
                                if (!string.IsNullOrEmpty(s.UsuarioId))
                                {
                                    <div title="Usuário ID: @s.UsuarioId" class="font-mono text-[10px]">@(s.UsuarioId.Length > 8 ? s.UsuarioId[..8] : s.UsuarioId)…</div>
                                }
                                if (!string.IsNullOrEmpty(s.Ip))
                                {
                                    <div title="@s.UserAgentResumo">IP: @s.Ip</div>
                                }
                                if (!string.IsNullOrEmpty(s.MotivoEstorno))
                                {
                                    <div class="text-amber-800" title="Motivo">↪ @s.MotivoEstorno</div>
                                }
                            }
                            else
                            {
                                <span class="text-slate-300">—</span>
                            }
                        </td>
                        <td>
                            @if (!isEstornada && !isEstorno)
                            {
                                <form asp-action="Estornar" asp-route-id="@s.Id" method="post"
                                      x-data="{ open: false, motivo: '' }"
                                      @@submit="if (!motivo || motivo.length < 3) { $event.preventDefault(); alert('Informe o motivo do estorno (mín. 3 caracteres).'); }">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="motivo" :value="motivo" />
                                    <button type="button" @@click="open = true; setTimeout(() => $refs.motivoInput?.focus(), 50)"
                                            class="text-xs text-red-500 hover:text-red-700 font-medium">
                                        Estornar
                                    </button>
                                    <div x-show="open" x-cloak
                                         class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                                         @@click.self="open = false">
                                        <div class="bg-white rounded-xl shadow-xl w-full max-w-md p-6">
                                            <h3 class="text-lg font-semibold text-slate-900 mb-3">Estornar saída</h3>
                                            <p class="text-sm text-slate-600 mb-4">
                                                O estoque será restaurado. Informe o motivo para registro de auditoria.
                                            </p>
                                            <label class="block text-sm font-medium text-slate-700 mb-1">Motivo *</label>
                                            <select x-model="motivo"
                                                    class="w-full mb-3 border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-300">
                                                <option value="">Selecione...</option>
                                                <option value="Erro de digitação">Erro de digitação</option>
                                                <option value="Cancelamento de venda">Cancelamento de venda</option>
                                                <option value="Cliente devolveu">Cliente devolveu</option>
                                                <option value="Item errado">Item errado</option>
                                                <option value="Outro">Outro</option>
                                            </select>
                                            <input x-show="motivo === 'Outro'" x-cloak x-ref="motivoInput"
                                                   type="text" placeholder="Descreva o motivo (mín. 3 caracteres)"
                                                   x-model="motivo" :value="motivo === 'Outro' ? '' : motivo"
                                                   minlength="3" maxlength="300"
                                                   class="w-full mb-3 border border-slate-300 rounded-lg px-3 py-2 text-sm" />
                                            <div class="flex justify-end gap-2">
                                                <button type="button" @@click="open = false; motivo = ''"
                                                        class="px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                                                    Cancelar
                                                </button>
                                                <button type="submit"
                                                        :disabled="!motivo || motivo.length < 3"
                                                        :class="(!motivo || motivo.length < 3) ? 'opacity-50 cursor-not-allowed' : ''"
                                                        class="px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700">
                                                    Confirmar estorno
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            }
                            else if (isEstornada)
                            {
                                <span class="text-xs text-slate-400">Estornada em @s.EstornadaEm!.Value.ToString("dd/MM")</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>

        <!-- Paginação -->
        @if (Model.Paginacao.Pages > 1)
        {
            <div class="flex justify-center gap-2 mt-6">
                @for (int p = 1; p <= Model.Paginacao.Pages; p++)
                {
                    <a href="@Url.Action("Historico", "Saidas", new { page = p, natureza = Model.FiltroNatureza, de = Model.PeriodoInicio, ate = Model.PeriodoFim })"
                       class="px-3 py-1.5 rounded text-sm @(p == Model.Paginacao.Page ? "bg-indigo-600 text-white" : "bg-white border border-slate-300 text-slate-700 hover:bg-slate-50")">
                        @p
                    </a>
                }
            </div>
        }
    }
</div>
