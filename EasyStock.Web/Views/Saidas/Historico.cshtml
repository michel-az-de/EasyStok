@model SaidasHistoricoViewModel
@{
    ViewBag.Title = "Histórico de Saídas";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Histórico de Saídas</h1>
    <a asp-action="Nova" asp-controller="Saidas"
       class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
        + Nova Saída
    </a>
</div>

<!-- KPI chips -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="ws text-center">
        <div class="text-2xl font-bold text-gray-900">@Model.TotalRegistros</div>
        <div class="text-xs text-gray-500 mt-1">Total de registros</div>
    </div>
    <div class="ws text-center">
        <div class="text-2xl font-bold text-blue-600">@Model.TotalUnidades</div>
        <div class="text-xs text-gray-500 mt-1">Unidades saídas</div>
    </div>
    <div class="ws text-center">
        <div class="text-2xl font-bold text-green-600">R$ @Model.ReceitaTotal.ToString("N2")</div>
        <div class="text-xs text-gray-500 mt-1">Receita total</div>
    </div>
    <div class="ws text-center">
        <div class="text-2xl font-bold text-red-500">@Model.TotalPerdas</div>
        <div class="text-xs text-gray-500 mt-1">Perdas / Ajustes</div>
    </div>
</div>

<!-- Filtros -->
<form method="get" class="ws mb-6">
    <div class="flex flex-wrap gap-3 items-end">
        <!-- Pill filters por natureza -->
        <div class="flex gap-2 flex-wrap">
            @{
                var naturezas = new[] { ("", "Todas"), ("venda", "Vendas"), ("perda", "Perdas"), ("doacao", "Doações"), ("uso_interno", "Uso Interno") };
            }
            @foreach (var (val, label) in naturezas)
            {
                var isActive = Model.FiltroNatureza == val || (val == "" && Model.FiltroNatureza == null);
                <a href="@Url.Action("Historico", "Saidas", new { natureza = val == "" ? null : val, de = Model.PeriodoInicio, ate = Model.PeriodoFim })"
                   class="px-3 py-1.5 rounded-full text-sm font-medium @(isActive ? "bg-indigo-600 text-white" : "bg-white border border-gray-300 text-gray-700 hover:bg-gray-50")">
                    @label
                </a>
            }
        </div>
        <!-- Date range -->
        <div class="flex gap-2 items-center ml-auto">
            <input type="date" name="de" value="@Model.PeriodoInicio"
                   class="border border-gray-300 rounded-lg px-3 py-1.5 text-sm" />
            <span class="text-gray-400 text-sm">a</span>
            <input type="date" name="ate" value="@Model.PeriodoFim"
                   class="border border-gray-300 rounded-lg px-3 py-1.5 text-sm" />
            <button type="submit"
                    class="px-4 py-1.5 bg-gray-100 border border-gray-300 rounded-lg text-sm hover:bg-gray-200">
                Filtrar
            </button>
        </div>
    </div>
</form>

<!-- Tabela -->
<div class="ws">
    @if (!Model.Itens.Any())
    {
        <div class="text-center py-12 text-gray-400">
            <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
            </svg>
            <p class="text-sm">Nenhuma saída encontrada</p>
        </div>
    }
    else
    {
        <table class="tbl-full">
            <thead>
                <tr>
                    <th>Produto</th>
                    <th>Natureza</th>
                    <th>Qtd</th>
                    <th>Valor</th>
                    <th>Data</th>
                    <th>Canal</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Itens)
                {
                    <tr>
                        <td>
                            <div class="font-medium text-gray-900">@(s.Produto?.Nome ?? s.ProdutoId)</div>
                            @if (s.ProdutoVariacao != null)
                            {
                                <div class="text-xs text-gray-500">@s.ProdutoVariacao.Nome</div>
                            }
                        </td>
                        <td>
                            @{
                                var naturezaColor = s.Natureza?.ToLower() switch {
                                    "venda" => "bg-green-100 text-green-700",
                                    "perda" => "bg-red-100 text-red-700",
                                    "devolucao" or "devolução" => "bg-blue-100 text-blue-700",
                                    _ => "bg-gray-100 text-gray-700"
                                };
                            }
                            <span class="px-2 py-0.5 rounded-full text-xs font-medium @naturezaColor">
                                @s.Natureza
                            </span>
                        </td>
                        <td class="font-medium">@s.Qty</td>
                        <td>
                            @if (s.Custo.HasValue)
                            {
                                <span>R$ @s.Custo.Value.ToString("N2")</span>
                            }
                            else
                            {
                                <span class="text-gray-400">—</span>
                            }
                        </td>
                        <td class="text-gray-600">@s.DataMovimentacao.ToString("dd/MM/yyyy")</td>
                        <td class="text-gray-500 text-sm">@(s.Descricao ?? "—")</td>
                        <td>
                            <form asp-action="Estornar" asp-controller="Saidas"
                                  asp-route-id="@s.Id" method="post"
                                  x-data="{ confirm: false }">
                                @Html.AntiForgeryToken()
                                <button type="button" @@click="confirm = true"
                                        class="text-xs text-red-600 hover:text-red-700">Estornar</button>
                                <div x-show="confirm" x-cloak
                                     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                                     @@click.self="confirm = false">
                                    <div class="bg-white rounded-xl p-6 w-80 shadow-xl">
                                        <h3 class="font-semibold text-gray-900 mb-2">Confirmar estorno</h3>
                                        <p class="text-sm text-gray-600 mb-4">
                                            Isso reverterá a saída e adicionará o estoque de volta.
                                        </p>
                                        <div class="flex justify-end gap-3">
                                            <button type="button" @@click="confirm = false"
                                                    class="px-3 py-1.5 text-sm text-gray-700 border rounded-lg hover:bg-gray-50">
                                                Cancelar
                                            </button>
                                            <button type="submit"
                                                    class="px-3 py-1.5 text-sm bg-red-600 text-white rounded-lg hover:bg-red-700">
                                                Confirmar Estorno
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Paginação -->
        @if (Model.Paginacao.Pages > 1)
        {
            <div class="flex justify-center gap-2 mt-6">
                @for (int p = 1; p <= Model.Paginacao.Pages; p++)
                {
                    <a href="@Url.Action("Historico", "Saidas", new { page = p, natureza = Model.FiltroNatureza, de = Model.PeriodoInicio, ate = Model.PeriodoFim })"
                       class="px-3 py-1.5 rounded text-sm @(p == Model.Paginacao.Page ? "bg-indigo-600 text-white" : "bg-white border border-gray-300 text-gray-700 hover:bg-gray-50")">
                        @p
                    </a>
                }
            </div>
        }
    }
</div>
