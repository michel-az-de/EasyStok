@model EasyStock.Web.Models.ViewModels.Onboarding.OnboardingViewModel
@{
    ViewBag.Title = "Configurar conta";
}

<div class="max-w-2xl mx-auto py-8" x-data="{ step: 1 }">
    <header class="mb-6 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold mb-3 ring-1 bg-emerald-50 text-emerald-800 ring-emerald-200">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            14 dias de trial · sem cartão de crédito
        </div>
        <h1 class="text-2xl font-bold mb-1">Configure sua conta</h1>
        <p class="text-sm" style="color: var(--text-secondary);">Em 3 passos rápidos você está pronto para usar.</p>
        <ol class="flex justify-center gap-2 mt-4 text-xs">
            <li :class="step >= 1 ? 'font-bold' : ''">1. Empresa</li>
            <li>·</li>
            <li :class="step >= 2 ? 'font-bold' : ''">2. Loja</li>
            <li>·</li>
            <li :class="step >= 3 ? 'font-bold' : ''">3. Finalizar</li>
        </ol>
    </header>

    <form asp-controller="Onboarding" asp-action="Index" method="post" class="space-y-4 p-6 rounded-lg border" style="background: var(--surface-1, #fff); border-color: var(--border-soft, #e7e5e4);">
        <div asp-validation-summary="All" class="text-sm" style="color: var(--text-danger, #b91c1c);"></div>

        <div x-show="step === 1" x-transition>
            <h2 class="font-semibold mb-3">Sobre a empresa</h2>
            <div class="space-y-3">
                <div>
                    <label asp-for="NomeFantasia" class="block text-sm mb-1"></label>
                    <input asp-for="NomeFantasia" class="ui-field w-full text-sm" placeholder="Ex: Restaurante do José" />
                </div>
                <div>
                    <label asp-for="Telefone" class="block text-sm mb-1"></label>
                    <input asp-for="Telefone" class="ui-field w-full text-sm" placeholder="(11) 99999-0000" />
                    <p class="text-xs mt-1" style="color: var(--text-secondary);">Usado para notificações por WhatsApp/SMS quando ativadas.</p>
                </div>
                <div>
                    <label asp-for="Segmento" class="block text-sm mb-1"></label>
                    <select asp-for="Segmento" class="ui-field w-full text-sm">
                        <option value="restaurante">Restaurante / Foodservice</option>
                        <option value="varejo">Varejo</option>
                        <option value="distribuidora">Distribuidora</option>
                        <option value="outro">Outro</option>
                    </select>
                </div>
            </div>
            <div class="mt-5 flex justify-end">
                <button type="button" @@click="step = 2" class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors">Próximo</button>
            </div>
        </div>

        <div x-show="step === 2" x-transition>
            <h2 class="font-semibold mb-3">Sua primeira loja</h2>
            <div class="space-y-3">
                <div>
                    <label asp-for="LojaNome" class="block text-sm mb-1"></label>
                    <input asp-for="LojaNome" class="ui-field w-full text-sm" placeholder="Ex: Matriz, Filial Centro..." required />
                    <span asp-validation-for="LojaNome" class="text-xs" style="color: var(--text-danger);"></span>
                </div>
                <div>
                    <label asp-for="LojaEndereco" class="block text-sm mb-1"></label>
                    <input asp-for="LojaEndereco" class="ui-field w-full text-sm" placeholder="Rua, número, bairro, cidade" />
                </div>
                <div>
                    <label asp-for="LojaTelefone" class="block text-sm mb-1"></label>
                    <input asp-for="LojaTelefone" class="ui-field w-full text-sm" placeholder="(11) 0000-0000" />
                </div>
            </div>
            <div class="mt-5 flex justify-between">
                <button type="button" @@click="step = 1" class="btn-outline-dark">Voltar</button>
                <button type="button" @@click="step = 3" class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors">Próximo</button>
            </div>
        </div>

        <div x-show="step === 3" x-transition>
            <h2 class="font-semibold mb-3">Pronto para começar?</h2>
            <p class="text-sm mb-4">Você tem <strong>14 dias de trial</strong> com acesso a tudo. Sem cartão de crédito.</p>
            <ul class="text-sm list-disc pl-5 space-y-1 mb-5" style="color: var(--text-secondary);">
                <li>Catálogo, estoque e movimentação multi-loja.</li>
                <li>Pedidos, vendas e caixa integrados.</li>
                <li>Relatórios em tempo real.</li>
            </ul>
            <div class="flex justify-between">
                <button type="button" @@click="step = 2" class="btn-outline-dark">Voltar</button>
                <button type="submit" class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors">Concluir e entrar</button>
            </div>
        </div>
    </form>

    <p class="text-center text-xs text-slate-500 mt-4">
        Já configurou antes? <a href="/dashboard" class="text-indigo-600 hover:underline">Ir para o painel</a>
    </p>
</div>
