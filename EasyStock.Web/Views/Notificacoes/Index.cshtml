@model NotificacoesViewModel
@{
    ViewBag.Title = "Notificações";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
        <h1 class="text-2xl font-bold text-gray-900">Notificações</h1>
        @if (Model.NaoLidas > 0)
        {
            <span class="px-2 py-0.5 bg-red-100 text-red-600 rounded-full text-sm font-medium">
                @Model.NaoLidas não lidas
            </span>
        }
    </div>
    @if (Model.NaoLidas > 0)
    {
        <form asp-action="MarcarTodas" asp-controller="Notificacoes" method="post">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="text-sm text-indigo-600 hover:text-indigo-700 font-medium">
                Marcar todas como lidas
            </button>
        </form>
    }
</div>

<!-- Tabs -->
<div x-data="{ tab: 'todas' }" class="mb-6">
    <div class="flex gap-1 bg-gray-100 rounded-lg p-1 w-fit">
        <button type="button" @@click="tab = 'todas'"
                :class="tab === 'todas' ? 'bg-white shadow text-gray-900' : 'text-gray-500 hover:text-gray-700'"
                class="px-4 py-1.5 rounded-md text-sm font-medium transition-all">
            Todas
        </button>
        <button type="button" @@click="tab = 'nao_lidas'"
                :class="tab === 'nao_lidas' ? 'bg-white shadow text-gray-900' : 'text-gray-500 hover:text-gray-700'"
                class="px-4 py-1.5 rounded-md text-sm font-medium transition-all">
            Não lidas
        </button>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="ws mt-4 text-center py-16 text-gray-400">
            <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            <p class="text-sm">Nenhuma notificação</p>
        </div>
    }
    else
    {
        <div class="space-y-2 mt-4">
            @foreach (var n in Model.Items)
            {
                var tipoIcon = n.Tipo switch {
                    "estoque_critico" => "🔴",
                    "validade" => "⚠️",
                    "reposicao" => "📦",
                    "parado" => "🕐",
                    _ => "🔔"
                };
                <div x-show="tab === 'todas' || (tab === 'nao_lidas' && !@n.Lida.ToString().ToLower())"
                     class="ws flex items-start gap-4 @(!n.Lida ? "border-l-4 border-indigo-500" : "opacity-70")">
                    <span class="text-2xl flex-shrink-0">@tipoIcon</span>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-2">
                            <div>
                                <div class="font-medium text-gray-900 text-sm">@n.Titulo</div>
                                <div class="text-sm text-gray-600 mt-0.5">@n.Mensagem</div>
                                <div class="text-xs text-gray-400 mt-1">
                                    @n.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>
                            <div class="flex items-center gap-2 flex-shrink-0">
                                @if (!n.Lida)
                                {
                                    <form asp-action="MarcarLida" asp-controller="Notificacoes"
                                          asp-route-id="@n.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="text-xs text-indigo-600 hover:text-indigo-700 whitespace-nowrap">
                                            Marcar lida
                                        </button>
                                    </form>
                                }
                                <form asp-action="Excluir" asp-controller="Notificacoes"
                                      asp-route-id="@n.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="text-xs text-gray-400 hover:text-red-500">×</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
