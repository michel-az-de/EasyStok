@model NotificacoesViewModel
@{
    ViewBag.Title = "Notificações";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
        <div class="pg-hd">
            <h1>Notificações</h1>
            <p>Acompanhe alertas e atualizações do seu estoque</p>
        </div>
        @if (Model.NaoLidas > 0)
        {
            <span class="px-2 py-0.5 bg-red-100 text-red-600 rounded-full text-sm font-medium">
                @Model.NaoLidas não lidas
            </span>
        }
    </div>
    @if (Model.NaoLidas > 0)
    {
        <form asp-action="MarcarTodas" asp-controller="Notificacoes" method="post">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="text-sm text-indigo-600 hover:text-indigo-700 font-medium">
                Marcar todas como lidas
            </button>
        </form>
    }
</div>

<!-- Tabs -->
<div x-data="{ tab: 'todas' }" class="mb-6">
    <div class="flex gap-1 bg-slate-100 rounded-lg p-1 w-fit">
        <button type="button" @@click="tab = 'todas'"
                :class="tab === 'todas' ? 'bg-white shadow text-slate-900' : 'text-slate-500 hover:text-slate-700'"
                class="px-4 py-1.5 rounded-md text-sm font-medium transition-all">
            Todas
        </button>
        <button type="button" @@click="tab = 'nao_lidas'"
                :class="tab === 'nao_lidas' ? 'bg-white shadow text-slate-900' : 'text-slate-500 hover:text-slate-700'"
                class="px-4 py-1.5 rounded-md text-sm font-medium transition-all">
            Não lidas
        </button>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="ws mt-4">
            @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
                { "EmptyIcon", "🔔" },
                { "EmptyTitle", "Nenhuma notificação" },
                { "EmptyDescription", "Você está em dia! Notificações de estoque aparecerão aqui." }
            })
        </div>
    }
    else
    {
        <div class="space-y-2 mt-4">
            @foreach (var n in Model.Items)
            {
                var tipoIcon = n.Tipo switch {
                    "estoque_critico" => "🔴",
                    "validade" => "⚠️",
                    "reposicao" => "📦",
                    "parado" => "🕐",
                    _ => "🔔"
                };
                <div x-show="tab === 'todas' || (tab === 'nao_lidas' && !@n.Lida.ToString().ToLower())"
                     class="ws flex items-start gap-4 @(!n.Lida ? "border-l-4 border-indigo-500" : "opacity-70")">
                    <span class="text-2xl flex-shrink-0">@tipoIcon</span>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-2">
                            <div>
                                <div class="font-medium text-slate-900 text-sm">@n.Titulo</div>
                                <div class="text-sm text-slate-600 mt-0.5">@n.Mensagem</div>
                                <div class="text-xs text-slate-400 mt-1">
                                    @n.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>
                            <div class="flex items-center gap-2 flex-shrink-0">
                                @if (!n.Lida)
                                {
                                    <form asp-action="MarcarLida" asp-controller="Notificacoes"
                                          asp-route-id="@n.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="text-xs text-indigo-600 hover:text-indigo-700 whitespace-nowrap">
                                            Marcar lida
                                        </button>
                                    </form>
                                }
                                <form asp-action="Excluir" asp-controller="Notificacoes"
                                      asp-route-id="@n.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="text-xs text-slate-400 hover:text-red-500">×</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
