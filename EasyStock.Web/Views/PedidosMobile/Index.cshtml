@model PedidosMobileViewModel
@{
    ViewBag.Title = "Pedidos (mobile)";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Pedidos do app</h1>
        <p>Revise pedidos criados no app pelo operador e linke ao fluxo de pedidos do ERP</p>
    </div>
    <a href="/pedidos" class="ui-secondary-btn px-4 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50">
        ← Pedidos ERP
    </a>
</div>

<div class="ws mb-6">
    <form method="get" class="flex gap-3 items-center">
        @foreach (var (val, label) in new[] { ("false", "Todos"), ("true", "Pendentes (sem link)") })
        {
            var isActive = (val == "true") == Model.PendingOnly;
            <a href="@Url.Action("Index", "PedidosMobile", new { pendingOnly = val == "true" })"
               class="px-3 py-2 rounded-lg text-sm font-medium @(isActive ? "app-primary-btn bg-indigo-600 text-white" : "ui-secondary-btn bg-white border border-slate-300 text-slate-700 hover:bg-slate-50")">
                @label
            </a>
        }
        <span class="text-sm text-slate-500 ml-auto">@Model.Items.Count pedido(s)</span>
    </form>
</div>

<div class="ws">
    @if (!Model.Items.Any())
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIllustration", "inbox" },
            { "EmptyTitle", "Nenhum pedido do app" },
            { "EmptyDescription", "Pedidos criados pelos operadores no app aparecem aqui para revisão." }
        })
    }
    else
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead><tr><th>Cliente</th><th>Status</th><th>Total</th><th>Origem</th><th>ERP</th><th></th></tr></thead>
            <tbody>
                @foreach (var m in Model.Items)
                {
                    <tr>
                        <td>
                            <div class="font-medium text-slate-900">@m.ClientSnapshotName</div>
                            @if (!string.IsNullOrEmpty(m.ClientSnapshotRef))
                            {
                                <div class="text-xs text-slate-500">@m.ClientSnapshotRef</div>
                            }
                        </td>
                        <td><span class="px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600">@m.Status</span></td>
                        <td class="text-slate-600">@m.Total.ToString("C")</td>
                        <td class="text-xs text-slate-500">
                            @(m.LastOperatorName ?? "—") @if (!string.IsNullOrEmpty(m.LastDeviceId)) { <div class="text-slate-400">@m.LastDeviceId</div> }
                        </td>
                        <td>
                            @if (m.Linked)
                            {
                                <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 bg-green-100 text-green-700 rounded-full">✓ linkado</span>
                                <a href="/pedidos/@m.ErpPedidoId" class="text-xs text-indigo-600 hover:text-indigo-700 ml-1">abrir</a>
                            }
                            else
                            {
                                <span class="text-xs px-2 py-0.5 bg-amber-100 text-amber-800 rounded-full">pendente</span>
                            }
                        </td>
                        <td class="text-right">
                            @if (!m.Linked)
                            {
                                <div x-data="{ openLink: false }" class="inline-block relative">
                                    <button type="button" @@click="openLink = !openLink" class="text-sm text-indigo-600 hover:text-indigo-700">Linkar / Promover</button>
                                    <div x-show="openLink" x-cloak @@click.outside="openLink = false"
                                         class="absolute right-0 mt-1 w-72 bg-white border border-slate-200 rounded-lg shadow-lg z-10 p-3">
                                        <form asp-action="Promover" asp-controller="PedidosMobile" asp-route-id="@m.Id" method="post" class="mb-3">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="w-full px-3 py-2 bg-indigo-600 text-white text-sm font-medium rounded hover:bg-indigo-700">
                                                ➕ Promover (criar Pedido ERP)
                                            </button>
                                        </form>
                                        <form asp-action="Link" asp-controller="PedidosMobile" asp-route-id="@m.Id" method="post" class="border-t pt-3">
                                            @Html.AntiForgeryToken()
                                            <label class="block text-xs text-slate-600 mb-1">Linkar a Pedido ERP existente:</label>
                                            <select name="erpPedidoId" required class="ui-select w-full text-sm mb-2">
                                                <option value="">— escolha —</option>
                                                @foreach (var ep in Model.ErpPedidos)
                                                {
                                                    <option value="@ep.Id">@(ep.ClienteNome ?? "—") · @ep.Total.ToString("C") · @ep.CriadoEm.ToLocalTime():dd/MM</option>
                                                }
                                            </select>
                                            <button type="submit" class="w-full px-3 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded hover:bg-slate-50">
                                                🔗 Linkar
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <button type="button"
                                        @@click="$dispatch('confirm-action', {
                                            titulo: 'Desfazer link com o ERP?',
                                            mensagem: 'O pedido do app volta pra lista de pendentes e some dos pedidos do ERP.',
                                            textoBotao: 'Desfazer link',
                                            classBotao: 'bg-red-600 hover:bg-red-700',
                                            formAction: '@Url.Action("Unlink", "PedidosMobile", new { id = m.Id })'
                                        })"
                                        class="text-sm text-red-600 hover:text-red-700">Desfazer link</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>
