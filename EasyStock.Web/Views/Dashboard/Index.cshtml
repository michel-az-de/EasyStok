@model DashboardViewModel
@using System.Text.Json
@{
    var primeiroNome = (ViewBag.UsuarioNome as string ?? "").Split(' ').First();
    var lojas = ViewBag.Lojas as List<EasyStock.Web.Models.Api.LojaApi> ?? new();
    var lojaAtualId = ViewBag.LojaAtualId as string;
    var multiLoja = lojas.Count > 1;
}

<div x-data="dashboardApp()" x-init="init()" class="space-y-6">

    @* Header — saudação travada em fuso BR para evitar "Boa noite às 15h" quando o navegador roda em UTC. *@
    <div class="pg-hd flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div x-data="{
                get saudacao() {
                    const fmt = new Intl.DateTimeFormat('pt-BR', { timeZone: 'America/Sao_Paulo', hour: '2-digit', hour12: false });
                    const h = parseInt(fmt.format(new Date()), 10);
                    return h < 12 ? 'Bom dia' : h < 18 ? 'Boa tarde' : 'Boa noite';
                },
                get dataLocal() {
                    return new Date().toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo', day: '2-digit', month: 'long', year: 'numeric' });
                }
            }">
            <h1><span x-text="saudacao"></span>@(string.IsNullOrEmpty(primeiroNome) ? "!" : $", {primeiroNome}!")</h1>
            <p class="text-sm text-slate-500">Resumo do seu negócio, <span x-text="dataLocal"></span>.</p>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
            @if (multiLoja)
            {
                <select x-model="lojaId" @@change="reload()"
                        class="inp text-sm py-1.5 px-3 min-w-[140px]">
                    <option value="">Todas as lojas</option>
                    @foreach (var l in lojas.Where(l => l.Ativa))
                    {
                        @if (l.Id.ToString() == lojaAtualId)
                        {
                            <option value="@l.Id" selected>@l.Nome</option>
                        }
                        else
                        {
                            <option value="@l.Id">@l.Nome</option>
                        }
                    }
                </select>
            }
            <button type="button" @@click="exportarPDF()" title="Baixar relatório PDF"
                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold bg-navy-700 text-white hover:bg-navy-800 transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Baixar PDF
            </button>
            <div class="flex gap-1 bg-slate-100 rounded-lg p-0.5">
                <template x-for="p in periodos" :key="p.value">
                    <button type="button"
                            :class="periodo === p.value
                                ? 'bg-white text-navy-700 shadow-sm font-semibold'
                                : 'text-slate-500 hover:text-slate-700'"
                            class="px-2.5 py-1 text-xs rounded-md transition-all"
                            @@click="periodo = p.value; reload()"
                            x-text="p.label"></button>
                </template>
            </div>
            <button type="button" @@click="reload()" title="Atualizar dados"
                    class="p-1.5 rounded-lg text-slate-400 hover:text-navy-600 hover:bg-slate-100 transition-colors"
                    :class="loading && 'animate-spin'">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
            </button>
        </div>
    </div>

    @* Entregues sem venda banner (BUG 2) *@
    <template x-if="data && data.entreguesSemVenda > 0">
        <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-amber-50 border border-amber-200 text-amber-800 text-sm">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 9v4m0 4h.01M10.29 3.86l-7.11 12.3A2 2 0 004.91 19h14.18a2 2 0 001.73-2.84l-7.11-12.3a2 2 0 00-3.42 0z"/>
            </svg>
            <span>
                <span x-text="data.entreguesSemVenda" class="font-bold"></span>
                <span x-text="data.entreguesSemVenda === 1 ? 'pedido entregue aguardando registro de venda' : 'pedidos entregues aguardando registro de venda'"></span>
            </span>
        </div>
    </template>

    @* ===== SEÇÃO 1: VISÃO GERAL (KPI Cards) ===== *@
    <section>
        <div class="flex items-center gap-2 mb-4">
            <h2 class="font-bold text-slate-800">Visão geral</h2>
            <span x-show="loading" class="inline-block w-4 h-4 border-2 border-slate-200 border-t-navy-600 rounded-full animate-spin"></span>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            @* Receita *@
            <div class="ws group" title="Total de vendas confirmadas no período">
                <div class="kpi-lbl">Receita</div>
                <template x-if="loading && !data">
                    <div class="h-7 w-24 bg-slate-100 rounded animate-pulse mt-1"></div>
                </template>
                <template x-if="data">
                    <div>
                        <div class="kpi-val text-emerald-700" x-text="fmt.currency(data.kpis.receita)"></div>
                        <div class="flex items-center gap-1 mt-1">
                            <span :class="deltaClass(data.delta.receita)" class="text-xs font-semibold" x-text="fmt.delta(data.delta.receita)"></span>
                            <span class="text-xs text-slate-400">vs anterior</span>
                        </div>
                    </div>
                </template>
            </div>

            @* Ticket Médio = Receita / Vendas confirmadas (com VendaId). Denominador
               diferente do card "Pedidos" porque pedidos cancelados/pendentes nao geram
               venda — o tooltip explica pra evitar leitura tipo "795 / 17 = 47 != 61". *@
            <div class="ws group" title="Receita dividida pelo número de vendas confirmadas no período (pedidos cancelados ou ainda em aberto não entram no denominador).">
                <div class="kpi-lbl">Ticket médio</div>
                <template x-if="loading && !data">
                    <div class="h-7 w-20 bg-slate-100 rounded animate-pulse mt-1"></div>
                </template>
                <template x-if="data">
                    <div>
                        <div class="kpi-val text-slate-900" x-text="fmt.currency(data.kpis.ticketMedio)"></div>
                        <div class="flex items-center gap-1 mt-1">
                            <span :class="deltaClass(data.delta.ticketMedio)" class="text-xs font-semibold" x-text="fmt.delta(data.delta.ticketMedio)"></span>
                            <span class="text-xs text-slate-400">vs anterior</span>
                        </div>
                    </div>
                </template>
            </div>

            @* Pedidos: total criados (entregues + pendentes + cancelados). O sub-rotulo
               de breakdown ajuda a conciliar com o ticket medio (que usa vendas, nao pedidos). *@
            <a href="/pedidos" class="ws group hover:border-slate-300 transition-colors" title="Total de pedidos criados no período — inclui entregues, pendentes e cancelados. O ticket médio acima usa só os que viraram venda confirmada.">
                <div class="kpi-lbl">Pedidos</div>
                <template x-if="loading && !data">
                    <div class="h-7 w-12 bg-slate-100 rounded animate-pulse mt-1"></div>
                </template>
                <template x-if="data">
                    <div>
                        <div class="kpi-val text-slate-900" x-text="data.kpis.pedidos"></div>
                        <div class="flex items-center gap-1 mt-1 flex-wrap">
                            <span :class="deltaClass(data.delta.pedidos)" class="text-xs font-semibold" x-text="fmt.delta(data.delta.pedidos)"></span>
                            <span class="text-xs text-slate-400">vs anterior</span>
                            <span class="text-xs text-slate-400" x-show="data.kpis.pedidosEntregues != null">
                                · <span x-text="data.kpis.pedidosEntregues"></span> entregues
                            </span>
                        </div>
                    </div>
                </template>
            </a>

            @* Itens em Estoque (soma de QuantidadeAtual de lotes ativos com qty > 0).
               O sub-rotulo "% critico" se refere a LOTES (rows ItemEstoque), nao a unidades —
               antes ficava ambiguo e podia mostrar 100% no card e 88% no donut da mesma tela. *@
            <a href="/estoque" class="ws group hover:border-slate-300 transition-colors" title="Unidades em lotes ativos (quantidade > 0). O '% crítico' abaixo se refere aos lotes, não às unidades.">
                <div class="kpi-lbl">Itens em estoque</div>
                <template x-if="loading && !data">
                    <div class="h-7 w-14 bg-slate-100 rounded animate-pulse mt-1"></div>
                </template>
                <template x-if="data">
                    <div>
                        <div class="kpi-val text-indigo-600" x-text="fmt.number(data.kpis.itensEmEstoque)"></div>
                        <div class="flex items-center gap-1 mt-1">
                            <span :class="deltaClass(data.delta.itensEmEstoque)" class="text-xs font-semibold" x-text="fmt.delta(data.delta.itensEmEstoque)"></span>
                            <span class="text-xs text-slate-400" x-show="data.kpis.percentualCritico > 0">
                                · <span x-text="fmt.pct(data.kpis.percentualCritico)"></span> dos lotes crítico
                            </span>
                        </div>
                    </div>
                </template>
            </a>

            @* Custo em Estoque *@
            <div class="ws group" title="Valor investido, pelo custo de compra dos produtos">
                <div class="kpi-lbl">Custo em estoque</div>
                <template x-if="loading && !data">
                    <div class="h-7 w-24 bg-slate-100 rounded animate-pulse mt-1"></div>
                </template>
                <template x-if="data">
                    <div>
                        <div class="kpi-val text-slate-900" x-text="fmt.currency(data.kpis.custoEstoque)"></div>
                        <div class="flex items-center gap-1 mt-1">
                            <span :class="deltaClass(data.delta.custoEstoque, true)" class="text-xs font-semibold" x-text="fmt.delta(data.delta.custoEstoque)"></span>
                            <span class="text-xs text-slate-400">vs anterior</span>
                        </div>
                    </div>
                </template>
            </div>

            @* Margem Bruta *@
            <div class="ws group"
                 :title="data && data.kpis.margemBruta == null
                    ? 'Margem indisponível: as movimentações de venda do período não têm custo unitário informado.'
                    : 'Quanto sobra depois de descontar o custo. Baseado no custo médio de entrada'">
                <div class="kpi-lbl">Margem bruta</div>
                <template x-if="loading && !data">
                    <div class="h-7 w-16 bg-slate-100 rounded animate-pulse mt-1"></div>
                </template>
                <template x-if="data">
                    <div>
                        <div class="kpi-val"
                             :class="data.kpis.margemBruta == null ? 'text-slate-400' : data.kpis.margemBruta >= 20 ? 'text-emerald-700' : 'text-amber-600'"
                             x-text="fmt.pct(data.kpis.margemBruta)"></div>
                        <div class="flex items-center gap-1 mt-1">
                            <span :class="deltaClass(data.delta.margemBruta)" class="text-xs font-semibold"
                                  x-text="data.delta.margemBruta == null ? '—' : (data.delta.margemBruta > 0 ? '+' : '') + data.delta.margemBruta.toFixed(1).replace('.', ',') + ' pp'"></span>
                            <span class="text-xs text-slate-400" x-text="data.kpis.margemBruta == null ? 'sem custo informado' : 'vs anterior'"></span>
                        </div>
                    </div>
                </template>
            </div>

            @* Lotes Produzidos *@
            <a href="/lotes" class="ws group hover:border-slate-300 transition-colors" title="Lotes de produção finalizados no período">
                <div class="kpi-lbl">Lotes produzidos</div>
                <template x-if="loading && !data">
                    <div class="h-7 w-10 bg-slate-100 rounded animate-pulse mt-1"></div>
                </template>
                <template x-if="data">
                    <div>
                        <div class="kpi-val text-slate-900" x-text="data.kpis.lotesProduzidos"></div>
                        <div class="flex items-center gap-1 mt-1">
                            <span :class="deltaClass(data.delta.lotesProduzidos)" class="text-xs font-semibold" x-text="fmt.delta(data.delta.lotesProduzidos)"></span>
                            <span class="text-xs text-slate-400">vs anterior</span>
                        </div>
                    </div>
                </template>
            </a>

            @* Clientes Ativos *@
            <a href="/clientes" class="ws group hover:border-slate-300 transition-colors" title="Clientes com pelo menos um pedido no período">
                <div class="kpi-lbl">Clientes ativos</div>
                <template x-if="loading && !data">
                    <div class="h-7 w-10 bg-slate-100 rounded animate-pulse mt-1"></div>
                </template>
                <template x-if="data">
                    <div>
                        <div class="kpi-val text-slate-900" x-text="data.kpis.clientesAtivos"></div>
                        <div class="flex items-center gap-1 mt-1">
                            <span :class="deltaClass(data.delta.clientesAtivos)" class="text-xs font-semibold" x-text="fmt.delta(data.delta.clientesAtivos)"></span>
                            <span class="text-xs text-slate-400">vs anterior</span>
                        </div>
                    </div>
                </template>
            </a>
        </div>
    </section>

    @* Insights *@
    <template x-if="data && data.insights && data.insights.length > 0">
        <section class="space-y-2">
            <template x-for="insight in data.insights" :key="insight.componente + insight.texto">
                <div class="flex items-start gap-3 px-4 py-3 rounded-xl text-sm border"
                     :class="{
                         'bg-red-50 border-red-200 text-red-800': insight.severidade === 'alert',
                         'bg-amber-50 border-amber-200 text-amber-800': insight.severidade === 'warning',
                         'bg-emerald-50 border-emerald-200 text-emerald-800': insight.severidade === 'positive'
                     }">
                    <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <template x-if="insight.severidade === 'positive'">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </template>
                        <template x-if="insight.severidade !== 'positive'">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </template>
                    </svg>
                    <span x-text="insight.texto"></span>
                </div>
            </template>
        </section>
    </template>

    @* ===== SEÇÃO 2: VENDAS & FINANCEIRO ===== *@
    <section x-data="{ open: true }">
        <button type="button" class="accordion-trigger w-full flex items-center justify-between py-2" @@click="open = !open">
            <h2 class="font-bold text-slate-800">Vendas e financeiro</h2>
            <svg class="w-4 h-4 text-slate-400 transition-transform" :class="open && 'rotate-180'" viewBox="0 0 20 20" fill="currentColor">
                <path d="M5.5 7.5L10 12l4.5-4.5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
        <div x-show="open" x-transition.duration.180ms class="mt-4 space-y-4">
            @* Pedidos pendentes resumo *@
            <template x-if="data && data.pedidosPendentesTotal > 0">
                <div class="ws">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="font-semibold text-slate-700">Pedidos aguardando pagamento</h3>
                        <span class="badge badge-warn px-2 py-0.5 rounded-full text-xs font-semibold"
                              x-text="fmt.currency(data.pedidosPendentesTotal) + ' em aberto'"></span>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="tbl-full">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th>Itens</th>
                                    <th class="text-right">Total</th>
                                    <th class="text-right">Pago</th>
                                    <th class="text-right">Em aberto</th>
                                    <th class="text-right">Data</th>
                                </tr>
                            </thead>
                            <tbody>
                                <template x-for="p in data.pedidosPendentes.slice(0, 10)" :key="p.id">
                                    <tr class="cursor-pointer hover:bg-slate-50" @@click="openPedido(p.id)">
                                        <td x-text="p.clienteNome || 'Sem cliente'"></td>
                                        <td class="text-slate-500 text-sm max-w-[200px] truncate" x-text="p.itensResumo"></td>
                                        <td class="text-right font-mono" x-text="fmt.currency(p.total)"></td>
                                        <td class="text-right font-mono text-slate-500" x-text="fmt.currency(p.totalPago)"></td>
                                        <td class="text-right font-mono font-semibold text-amber-600" x-text="fmt.currency(p.emAberto)"></td>
                                        <td class="text-right text-slate-500" x-text="fmt.date(p.criadoEm)"></td>
                                    </tr>
                                </template>
                            </tbody>
                        </table>
                    </div>
                    <template x-if="data.pedidosPendentes.length > 10">
                        <a href="/pedidos?status=pendente" class="block text-center text-xs text-indigo-600 hover:underline mt-3">
                            Ver todos os pedidos pendentes
                        </a>
                    </template>
                </div>
            </template>
            <template x-if="data && data.pedidosPendentesTotal === 0">
                <div class="ws text-center py-6 text-slate-400 text-sm">
                    Tudo pago! Nenhum pedido aguardando pagamento.
                </div>
            </template>

            <div class="ws">
                <h3 class="font-semibold text-slate-700 mb-3">Receita × Custo × Lucro</h3>
                <div id="chart-receita-custo" class="relative h-[280px]">
                    <canvas id="canvas-receita-custo"></canvas>
                </div>
            </div>

            @* Fluxo de Caixa *@
            <div class="ws">
                <h3 class="font-semibold text-slate-700 mb-3">Fluxo de caixa</h3>
                <template x-if="!extrasLoaded">
                    <div class="h-[240px] flex items-center justify-center text-slate-400 text-sm">
                        <span class="inline-block w-4 h-4 border-2 border-slate-200 border-t-navy-600 rounded-full animate-spin mr-2"></span>
                        Carregando...
                    </div>
                </template>
                <div id="chart-fluxo-caixa" class="h-[240px]" x-show="extrasLoaded">
                    <canvas id="canvas-fluxo-caixa"></canvas>
                </div>
            </div>

            @* Rankings *@
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                <div class="ws">
                    <h3 class="font-semibold text-slate-700 mb-3">Top 5 produtos vendidos</h3>
                    <template x-if="!extrasLoaded">
                        <div class="h-[200px] animate-pulse bg-slate-50 rounded-lg"></div>
                    </template>
                    <div class="h-[200px]" x-show="extrasLoaded">
                        <canvas id="canvas-top-produtos"></canvas>
                    </div>
                </div>
                <div class="ws">
                    <h3 class="font-semibold text-slate-700 mb-3">Top 5 clientes por receita</h3>
                    <template x-if="!extrasLoaded">
                        <div class="h-[200px] animate-pulse bg-slate-50 rounded-lg"></div>
                    </template>
                    <div class="h-[200px]" x-show="extrasLoaded">
                        <canvas id="canvas-top-clientes"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ===== SEÇÃO 3: ESTOQUE & PRODUÇÃO ===== *@
    <section x-data="{ open: true }">
        <button type="button" class="accordion-trigger w-full flex items-center justify-between py-2" @@click="open = !open">
            <h2 class="font-bold text-slate-800">Estoque e produção</h2>
            <svg class="w-4 h-4 text-slate-400 transition-transform" :class="open && 'rotate-180'" viewBox="0 0 20 20" fill="currentColor">
                <path d="M5.5 7.5L10 12l4.5-4.5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
        <div x-show="open" x-transition.duration.180ms class="mt-4 space-y-4">
            @* Estoque status *@
            <template x-if="data">
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                    <div class="ws flex items-center gap-3">
                        <div class="w-3 h-3 rounded-full bg-ok-500"></div>
                        <div>
                            <div class="text-lg font-bold text-slate-900" x-text="data.estoqueStatus.ok"></div>
                            <div class="text-xs text-slate-500">OK</div>
                        </div>
                    </div>
                    <div class="ws flex items-center gap-3">
                        <div class="w-3 h-3 rounded-full bg-warn-500"></div>
                        <div>
                            <div class="text-lg font-bold text-slate-900" x-text="data.estoqueStatus.atencao"></div>
                            <div class="text-xs text-slate-500">Atenção</div>
                        </div>
                    </div>
                    <div class="ws flex items-center gap-3">
                        <div class="w-3 h-3 rounded-full bg-crit-500"></div>
                        <div>
                            <div class="text-lg font-bold text-slate-900" x-text="data.estoqueStatus.critico"></div>
                            <div class="text-xs text-slate-500">Crítico</div>
                        </div>
                    </div>
                    <div class="ws flex items-center gap-3">
                        <div class="w-3 h-3 rounded-full bg-slate-400"></div>
                        <div>
                            <div class="text-lg font-bold text-slate-900" x-text="data.estoqueStatus.parado"></div>
                            <div class="text-xs text-slate-500">Parado</div>
                        </div>
                    </div>
                </div>
            </template>

            @* Alertas de estoque *@
            <div>
                <template x-if="data && data.alertasEstoque && data.alertasEstoque.length > 0">
                    <div class="ws">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
                            <div class="flex items-center gap-2">
                                <h3 class="font-semibold text-slate-700">Alertas de estoque</h3>
                                <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-red-100 text-red-700 text-xs font-bold"
                                      x-text="data.alertasEstoque.length"></span>
                            </div>
                            @* Filtros de tipo *@
                            <div class="flex gap-1 text-xs">
                                <button type="button" @@click="filtroAlerta = 'todos'"
                                        :class="filtroAlerta === 'todos' ? 'bg-slate-700 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'"
                                        class="px-2.5 py-1 rounded-full font-medium transition-colors">
                                    Todos
                                </button>
                                <template x-if="contarTipo('critico') > 0">
                                    <button type="button" @@click="filtroAlerta = 'critico'"
                                            :class="filtroAlerta === 'critico' ? 'bg-red-600 text-white' : 'bg-red-50 text-red-700 hover:bg-red-100'"
                                            class="px-2.5 py-1 rounded-full font-medium transition-colors flex items-center gap-1">
                                        <span>Crítico</span>
                                        <span x-text="contarTipo('critico')" class="font-bold"></span>
                                    </button>
                                </template>
                                <template x-if="contarTipo('vencimento') > 0">
                                    <button type="button" @@click="filtroAlerta = 'vencimento'"
                                            :class="filtroAlerta === 'vencimento' ? 'bg-amber-500 text-white' : 'bg-amber-50 text-amber-700 hover:bg-amber-100'"
                                            class="px-2.5 py-1 rounded-full font-medium transition-colors flex items-center gap-1">
                                        <span>Vencimento</span>
                                        <span x-text="contarTipo('vencimento')" class="font-bold"></span>
                                    </button>
                                </template>
                                <template x-if="contarTipo('parado') > 0">
                                    <button type="button" @@click="filtroAlerta = 'parado'"
                                            :class="filtroAlerta === 'parado' ? 'bg-slate-600 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'"
                                            class="px-2.5 py-1 rounded-full font-medium transition-colors flex items-center gap-1">
                                        <span>Parado</span>
                                        <span x-text="contarTipo('parado')" class="font-bold"></span>
                                    </button>
                                </template>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                            <template x-for="a in alertasFiltrados.slice(0, 9)" :key="a.itemEstoqueId">
                                <div class="flex items-start gap-3 p-3 rounded-xl border transition-shadow hover:shadow-sm"
                                     :class="{
                                         'border-red-200 bg-red-50':    a.tipo === 'critico',
                                         'border-amber-200 bg-amber-50': a.tipo === 'vencimento',
                                         'border-slate-200 bg-slate-50': a.tipo === 'parado'
                                     }">
                                    @* Ícone *@
                                    <div class="flex-shrink-0 mt-0.5 rounded-lg p-1.5"
                                         :class="{
                                             'bg-red-100 text-red-600':    a.tipo === 'critico',
                                             'bg-amber-100 text-amber-600': a.tipo === 'vencimento',
                                             'bg-slate-200 text-slate-500': a.tipo === 'parado'
                                         }">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" :d="iconeAlerta(a.tipo)"/>
                                        </svg>
                                    </div>

                                    @* Conteúdo *@
                                    <div class="flex-1 min-w-0">
                                        <p class="font-semibold text-slate-800 text-sm truncate" x-text="a.nomeProduto || 'Produto'"></p>
                                        <p class="text-xs text-slate-500 mt-0.5" x-text="labelAlerta(a)"></p>
                                    </div>

                                    @* CTA *@
                                    <a :href="a.tipo === 'parado'
                                                ? '/saidas/nova?produtoId=' + a.produtoId
                                                : '/entradas/reposicao?produtoId=' + a.produtoId"
                                       class="flex-shrink-0 self-center text-xs font-semibold whitespace-nowrap transition-colors"
                                       :class="{
                                           'text-red-700 hover:text-red-900':    a.tipo === 'critico',
                                           'text-amber-700 hover:text-amber-900': a.tipo === 'vencimento',
                                           'text-slate-600 hover:text-slate-900': a.tipo === 'parado'
                                       }"
                                       x-text="a.tipo === 'parado' ? 'Registrar saída →' : 'Repor →'"></a>
                                </div>
                            </template>
                        </div>

                        <template x-if="alertasFiltrados.length > 9">
                            <a href="/estoque?status=critico" class="block text-center text-xs text-indigo-600 hover:underline mt-4">
                                Ver todos os alertas de estoque →
                            </a>
                        </template>
                    </div>
                </template>
                <template x-if="data && (!data.alertasEstoque || data.alertasEstoque.length === 0)">
                    <div class="ws text-center py-8">
                        <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-emerald-50 text-emerald-600 mb-3">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <p class="font-semibold text-slate-700">Estoque em dia!</p>
                        <p class="text-sm text-slate-400 mt-1">Nenhum produto crítico, vencendo ou parado.</p>
                    </div>
                </template>
            </div>

            @* Estoque: donut + validade timeline *@
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                <div class="ws">
                    <h3 class="font-semibold text-slate-700 mb-3">Situação do estoque</h3>
                    <div id="chart-estoque-donut" class="h-[240px]">
                        <canvas id="canvas-estoque-donut"></canvas>
                    </div>
                </div>
                <div class="ws">
                    <h3 class="font-semibold text-slate-700 mb-3">Validades próximas (4 semanas)</h3>
                    <template x-if="!extrasLoaded">
                        <div class="h-[240px] animate-pulse bg-slate-50 rounded-lg"></div>
                    </template>
                    <div id="chart-validade-timeline" class="h-[240px]" x-show="extrasLoaded">
                        <canvas id="canvas-validade-timeline"></canvas>
                    </div>
                </div>
            </div>

            @* Produção por operador + entradas/saídas semanal *@
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                <div class="ws">
                    <h3 class="font-semibold text-slate-700 mb-3">Produção por operador</h3>
                    <template x-if="!extrasLoaded">
                        <div class="h-[200px] animate-pulse bg-slate-50 rounded-lg"></div>
                    </template>
                    <template x-if="extrasLoaded && extras && (!extras.producaoPorOperador || extras.producaoPorOperador.length === 0)">
                        <div class="h-[200px] flex flex-col items-center justify-center text-slate-400 text-sm gap-2">
                            <p>Nenhum lote finalizado no período.</p>
                            <a href="/lotes" class="text-indigo-600 text-xs hover:underline">Ver lotes de produção →</a>
                        </div>
                    </template>
                    <div class="h-[200px]" x-show="extrasLoaded && extras && extras.producaoPorOperador && extras.producaoPorOperador.length > 0">
                        <canvas id="canvas-producao-operador"></canvas>
                    </div>
                </div>
                <div class="ws">
                    <h3 class="font-semibold text-slate-700 mb-3">Entradas × Saídas por semana</h3>
                    <template x-if="!extrasLoaded">
                        <div class="h-[200px] animate-pulse bg-slate-50 rounded-lg"></div>
                    </template>
                    <div class="h-[200px]" x-show="extrasLoaded">
                        <canvas id="canvas-entradas-saidas"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ===== SEÇÃO 4: CLIENTES & FORNECEDORES ===== *@
    <section x-data="{ open: false }">
        <button type="button" class="accordion-trigger w-full flex items-center justify-between py-2" @@click="open = !open">
            <h2 class="font-bold text-slate-800">Clientes e fornecedores</h2>
            <svg class="w-4 h-4 text-slate-400 transition-transform" :class="open && 'rotate-180'" viewBox="0 0 20 20" fill="currentColor">
                <path d="M5.5 7.5L10 12l4.5-4.5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
        <div x-show="open" x-transition.duration.180ms class="mt-4 space-y-4">

            @* Novos clientes por mês *@
            <div class="ws">
                <h3 class="font-semibold text-slate-700 mb-3">Novos clientes por mês</h3>
                <template x-if="!extrasLoaded">
                    <div class="h-[200px] animate-pulse bg-slate-50 rounded-lg"></div>
                </template>
                <template x-if="extrasLoaded && extras && (!extras.novosClientes || extras.novosClientes.length === 0)">
                    <div class="h-[200px] flex flex-col items-center justify-center text-slate-400 text-sm gap-2">
                        <p>Nenhum cliente cadastrado nos últimos 6 meses.</p>
                        <a href="/clientes/novo" class="text-indigo-600 text-xs hover:underline">Cadastrar cliente →</a>
                    </div>
                </template>
                <div class="h-[200px]" x-show="extrasLoaded && extras && extras.novosClientes && extras.novosClientes.length > 0">
                    <canvas id="canvas-novos-clientes"></canvas>
                </div>
            </div>

            @* Fornecedores *@
            <template x-if="extrasLoaded && extras && extras.fornecedores">
                <div class="ws">
                    <h3 class="font-semibold text-slate-700 mb-4">Fornecedores</h3>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
                        <div class="text-center p-3 rounded-xl bg-emerald-50">
                            <div class="text-2xl font-bold text-emerald-700" x-text="extras.fornecedores.ativos"></div>
                            <div class="text-xs text-slate-500 mt-1">Ativos</div>
                        </div>
                        <div class="text-center p-3 rounded-xl bg-slate-50">
                            <div class="text-2xl font-bold text-slate-500" x-text="extras.fornecedores.inativos"></div>
                            <div class="text-xs text-slate-500 mt-1">Inativos</div>
                        </div>
                    </div>
                    <template x-if="extras.fornecedores.lista && extras.fornecedores.lista.length > 0">
                        <div class="space-y-2">
                            <template x-for="f in extras.fornecedores.lista.slice(0, 8)" :key="f.id">
                                <div class="flex items-center justify-between py-1.5 px-2 rounded-lg hover:bg-slate-50">
                                    <span class="text-sm text-slate-700" x-text="f.nome"></span>
                                    <span class="text-xs px-2 py-0.5 rounded-full font-medium"
                                          :class="f.ativo ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-100 text-slate-500'"
                                          x-text="f.ativo ? 'Ativo' : 'Inativo'"></span>
                                </div>
                            </template>
                            <template x-if="extras.fornecedores.lista.length > 8">
                                <a href="/fornecedores" class="block text-center text-xs text-indigo-600 hover:underline mt-2">
                                    Ver todos os fornecedores →
                                </a>
                            </template>
                        </div>
                    </template>
                    <template x-if="!extras.fornecedores.lista || extras.fornecedores.lista.length === 0">
                        <div class="text-center py-6 text-slate-400 text-sm">
                            Nenhum fornecedor cadastrado.
                            <a href="/fornecedores/novo" class="block text-indigo-600 text-xs mt-1 hover:underline">Cadastrar fornecedor →</a>
                        </div>
                    </template>
                </div>
            </template>
            <template x-if="!extrasLoaded">
                <div class="ws animate-pulse h-[180px] bg-slate-50 rounded-xl"></div>
            </template>
        </div>
    </section>

    @* IA usage (preserved from original) *@
    @if (Model.IaConfigurada)
    {
        <div class="ws">
            <div class="flex items-center justify-between mb-3">
                <h2 class="font-bold text-slate-800">Gerações de IA este mês</h2>
                <a href="/anuncios" class="text-xs text-indigo-600 hover:underline">Gerar anúncio →</a>
            </div>
            @if (Model.IaIlimitada)
            {
                <div class="flex items-center gap-3">
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold ring-1 bg-emerald-50 text-emerald-800 ring-emerald-200">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                        Ilimitado
                    </span>
                    <span class="text-sm text-slate-500">@Model.GeracoesIaUsadas @(Model.GeracoesIaUsadas == 1 ? "geração realizada" : "gerações realizadas")</span>
                </div>
            }
            else
            {
                var pct = Model.GeracoesIaPercent;
                var barColor = pct >= 90 ? "bg-red-500" : pct >= 70 ? "bg-amber-400" : "bg-emerald-500";
                var textColor = pct >= 90 ? "text-red-600" : pct >= 70 ? "text-amber-600" : "text-emerald-600";
                <div class="flex items-center gap-3 mb-2">
                    <span class="text-2xl font-bold @textColor">@Model.GeracoesIaUsadas</span>
                    <span class="text-slate-400 text-sm">/ @Model.GeracoesIaLimite gerações</span>
                </div>
                <div class="w-full bg-slate-100 rounded-full h-2">
                    <div class="@barColor h-2 rounded-full transition-all" style="width:@(pct)%"></div>
                </div>
                <p class="text-xs text-slate-400 mt-1">@pct% utilizado</p>
            }
        </div>
    }

    @* Quick actions *@
    <div class="ws hidden lg:block">
        <h2 class="font-bold text-slate-800 mb-4">Ações rápidas</h2>
        <div class="grid grid-cols-3 sm:grid-cols-6 gap-3">
            @{
                var acoes = new[]
                {
                    new { IconPath = "M19 14l-7 7m0 0l-7-7m7 7V3", Label = "Nova entrada", Href = "/entradas/nova" },
                    new { IconPath = "M5 10l7-7m0 0l7 7m-7-7v18", Label = "Registrar saída", Href = "/saidas/nova" },
                    new { IconPath = "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15", Label = "Repor estoque", Href = "/entradas/reposicao" },
                    new { IconPath = "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4", Label = "Ver estoque", Href = "/estoque" },
                    new { IconPath = "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z", Label = "Gerar anúncio", Href = "/anuncios" },
                    new { IconPath = "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z", Label = "Movimentações", Href = "/analytics/movimentacoes" },
                };
            }
            @foreach (var acao in acoes)
            {
                <a href="@acao.Href"
                   class="quick-action-card flex flex-col items-center gap-2 p-3 rounded-xl border border-slate-200 hover:border-indigo-300 hover:bg-indigo-50 transition-all text-center group">
                    <span class="quick-action-icon w-9 h-9 rounded-full bg-slate-50 group-hover:bg-indigo-100 text-slate-500 group-hover:text-indigo-600 flex items-center justify-center transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="@acao.IconPath" />
                        </svg>
                    </span>
                    <span class="text-xs font-semibold text-slate-600">@acao.Label</span>
                </a>
            }
        </div>
    </div>

    @* Drawer: detalhes do pedido *@
    <div x-show="drawer.open"
         class="fixed inset-0 z-50 flex justify-end no-print"
         style="display:none"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">
        <div class="fixed inset-0 bg-black/30" @@click="drawer.open = false"></div>
        <div class="relative w-full max-w-lg bg-white shadow-2xl flex flex-col h-full"
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="translate-x-full"
             x-transition:enter-end="translate-x-0"
             x-transition:leave="transition ease-in duration-150"
             x-transition:leave-start="translate-x-0"
             x-transition:leave-end="translate-x-full">
            <div class="flex items-center justify-between px-5 py-4 border-b">
                <h3 class="font-bold text-slate-800" x-text="drawer.title">Pedido</h3>
                <button type="button" @@click="drawer.open = false"
                        class="p-1.5 rounded-lg text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <div class="flex-1 overflow-y-auto px-5 py-4" x-html="drawer.body">
                <div class="space-y-3">
                    <div class="h-4 bg-slate-100 rounded animate-pulse w-3/4"></div>
                    <div class="h-4 bg-slate-100 rounded animate-pulse w-1/2"></div>
                    <div class="h-4 bg-slate-100 rounded animate-pulse w-2/3"></div>
                </div>
            </div>
            <div x-show="drawer.footer" class="px-5 py-4 border-t" x-html="drawer.footer"></div>
        </div>
    </div>

    @* Error state *@
    <template x-if="error">
        <div class="ws text-center py-8">
            <p class="text-red-600 mb-3" x-text="error"></p>
            <button type="button" @@click="reload()" class="btn btn-sm btn-outline">Tentar novamente</button>
        </div>
    </template>
</div>

@section Styles {
<style>
@@media print {
    nav, aside, header nav, .no-print { display: none !important; }
    body { background: white !important; color: black !important; }
    canvas { max-width: 100% !important; }
    #dashboard-kpis, #section-vendas, #section-estoque, #section-clientes { page-break-inside: avoid; }
}
</style>
}

@section Scripts {
    <script src="~/js/dashboard-charts.js"></script>
    <script>
        function dashboardApp() {
            const fmtCurrency = new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' });
            const fmtNumber = new Intl.NumberFormat('pt-BR');
            const fmtPct = (v) => v != null ? v.toFixed(1).replace('.', ',') + '%' : '—';
            const fmtDelta = (v) => {
                if (v == null) return '—';
                const sign = v > 0 ? '+' : '';
                return sign + v.toFixed(1).replace('.', ',') + '%';
            };
            const fmtDate = (iso) => {
                if (!iso) return '—';
                const d = new Date(iso);
                return d.toLocaleDateString('pt-BR');
            };

            return {
                periodo: 30,
                lojaId: '',
                loading: false,
                data: null,
                error: null,
                filtroAlerta: 'todos',
                extras: null,
                extrasLoaded: false,
                extrasLoading: false,
                extrasRequestId: 0,
                drawer: { open: false, title: '', body: '', footer: '' },
                periodos: [
                    { value: 1,   label: 'Hoje' },
                    { value: 7,   label: '7d' },
                    { value: 30,  label: '30d' },
                    { value: 90,  label: '3 meses' },
                    { value: 365, label: '1 ano' },
                ],
                fmt: {
                    currency: (v) => fmtCurrency.format(v ?? 0),
                    number:   (v) => fmtNumber.format(v ?? 0),
                    pct:      fmtPct,
                    delta:    fmtDelta,
                    date:     fmtDate,
                },

                alertasFiltrados() {
                    if (!this.data || !this.data.alertasEstoque) return [];
                    if (this.filtroAlerta === 'todos') return this.data.alertasEstoque;
                    return this.data.alertasEstoque.filter(a => a.tipo === this.filtroAlerta);
                },
                contarAlerta(tipo) {
                    if (!this.data || !this.data.alertasEstoque) return 0;
                    return this.data.alertasEstoque.filter(a => a.tipo === tipo).length;
                },
                iconeAlerta(tipo) {
                    if (tipo === 'critico') return 'M12 9v4m0 4h.01M10.29 3.86l-7.11 12.3A2 2 0 004.91 19h14.18a2 2 0 001.73-2.84l-7.11-12.3a2 2 0 00-3.42 0z';
                    if (tipo === 'vencimento') return 'M12 8v4l2.5 2.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z';
                    return 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4';
                },
                labelAlerta(a) {
                    if (a.tipo === 'vencimento') return 'Vence em ' + a.dias + (a.dias === 1 ? ' dia' : ' dias');
                    if (a.tipo === 'parado') return 'Parado há ' + a.dias + (a.dias === 1 ? ' dia' : ' dias');
                    return 'Apenas ' + a.quantidade + (a.quantidade === 1 ? ' unidade' : ' unidades');
                },

                deltaClass(val, invert) {
                    if (val == null || val === 0) return 'text-slate-400';
                    const positive = invert ? val < 0 : val > 0;
                    return positive ? 'text-emerald-600' : 'text-red-500';
                },

                exportarPDF() {
                    window.print();
                },

                async openPedido(id) {
                    const safeId = encodeURIComponent(String(id || ''));
                    this.drawer = {
                        open: true,
                        title: 'Carregando pedido...',
                        body: '<div class="space-y-3"><div class="h-4 bg-slate-100 rounded animate-pulse w-3/4"></div><div class="h-4 bg-slate-100 rounded animate-pulse w-1/2"></div><div class="h-32 bg-slate-50 rounded animate-pulse mt-4"></div></div>',
                        footer: ''
                    };
                    try {
                        const resp = await window.api.get('/dashboard/pedido/' + safeId);
                        // API retorna PedidoDetalheResult = { pedido, itens, eventos, pagamentos }.
                        // Antes lia campos flat em resp e tudo vinha undefined ("Sem cliente / R$ 0").
                        const root = resp.data ?? resp;
                        const pedido = root.pedido ?? root;
                        const detalhes = {
                            pedido,
                            itens: root.itens ?? pedido.itens ?? [],
                            pagamentos: root.pagamentos ?? pedido.pagamentos ?? []
                        };
                        this.drawer.title = 'Pedido #' + String(pedido.id || id).substring(0, 8).toUpperCase();
                        this.drawer.body = this._buildPedidoBody(detalhes);
                        this.drawer.footer = this._buildPedidoFooter(detalhes);
                    } catch (e) {
                        console.error('[dashboard] pedido:', e);
                        this.drawer.body = '<p class="text-red-600 text-sm">Não foi possível carregar os detalhes.</p>';
                    }
                },

                _buildPedidoBody({ pedido, itens, pagamentos }) {
                    const esc = (s) => String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
                    const currency = (v) => fmtCurrency.format(Number(v) || 0);
                    const date = (s) => s ? new Date(s).toLocaleDateString('pt-BR') : '—';
                    const statusMap = {
                        aguardando: { cls: 'bg-amber-100 text-amber-700', label: 'Aguardando' },
                        preparando: { cls: 'bg-blue-100 text-blue-700',   label: 'Em preparo' },
                        pronto:     { cls: 'bg-violet-100 text-violet-700', label: 'Pronto' },
                        entregue:   { cls: 'bg-emerald-100 text-emerald-700', label: 'Entregue' },
                        cancelado:  { cls: 'bg-red-100 text-red-700', label: 'Cancelado' }
                    };
                    const statusBadge = (s) => {
                        const m = statusMap[s] || { cls: 'bg-slate-100 text-slate-600', label: s || '—' };
                        return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ${m.cls}">${esc(m.label)}</span>`;
                    };

                    const totalVal = Number(pedido.total) || 0;
                    const totalPago = Number(pedido.totalPago) || 0;
                    const cancelado = pedido.status === 'cancelado';

                    let html = `<div class="space-y-4">`;
                    html += `<div class="grid grid-cols-2 gap-3">
                        <div><p class="text-xs text-slate-500">Cliente</p><p class="font-semibold text-slate-800">${esc(pedido.clienteNome || 'Sem cliente')}</p></div>
                        <div><p class="text-xs text-slate-500">Situação</p><p class="mt-0.5">${statusBadge(pedido.status)}</p></div>
                        <div><p class="text-xs text-slate-500">Data</p><p class="font-medium text-slate-700">${date(pedido.criadoEm)}</p></div>
                        <div><p class="text-xs text-slate-500">Total</p><p class="font-bold text-slate-900">${currency(totalVal)}</p></div>
                    </div>`;

                    if (itens && itens.length) {
                        html += `<div><p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-2">Itens</p><div class="space-y-1.5">`;
                        for (const item of itens) {
                            const nome = esc(item.nome || 'Item');
                            const qtd = Number(item.quantidade) || 0;
                            const sub = Number(item.subtotal) || (Number(item.precoUnitario) || 0) * qtd;
                            html += `<div class="flex justify-between text-sm"><span class="text-slate-700">${nome} × ${qtd}</span><span class="font-mono text-slate-600">${currency(sub)}</span></div>`;
                        }
                        html += `</div></div>`;
                    }

                    if (pagamentos && pagamentos.length) {
                        html += `<div><p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-2">Pagamentos</p><div class="space-y-1.5">`;
                        for (const pg of pagamentos) {
                            const valor = Number(pg.valor) || 0;
                            const metodo = esc(pg.metodo || 'Pagamento');
                            const dt = date(pg.pagoEm);
                            html += `<div class="flex justify-between text-sm"><span class="text-slate-600">${metodo} — ${dt}</span><span class="font-mono font-semibold text-emerald-700">${currency(valor)}</span></div>`;
                        }
                        html += `</div></div>`;
                    }

                    // Pedido cancelado nao tem saldo cobravel — nao exibe "Em aberto".
                    const emAberto = totalVal - totalPago;
                    if (!cancelado && emAberto > 0) {
                        html += `<div class="flex justify-between items-center pt-2 border-t"><span class="font-semibold text-slate-700">Em aberto</span><span class="font-bold text-amber-600 text-lg">${currency(emAberto)}</span></div>`;
                    }

                    html += `</div>`;
                    return html;
                },

                _buildPedidoFooter({ pedido }) {
                    const totalVal = Number(pedido.total) || 0;
                    const totalPago = Number(pedido.totalPago) || 0;
                    if (pedido.status === 'cancelado' || (totalVal - totalPago) <= 0) return '';
                    return `<a href="/pedidos/${pedido.id}" class="btn btn-sm btn-primary w-full text-center">Ver pedido completo →</a>`;
                },

                async loadExtras() {
                    const requestId = ++this.extrasRequestId;
                    this.extrasLoading = true;
                    try {
                        const tz = new Date().getTimezoneOffset();
                        let url = `/dashboard/extras?periodo=${encodeURIComponent(this.periodo)}&tz=${tz}`;
                        if (this.lojaId) url += `&lojaId=${encodeURIComponent(this.lojaId)}`;
                        const result = await window.api.get(url);
                        // Descarta resposta se outro loadExtras foi disparado depois (race).
                        if (requestId !== this.extrasRequestId) return;
                        this.extras = result.data ?? result;
                        this.extrasLoaded = true;
                        if (typeof window.dashboardCharts !== 'undefined') {
                            window.dashboardCharts.updateExtras(this.extras);
                        }
                    } catch (e) {
                        if (requestId === this.extrasRequestId) {
                            console.error('[dashboard] extras:', e);
                        }
                    } finally {
                        if (requestId === this.extrasRequestId) {
                            this.extrasLoading = false;
                        }
                    }
                },

                async init() {
                    await this.reload();
                },

                async reload() {
                    this.loading = true;
                    this.error = null;
                    this.filtroAlerta = 'todos';
                    this.extrasLoaded = false;
                    try {
                        const tz = new Date().getTimezoneOffset();
                        let url = `/dashboard/data?periodo=${encodeURIComponent(this.periodo)}&tz=${tz}`;
                        if (this.lojaId) url += `&lojaId=${encodeURIComponent(this.lojaId)}`;
                        const result = await window.api.get(url);
                        this.data = result.data ?? result;
                        if (typeof window.dashboardCharts !== 'undefined') {
                            window.dashboardCharts.update(this.data, this.periodo, this.lojaId);
                        }
                        // Carrega extras em background após dados principais
                        this.loadExtras();
                    } catch (e) {
                        console.error('[dashboard]', e);
                        this.error = 'Não foi possível carregar os dados. Verifique sua conexão.';
                    } finally {
                        this.loading = false;
                    }
                }
            };
        }
    </script>
}
