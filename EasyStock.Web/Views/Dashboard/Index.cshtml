@model DashboardViewModel
@using System.Globalization
@using System.Text.Json
@{
    var ptBR = new CultureInfo("pt-BR");
    // Saudacao e data no fuso de Brasilia: o container roda em UTC, entao
    // DateTime.Now adiantava ~3h e trocava a saudacao (e a data perto da
    // meia-noite). Mesmo padrao de ListarJanelasDisponiveisUseCase.
    var agoraBrasil = TimeZoneInfo.ConvertTimeFromUtc(
        DateTime.UtcNow, TimeZoneInfo.FindSystemTimeZoneById("America/Sao_Paulo"));
    var hora = agoraBrasil.Hour;
    var saudacao = hora < 12 ? "Bom dia" : hora < 18 ? "Boa tarde" : "Boa noite";
    var primeiroNome = (ViewBag.UsuarioNome as string ?? "").Split(' ').First();
    var dataHoje = agoraBrasil.ToString("dd 'de' MMMM 'de' yyyy", ptBR);

    // Mensagem de status -- prioriza o que exige acao
    string statusMsg;
    string statusTone;
    if (Model.EstoqueCritico > 0 && Model.ProximosVencimento > 0)
    {
        statusMsg = $"Você tem {TextHelpers.Plural(Model.EstoqueCritico, "item", "itens")} em estoque crítico e {TextHelpers.Plural(Model.ProximosVencimento, "próximo", "próximos")} ao vencimento.";
        statusTone = "critical";
    }
    else if (Model.EstoqueCritico > 0)
    {
        statusMsg = $"Você tem {TextHelpers.Plural(Model.EstoqueCritico, "item", "itens")} em estoque crítico precisando de reposição.";
        statusTone = "critical";
    }
    else if (Model.ProximosVencimento > 0)
    {
        statusMsg = $"{TextHelpers.Plural(Model.ProximosVencimento, "item", "itens")} {(Model.ProximosVencimento == 1 ? "vence" : "vencem")} em até 7 dias. Vale girar antes que estraguem.";
        statusTone = "warning";
    }
    else if (Model.SugestoesReposicao > 0)
    {
        statusMsg = $"Nada urgente hoje. {TextHelpers.Plural(Model.SugestoesReposicao, "sugestão", "sugestões")} de reposição {(Model.SugestoesReposicao == 1 ? "pronta" : "prontas")} para revisão.";
        statusTone = "info";
    }
    else if (Model.ReceitaMes > 0)
    {
        statusMsg = $"Estoque saudável. Vendas dos últimos 30 dias: {Model.ReceitaMes.ToString("C", ptBR)}.";
        statusTone = "ok";
    }
    else
    {
        statusMsg = "Tudo certo por aqui. Comece registrando uma entrada ou venda.";
        statusTone = "ok";
    }

    var toneClass = statusTone switch
    {
        "critical" => "ds-status--critical",
        "warning" => "ds-status--warning",
        "info" => "ds-status--info",
        _ => "ds-status--ok"
    };
}

@if (Model.TodasApisFalharam)
{
    <div class="ws ds-api-error mb-6" role="alert">
        <div class="flex items-start gap-3">
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5 19h14a2 2 0 001.84-2.75L13.74 4a2 2 0 00-3.48 0l-7.1 12.25A2 2 0 005 19z" />
            </svg>
            <div class="flex-1">
                <h2 class="font-bold text-slate-800">Não conseguimos carregar seus dados agora</h2>
                <p class="text-sm text-slate-600 mt-1">Pode ser instabilidade na conexão ou no servidor. Tente recarregar a página em alguns segundos.</p>
                <button type="button" onclick="window.location.reload()" class="mt-3 px-3 py-1.5 text-xs font-semibold rounded-lg bg-slate-900 text-white hover:bg-slate-800 transition-colors">
                    Recarregar
                </button>
            </div>
        </div>
    </div>
}
else if (Model.ResumoApiFalhou)
{
    <div class="ws ds-api-warning mb-6" role="status">
        <div class="flex items-center gap-3">
            <svg class="w-4 h-4 flex-shrink-0 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-sm text-slate-700">Alguns indicadores podem estar desatualizados — não conseguimos atualizar o resumo agora.</p>
        </div>
    </div>
}

@* ─── Checklist de ativação "Comece por aqui" (issue 415) ──────────── *@
@if (Model.MostrarChecklist)
{
    <section class="ws ds-onboarding mb-6" aria-labelledby="onb-title">
        <div class="flex items-start justify-between gap-3 mb-3">
            <div>
                <h2 id="onb-title" class="font-bold text-slate-800 flex items-center gap-2">
                    <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                    </svg>
                    Comece por aqui
                </h2>
                <p class="text-xs text-slate-500 mt-0.5">@Model.OnboardingConcluidos de @Model.OnboardingTotal concluídos. Siga os passos para deixar sua loja pronta para vender.</p>
            </div>
            <form method="post" asp-controller="Dashboard" asp-action="DispensarOnboarding" class="shrink-0">
                <button type="submit" class="text-xs text-slate-400 hover:text-slate-600 hover:underline whitespace-nowrap"
                        title="Dispensar este guia" aria-label="Dispensar o guia Comece por aqui">
                    Dispensar ✕
                </button>
            </form>
        </div>
        <ul class="ds-onboarding-list space-y-2">
            @foreach (var passo in Model.OnboardingPassos)
            {
                <li class="flex items-center gap-3">
                    @if (passo.Concluido)
                    {
                        <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-label="Concluído">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-sm text-slate-400 line-through flex-1">@passo.Titulo</span>
                    }
                    else
                    {
                        <svg class="w-5 h-5 text-slate-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="12" r="9" stroke-width="2" />
                        </svg>
                        <span class="text-sm text-slate-700 flex-1">@passo.Titulo</span>
                        <a href="@passo.Href" class="text-xs font-semibold text-indigo-600 hover:underline shrink-0">@passo.Acao →</a>
                    }
                </li>
            }
        </ul>
    </section>
}

<header class="ds-header mb-6">
    <h1 class="text-2xl font-bold text-slate-900">@saudacao@(string.IsNullOrEmpty(primeiroNome) ? "." : $", {primeiroNome}.")</h1>
    <p class="ds-status @toneClass mt-1" role="status" aria-live="polite">@statusMsg</p>
    <p class="text-xs text-slate-400 mt-1">@dataHoje</p>
</header>

@* ─── Pulso de hoje: resumo do dia já buscado em /analytics/dia (issue 592) ─── *@
@{
    var temPulsoHoje = Model.FaturamentoHoje > 0 || Model.PedidosEntreguesHoje > 0
        || Model.PedidosPendentes > 0 || Model.CaixaAbertaHoje || Model.CaixaFechadaHoje
        || Model.PixRecebidosHoje > 0;
}
@if (temPulsoHoje)
{
    <section class="ws mb-6" aria-labelledby="ds-pulso-title">
        <div class="ds-section-hd">
            <svg class="w-5 h-5" style="color:var(--orange-600)" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            <h2 id="ds-pulso-title">Pulso de hoje</h2>
            <span class="ds-section-meta">resumo de @dataHoje</span>
        </div>
        <div class="ds-pulse-grid">
            <div class="ds-pulse ds-pulse--accent">
                <div class="ds-pulse-lbl">Faturamento hoje</div>
                <div class="ds-pulse-val">@Model.FaturamentoHoje.ToString("C", ptBR)</div>
                <div class="ds-pulse-sub">@TextHelpers.Plural(Model.PedidosEntreguesHoje, "pedido entregue", "pedidos entregues")</div>
            </div>

            <div class="ds-pulse">
                <div class="ds-pulse-lbl">Ticket médio</div>
                <div class="ds-pulse-val">@Model.TicketMedioHoje.ToString("C", ptBR)</div>
                <div class="ds-pulse-sub">por pedido hoje</div>
            </div>

            @if (Model.CaixaAbertaHoje)
            {
                <a href="/caixa" class="ds-pulse">
                    <div class="ds-pulse-lbl">Caixa</div>
                    <div class="ds-pulse-val">@Model.SaldoCaixaAtual.ToString("C", ptBR)</div>
                    <div class="ds-pulse-sub up"><span class="ds-pulse-led"></span>caixa aberto</div>
                </a>
            }
            else if (Model.CaixaFechadaHoje)
            {
                <a href="/caixa" class="ds-pulse">
                    <div class="ds-pulse-lbl">Caixa</div>
                    <div class="ds-pulse-val">@Model.SaldoCaixaAtual.ToString("C", ptBR)</div>
                    <div class="ds-pulse-sub">fechado hoje</div>
                </a>
            }
            else
            {
                <a href="/caixa" class="ds-pulse">
                    <div class="ds-pulse-lbl">Caixa</div>
                    <div class="ds-pulse-val" style="font-size:16px">Abrir caixa →</div>
                    <div class="ds-pulse-sub warn">não aberto hoje</div>
                </a>
            }

            @if (Model.PedidosPendentes > 0)
            {
                <a href="/pedidos" class="ds-pulse" aria-label="Ver pedidos pendentes no cockpit de pedidos">
                    <div class="ds-pulse-lbl">Pendentes</div>
                    <div class="ds-pulse-val">@Model.PedidosPendentes <small>· @Model.ValorPedidosPendentes.ToString("C", ptBR)</small></div>
                    <div class="ds-pulse-sub warn">aguardando entrega</div>
                </a>
            }

            @if (Model.PixRecebidosHoje > 0)
            {
                <div class="ds-pulse">
                    <div class="ds-pulse-lbl">Pix recebidos</div>
                    <div class="ds-pulse-val">@Model.ValorPixHoje.ToString("C", ptBR)</div>
                    <div class="ds-pulse-sub">@TextHelpers.Plural(Model.PixRecebidosHoje, "transação", "transações")</div>
                </div>
            }
        </div>
    </section>
}

@* ─── Atalhos contextuais movidos pro topo (issue 592, fatia 3) ─── *@
