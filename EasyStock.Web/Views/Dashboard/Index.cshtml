@model DashboardViewModel
@using System.Globalization
@{
    var ptBR = new CultureInfo("pt-BR");
    var hora = DateTime.Now.Hour;
    var saudacao = hora < 12 ? "Bom dia" : hora < 18 ? "Boa tarde" : "Boa noite";
    var primeiroNome = (ViewBag.UsuarioNome as string ?? "").Split(' ').First();
}

<div class="pg-hd mb-6">
    <h1>@saudacao@(string.IsNullOrEmpty(primeiroNome) ? "!" : $", {primeiroNome}!")</h1>
    <p>Resumo do seu estoque hoje, @DateTime.Now.ToString("dd 'de' MMMM", ptBR).</p>
</div>

<div class="dashboard-kpi-grid grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <a href="/estoque" class="ws dashboard-kpi-card block hover:border-slate-300 transition-colors" title="Produtos com estoque ativo (exclui vencidos e sem lotes)">
        <div class="kpi-lbl">Produtos ativos</div>
        <div class="kpi-val dashboard-kpi-value text-slate-900">@Model.TotalProdutos</div>
        <div class="text-xs text-slate-400 mt-1">com estoque não vencido</div>
    </a>
    <a href="/estoque" class="ws dashboard-kpi-card block hover:border-slate-300 transition-colors" title="Soma das quantidades de todas as unidades em estoque (todos os lotes)">
        <div class="kpi-lbl">Unidades em estoque</div>
        <div class="kpi-val dashboard-kpi-value text-emerald-600">@Model.QuantidadeTotalEmEstoque</div>
        <div class="text-xs text-slate-400 mt-1">total em lotes</div>
    </a>
    <a href="/estoque" class="ws dashboard-kpi-card block hover:border-slate-300 transition-colors" title="Valor de venda estimado de todo o estoque atual">
        <div class="kpi-lbl">Valor em estoque</div>
        <div class="kpi-val dashboard-kpi-value text-indigo-600">@Model.ValorEstoque.ToString("C", ptBR)</div>
        <div class="text-xs text-slate-400 mt-1">preço de venda</div>
    </a>
    <a href="/saidas/historico" class="ws dashboard-kpi-card block hover:border-slate-300 transition-colors" title="Receita registrada com saídas nos últimos 30 dias">
        <div class="kpi-lbl">Receita registrada</div>
        <div class="kpi-val dashboard-kpi-value text-emerald-800">@Model.ReceitaMes.ToString("C", ptBR)</div>
        <div class="text-xs text-slate-400 mt-1">últimos 30 dias</div>
    </a>
</div>

<div class="dashboard-kpi-grid grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <a href="/estoque?status=critico" class="ws dashboard-kpi-card dashboard-attention-card flex items-center gap-3 hover:border-red-300 transition-colors cursor-pointer">
        <div class="dashboard-attention-icon dashboard-attention-icon--critical">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 9v4m0 4h.01M10.29 3.86l-7.11 12.3A2 2 0 004.91 19h14.18a2 2 0 001.73-2.84l-7.11-12.3a2 2 0 00-3.42 0z" />
            </svg>
        </div>
        <div>
            <div class="kpi-val dashboard-kpi-value dashboard-kpi-value--attention text-red-600">@Model.EstoqueCritico</div>
            <div class="kpi-lbl">Estoque crítico</div>
        </div>
    </a>
    <a href="/estoque?status=atencao" class="ws dashboard-kpi-card dashboard-attention-card flex items-center gap-3 hover:border-amber-300 transition-colors cursor-pointer">
        <div class="dashboard-attention-icon dashboard-attention-icon--warning">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 8v4l2.5 2.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div>
            <div class="kpi-val dashboard-kpi-value dashboard-kpi-value--attention text-amber-600">@Model.ProximosVencimento</div>
            <div class="kpi-lbl">Próx. ao vencimento</div>
        </div>
    </a>
    <a href="/estoque?status=parado" class="ws dashboard-kpi-card dashboard-attention-card flex items-center gap-3 hover:border-blue-300 transition-colors cursor-pointer">
        <div class="dashboard-attention-icon dashboard-attention-icon--info">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 13.5h10M9 17h6M8 6h8a2 2 0 012 2v8a2 2 0 01-2 2H8a2 2 0 01-2-2V8a2 2 0 012-2z" />
            </svg>
        </div>
        <div>
            <div class="kpi-val dashboard-kpi-value dashboard-kpi-value--attention text-blue-600">@Model.ProdutosParados</div>
            <div class="kpi-lbl">Parados +30 dias</div>
        </div>
    </a>
    <a href="/entradas/reposicao" class="ws dashboard-kpi-card dashboard-attention-card flex items-center gap-3 hover:border-emerald-300 transition-colors cursor-pointer">
        <div class="dashboard-attention-icon dashboard-attention-icon--success">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 3v2.5m0 13V21m7.07-14.07l-1.77 1.77M6.7 17.3l-1.77 1.77M21 12h-2.5M5.5 12H3m14.3 5.3l1.77 1.77M6.93 6.93L5.16 5.16M15.5 12a3.5 3.5 0 11-7 0 3.5 3.5 0 017 0z" />
            </svg>
        </div>
        <div>
            <div class="kpi-val dashboard-kpi-value dashboard-kpi-value--attention text-emerald-600">@Model.SugestoesReposicao</div>
            <div class="kpi-lbl">Sugestões de reposição</div>
        </div>
    </a>
</div>

@if (Model.IaConfigurada)
{
    <div class="ws mb-6">
        <div class="flex items-center justify-between mb-3">
            <h2 class="font-bold text-slate-800">Gerações de IA este mês</h2>
            <a href="/anuncios" class="text-xs text-indigo-600 hover:underline">Gerar anúncio →</a>
        </div>
        @if (Model.IaIlimitada)
        {
            <div class="flex items-center gap-3">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold ring-1 bg-emerald-50 text-emerald-800 ring-emerald-200">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                    Ilimitado
                </span>
                <span class="text-sm text-slate-500">@Model.GeracoesIaUsadas @(Model.GeracoesIaUsadas == 1 ? "geração realizada" : "gerações realizadas")</span>
            </div>
        }
        else
        {
            var pct = Model.GeracoesIaPercent;
            var barColor = pct >= 90 ? "bg-red-500" : pct >= 70 ? "bg-amber-400" : "bg-emerald-500";
            var textColor = pct >= 90 ? "text-red-600" : pct >= 70 ? "text-amber-600" : "text-emerald-600";
            <div class="flex items-center gap-3 mb-2">
                <span class="text-2xl font-bold @textColor">@Model.GeracoesIaUsadas</span>
                <span class="text-slate-400 text-sm">/ @Model.GeracoesIaLimite gerações</span>
            </div>
            <div class="w-full bg-slate-100 rounded-full h-2">
                <div class="@barColor h-2 rounded-full transition-all" style="width:@(pct)%"></div>
            </div>
            <p class="text-xs text-slate-400 mt-1">@pct% utilizado</p>
        }
    </div>
}

<div class="grid grid-cols-1 gap-6 mb-6">
    <div class="ws">
        <div class="flex items-center justify-between mb-4">
            <h2 class="font-bold text-slate-800">Movimentações recentes</h2>
            <a href="/analytics/movimentacoes" class="text-xs text-indigo-600 hover:underline">Ver todas →</a>
        </div>
        @if (Model.MovimentacoesRecentes.Any())
        {
            <div class="overflow-x-auto">
                <table class="tbl-full">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th class="text-right">Registros</th>
                            <th class="text-right">Qtd</th>
                            <th class="text-right">Valor</th>
                            <th class="text-right">Data</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model.MovimentacoesRecentes)
                        {
                            var tipoParam = m.Tipo is "Saida" or "Saída" ? "Saida" : m.Tipo;
                            <tr class="cursor-pointer hover:bg-slate-50"
                                data-row-href="/analytics/movimentacoes?data=@m.Data.ToString("yyyy-MM-dd")&tipo=@tipoParam">
                                <td>
                                    @{
                                        var badgeClass = m.Tipo switch
                                        {
                                            "Entrada" => "badge-ok",
                                            "Saida" or "Saída" => "badge-critical",
                                            _ => "badge-slow"
                                        };
                                        var tipoLabel = m.Tipo is "Saida" ? "Saída" : m.Tipo;
                                    }
                                    <span class="badge @badgeClass px-2 py-0.5 rounded-full text-xs font-semibold">@tipoLabel</span>
                                </td>
                                <td class="text-right text-slate-500">@m.TotalMovimentacoes</td>
                                <td class="text-right font-mono">@m.Qty</td>
                                <td class="text-right text-slate-500">
                                    @if (m.Valor.HasValue)
                                    {
                                        @m.Valor.Value.ToString("C", ptBR)
                                    }
                                    else
                                    {
                                        <span>—</span>
                                    }
                                </td>
                                <td class="text-right text-slate-500">@m.Data.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
                { "EmptyIllustration", "chart" },
                { "EmptyTitle", "Nenhuma movimentação este mês" },
                { "EmptyDescription", "Registre sua primeira entrada para começar a acompanhar o fluxo do estoque." },
                { "EmptyCta", "Registrar entrada" },
                { "EmptyCtaHref", "/entradas/nova" }
            })
        }
    </div>

    <div class="ws dashboard-chart-card">
        <div class="flex items-center justify-between mb-4">
            <h2 class="font-bold text-slate-800">Receita Bruta</h2>
            <div class="flex gap-1">
                @foreach (var (m, label) in new[] { (3, "3m"), (6, "6m"), (12, "12m") })
                {
                    var isActive = (ViewBag.MesesGrafico as int? ?? 6) == m;
                    <a href="/dashboard?meses=@m"
                       class="px-2.5 py-1 text-xs font-medium rounded-lg @(isActive ? "bg-indigo-600 text-white" : "text-slate-500 hover:bg-slate-100")">
                        @label
                    </a>
                }
            </div>
        </div>
        @if (Model.GraficoLabels.Any())
        {
            <div class="dashboard-chart-wrap">
                <canvas id="grafico-receita" height="260"></canvas>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
                { "EmptyIllustration", "chart" },
                { "EmptyTitle", "Sem dados de receita ainda" },
                { "EmptyDescription", "Registre saídas para visualizar o gráfico de receita do período." },
                { "EmptyCta", "Registrar saída" },
                { "EmptyCtaHref", "/saidas/nova" }
            })
        }
    </div>
</div>

<div class="ws hidden lg:block">
    <h2 class="font-bold text-slate-800 mb-4">Ações rápidas</h2>
    <div class="grid grid-cols-3 sm:grid-cols-6 gap-3">
        @{
            var acoes = new[]
            {
                // arrow-down (entrada)
                new { IconPath = "M19 14l-7 7m0 0l-7-7m7 7V3", Label = "Nova entrada", Href = "/entradas/nova" },
                // arrow-up (saída)
                new { IconPath = "M5 10l7-7m0 0l7 7m-7-7v18", Label = "Registrar saída", Href = "/saidas/nova" },
                // refresh (repor)
                new { IconPath = "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15", Label = "Repor estoque", Href = "/entradas/reposicao" },
                // package (estoque)
                new { IconPath = "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4", Label = "Ver estoque", Href = "/estoque" },
                // sparkles (IA)
                new { IconPath = "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z", Label = "Gerar anúncio", Href = "/anuncios" },
                // chart bar (movimentações)
                new { IconPath = "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z", Label = "Movimentações", Href = "/analytics/movimentacoes" },
            };
        }
        @foreach (var acao in acoes)
        {
            <a href="@acao.Href"
               class="quick-action-card flex flex-col items-center gap-2 p-3 rounded-xl border border-slate-200 hover:border-indigo-300 hover:bg-indigo-50 transition-all text-center group">
                <span class="quick-action-icon w-9 h-9 rounded-full bg-slate-50 group-hover:bg-indigo-100 text-slate-500 group-hover:text-indigo-600 flex items-center justify-center transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="@acao.IconPath" />
                    </svg>
                </span>
                <span class="text-xs font-semibold text-slate-600">@acao.Label</span>
            </a>
        }
    </div>
</div>

@section Scripts {
    @if (Model.GraficoLabels.Any() && Model.GraficoDados.Any(d => d > 0))
    {
    <script>
        const ctx = document.getElementById('grafico-receita');
        if (ctx) {
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoLabels)),
                    datasets: [{
                        label: 'Receita',
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoDados)),
                        borderColor: '#1E48A8',
                        backgroundColor: 'rgba(30, 72, 168,0.1)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0
                    }]
                },
                options: {
                    responsive: true,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: ctx => ' R$ ' + ctx.parsed.y.toLocaleString('pt-BR', { minimumFractionDigits: 2 })
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: '#64748B' },
                            grid: { display: false }
                        },
                        y: {
                            ticks: {
                                color: '#64748B',
                                callback: v => 'R$ ' + v.toLocaleString('pt-BR')
                            },
                            grid: { color: 'rgba(148, 163, 184, 0.18)' }
                        }
                    }
                }
            });
        }
    </script>
    }
}
