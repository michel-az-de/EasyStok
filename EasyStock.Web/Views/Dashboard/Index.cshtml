@* ─── Layout 2 colunas: principal (alertas+gráfico+movs) | lateral (KPIs+IA) ─── *@
<div class="ds-dash-grid">
    <div class="ds-dash-main">

@* ─── Alertas priorizados (só aparece quando há algo) ────────── *@
@if (Model.TemQualquerAlerta)
{
    <section class="ws ds-alerts mb-6" aria-labelledby="ds-alerts-title">
        <div class="flex items-center justify-between mb-3">
            <h2 id="ds-alerts-title" class="font-bold text-slate-800 flex items-center gap-2">
                <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5 19h14a2 2 0 001.84-2.75L13.74 4a2 2 0 00-3.48 0l-7.1 12.25A2 2 0 005 19z" />
                </svg>
                Atenção
            </h2>
            <span class="text-xs text-slate-400">prioridade alta primeiro</span>
        </div>
        <ul class="ds-alerts-list">
            @if (Model.EstoqueCritico > 0)
            {
                var lbl = Model.EstoqueCritico == 1 ? "produto crítico" : "produtos críticos";
                <li>
                    <a href="/estoque?status=critico" class="ds-alert ds-alert--critical"
                       aria-label="@(Model.EstoqueCritico) @lbl. Ir para a lista para repor.">
                        <span class="ds-alert-dot" aria-hidden="true"></span>
                        <span class="ds-alert-count">@Model.EstoqueCritico</span>
                        <span class="ds-alert-text">@lbl</span>
                        <span class="ds-alert-cta" aria-hidden="true">Repor agora →</span>
                    </a>
                </li>
            }
            @if (Model.ProximosVencimento > 0)
            {
                var lbl = Model.ProximosVencimento == 1 ? "lote vence em 7 dias" : "lotes vencem em 7 dias";
                <li>
                    <a href="/estoque?status=vencendo" class="ds-alert ds-alert--warning"
                       aria-label="@(Model.ProximosVencimento) @lbl. Ir para os lotes.">
                        <span class="ds-alert-dot" aria-hidden="true"></span>
                        <span class="ds-alert-count">@Model.ProximosVencimento</span>
                        <span class="ds-alert-text">@(Model.ProximosVencimento == 1 ? "vence em 7 dias" : "vencem em 7 dias")</span>
                        <span class="ds-alert-cta" aria-hidden="true">Ver lotes →</span>
                    </a>
                </li>
            }
            @if (Model.LotesVencidos > 0)
            {
                var lblV = Model.LotesVencidos == 1 ? "lote vencido com saldo" : "lotes vencidos com saldo";
                <li>
                    <a href="/estoque?status=vencido" class="ds-alert ds-alert--critical"
                       aria-label="@(Model.LotesVencidos) @lblV. Risco sanitário (RDC 727). Ir para os lotes vencidos.">
                        <span class="ds-alert-dot" aria-hidden="true"></span>
                        <span class="ds-alert-count">@Model.LotesVencidos</span>
                        <span class="ds-alert-text">@lblV</span>
                        <span class="ds-alert-cta" aria-hidden="true">Descartar/revisar →</span>
                    </a>
                </li>
            }
            @if (Model.ProdutosParados > 0)
            {
                var paradosAria = $"{TextHelpers.Plural(Model.ProdutosParados, "produto parado", "produtos parados")} há mais de 30 dias. Considerar liquidar.";
                <li>
                    <a href="/estoque?status=parado" class="ds-alert ds-alert--info"
                       aria-label="@paradosAria">
                        <span class="ds-alert-dot" aria-hidden="true"></span>
                        <span class="ds-alert-count">@Model.ProdutosParados</span>
                        <span class="ds-alert-text">@TextHelpers.PluralWord(Model.ProdutosParados, "parado", "parados") há +30 dias</span>
                        <span class="ds-alert-cta" aria-hidden="true">Considerar liquidar →</span>
                    </a>
                </li>
            }
            @if (Model.SugestoesReposicao > 0)
            {
                var lbl = Model.SugestoesReposicao == 1 ? "sugestão de reposição" : "sugestões de reposição";
                <li>
                    <a href="/entradas/reposicao" class="ds-alert ds-alert--success"
                       aria-label="@(Model.SugestoesReposicao) @lbl. Ver a lista.">
                        <span class="ds-alert-dot" aria-hidden="true"></span>
                        <span class="ds-alert-count">@Model.SugestoesReposicao</span>
                        <span class="ds-alert-text">@lbl</span>
                        <span class="ds-alert-cta" aria-hidden="true">Ver lista →</span>
                    </a>
                </li>
            }
        </ul>
    </section>
}

@* ─── Gráfico de vendas por mês ─────────────────────────────── *@
<div class="ws dashboard-chart-card mb-6">
    <div class="flex items-start justify-between mb-4 flex-wrap gap-2">
        <div>
            <h2 class="font-bold text-slate-800">Vendas por mês</h2>
            @if (Model.TemComparativoReceita)
            {
                var pct = Model.VariacaoReceitaPercent;
                var deltaClass = pct > 0 ? "text-emerald-600" : pct < 0 ? "text-red-600" : "text-slate-500";
                var arrow = pct > 0 ? "↗" : pct < 0 ? "↘" : "→";
                <p class="text-xs @deltaClass mt-0.5">@arrow @Math.Abs(pct)% vs. mês anterior</p>
            }
            else
            {
                <p class="text-xs text-slate-400 mt-0.5">Acompanhe a evolução das vendas mês a mês</p>
            }
        </div>
        <div class="flex gap-1">
            @foreach (var (m, label) in new[] { (3, "3m"), (6, "6m"), (12, "12m") })
            {
                var isActive = (ViewBag.MesesGrafico as int? ?? 6) == m;
                <a href="/dashboard?meses=@m"
                   class="px-2.5 py-1 text-xs font-medium rounded-lg @(isActive ? "bg-indigo-600 text-white" : "text-slate-500 hover:bg-slate-100")">
                    @label
                </a>
            }
        </div>
    </div>
    @if (Model.GraficoLabels.Any())
    {
        <div class="dashboard-chart-wrap">
            <canvas id="grafico-receita" height="260"></canvas>
        </div>
    }
    else
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIllustration", "chart" },
            { "EmptyTitle", "Ainda sem vendas registradas" },
            { "EmptyDescription", "Quando você registrar a primeira saída, o gráfico mostra a evolução das vendas mês a mês." },
            { "EmptyCta", "Registrar primeira saída" },
            { "EmptyCtaHref", "/saidas/nova" }
        })
    }
</div>

@* ─── Últimas movimentações (agrupadas por data) ─────────────── *@
<div class="ws mb-6">
    <div class="flex items-center justify-between mb-4">
        <h2 class="font-bold text-slate-800">Últimas movimentações</h2>
        <a href="/analytics/movimentacoes" class="text-xs text-indigo-600 hover:underline">Ver todas →</a>
    </div>
    @if (Model.MovimentacoesRecentes.Any())
    {
        var agrupado = Model.MovimentacoesRecentes
            .GroupBy(m => m.Data)
            .OrderByDescending(g => g.Key)
            .ToList();

        <div class="ds-mov-list">
            @foreach (var grupo in agrupado)
            {
                var hoje = DateOnly.FromDateTime(DateTime.Today);
                var ontem = hoje.AddDays(-1);
                string rotuloDia = grupo.Key == hoje ? "Hoje" : grupo.Key == ontem ? "Ontem" : grupo.Key.ToString("dd 'de' MMMM", ptBR);

                <div class="ds-mov-day">
                    <div class="ds-mov-day-label">@rotuloDia · @grupo.Key.ToString("dd/MM/yyyy")</div>
                    @foreach (var m in grupo)
                    {
                        var tipoNormalizado = m.Tipo is "Saida" or "Saída" ? "Saida" : m.Tipo;
                        var label = tipoNormalizado switch
                        {
                            "Entrada" => TextHelpers.Plural(m.TotalMovimentacoes, "entrada", "entradas"),
                            "Saida" => TextHelpers.Plural(m.TotalMovimentacoes, "saída", "saídas"),
                            _ => $"{m.TotalMovimentacoes} {m.Tipo.ToLower()}"
                        };
                        var dotClass = tipoNormalizado switch
                        {
                            "Entrada" => "bg-emerald-500",
                            "Saida" => "bg-red-500",
                            _ => "bg-slate-400"
                        };
                        <a href="/analytics/movimentacoes?data=@grupo.Key.ToString("yyyy-MM-dd")&tipo=@tipoNormalizado"
                           class="ds-mov-row">
                            <span class="ds-mov-dot @dotClass"></span>
                            <span class="ds-mov-main"><strong>@label</strong> · @m.Qty unid.</span>
                            <span class="ds-mov-val">
                                @if (m.Valor.HasValue)
                                {
                                    @m.Valor.Value.ToString("C", ptBR)
                                }
                                else
                                {
                                    <span class="text-slate-300">—</span>
                                }
                            </span>
                        </a>
                    }
                </div>
            }
        </div>
    }
    else
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIllustration", "chart" },
            { "EmptyTitle", "Nenhuma movimentação ainda" },
            { "EmptyDescription", "Registre sua primeira entrada para começar a acompanhar o fluxo do estoque." },
            { "EmptyCta", "Registrar entrada" },
            { "EmptyCtaHref", "/entradas/nova" }
        })
    }
</div>

    </div>
    <div class="ds-dash-aside">

@* ─── KPIs principais (3 cards), agora empilhados na lateral ─── *@
<div class="ds-kpi-stack mb-6">
    <div class="ws ds-kpi" title="Receita gerada com saídas nos últimos 30 dias">
        <div class="ds-kpi-lbl">Vendas</div>
        <div class="ds-kpi-val text-slate-900">@Model.ReceitaMes.ToString("C", ptBR)</div>
        @if (Model.TemComparativoReceita)
        {
            var pct = Model.VariacaoReceitaPercent;
            var deltaClass = pct > 0 ? "text-emerald-600" : pct < 0 ? "text-red-600" : "text-slate-500";
            var arrow = pct > 0 ? "↗" : pct < 0 ? "↘" : "→";
            <div class="ds-kpi-sub @deltaClass">@arrow @Math.Abs(pct)% vs. mês anterior</div>
        }
        else
        {
            <div class="ds-kpi-sub text-slate-400">últimos 30 dias</div>
        }
        @if (Model.ReceitaMes == 0)
        {
            <a href="/produtos?semPreco=true"
               class="text-xs text-amber-600 hover:text-amber-700 hover:underline mt-1 block"
               title="Saídas registradas com produtos sem preço resultam em receita zero">
                ⚠ Verifique produtos sem preço
            </a>
        }
    </div>

    <div class="ws ds-kpi" title="Capital imobilizado (a custo) de todo o estoque atual">
        <div class="ds-kpi-lbl">Estoque em R$ (custo)</div>
        <div class="ds-kpi-val text-slate-900">@Model.ValorEstoque.ToString("C", ptBR)</div>
        <div class="ds-kpi-sub text-slate-400">@TextHelpers.Plural(Model.TotalProdutos, "produto", "produtos") · @Model.QuantidadeTotalEmEstoque unid.</div>
    </div>

    <div class="ws ds-kpi" title="Média de unidades vendidas por dia">
        <div class="ds-kpi-lbl">Média de vendas / dia</div>
        <div class="ds-kpi-val text-slate-900">@Model.MediaVendasDiaria.ToString("N1", ptBR)</div>
        <div class="ds-kpi-sub text-slate-400">unidades por dia</div>
    </div>
</div>

@* ─── Card pequeno de IA (apenas se uso alto) ────────────────── *@
@if (Model.IaConfigurada && !Model.IaIlimitada && Model.GeracoesIaPercent >= 70)
{
    var pct = Model.GeracoesIaPercent;
    var barColor = pct >= 90 ? "bg-red-500" : "bg-amber-400";
    var textColor = pct >= 90 ? "text-red-600" : "text-amber-600";
    <div class="ws mb-6">
        <div class="flex items-center justify-between mb-2">
            <div>
                <h3 class="font-semibold text-slate-700 text-sm">Você usou @pct% das gerações de IA deste mês</h3>
                <p class="text-xs text-slate-400 mt-0.5">@Model.GeracoesIaUsadas de @Model.GeracoesIaLimite anúncios</p>
            </div>
            <a href="/assinatura" class="text-xs text-indigo-600 hover:underline whitespace-nowrap">Ver plano →</a>
        </div>
        <div class="w-full bg-slate-100 rounded-full h-1.5">
            <div class="@barColor h-1.5 rounded-full transition-all" style="width:@(pct)%"></div>
        </div>
    </div>
}

    </div>
</div>

@section Scripts {
    @if (Model.GraficoLabels.Any())
    {
    <script>
        (function () {
            const ctx = document.getElementById('grafico-receita');
            if (!ctx) return;
            const css = getComputedStyle(document.documentElement);
            const navy = css.getPropertyValue('--navy-500').trim() || 'rgb(30, 72, 168)';
            const ink  = css.getPropertyValue('--text-muted').trim() || 'rgb(112, 120, 146)';
            const labels = @Json.Serialize(Model.GraficoLabels);
            const dados = @Json.Serialize(Model.GraficoDados);

            if (!dados.some(function (v) { return v > 0; })) {
                var wrap = ctx.closest('.dashboard-chart-wrap');
                if (wrap) wrap.innerHTML =
                    '<div class="h-full flex flex-col items-center justify-center text-slate-400 text-sm gap-2 py-8">' +
                    '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>' +
                    '<p>Nenhuma venda com valor registrada no período.</p>' +
                    '<a href="/produtos?semPreco=true" class="text-indigo-600 text-xs hover:underline">Verificar produtos sem preço →</a>' +
                    '</div>';
                return;
            }

            new Chart(ctx, {
                type: labels.length > 1 ? 'line' : 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Vendas',
                        data: dados,
                        borderColor: navy,
                        backgroundColor: labels.length > 1
                            ? (function() {
                                var g = ctx.getContext('2d').createLinearGradient(0, 0, 0, 260);
                                g.addColorStop(0, 'rgba(30, 72, 168, 0.25)');
                                g.addColorStop(1, 'rgba(30, 72, 168, 0)');
                                return g;
                              })()
                            : 'rgba(30, 72, 168, 0.7)',
                        borderWidth: 2.5,
                        fill: labels.length > 1,
                        tension: 0.35,
                        pointRadius: labels.length > 1 ? 0 : undefined,
                        pointHoverRadius: 5,
                        pointHoverBackgroundColor: 'rgb(30,72,168)',
                        pointHoverBorderColor: 'white',
                        pointHoverBorderWidth: 2,
                        borderRadius: labels.length > 1 ? undefined : 6,
                        maxBarThickness: 80
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgb(15,23,42)',
                            titleColor: 'rgb(226,232,240)',
                            bodyColor: 'white',
                            padding: 10,
                            cornerRadius: 8,
                            displayColors: false,
                            callbacks: {
                                label: ctx => ' R$ ' + ctx.parsed.y.toLocaleString('pt-BR', { minimumFractionDigits: 2 })
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: ink },
                            grid: { display: false }
                        },
                        y: {
                            beginAtZero: true,
                            ticks: {
                                color: ink,
                                callback: v => 'R$ ' + v.toLocaleString('pt-BR')
                            },
                            grid: { color: 'rgba(148, 163, 184, 0.18)' }
                        }
                    }
                }
            });
        })();
    </script>
    }
}
