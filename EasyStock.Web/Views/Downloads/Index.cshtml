@model EasyStock.Web.Controllers.ApkVersionInfo
@{
    ViewData["Title"] = "Baixar EasyStok PDV — APK Android";
    Layout = "~/Views/Shared/_LayoutSite.cshtml";
}

<section class="bg-zinc-50 min-h-[70vh] py-12">
  <div class="container mx-auto px-4 max-w-3xl">

    <header class="text-center mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-zinc-900 mb-3">
        EasyStok PDV — App Android
      </h1>
      <p class="text-zinc-600">
        Instale no tablet ou celular Android. Funciona offline e sincroniza
        automaticamente quando volta à internet.
      </p>
    </header>

    @if (Model.Available)
    {
      <div class="bg-white rounded-2xl shadow-sm border border-zinc-200 p-6 md:p-8">

        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
          <div>
            <div class="text-sm text-zinc-500">Versão atual</div>
            <div class="text-2xl font-semibold text-zinc-900">@Model.Version</div>
            <div class="text-xs text-zinc-400 mt-1">
              Build <code>@Model.Sha</code> · @Model.ReleasedAt.ToString("dd/MM/yyyy HH:mm 'UTC'")
            </div>
          </div>
          <div class="text-sm text-zinc-500">
            @{
              var mb = Model.SizeBytes / 1024.0 / 1024.0;
            }
            <div>Tamanho: <strong>@mb.ToString("F1") MB</strong></div>
            <div>Compatível: Android 8+ (SDK 26+)</div>
          </div>
        </div>

        <a href="/downloads/apk"
           class="block w-full md:w-auto md:inline-block text-center bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-lg px-8 py-4 text-lg transition"
           rel="nofollow">
          Baixar APK
        </a>

        <div class="mt-8 pt-6 border-t border-zinc-100">
          <h2 class="text-lg font-semibold text-zinc-900 mb-3">Como instalar</h2>
          <ol class="list-decimal list-inside space-y-2 text-zinc-700 text-sm">
            <li>Toque no botão <strong>Baixar APK</strong> acima.</li>
            <li>Quando o Android avisar sobre "fontes desconhecidas", autorize a instalação.</li>
            <li>Abra o arquivo baixado e siga as instruções de instalação.</li>
            <li>Pareie o dispositivo com sua loja pelo código fornecido no painel.</li>
          </ol>
          <p class="text-xs text-zinc-500 mt-4">
            Atualizações futuras chegam automaticamente — não é preciso baixar o APK de novo.
          </p>
        </div>
      </div>
    }
    else
    {
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 text-amber-900">
        <strong>APK ainda não publicado.</strong>
        Aguarde o próximo deploy ou contate o suporte.
      </div>
    }

  </div>
</section>
