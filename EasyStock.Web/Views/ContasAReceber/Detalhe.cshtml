@model EasyStock.Web.Models.ViewModels.Financeiro.ContaReceberDetalheViewModel
@{
    var c = Model.Conta;
    var statusBadge = c.Status switch
    {
        "Rascunho" => "bg-gray-100 text-gray-700",
        "Aberta" => "bg-blue-100 text-blue-700",
        "ParcialmentePaga" => "bg-yellow-100 text-yellow-700",
        "Paga" => "bg-green-100 text-green-700",
        "Vencida" => "bg-red-100 text-red-700",
        "Cancelada" => "bg-gray-100 text-gray-500",
        _ => "bg-gray-100 text-gray-700"
    };
}

<div class="page-content max-w-5xl">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-semibold">@c.Descricao</h1>
            <p class="text-sm text-gray-500">
                Emitida em @c.DataEmissao.ToString("dd/MM/yyyy")
                @if (c.DataCompetencia.HasValue) { <text>· Competencia: @c.DataCompetencia.Value.ToString("MM/yyyy")</text> }
            </p>
        </div>
        <div class="flex gap-2">
            <a href="/contas-a-receber" class="btn btn-ghost">Voltar</a>
            @if (c.Status == "Rascunho")
            {
                <form method="post" action="/contas-a-receber/@c.Id/emitir" class="inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">Emitir</button>
                </form>
            }
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
        <div class="card">
            <div class="text-xs text-gray-500">Status</div>
            <span class="inline-block mt-2 px-2 py-1 rounded text-sm @statusBadge">@c.Status</span>
        </div>
        <div class="card">
            <div class="text-xs text-gray-500">Total</div>
            <div class="text-2xl font-semibold mt-1">@c.ValorTotal.ToString("C")</div>
        </div>
        <div class="card">
            <div class="text-xs text-gray-500">Recebido</div>
            <div class="text-2xl font-semibold text-green-700 mt-1">@c.TotalRecebido.ToString("C")</div>
        </div>
        <div class="card">
            <div class="text-xs text-gray-500">Pendente</div>
            <div class="text-2xl font-semibold text-red-700 mt-1">@c.Pendente.ToString("C")</div>
        </div>
    </div>

    @if (c.Status == "Cancelada" && !string.IsNullOrWhiteSpace(c.MotivoCancelamento))
    {
        <div class="card bg-gray-50 border-gray-200 mb-4">
            <div class="text-xs text-gray-500 mb-1">Motivo do cancelamento</div>
            <div class="text-sm">@c.MotivoCancelamento</div>
        </div>
    }

    <div class="card mb-4">
        <h2 class="text-lg font-medium mb-3">Parcelas</h2>
        <table class="min-w-full divide-y divide-gray-200">
            <thead>
                <tr class="text-left text-xs font-medium text-gray-500 uppercase">
                    <th class="px-3 py-2">N</th>
                    <th class="px-3 py-2">Vencimento</th>
                    <th class="px-3 py-2 text-right">Valor</th>
                    <th class="px-3 py-2 text-right">Recebido</th>
                    <th class="px-3 py-2 text-right">Saldo</th>
                    <th class="px-3 py-2">Status</th>
                    <th class="px-3 py-2">Pix</th>
                    <th class="px-3 py-2">Acao</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var p in c.Parcelas.OrderBy(x => x.Numero))
                {
                    var podeReceber = c.Status != "Cancelada" && p.Status != "Paga" && p.Status != "Cancelada" && c.Status != "Rascunho";
                    <tr x-data="{ open: false }">
                        <td class="px-3 py-2">@p.Numero</td>
                        <td class="px-3 py-2 text-sm">@p.DataVencimento.ToString("dd/MM/yyyy")</td>
                        <td class="px-3 py-2 text-right">@p.Valor.ToString("C")</td>
                        <td class="px-3 py-2 text-right text-green-700">@p.ValorPago.ToString("C")</td>
                        <td class="px-3 py-2 text-right">@p.Saldo.ToString("C")</td>
                        <td class="px-3 py-2 text-sm">@p.Status</td>
                        <td class="px-3 py-2 text-sm text-gray-500">
                            @if (!string.IsNullOrWhiteSpace(p.EfiTxid))
                            {
                                <span class="text-xs bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded" title="@p.PixCopiaCola">QR ativo</span>
                            }
                            else if (podeReceber)
                            {
                                <form method="post" action="/contas-a-receber/@c.Id/parcelas/@p.Id/pix" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-xs text-blue-600 hover:underline">Gerar Pix</button>
                                </form>
                            }
                        </td>
                        <td class="px-3 py-2">
                            @if (podeReceber)
                            {
                                <button type="button" @@click="open = !open" class="text-blue-600 text-sm hover:underline">Receber</button>
                            }
                        </td>
                        @if (podeReceber)
                        {
                            <td colspan="8" class="px-3 pb-3" x-show="open" x-cloak>
                                <form method="post" action="/contas-a-receber/@c.Id/parcelas/@p.Id/pagar" class="grid grid-cols-1 md:grid-cols-5 gap-2 items-end bg-gray-50 p-2 rounded">
                                    @Html.AntiForgeryToken()
                                    <div>
                                        <label class="form-label text-xs">Valor (R$) *</label>
                                        <input type="number" name="valor" required step="0.01" min="0.01" max="@p.Saldo" value="@p.Saldo" class="form-input" />
                                    </div>
                                    <div>
                                        <label class="form-label text-xs">Metodo *</label>
                                        <select name="metodo" required class="form-input">
                                            <option value="pix">Pix</option>
                                            <option value="dinheiro">Dinheiro</option>
                                            <option value="debito">Debito</option>
                                            <option value="credito">Credito</option>
                                            <option value="transferencia">Transferencia</option>
                                            <option value="outro">Outro</option>
                                        </select>
                                    </div>
                                    <div class="md:col-span-2">
                                        <label class="form-label text-xs">Observacao</label>
                                        <input type="text" name="observacao" maxlength="500" class="form-input" />
                                    </div>
                                    <div class="flex gap-1">
                                        <button type="submit" class="btn btn-primary btn-sm">Confirmar</button>
                                        <button type="button" @@click="open = false" class="btn btn-ghost btn-sm">Cancelar</button>
                                    </div>
                                </form>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (c.Status != "Cancelada" && c.Status != "Paga")
    {
        <div class="card border-red-200 bg-red-50">
            <h3 class="font-medium text-red-900 mb-2">Cancelar conta</h3>
            <form method="post" action="/contas-a-receber/@c.Id/cancelar" class="flex gap-2 items-end">
                @Html.AntiForgeryToken()
                <div class="flex-1">
                    <label class="form-label text-xs">Motivo *</label>
                    <input type="text" name="motivo" required maxlength="500" class="form-input" placeholder="Ex: Cliente desistiu" />
                </div>
                <button type="submit" class="btn btn-danger" onclick="return confirm('Cancelar esta conta?')">Cancelar conta</button>
            </form>
        </div>
    }
</div>
