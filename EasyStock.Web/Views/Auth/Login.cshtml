@model LoginViewModel
@{
    Layout = null;
    ViewBag.Title = "Login";
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login — EasyStock</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/app.css" />
</head>
<body class="h-full bg-slate-100 font-[Inter] antialiased flex items-center justify-center min-h-screen">
    <div class="w-full max-w-sm mx-auto px-4">
        <!-- Logo -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center gap-2 mb-2">
                <span class="text-4xl">📦</span>
                <span class="text-3xl font-extrabold text-slate-900 tracking-tight">EasyStock</span>
            </div>
            <p class="text-slate-500 text-sm">Gerencie seu estoque com inteligência</p>
        </div>

        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-8">
            <h1 class="text-xl font-bold text-slate-900 mb-1">Entrar</h1>
            <p class="text-slate-500 text-sm mb-6">Acesse sua conta para continuar</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 mb-4">
                    @Html.ValidationSummary(false, "", new { @class = "" })
                </div>
            }

            <form asp-action="Login" asp-controller="Auth" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div class="mb-4">
                    <label asp-for="Email" class="block text-sm font-semibold text-slate-700 mb-1.5">E-mail</label>
                    <input asp-for="Email" type="email" autocomplete="email"
                           class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                           placeholder="seu@email.com" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="mb-6">
                    <div class="flex items-center justify-between mb-1.5">
                        <label asp-for="Senha" class="block text-sm font-semibold text-slate-700">Senha</label>
                        <a href="/auth/esqueci-senha" class="text-xs text-indigo-600 hover:text-indigo-700">Esqueceu a senha?</a>
                    </div>
                    <input asp-for="Senha" type="password" autocomplete="current-password"
                           class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                           placeholder="Sua senha" />
                    <span asp-validation-for="Senha" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <button type="submit"
                        class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2.5 rounded-lg transition-colors text-sm">
                    Entrar
                </button>
            </form>
        </div>

        <p class="text-center text-sm text-slate-500 mt-4">
            Não tem conta?
            <a href="/auth/registrar" class="text-indigo-600 hover:text-indigo-700 font-medium">Criar conta grátis</a>
        </p>

        <p class="text-center text-xs text-slate-400 mt-4">
            &copy; @DateTime.Now.Year EasyStock. Todos os direitos reservados.
        </p>
    </div>
    <script src="~/js/toast.js"></script>
</body>
</html>
