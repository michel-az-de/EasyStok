@model LoginViewModel
@{
    Layout = null;
    ViewBag.Title = "Login";
    var sessionExpired = ViewBag.SessionExpired == true;
    var apiUnavailable = ViewBag.ApiUnavailable == true;
    var returnUrl = (ViewBag.ReturnUrl as string) ?? string.Empty;
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - EasyStock</title>
    <script>
        (function () {
            const stored = localStorage.getItem('easystock-theme');
            const theme = stored === 'dark' || stored === 'light' ? stored : 'light';
            document.documentElement.dataset.theme = theme;
            document.documentElement.classList.toggle('theme-dark', theme === 'dark');
        })();
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.dist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />

    <style>
        [x-cloak] { display: none !important; }

        /* Entrance: fade + slide */
        .login-enter { animation: login-enter .55s cubic-bezier(.18,.89,.32,1.15) both; }
        .login-enter-stagger-1 { animation: login-enter .5s .08s cubic-bezier(.18,.89,.32,1.15) both; }
        .login-enter-stagger-2 { animation: login-enter .5s .15s cubic-bezier(.18,.89,.32,1.15) both; }
        @@keyframes login-enter {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: none; }
        }

        /* Brand panel: pulse no logo */
        .login-logo-pulse { animation: login-logo-pulse 3s ease-in-out infinite; }
        @@keyframes login-logo-pulse {
            0%, 100% { transform: scale(1); }
            50%      { transform: scale(1.04); }
        }

        /* Input: borda + glow ao focar; check verde quando email valido */
        .login-input-wrap { position: relative; }
        .login-input-valid {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%) scale(0);
            opacity: 0;
            width: 20px;
            height: 20px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: #10b981;
            color: #fff;
            transition: transform .2s cubic-bezier(.18,.89,.32,1.4), opacity .2s ease;
            pointer-events: none;
        }
        .login-input-valid--show { transform: translateY(-50%) scale(1); opacity: 1; }

        /* CapsLock badge */
        .login-caps {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            margin-top: 6px;
            font-size: 11px;
            font-weight: 600;
            color: #b45309;
            padding: 3px 8px;
            border-radius: 6px;
            background: rgba(254, 243, 199, .85);
            border: 1px solid rgba(245, 158, 11, .35);
            opacity: 0;
            transform: translateY(-4px);
            transition: opacity .2s ease, transform .2s ease;
            pointer-events: none;
        }
        .login-caps--show { opacity: 1; transform: none; }
        html.theme-dark .login-caps {
            background: rgba(120, 53, 15, .35);
            color: #fbbf24;
            border-color: rgba(217, 119, 6, .35);
        }

        /* Barra de progresso fina no submit */
        .login-progress {
            position: absolute;
            left: 0; right: 0; top: 0;
            height: 3px;
            border-radius: 3px 3px 0 0;
            overflow: hidden;
            background: rgba(99, 102, 241, .1);
            opacity: 0;
            transition: opacity .2s ease;
        }
        .login-progress--show { opacity: 1; }
        .login-progress::after {
            content: "";
            position: absolute;
            top: 0; left: 0; bottom: 0;
            width: 30%;
            background: linear-gradient(90deg, transparent, #4f46e5, transparent);
            animation: login-progress-slide 1.1s ease-in-out infinite;
        }
        @@keyframes login-progress-slide {
            from { left: -30%; }
            to   { left: 100%; }
        }

        /* Overlay de transicao mostrado quando a rede tarda — tom neutro,
           nunca afirma sucesso antes do servidor confirmar. */
        .login-success-overlay {
            position: fixed; inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 18px;
            background: rgba(15, 23, 42, .82);
            backdrop-filter: blur(8px);
            z-index: 100;
            opacity: 0;
            pointer-events: none;
            transition: opacity .25s ease;
        }
        .login-success-overlay--show { opacity: 1; pointer-events: auto; }
        .login-success-spinner {
            width: 56px; height: 56px;
            border-radius: 999px;
            border: 4px solid rgba(255, 255, 255, .18);
            border-top-color: #6366f1;
            animation: login-spinner-rot 1s linear infinite;
        }
        @@keyframes login-spinner-rot {
            to { transform: rotate(360deg); }
        }
        .login-success-text {
            color: #e2e8f0;
            font-size: 14px;
            font-weight: 500;
            text-align: center;
            max-width: 280px;
        }
        .login-success-text strong { color: #fff; font-weight: 700; display: block; font-size: 16px; margin-bottom: 2px; }
    </style>
</head>
<body class="h-full font-[Inter] antialiased min-h-screen" style="background-color:var(--app-bg);background-image:var(--app-bg-image);">
    <div class="auth-login-shell min-h-screen px-4 py-6 md:px-6 lg:px-8" x-data="loginForm()">
        <div class="auth-login-layout mx-auto w-full max-w-6xl overflow-hidden rounded-[2rem] border border-white/60 shadow-2xl shadow-slate-900/10 login-enter">
            <section class="auth-login-brand hidden lg:flex lg:flex-col lg:justify-between">
                <div>
                    <div class="inline-flex items-center gap-3 mb-6">
                        <span class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-white shadow-lg login-logo-pulse">
                            <svg width="36" height="36" viewBox="0 0 64 64" fill="none" aria-label="EasyStock">
                                <path d="M32 6 L56 18 L32 30 L8 18 Z" fill="#E85814"/>
                                <path d="M8 18 L32 30 L32 58 L8 46 Z" fill="#0E2A6E"/>
                                <path d="M56 18 L32 30 L32 58 L56 46 Z" fill="#06143A"/>
                            </svg>
                        </span>
                        <span class="text-3xl font-extrabold tracking-tight text-white" style="font-family:'Fraunces',serif;letter-spacing:-0.02em;">
                            <span>Easy</span><span style="color:#F26B25">Stok</span>
                        </span>
                    </div>
                    <p class="text-sm uppercase tracking-[0.35em] text-white/65 mb-4 login-enter-stagger-1">Operação em tempo real</p>
                    <h1 class="text-4xl font-extrabold leading-tight text-white max-w-md login-enter-stagger-1">Controle estoque, validade e saída em um fluxo mais claro.</h1>
                    <p class="mt-4 max-w-lg text-base leading-7 text-white/78 login-enter-stagger-2">Uma entrada mais alinhada ao restante do produto, com foco em rotina, leitura rápida e confiança para quem opera o dia inteiro.</p>
                </div>
                <div class="grid grid-cols-2 gap-3 text-sm text-white/78 login-enter-stagger-2">
                    <div class="auth-login-brand-stat">
                        <span class="auth-login-brand-stat__value">Visão</span>
                        <span class="auth-login-brand-stat__label">Dashboards, alertas e histórico num único lugar</span>
                    </div>
                    <div class="auth-login-brand-stat">
                        <span class="auth-login-brand-stat__value">Execução</span>
                        <span class="auth-login-brand-stat__label">Entradas e saídas com menos atrito operacional</span>
                    </div>
                </div>
            </section>

            <section class="auth-login-panel">
                <div class="w-full max-w-md mx-auto">
                    <div class="text-center mb-8 lg:text-left">
                        <div class="inline-flex items-center gap-3 mb-3 lg:hidden">
                            <span class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-white shadow-lg">
                                <svg width="36" height="36" viewBox="0 0 64 64" fill="none" aria-label="EasyStock">
                                    <path d="M32 6 L56 18 L32 30 L8 18 Z" fill="#E85814"/>
                                    <path d="M8 18 L32 30 L32 58 L8 46 Z" fill="#0E2A6E"/>
                                    <path d="M56 18 L32 30 L32 58 L56 46 Z" fill="#06143A"/>
                                </svg>
                            </span>
                            <span class="text-3xl font-extrabold tracking-tight auth-title" style="font-family:'Fraunces',serif;letter-spacing:-0.02em;">
                                <span>Easy</span><span style="color:#F26B25">Stok</span>
                            </span>
                        </div>
                        <p class="auth-subtitle text-sm mt-2" x-show="!returningUser" x-cloak>Acesse sua conta para continuar a operação</p>
                        <p class="auth-subtitle text-sm mt-2" x-show="returningUser" x-cloak>
                            Bem-vindo de volta<span x-show="emailHint" x-cloak>, <strong class="font-semibold" x-text="emailHint"></strong></span> 👋
                        </p>
                    </div>

            @if (sessionExpired)
            {
                <div class="auth-alert-warn text-sm rounded-xl px-4 py-3 mb-4 flex items-center gap-2 login-enter-stagger-1">
                    <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-11.25a.75.75 0 00-1.5 0v4.5a.75.75 0 001.5 0v-4.5zm-.75 7a.875.875 0 100-1.75.875.875 0 000 1.75z" clip-rule="evenodd"/>
                    </svg>
                    <span>Sua sessão expirou. Faça login novamente para continuar.</span>
                </div>
            }

            @if (apiUnavailable)
            {
                <div class="auth-alert-error text-sm rounded-xl px-4 py-3 mb-4 flex items-center gap-2 login-enter-stagger-1">
                    <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
                    </svg>
                    <span>Serviço temporariamente indisponível. Tente novamente em alguns instantes.</span>
                </div>
            }

                    <div class="auth-card rounded-3xl shadow-2xl p-8 relative login-enter-stagger-1">
                        <div class="login-progress" :class="loading ? 'login-progress--show' : ''" aria-hidden="true"></div>
                        <h1 class="text-xl font-bold auth-card-title mb-1">Entrar</h1>
                        <p class="auth-card-subtitle text-sm mb-6">Acesse sua conta para continuar</p>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="auth-alert-error text-sm rounded-lg px-4 py-3 mb-4 flex items-start gap-2">
                        <svg class="w-4 h-4 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/>
                        </svg>
                        <div>@Html.ValidationSummary(false, "", new { @class = "" })</div>
                    </div>
                }

                <form asp-action="Login" asp-controller="Auth" method="post" x-ref="form" @@submit.prevent="handleSubmit($event)">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <div class="mb-4">
                        <label asp-for="Email" class="block text-sm font-semibold auth-label mb-1.5">E-mail</label>
                        <div class="login-input-wrap">
                            <input asp-for="Email" type="email" autocomplete="email" required
                                   x-model="email"
                                   x-ref="emailInput"
                                   @@input="onEmailInput"
                                   class="auth-input w-full px-4 py-3 pr-11 rounded-xl text-sm focus:outline-none transition-all"
                                   placeholder="seu@email.com"
                                   :disabled="loading" />
                            <span class="login-input-valid" :class="emailValid ? 'login-input-valid--show' : ''" aria-hidden="true">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                                    <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </span>
                        </div>
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div class="mb-2">
                        <div class="flex items-center justify-between mb-1.5">
                            <label asp-for="Senha" class="block text-sm font-semibold auth-label">Senha</label>
                            <a href="/auth/esqueci-senha" class="text-xs text-indigo-500 hover:text-indigo-400">Esqueceu a senha?</a>
                        </div>
                        <div class="relative">
                            <input asp-for="Senha" autocomplete="current-password" required
                                   x-bind:type="showPass ? 'text' : 'password'"
                                   @@keyup="onPasswordKey($event)"
                                   @@keydown="onPasswordKey($event)"
                                   class="auth-input w-full px-4 py-3 pr-11 rounded-xl text-sm focus:outline-none transition-all"
                                   placeholder="Sua senha"
                                   :disabled="loading" />
                            <button type="button"
                                    @@click="showPass = !showPass"
                                    class="absolute inset-y-0 right-0 px-3 flex items-center auth-icon-btn transition-colors"
                                    tabindex="-1"
                                    :aria-label="showPass ? 'Ocultar senha' : 'Mostrar senha'">
                                <svg x-show="!showPass" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                                <svg x-show="showPass" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" x-cloak>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Senha" class="text-red-500 text-xs mt-1 block"></span>
                        <span class="login-caps" :class="capsOn ? 'login-caps--show' : ''" role="status">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                                <path d="M12 3l8 9h-5v6h-6v-6H4l8-9z" fill="currentColor"/>
                            </svg>
                            Caps Lock ativado
                        </span>
                    </div>

                    <div class="mt-4 mb-6">
                        <label for="ManterLogado" class="auth-check-control">
                            <input asp-for="ManterLogado" type="checkbox" id="ManterLogado"
                                   x-model="manterLogado"
                                   class="auth-checkbox sr-only peer" />
                            <span class="auth-check-indicator" aria-hidden="true">
                                <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none">
                                    <path d="M3.5 8.5L6.5 11.5L12.5 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </span>
                            <span class="text-sm auth-label cursor-pointer select-none">Manter-me conectado por 30 dias</span>
                        </label>
                    </div>

                    <button type="submit"
                            :disabled="loading"
                            class="w-full bg-indigo-600 hover:bg-indigo-700 disabled:bg-indigo-400 disabled:cursor-not-allowed text-white font-semibold py-3 rounded-xl transition-all text-sm flex items-center justify-center gap-2 shadow-lg shadow-indigo-500/25"
                            :class="loading ? 'scale-[.99]' : ''">
                        <svg x-show="loading" class="animate-spin h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" x-cloak>
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                        </svg>
                        <span x-text="loading ? 'Validando…' : 'Entrar'">Entrar</span>
                    </button>
                </form>
            </div>

                    <p class="text-center text-sm auth-subtitle mt-4 lg:text-left login-enter-stagger-2">
                Não tem conta?
                <a href="/auth/registrar" class="text-indigo-500 hover:text-indigo-400 font-medium">Criar conta grátis</a>
            </p>

                    <p class="text-center text-xs auth-footer mt-4 lg:text-left">
                &copy; @DateTime.Now.Year EasyStock. Todos os direitos reservados.
            </p>
                </div>
            </section>
        </div>

        <!-- Overlay de transicao: aparece apos ~700ms quando a rede ta lenta.
             Texto neutro porque nao temos confirmacao do servidor ainda. -->
        <div class="login-success-overlay" :class="successing ? 'login-success-overlay--show' : ''" x-cloak aria-hidden="true">
            <div class="login-success-spinner" aria-hidden="true"></div>
            <div class="login-success-text">
                <strong>Conectando…</strong>
                Validando suas credenciais e preparando o painel.
            </div>
        </div>
    </div>

    <script src="~/js/toast.js"></script>
    <script>
        function loginForm() {
            const STORAGE_EMAIL = 'easystock-login-email';
            const STORAGE_KEEP = 'easystock-login-manter';

            return {
                loading: false,
                showPass: false,
                email: '',
                emailValid: false,
                emailHint: '',
                returningUser: false,
                manterLogado: false,
                capsOn: false,
                successing: false,

                init() {
                    // Auto-preenche email salvo da ultima vez (so se nao tiver erro de validacao
                    // do servidor pre-renderizado, pra nao sobrescrever o que o usuario tentou).
                    const serverEmail = this.$refs.emailInput?.value || '';
                    if (!serverEmail) {
                        const saved = localStorage.getItem(STORAGE_EMAIL) || '';
                        if (saved) {
                            this.email = saved;
                            this.emailHint = saved.split('@@')[0]; // mostra so a parte antes do arroba
                            this.returningUser = true;
                        }
                    } else {
                        this.email = serverEmail;
                    }
                    this.emailValid = this.isValidEmail(this.email);

                    // Preferencia "manter conectado" tambem persiste
                    const keep = localStorage.getItem(STORAGE_KEEP);
                    if (keep === 'true') this.manterLogado = true;

                    // Foco inteligente: se tem email salvo, vai direto pra senha; senao no email.
                    this.$nextTick(() => {
                        if (this.email) {
                            const senha = document.querySelector('input[name="Senha"]');
                            senha?.focus();
                        } else {
                            this.$refs.emailInput?.focus();
                        }
                    });
                },

                isValidEmail(v) {
                    if (!v) return false;
                    // Validacao basica: tem arroba e ponto depois — suficiente pra ux, server valida
                    return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(v.trim());
                },

                onEmailInput() {
                    this.emailValid = this.isValidEmail(this.email);
                    this.returningUser = false; // assim que digita, some o "bem-vindo de volta"
                },

                onPasswordKey(e) {
                    // Detecta caps lock — funciona pra teclas alfabeticas
                    if (e.getModifierState) {
                        this.capsOn = e.getModifierState('CapsLock');
                    }
                },

                handleSubmit(e) {
                    if (this.loading) return;
                    const form = this.$refs.form;
                    if (!form.checkValidity()) {
                        form.reportValidity();
                        return;
                    }

                    // Persiste preferencias localmente ANTES de submeter — se o login falhar,
                    // ao recarregar pelo menos o operador ja tem email preenchido.
                    try {
                        if (this.email) localStorage.setItem(STORAGE_EMAIL, this.email);
                        localStorage.setItem(STORAGE_KEEP, this.manterLogado ? 'true' : 'false');
                    } catch { /* localStorage off / privado */ }

                    this.loading = true;
                    // Overlay de transicao so aparece se a rede tardar > 800ms.
                    // Em rede rapida, o navegador ja redirecionou e o overlay nem mostra.
                    setTimeout(() => {
                        if (this.loading) this.successing = true;
                    }, 800);
                    form.submit();
                }
            };
        }
    </script>
</body>
</html>
