@model RegisterViewModel
@{
    Layout = null;
    ViewBag.Title = "Criar conta";
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Criar conta �� EasyStock</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/app.css" />
</head>
<body class="bg-slate-100 font-[Inter] antialiased py-8">
    <div class="w-full max-w-lg mx-auto px-4">
        <!-- Logo -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center gap-2 mb-2">
                <span class="text-4xl">📦</span>
                <span class="text-3xl font-extrabold text-slate-900 tracking-tight">EasyStock</span>
            </div>
            <p class="text-slate-500 text-sm">Comece a gerenciar seu estoque gratuitamente</p>
        </div>

        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-8">
            <h1 class="text-xl font-bold text-slate-900 mb-1">Criar sua conta</h1>
            <p class="text-slate-500 text-sm mb-6">Preencha os dados da sua empresa para começar.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 mb-4">
                    @Html.ValidationSummary(false, "", new { @class = "" })
                </div>
            }

            <form asp-action="Registrar" asp-controller="Auth" method="post">
                @Html.AntiForgeryToken()

                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-3">Sua Empresa</p>

                <div class="space-y-3 mb-5">
                    <div>
                        <label asp-for="NomeEmpresa" class="block text-sm font-semibold text-slate-700 mb-1.5">
                            Nome da empresa *
                        </label>
                        <input asp-for="NomeEmpresa" type="text" autocomplete="organization"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                               placeholder="Ex: Minha Loja Ltda" />
                        <span asp-validation-for="NomeEmpresa" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Documento" class="block text-sm font-semibold text-slate-700 mb-1.5">
                            CNPJ / CPF
                            <span class="text-slate-400 font-normal">(opcional)</span>
                        </label>
                        <input asp-for="Documento" type="text"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                               placeholder="00.000.000/0001-00" />
                    </div>
                </div>

                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-3">Administrador</p>

                <div class="space-y-3 mb-6">
                    <div>
                        <label asp-for="NomeAdmin" class="block text-sm font-semibold text-slate-700 mb-1.5">Seu nome *</label>
                        <input asp-for="NomeAdmin" type="text" autocomplete="name"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                               placeholder="Nome completo" />
                        <span asp-validation-for="NomeAdmin" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Email" class="block text-sm font-semibold text-slate-700 mb-1.5">E-mail *</label>
                        <input asp-for="Email" type="email" autocomplete="email"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                               placeholder="seu@email.com" />
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Senha" class="block text-sm font-semibold text-slate-700 mb-1.5">Senha *</label>
                        <input asp-for="Senha" type="password" autocomplete="new-password"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                               placeholder="Mínimo 8 caracteres" />
                        <span asp-validation-for="Senha" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="ConfirmarSenha" class="block text-sm font-semibold text-slate-700 mb-1.5">Confirmar senha *</label>
                        <input asp-for="ConfirmarSenha" type="password" autocomplete="new-password"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                               placeholder="Repita a senha" />
                        <span asp-validation-for="ConfirmarSenha" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <button type="submit"
                        class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2.5 rounded-lg transition-colors text-sm">
                    Criar conta grátis
                </button>
            </form>
        </div>

        <p class="text-center text-sm text-slate-500 mt-4">
            Já tem uma conta?
            <a href="/auth/login" class="text-indigo-600 hover:text-indigo-700 font-medium">Entrar</a>
        </p>

        <p class="text-center text-xs text-slate-400 mt-3">
            &copy; @DateTime.Now.Year EasyStock. Todos os direitos reservados.
        </p>
    </div>
    <script src="~/js/toast.js"></script>
</body>
</html>
