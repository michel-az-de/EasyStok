@model RegisterViewModel
@{
    Layout = null;
    ViewBag.Title = "Criar conta";
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Criar conta — EasyStock</title>
    <!-- tailwind: build local em ~/css/tailwind.dist.css -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.dist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body class="bg-slate-100 font-[Inter] antialiased py-8">
    <div class="w-full max-w-lg mx-auto px-4">
        <!-- Logo -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center gap-2 mb-2">
                <svg width="40" height="40" viewBox="0 0 64 64" fill="none" aria-label="EasyStock">
                    <path d="M32 6 L56 18 L32 30 L8 18 Z" fill="#E85814"/>
                    <path d="M8 18 L32 30 L32 58 L8 46 Z" fill="#0E2A6E"/>
                    <path d="M56 18 L32 30 L32 58 L56 46 Z" fill="#06143A"/>
                </svg>
                <span class="text-3xl font-extrabold tracking-tight" style="font-family:'Fraunces',serif;letter-spacing:-0.02em;color:#0A1530;"><span>Easy</span><span style="color:#E85814">Stok</span></span>
            </div>
            <p class="text-slate-500 text-sm">Comece a gerenciar seu estoque gratuitamente</p>
        </div>

        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-8">
            <h1 class="text-xl font-bold text-slate-900 mb-1">Criar sua conta</h1>
            <p class="text-slate-500 text-sm mb-6">Preencha os dados da sua empresa para começar.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 mb-4">
                    @Html.ValidationSummary(false, "", new { @class = "" })
                </div>
            }

            <form asp-action="Registrar" asp-controller="Auth" method="post"
                  x-data="{ loading: false }" @@submit="loading = true">
                @Html.AntiForgeryToken()

                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-3">Sua Empresa</p>

                <div class="space-y-3 mb-5">
                    <div>
                        <label asp-for="NomeEmpresa" class="block text-sm font-semibold text-slate-700 mb-1.5">
                            Nome da empresa *
                        </label>
                        <input asp-for="NomeEmpresa" type="text" autocomplete="organization"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                               placeholder="Ex: Minha Loja Ltda" />
                        <span asp-validation-for="NomeEmpresa" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Documento" class="block text-sm font-semibold text-slate-700 mb-1.5">
                            CNPJ / CPF
                            <span class="text-slate-400 font-normal">(opcional)</span>
                        </label>
                        <input asp-for="Documento" id="reg-doc" type="text"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                               placeholder="00.000.000/0001-00" />
                        <p id="reg-doc-msg" class="text-xs mt-1 hidden"></p>
                    </div>
                </div>

                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-3">Administrador</p>

                <div class="space-y-3 mb-6">
                    <div>
                        <label asp-for="NomeAdmin" class="block text-sm font-semibold text-slate-700 mb-1.5">Seu nome *</label>
                        <input asp-for="NomeAdmin" type="text" autocomplete="name"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                               placeholder="Nome completo" />
                        <span asp-validation-for="NomeAdmin" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Email" class="block text-sm font-semibold text-slate-700 mb-1.5">E-mail *</label>
                        <input asp-for="Email" id="reg-email" type="email" autocomplete="email"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                               placeholder="seu@email.com" />
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                        <p id="reg-email-msg" class="text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <label asp-for="Senha" class="block text-sm font-semibold text-slate-700 mb-1.5">Senha *</label>
                        <input asp-for="Senha" type="password" autocomplete="new-password" minlength="8" required
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                               placeholder="Mínimo 8 caracteres" />
                        <span asp-validation-for="Senha" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="ConfirmarSenha" class="block text-sm font-semibold text-slate-700 mb-1.5">Confirmar senha *</label>
                        <input asp-for="ConfirmarSenha" type="password" autocomplete="new-password" minlength="8" required
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                               placeholder="Repita a senha" />
                        <span asp-validation-for="ConfirmarSenha" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <button type="submit"
                        :disabled="loading"
                        :class="loading ? 'opacity-60 cursor-not-allowed' : ''"
                        class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2.5 rounded-lg transition-colors text-sm flex items-center justify-center gap-2">
                    <span x-show="!loading">Criar conta grátis</span>
                    <span x-show="loading" x-cloak class="flex items-center gap-2">
                        <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                        </svg>
                        Criando…
                    </span>
                </button>
            </form>
        </div>

        <p class="text-center text-sm text-slate-500 mt-4">
            Já tem uma conta?
            <a href="/auth/login" class="text-indigo-600 hover:text-indigo-700 font-medium">Entrar</a>
        </p>

        <p class="text-center text-xs text-slate-400 mt-3">
            &copy; @DateTime.Now.Year EasyStock. Todos os direitos reservados.
        </p>
    </div>
    <script src="~/js/toast.js"></script>
    <script>
    (function () {
        function debounce(fn, ms) {
            var t; return function () { clearTimeout(t); var a = arguments, c = this; t = setTimeout(function () { fn.apply(c, a); }, ms); };
        }
        function show(el, ok, msg) {
            if (!el) return;
            el.classList.remove('hidden', 'text-green-600', 'text-red-500');
            el.classList.add(ok ? 'text-green-600' : 'text-red-500');
            el.textContent = msg;
        }
        function check(url, valEl, msgEl, msgOk, msgFail) {
            if (!valEl || !msgEl) return;
            var v = (valEl.value || '').trim();
            if (!v) { msgEl.classList.add('hidden'); return; }
            fetch(url + encodeURIComponent(v), { credentials: 'same-origin' })
                .then(function (r) { return r.ok ? r.json() : null; })
                .then(function (json) {
                    if (!json || !json.data) return;
                    show(msgEl, json.data.disponivel, json.data.disponivel ? msgOk : msgFail);
                })
                .catch(function () { /* silencia */ });
        }
        var email = document.getElementById('reg-email');
        var emailMsg = document.getElementById('reg-email-msg');
        if (email) email.addEventListener('blur', debounce(function () {
            check('/api/empresas/email-disponivel?email=', email, emailMsg, 'Email disponivel.', 'Email ja cadastrado.');
        }, 200));
        var doc = document.getElementById('reg-doc');
        var docMsg = document.getElementById('reg-doc-msg');
        if (doc) doc.addEventListener('blur', debounce(function () {
            check('/api/empresas/cnpj-disponivel?doc=', doc, docMsg, 'CNPJ/CPF disponivel.', 'CNPJ/CPF ja em uso.');
        }, 200));
    })();
    </script>
</body>
</html>
