@model RegisterViewModel
@{
    Layout = null;
    ViewBag.Title = "Criar conta";
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Criar conta — EasyStok</title>
    <script>
        (function () {
            const stored = localStorage.getItem('easystock-theme');
            const theme = stored === 'dark' || stored === 'light' ? stored : 'light';
            document.documentElement.dataset.theme = theme;
            document.documentElement.classList.toggle('theme-dark', theme === 'dark');
        })();
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js" integrity="sha384-l8f0VcPi/M1iHPv8egOnY/15TDwqgbOR1anMIJWvU6nLRgZVLTLSaNqi/TOoT5Fh" crossorigin="anonymous"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.dist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth-premium.css" asp-append-version="true" />
    <style>
        [x-cloak] { display: none !important; }
        .registrar-card-wide { max-width: 520px; }
    </style>
</head>
<body class="font-[Inter] antialiased">
    <div class="auth-prem-shell" x-data="registrarForm()">
        <div class="auth-prem-layout auth-prem-enter">

            <!-- ============ BRAND PANEL ============ -->
            <section class="auth-prem-brand">
                <div>
                    <div class="auth-prem-wordmark">
                        <div class="auth-prem-cube" aria-hidden="true">
                            <svg viewBox="0 0 64 64" fill="none">
                                <path d="M32 6 L56 18 L32 30 L8 18 Z" style="fill:var(--orange-600)"/>
                                <path d="M8 18 L32 30 L32 58 L8 46 Z" style="fill:var(--navy-700)"/>
                                <path d="M56 18 L32 30 L32 58 L56 46 Z" style="fill:var(--navy-900)"/>
                            </svg>
                        </div>
                        <span class="auth-prem-wordmark-text">Easy<span class="stok">Stok</span></span>
                    </div>

                    <p class="auth-prem-eyebrow">TRIAL · 14 DIAS · SEM CARTÃO</p>

                    <h1 class="auth-prem-headline">Comece em 3 minutos. Sem cartão.</h1>
                    <p class="auth-prem-lede">Cadastre sua empresa, configure sua primeira loja e comece a operar no mesmo dia.</p>

                    <ul class="auth-prem-bullets" style="margin-top: 28px;">
                        <li class="auth-prem-bullet">
                            <span class="auth-prem-bullet-mark">✓</span>
                            <span>Cadastro do estoque guiado, passo a passo</span>
                        </li>
                        <li class="auth-prem-bullet">
                            <span class="auth-prem-bullet-mark">✓</span>
                            <span>Equipe inteira inclusa no plano trial</span>
                        </li>
                        <li class="auth-prem-bullet">
                            <span class="auth-prem-bullet-mark">✓</span>
                            <span>Sem cobrança até você decidir continuar</span>
                        </li>
                    </ul>
                </div>

                <div class="auth-prem-brand-bottom">
                    PRIMEIRO ACESSO · v2026
                </div>
            </section>

            <!-- ============ FORM PANEL ============ -->
            <section class="auth-prem-panel">
                <div class="auth-prem-card auth-prem-enter-2 registrar-card-wide">

                    <h2 class="auth-prem-card-title">Sua conta gratuita</h2>
                    <p class="auth-prem-card-subtitle">Em 3 minutos você já está operando.</p>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="auth-prem-alert auth-prem-alert--error" role="alert" aria-live="assertive">
                            <svg class="auth-prem-alert-icon" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/>
                            </svg>
                            <div>@Html.ValidationSummary(false, "", new { @class = "" })</div>
                        </div>
                    }

                    <form asp-action="Registrar" asp-controller="Auth" method="post"
                          x-ref="form"
                          :aria-busy="loading ? 'true' : 'false'"
                          @@submit="handleSubmit">
                        @Html.AntiForgeryToken()

                        <p class="auth-prem-eyebrow" style="color: var(--text-muted); letter-spacing: 0.18em; margin: 4px 0 12px;">Sua Empresa</p>

                        <div class="auth-prem-field">
                            <label asp-for="NomeEmpresa" class="auth-prem-field-label">Nome da empresa *</label>
                            <input asp-for="NomeEmpresa" type="text" autocomplete="organization" required maxlength="150"
                                   class="auth-prem-input"
                                   placeholder="Ex: Minha Loja Ltda"
                                   :disabled="loading" />
                            <span asp-validation-for="NomeEmpresa" class="auth-prem-field-error"></span>
                        </div>

                        <div class="auth-prem-field">
                            <label asp-for="Documento" class="auth-prem-field-label">
                                CNPJ / CPF <span style="color: var(--text-muted); font-weight: 400;">(opcional)</span>
                            </label>
                            <div class="auth-prem-input-wrap">
                                <input asp-for="Documento" id="reg-doc" type="text" maxlength="30"
                                       class="auth-prem-input"
                                       placeholder="00.000.000/0001-00"
                                       :disabled="loading"
                                       @@blur="checkDoc"
                                       x-model="documento" />
                                <span x-show="docChecking" x-cloak class="auth-prem-spinner-inline" aria-hidden="true"></span>
                            </div>
                            <span class="auth-prem-field-help">Usado em notas fiscais. Você pode adicionar depois.</span>
                            <span class="auth-prem-inline-feedback"
                                  :class="docOk === true ? 'auth-prem-inline-feedback--ok' : 'auth-prem-inline-feedback--err'"
                                  x-show="docOk !== null && !docChecking" x-cloak
                                  x-text="docOk ? 'CNPJ/CPF disponível.' : 'CNPJ/CPF já em uso.'"></span>
                        </div>

                        <p class="auth-prem-eyebrow" style="color: var(--text-muted); letter-spacing: 0.18em; margin: 22px 0 12px;">Seu acesso</p>

                        <div class="auth-prem-field">
                            <label asp-for="NomeAdmin" class="auth-prem-field-label">Seu nome *</label>
                            <input asp-for="NomeAdmin" type="text" autocomplete="name" required maxlength="100"
                                   class="auth-prem-input"
                                   placeholder="Nome completo"
                                   :disabled="loading" />
                            <span asp-validation-for="NomeAdmin" class="auth-prem-field-error"></span>
                        </div>

                        <div class="auth-prem-field">
                            <label asp-for="Email" class="auth-prem-field-label">E-mail *</label>
                            <div class="auth-prem-input-wrap">
                                <input asp-for="Email" id="reg-email" type="email" autocomplete="email" required
                                       class="auth-prem-input"
                                       placeholder="seu@email.com"
                                       :disabled="loading"
                                       @@blur="checkEmail"
                                       x-model="emailVal" />
                                <span x-show="emailChecking" x-cloak class="auth-prem-spinner-inline" aria-hidden="true"></span>
                            </div>
                            <span asp-validation-for="Email" class="auth-prem-field-error"></span>
                            <span class="auth-prem-inline-feedback"
                                  :class="emailOk === true ? 'auth-prem-inline-feedback--ok' : 'auth-prem-inline-feedback--err'"
                                  x-show="emailOk !== null && !emailChecking" x-cloak
                                  x-text="emailOk ? 'E-mail disponível.' : 'E-mail já cadastrado.'"></span>
                        </div>

                        <div class="auth-prem-field">
                            <label asp-for="Senha" class="auth-prem-field-label">Senha *</label>
                            <div class="auth-prem-input-wrap">
                                <input asp-for="Senha" type="password" autocomplete="new-password" minlength="8" required
                                       x-model="senha"
                                       @@input="onSenhaInput"
                                       class="auth-prem-input"
                                       placeholder="Mínimo 8 caracteres"
                                       :disabled="loading" />
                            </div>
                            <div class="auth-prem-strength" :data-level="senhaLevel" aria-hidden="true">
                                <span class="auth-prem-strength-bar"></span>
                                <span class="auth-prem-strength-bar"></span>
                                <span class="auth-prem-strength-bar"></span>
                                <span class="auth-prem-strength-bar"></span>
                            </div>
                            <span class="auth-prem-strength-label" :data-level="senhaLevel" x-text="senhaLabel" x-show="senha.length > 0" x-cloak></span>
                            <span class="auth-prem-field-help" x-show="senha.length === 0">Use letras, números e símbolos para uma senha forte.</span>
                            <span asp-validation-for="Senha" class="auth-prem-field-error"></span>
                        </div>

                        <div class="auth-prem-field">
                            <label asp-for="ConfirmarSenha" class="auth-prem-field-label">Confirmar senha *</label>
                            <div class="auth-prem-input-wrap">
                                <input asp-for="ConfirmarSenha" type="password" autocomplete="new-password" minlength="8" required
                                       x-model="senhaConf"
                                       class="auth-prem-input auth-prem-input--with-icon-right"
                                       placeholder="Repita a senha"
                                       :disabled="loading" />
                                <span class="auth-prem-input-check"
                                      :class="senhaConf.length > 0 && senhaConf === senha ? 'is-show' : ''"
                                      aria-hidden="true">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                                        <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </span>
                            </div>
                            <span asp-validation-for="ConfirmarSenha" class="auth-prem-field-error"></span>
                        </div>

                        <button type="submit"
                                :disabled="loading"
                                :aria-busy="loading ? 'true' : 'false'"
                                class="auth-prem-launch"
                                style="margin-top: 8px;">
                            <span x-show="!loading">Começar agora</span>
                            <span x-show="loading" x-cloak style="display: inline-flex; align-items: center; gap: 10px;">
                                <span class="auth-prem-launch-spinner" aria-hidden="true"></span>
                                Criando…
                            </span>
                            <span class="auth-prem-launch-arrow" aria-hidden="true">→</span>
                        </button>
                    </form>

                    <p class="auth-prem-footer" style="margin-top: 22px;">
                        Já tem conta?
                        <a href="/auth/login" class="auth-prem-link">Entrar</a>
                    </p>
                    <p class="auth-prem-footer" style="margin-top: 6px;">
                        &copy; @DateTime.Now.Year EasyStok · Todos os direitos reservados
                    </p>
                </div>
            </section>
        </div>
    </div>

    <script src="~/js/toast.js"></script>
    <script>
        function registrarForm() {
            return {
                loading: false,
                senha: '',
                senhaConf: '',
                senhaLevel: 0,
                senhaLabel: '',
                emailVal: '',
                emailOk: null,
                emailChecking: false,
                documento: '',
                docOk: null,
                docChecking: false,

                onSenhaInput() {
                    const v = this.senha || '';
                    let score = 0;
                    if (v.length >= 8) score++;
                    if (/[A-Z]/.test(v) && /[a-z]/.test(v)) score++;
                    if (/\d/.test(v)) score++;
                    if (/[^A-Za-z0-9]/.test(v)) score++;
                    this.senhaLevel = score;
                    this.senhaLabel = ['Muito curta', 'Fraca', 'Razoável', 'Boa', 'Forte'][score];
                },

                async checkEmail() {
                    const v = (this.emailVal || '').trim();
                    if (!v || !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(v)) {
                        this.emailOk = null;
                        return;
                    }
                    this.emailChecking = true;
                    try {
                        const r = await fetch('/api/empresas/email-disponivel?email=' + encodeURIComponent(v), { credentials: 'same-origin' });
                        if (!r.ok) { this.emailOk = null; return; }
                        const json = await r.json();
                        this.emailOk = !!(json && json.data && json.data.disponivel);
                    } catch (e) {
                        this.emailOk = null;
                    } finally {
                        this.emailChecking = false;
                    }
                },

                async checkDoc() {
                    const v = (this.documento || '').trim();
                    if (!v) { this.docOk = null; return; }
                    this.docChecking = true;
                    try {
                        const r = await fetch('/api/empresas/cnpj-disponivel?doc=' + encodeURIComponent(v), { credentials: 'same-origin' });
                        if (!r.ok) { this.docOk = null; return; }
                        const json = await r.json();
                        this.docOk = !!(json && json.data && json.data.disponivel);
                    } catch (e) {
                        this.docOk = null;
                    } finally {
                        this.docChecking = false;
                    }
                },

                handleSubmit() {
                    if (this.loading) return;
                    this.loading = true;
                    // form segue submit normal
                }
            };
        }
    </script>
</body>
</html>
