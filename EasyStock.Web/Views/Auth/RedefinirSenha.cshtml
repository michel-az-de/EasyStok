@model ResetPasswordViewModel
@{
    Layout = null;
    ViewBag.Title = "Redefinir senha";
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redefinir senha - EasyStock</title>
    <!-- tailwind: build local em ~/css/tailwind.dist.css -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.dist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body class="h-full bg-slate-100 font-[Inter] antialiased flex items-center justify-center min-h-screen">
    <div class="w-full max-w-sm mx-auto px-4">
        <div class="text-center mb-8">
            <partial name="_LogoEasyStock" model='new { Size = 40, Variant = "auth" }' />
            <p class="text-slate-500 text-sm mt-3">Redefinição de senha</p>
        </div>

        <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-8">
            <h1 class="text-xl font-bold text-slate-900 mb-1">Criar nova senha</h1>
            <p class="text-slate-500 text-sm mb-6">Escolha uma senha forte com ao menos 8 caracteres.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 mb-4">
                    @Html.ValidationSummary(false, "", new { @class = "" })
                </div>
            }

            <form asp-action="RedefinirSenha" asp-controller="Auth" method="post"
                  x-data="{ loading: false }" @@submit="loading = true">
                @Html.AntiForgeryToken()
                <input asp-for="Token" type="hidden" />

                <div class="mb-4">
                    <label asp-for="NovaSenha" class="block text-sm font-semibold text-slate-700 mb-1.5">Nova senha</label>
                    <input asp-for="NovaSenha" type="password" autocomplete="new-password" minlength="8" required
                           class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                           placeholder="Mínimo 8 caracteres" />
                    <span asp-validation-for="NovaSenha" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="mb-6">
                    <label asp-for="ConfirmarSenha" class="block text-sm font-semibold text-slate-700 mb-1.5">Confirmar nova senha</label>
                    <input asp-for="ConfirmarSenha" type="password" autocomplete="new-password" minlength="8" required
                           class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all"
                           placeholder="Repita a senha" />
                    <span asp-validation-for="ConfirmarSenha" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <button type="submit"
                        :disabled="loading"
                        :class="loading ? 'opacity-60 cursor-not-allowed' : ''"
                        class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2.5 rounded-lg transition-colors text-sm flex items-center justify-center gap-2">
                    <span x-show="!loading">Redefinir senha</span>
                    <span x-show="loading" x-cloak class="flex items-center gap-2">
                        <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                        </svg>
                        Redefinindo…
                    </span>
                </button>
            </form>
        </div>

        <p class="text-center text-xs text-slate-400 mt-6">
            &copy; @DateTime.Now.Year EasyStock. Todos os direitos reservados.
        </p>
    </div>
</body>
</html>
