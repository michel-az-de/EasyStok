@model List<Loja>
@{
    Layout = null;
    ViewBag.Title = "Selecionar Loja";
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Selecionar Loja — EasyStock</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/app.css" />
</head>
<body class="h-full bg-slate-100 font-[Inter] antialiased flex items-center justify-center min-h-screen">
    <div class="w-full max-w-lg mx-auto px-4">
        <div class="text-center mb-8">
            <span class="text-4xl">🏪</span>
            <h1 class="text-2xl font-extrabold text-slate-900 mt-2">Selecione sua loja</h1>
            <p class="text-slate-500 text-sm mt-1">Escolha qual loja você deseja gerenciar agora</p>
        </div>

        <div class="grid gap-3">
            @foreach (var loja in Model)
            {
                <form asp-action="SelecionarLoja" asp-controller="Auth" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="lojaId" value="@loja.Id" />
                    <input type="hidden" name="lojaNome" value="@loja.Nome" />
                    <input type="hidden" name="lojaEmoji" value="@loja.Emoji" />
                    <button type="submit"
                            class="w-full bg-white hover:bg-indigo-50 border border-slate-200 hover:border-indigo-300 rounded-xl p-5 text-left flex items-center gap-4 transition-all shadow-sm group">
                        <span class="text-3xl">@(loja.Emoji ?? "🏪")</span>
                        <div>
                            <div class="font-bold text-slate-900 group-hover:text-indigo-700">@loja.Nome</div>
                            <div class="text-slate-500 text-sm">@loja.Cidade · @loja.Plano</div>
                        </div>
                        <svg class="ml-auto w-5 h-5 text-slate-300 group-hover:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </button>
                </form>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="bg-white rounded-xl border border-slate-200 p-8 text-center">
                <p class="text-slate-500">Nenhuma loja encontrada para este usuário.</p>
                <a href="/auth/logout" class="text-indigo-600 text-sm font-semibold mt-2 inline-block hover:underline">Fazer logout</a>
            </div>
        }
    </div>
</body>
</html>
