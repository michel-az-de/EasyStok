@model List<Loja>
@{
    Layout = null;
    ViewBag.Title = "Selecionar Loja";
    var podeCriarLoja = ViewBag.PodeCriarLoja == true;
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Selecionar Loja - EasyStok</title>
    <script>
        (function () {
            const stored = localStorage.getItem('easystock-theme');
            const theme = stored === 'dark' || stored === 'light' ? stored : 'light';
            document.documentElement.dataset.theme = theme;
            document.documentElement.classList.toggle('theme-dark', theme === 'dark');
        })();
    </script>
    <!-- tailwind: build local em ~/css/tailwind.dist.css (config em tailwind.config.js) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.dist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js" integrity="sha384-l8f0VcPi/M1iHPv8egOnY/15TDwqgbOR1anMIJWvU6nLRgZVLTLSaNqi/TOoT5Fh" crossorigin="anonymous"></script>
    <style>[x-cloak]{display:none!important}</style>
</head>
<body class="h-full font-[Inter] antialiased flex items-center justify-center min-h-screen" style="background-color:var(--app-bg);background-image:var(--app-bg-image);">
    <div class="w-full max-w-lg mx-auto px-4">
        <div class="text-center mb-8">
            <es-icon name="store" class="w-10 h-10 mx-auto" style="color: var(--orange-600);"></es-icon>
            <h1 class="text-2xl font-extrabold auth-title mt-2">
                @(Model.Any() ? "Selecione sua loja" : "Cadastre sua primeira loja")
            </h1>
            <p class="auth-subtitle text-sm mt-1">
                @(Model.Any() ? "Escolha qual loja você deseja gerenciar agora" : "Você precisa de pelo menos uma loja vinculada para começar a usar o sistema")
            </p>
        </div>

        @if (Model.Any())
        {
            <div class="grid gap-3">
                @foreach (var loja in Model)
                {
                    <form asp-action="SelecionarLoja" asp-controller="Auth" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="lojaId" value="@loja.Id" />
                        <input type="hidden" name="lojaNome" value="@loja.Nome" />
                        <input type="hidden" name="lojaEmoji" value="@loja.Emoji" />
                        <input type="hidden" name="empresaId" value="@loja.EmpresaId" />
                        <button type="submit" class="auth-loja-card w-full rounded-xl p-5 text-left flex items-center gap-4 transition-all shadow-sm group">
                            <span class="text-3xl">@(loja.Emoji ?? "🏪")</span>
                            <div>
                                <div class="font-bold auth-card-title group-hover:text-indigo-500 transition-colors">@loja.Nome</div>
                                <div class="auth-card-subtitle text-sm">@loja.Cidade · @loja.Plano</div>
                            </div>
                            <svg class="ml-auto w-5 h-5 auth-icon-muted group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </button>
                    </form>
                }
            </div>
        }
        else if (podeCriarLoja)
        {
            <div class="auth-card rounded-xl p-6"
                 x-data="{
                     emoji: '🏪',
                     nome: '',
                     cidade: '',
                     telefone: '',
                     emojis: ['🏪','🛒','🏬','🛍️','🏭','📦','🍔','☕','🍕','💊','💄','📚','🔧','🐾','🌱','💼','🚗','⚽'],
                     get nomeOk() { return this.nome.trim().length >= 2 && this.nome.trim().length <= 80; },
                     get telefoneOk() { return !this.telefone || /^[0-9()+\-\s]{8,20}$/.test(this.telefone); },
                     get podeEnviar() { return this.nomeOk && this.telefoneOk; }
                 }">
                <div class="flex items-start gap-3 mb-4 p-3 rounded-lg auth-info-banner">
                    <es-icon name="info" class="w-5 h-5 flex-shrink-0 mt-0.5 auth-info-banner__icon"></es-icon>
                    <p class="text-xs auth-card-subtitle leading-relaxed">
                        Para começar, configure sua primeira loja. Esta etapa é obrigatória, você poderá editar depois ou cadastrar mais lojas em <strong>Configurações &rarr; Lojas</strong>.
                    </p>
                </div>

                <form asp-action="Criar" asp-controller="Lojas" method="post" class="space-y-4"
                      @@submit="if (!podeEnviar) { $event.preventDefault(); }">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="emoji" :value="emoji" />

                    <!-- Emoji picker -->
                    <div>
                        <label class="block text-sm font-semibold auth-card-title mb-1.5">Identidade visual</label>
                        <div class="flex flex-wrap gap-1.5">
                            <template x-for="e in emojis" :key="e">
                                <button type="button" @@click="emoji = e"
                                        :class="emoji === e ? 'bg-indigo-100 ring-2 ring-indigo-400' : 'bg-slate-50 hover:bg-slate-100'"
                                        class="w-9 h-9 rounded-lg text-lg leading-none flex items-center justify-center transition">
                                    <span x-text="e"></span>
                                </button>
                            </template>
                        </div>
                    </div>

                    <!-- Nome -->
                    <div>
                        <label for="nome" class="block text-sm font-semibold auth-card-title mb-1">
                            Nome da loja <span class="text-red-500">*</span>
                        </label>
                        <input id="nome" name="nome" type="text" required maxlength="80" autofocus
                               x-model="nome"
                               placeholder="Ex.: Matriz Centro"
                               class="w-full px-3 py-2.5 rounded-lg border focus:ring-2 focus:ring-indigo-200 outline-none transition"
                               :class="(nome.length > 0 && !nomeOk) ? 'border-red-300 focus:border-red-500' : 'border-slate-300 focus:border-indigo-500'" />
                        <p x-show="nome.length > 0 && !nomeOk" x-cloak class="text-xs text-red-600 mt-1">
                            O nome deve ter entre 2 e 80 caracteres.
                        </p>
                    </div>

                    <!-- Cidade -->
                    <div>
                        <label for="cidade" class="block text-sm font-semibold auth-card-title mb-1">Cidade <span class="text-slate-400 font-normal">(opcional)</span></label>
                        <input id="cidade" name="cidade" type="text" maxlength="120"
                               x-model="cidade"
                               placeholder="Ex.: São Paulo, SP"
                               class="w-full px-3 py-2.5 rounded-lg border border-slate-300 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none transition" />
                    </div>

                    <!-- Telefone -->
                    <div>
                        <label for="telefone" class="block text-sm font-semibold auth-card-title mb-1">Telefone de contato <span class="text-slate-400 font-normal">(opcional)</span></label>
                        <input id="telefone" name="telefone" type="tel" maxlength="20"
                               x-model="telefone"
                               placeholder="(11) 90000-0000"
                               class="w-full px-3 py-2.5 rounded-lg border focus:ring-2 focus:ring-indigo-200 outline-none transition"
                               :class="(telefone.length > 0 && !telefoneOk) ? 'border-red-300 focus:border-red-500' : 'border-slate-300 focus:border-indigo-500'" />
                        <p x-show="telefone.length > 0 && !telefoneOk" x-cloak class="text-xs text-red-600 mt-1">
                            Telefone inválido — use apenas dígitos, espaços e ( ) + -.
                        </p>
                    </div>

                    <button type="submit"
                            :disabled="!podeEnviar"
                            :class="podeEnviar ? 'bg-indigo-600 hover:bg-indigo-700 text-white' : 'bg-slate-200 text-slate-400 cursor-not-allowed'"
                            class="w-full font-semibold py-2.5 rounded-lg transition-colors">
                        Criar loja e continuar
                    </button>
                </form>

                <form asp-action="Logout" asp-controller="Auth" method="post" class="mt-3 text-center">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="text-xs auth-card-subtitle hover:underline">Sair desta conta</button>
                </form>
            </div>
        }
        else
        {
            <div class="auth-card rounded-xl p-8 text-center">
                <svg class="w-12 h-12 mx-auto mb-3 auth-icon-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                <p class="auth-card-title font-semibold mb-1">Nenhuma loja vinculada à sua conta</p>
                <p class="auth-card-subtitle text-sm mb-4">
                    Você não tem permissão para criar lojas. Solicite ao administrador da sua empresa que vincule sua conta a uma loja existente.
                </p>
                <form asp-action="Logout" asp-controller="Auth" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="text-indigo-500 text-sm font-semibold hover:underline">Fazer logout</button>
                </form>
            </div>
        }
    </div>
</body>
</html>
