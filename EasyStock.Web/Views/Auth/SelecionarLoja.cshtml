@model List<Loja>
@{
    Layout = null;
    ViewBag.Title = "Selecionar Loja";
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Selecionar Loja — EasyStock</title>
    <script>
        (function () {
            const stored = localStorage.getItem('easystock-theme');
            const theme = stored === 'dark' || stored === 'light' ? stored : 'light';
            document.documentElement.dataset.theme = theme;
            document.documentElement.classList.toggle('theme-dark', theme === 'dark');
        })();
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { darkMode: 'class' };
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/app.css" />
</head>
<body class="h-full font-[Inter] antialiased flex items-center justify-center min-h-screen" style="background-color:var(--app-bg);background-image:var(--app-bg-image);">
    <div class="w-full max-w-lg mx-auto px-4">
        <div class="text-center mb-8">
            <span class="text-4xl">🏪</span>
            <h1 class="text-2xl font-extrabold auth-title mt-2">Selecione sua loja</h1>
            <p class="auth-subtitle text-sm mt-1">Escolha qual loja você deseja gerenciar agora</p>
        </div>

        <div class="grid gap-3">
            @foreach (var loja in Model)
            {
                <form asp-action="SelecionarLoja" asp-controller="Auth" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="lojaId" value="@loja.Id" />
                    <input type="hidden" name="lojaNome" value="@loja.Nome" />
                    <input type="hidden" name="lojaEmoji" value="@loja.Emoji" />
                    <input type="hidden" name="empresaId" value="@loja.EmpresaId" />
                    <button type="submit" class="auth-loja-card w-full rounded-xl p-5 text-left flex items-center gap-4 transition-all shadow-sm group">
                        <span class="text-3xl">@(loja.Emoji ?? "🏪")</span>
                        <div>
                            <div class="font-bold auth-card-title group-hover:text-indigo-500 transition-colors">@loja.Nome</div>
                            <div class="auth-card-subtitle text-sm">@loja.Cidade · @loja.Plano</div>
                        </div>
                        <svg class="ml-auto w-5 h-5 auth-icon-muted group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </button>
                </form>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="auth-card rounded-xl p-8 text-center">
                <p class="auth-card-subtitle">Nenhuma loja encontrada para este usuário.</p>
                <form asp-action="Logout" asp-controller="Auth" method="post" class="mt-2">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="text-indigo-500 text-sm font-semibold hover:underline">Fazer logout</button>
                </form>
            </div>
        }
    </div>
</body>
</html>
