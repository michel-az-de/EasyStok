@model EasyStock.Web.Services.DiagnosticoApiResult
@using EasyStock.Web.Services
@{
    Layout = null;
    var apiOk = ViewBag.ApiAlcancavel == true;
    var apiUrl = ViewBag.ApiBaseUrl as string ?? "N/A";
    var ts = (DateTimeOffset)ViewBag.Timestamp;
    var latenciaApiMs = (long)(ViewBag.LatenciaApiMs ?? 0L);
    var isAdmin = ViewBag.IsAdmin == true;

    var apiBase = apiUrl.Contains("/api") ? apiUrl[..apiUrl.LastIndexOf("/api")] : apiUrl;

    string StatusClass(string s) => s switch {
        "ok" => "bg-green-100 text-green-800",
        "degraded" => "bg-yellow-100 text-yellow-800",
        "critical" => "bg-red-100 text-red-800",
        "falha" => "bg-red-100 text-red-800",
        "nao_configurado" => "bg-slate-100 text-slate-500",
        _ => "bg-slate-100 text-slate-600"
    };
    string DotClass(string s) => s switch {
        "ok" => "bg-green-500",
        "degraded" => "bg-yellow-500",
        "critical" => "bg-red-500",
        "falha" => "bg-red-500",
        _ => "bg-slate-400"
    };
    string LatBadgeClass(long ms) => ms < 200 ? "text-green-700 bg-green-50" : ms < 1000 ? "text-yellow-700 bg-yellow-50" : "text-red-700 bg-red-50";

    // Normaliza valores desconhecidos pra "critical" — assim header (que cai no _ default
    // pra qualquer coisa fora de ok/degraded) e a aba Insights (que so reconhecia
    // critical/degraded) param de divergir quando a API devolve Status vazio/desconhecido.
    var rawStatus = apiOk && Model is not null ? Model!.Status : null;
    var overallStatus = rawStatus switch
    {
        "ok" or "degraded" or "critical" => rawStatus!,
        _ => "critical"
    };
    var overallIcon = overallStatus switch { "ok" => "check_circle", "degraded" => "warning", _ => "error" };
    var overallText = overallStatus switch { "ok" => "Todos os sistemas operacionais", "degraded" => "Sistema degradado", _ => "Falha critica detectada" };
    var overallHero = overallStatus switch { "ok" => "from-green-500 to-emerald-600", "degraded" => "from-yellow-500 to-amber-600", _ => "from-red-500 to-rose-600" };
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Central de Operacoes — EasyStock</title>
    <!-- tailwind: build local em ~/css/tailwind.dist.css -->
    @* pinned 2026-05-15 — recalculate SRI on upgrade *@
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"
            integrity="sha384-l8f0VcPi/M1iHPv8egOnY/15TDwqgbOR1anMIJWvU6nLRgZVLTLSaNqi/TOoT5Fh"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.js"
            integrity="sha384-dug+JxfBvklEQdJ4AYuBBAIScUz0bVN73xpy273gcAwHjb3qI0fXmuYNaNfdyYJG"
            crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.dist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/diagnostico.css" asp-append-version="true" />
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen" x-data="diagApp()" x-init="init()">

<!-- ── HERO HEADER ──────────────────────────────────────────────────── -->
<div class="bg-gradient-to-r @overallHero text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-5">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <div class="flex items-center gap-3">
                <span class="material-icons-round text-3xl opacity-90">@overallIcon</span>
                <div>
                    <h1 class="text-xl font-bold tracking-tight">Saúde do sistema</h1>
                    <p class="text-sm opacity-90">
                        @overallText
                        @if (apiOk && Model is not null)
                        {
                            <span class="opacity-75">
                                &mdash; @Model!.Ambiente &middot; v@(Model!.Versao) &middot; Uptime @Model!.Uptime
                            </span>
                        }
                    </p>
                </div>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-xs opacity-75" x-text="`Auto-refresh em ${countdown}s`"></span>
                <button @@click="refreshAll()" :disabled="refreshing"
                    class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/20 hover:bg-white/30 backdrop-blur text-white text-sm font-medium rounded-lg transition disabled:opacity-50">
                    <span class="material-icons-round text-base" :class="refreshing && 'animate-spin'">refresh</span>
                    <span x-text="refreshing ? 'Atualizando...' : 'Atualizar'">Atualizar</span>
                </button>
                <a href="/dashboard" class="inline-flex items-center gap-1 px-3 py-1.5 bg-white/10 hover:bg-white/20 text-white text-sm rounded-lg transition">
                    <span class="material-icons-round text-base">dashboard</span>
                    Dashboard
                </a>
            </div>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 py-6">

    <!-- ── Banner contextual ──────────────────────────────────────────── -->
    <div class="mb-6 px-4 py-3 rounded-xl bg-blue-50 border border-blue-200 flex items-start gap-3 text-sm text-blue-900">
        <span class="material-icons-round text-blue-600 text-base flex-shrink-0 mt-0.5">info</span>
        <div>
            <strong class="font-semibold">Esta página é para admins e suporte.</strong>
            Se tudo aqui está verde, suas operações estão rodando bem — você não precisa olhar.
        </div>
    </div>

    <!-- ── TABS ──────────────────────────────────────────────────────── -->
    <div class="flex gap-6 border-b border-slate-200 mb-6 overflow-x-auto">
        <button @@click="activeTab='overview'" class="pb-3 px-1 text-sm whitespace-nowrap transition-all"
            :class="activeTab==='overview' ? 'tab-active' : 'tab-inactive'">
            <span class="material-icons-round text-base align-middle mr-1">monitoring</span>Visao Geral
        </button>
        <button @@click="activeTab='endpoints'" class="pb-3 px-1 text-sm whitespace-nowrap transition-all"
            :class="activeTab==='endpoints' ? 'tab-active' : 'tab-inactive'">
            <span class="material-icons-round text-base align-middle mr-1">api</span>Endpoints
            <span x-show="endpoints" class="ml-1 text-xs px-1.5 py-0.5 rounded-full"
                :class="endpointsFailed > 0 ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700'"
                x-text="endpoints ? `${endpoints.saudaveis}/${endpoints.resultados.length}` : ''"></span>
        </button>
        <button @@click="activeTab='logs'" class="pb-3 px-1 text-sm whitespace-nowrap transition-all"
            :class="activeTab==='logs' ? 'tab-active' : 'tab-inactive'">
            <span class="material-icons-round text-base align-middle mr-1">receipt_long</span>Logs Inteligentes
            <span x-show="enhancedLogs && enhancedLogs.resumo" class="ml-1 text-xs px-1.5 py-0.5 rounded-full"
                :class="enhancedLogs?.resumo?.totalErrors > 0 ? 'bg-red-100 text-red-700' : 'bg-slate-100 text-slate-600'"
                x-text="enhancedLogs?.resumo ? enhancedLogs.resumo.totalErrors + ' erros' : ''"></span>
        </button>
        <button @@click="activeTab='insights'" class="pb-3 px-1 text-sm whitespace-nowrap transition-all"
            :class="activeTab==='insights' ? 'tab-active' : 'tab-inactive'">
            <span class="material-icons-round text-base align-middle mr-1">psychology</span>Insights
            @if (overallStatus == "critical" || overallStatus == "degraded")
            {
                <span class="ml-1 text-xs px-1.5 py-0.5 rounded-full bg-red-100 text-red-700 font-semibold" title="Estado crítico/degradado detectado">!</span>
            }
            <span x-show="patterns.length > 0" class="ml-1 text-xs px-1.5 py-0.5 rounded-full bg-amber-100 text-amber-800"
                x-text="patterns.length"></span>
        </button>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB 1: VISAO GERAL
         ══════════════════════════════════════════════════════════════════ -->
    <div x-show="activeTab==='overview'" x-cloak class="fade-in">

        <!-- KPI Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            @if (apiOk && Model is not null)
            {
                <div class="bg-white rounded-xl border border-slate-200 p-4">
                    <div class="text-xs text-slate-500 font-medium mb-1">Uptime</div>
                    <div class="text-2xl font-bold text-slate-800">@Model!.Uptime</div>
                    <div class="text-xs text-slate-400 mt-1">@Model!.Ambiente</div>
                </div>
            }
            else
            {
                <div class="bg-white rounded-xl border border-red-200 p-4">
                    <div class="text-xs text-slate-500 font-medium mb-1">Uptime</div>
                    <div class="text-2xl font-bold text-red-600">Offline</div>
                    <div class="text-xs text-red-400 mt-1">API inacessivel</div>
                </div>
            }

            <div class="bg-white rounded-xl border border-slate-200 p-4">
                <div class="text-xs text-slate-500 font-medium mb-1">Latencia API</div>
                <div class="text-2xl font-bold @(latenciaApiMs < 200 ? "text-green-600" : latenciaApiMs < 1000 ? "text-yellow-600" : "text-red-600")">@latenciaApiMs<span class="text-sm font-medium">ms</span></div>
                <div class="text-xs text-slate-400 mt-1">Web → API round-trip</div>
            </div>

            <div class="bg-white rounded-xl border border-slate-200 p-4">
                <div class="text-xs text-slate-500 font-medium mb-1">Erros 48h</div>
                <div class="text-2xl font-bold" :class="errorCount24h > 0 ? 'text-red-600' : 'text-green-600'"
                    x-text="enhancedLogs ? enhancedLogs.resumo.totalErrors : '—'">—</div>
                <div class="text-xs text-slate-400 mt-1" x-text="enhancedLogs ? enhancedLogs.resumo.totalWarnings + ' warnings' : 'Carregando...'">Carregando...</div>
            </div>

            <div class="bg-white rounded-xl border border-slate-200 p-4">
                <div class="text-xs text-slate-500 font-medium mb-1">Endpoints</div>
                <div class="text-2xl font-bold" :class="endpointsFailed > 0 ? 'text-red-600' : 'text-green-600'"
                    x-text="endpoints ? endpoints.saudaveis + '/' + endpoints.resultados.length : '—'">—</div>
                <div class="text-xs text-slate-400 mt-1" x-text="endpoints ? endpoints.lentos + ' lentos, ' + endpoints.falhas + ' falhas' : 'Carregando...'">Carregando...</div>
            </div>
        </div>

        <!-- Charts Row -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
            <!-- Health Timeline Chart -->
            <div class="bg-white rounded-xl border border-slate-200 p-5">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="font-semibold text-slate-800 text-sm flex items-center gap-1.5">
                        <span class="material-icons-round text-base text-indigo-500">show_chart</span>
                        Saude da API & Banco
                    </h3>
                    <div class="flex items-center gap-3">
                        <span class="text-xs text-slate-400" x-text="healthHistory ? healthHistory.total + ' snapshots' : ''"></span>
                        <button @@click="zerarMedidores()" :disabled="zerandoMedidores"
                            class="flex items-center gap-1 px-2.5 py-1 text-xs font-medium text-red-700 bg-red-50 border border-red-200 rounded-lg hover:bg-red-100 disabled:opacity-50 transition">
                            <span class="material-icons-round text-sm" :class="zerandoMedidores ? 'animate-spin' : ''">
                                <template x-if="zerandoMedidores">sync</template>
                                <template x-if="!zerandoMedidores">restart_alt</template>
                            </span>
                            <span x-text="zerandoMedidores ? 'Zerando...' : 'Zerar Medidores'"></span>
                        </button>
                    </div>
                </div>
                <div x-show="zerarMsg" x-cloak x-transition
                    class="mb-2 px-3 py-1.5 rounded-lg text-xs flex items-center gap-1.5"
                    :class="zerarOk ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-red-50 text-red-700 border border-red-200'">
                    <span class="material-icons-round text-sm" x-text="zerarOk ? 'check_circle' : 'error'"></span>
                    <span x-text="zerarMsg"></span>
                </div>
                <div class="h-52 relative">
                    <canvas id="healthChart"></canvas>
                    <div x-show="!healthHistory" class="absolute inset-0 flex items-center justify-center text-slate-400 text-sm">
                        <span class="material-icons-round animate-spin mr-2">hourglass_empty</span>Carregando...
                    </div>
                    <div x-show="healthHistory && (!healthHistory.snapshots || healthHistory.snapshots.length === 0)" class="absolute inset-0 flex items-center justify-center text-slate-400 text-sm">
                        <span class="material-icons-round mr-2">hourglass_empty</span>Aguardando snapshots (coletados a cada 60s)...
                    </div>
                </div>
            </div>

            <!-- Error Rate Chart -->
            <div class="bg-white rounded-xl border border-slate-200 p-5">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="font-semibold text-slate-800 text-sm flex items-center gap-1.5">
                        <span class="material-icons-round text-base text-red-500">error_outline</span>
                        Erros por Hora (48h)
                    </h3>
                </div>
                <div class="h-52 relative">
                    <canvas id="errorsChart"></canvas>
                    <div x-show="!enhancedLogs" class="absolute inset-0 flex items-center justify-center text-slate-400 text-sm">
                        @if (isAdmin)
                        {
                            <span><span class="material-icons-round animate-spin mr-2 align-middle">hourglass_empty</span>Carregando...</span>
                        }
                        else
                        {
                            <span><span class="material-icons-round mr-2 align-middle">lock</span>Requer permissao Admin</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- SLO Strip -->
        <div class="bg-white rounded-xl border border-slate-200 p-4 mb-4">
            <div class="flex items-center gap-2 mb-3">
                <span class="material-icons-round text-base text-emerald-500">verified</span>
                <h3 class="text-sm font-semibold text-slate-700">SLO — Últimas 24h</h3>
                <span x-show="!slo" class="ml-2 text-xs text-slate-400 flex items-center gap-1">
                    <span class="material-icons-round text-xs animate-spin">hourglass_empty</span>carregando...
                </span>
                <span class="text-xs text-slate-400 ml-auto" x-show="slo" x-text="slo?.snapshotsAnalisados ? slo.snapshotsAnalisados + ' snapshots' : ''"></span>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
                <div>
                    <div class="text-2xl font-bold"
                        :class="slo?.uptime24h >= 99.9 ? 'text-green-600' : slo?.uptime24h >= 99 ? 'text-yellow-600' : slo?.uptime24h != null ? 'text-red-600' : 'text-slate-300'"
                        x-text="slo?.uptime24h != null ? slo.uptime24h.toFixed(1) + '%' : '—'"></div>
                    <div class="text-xs text-slate-500">Uptime</div>
                </div>
                <div>
                    <div class="text-2xl font-bold"
                        :class="slo?.avgResponseTimeMs != null ? 'text-indigo-600' : 'text-slate-300'"
                        x-text="slo?.avgResponseTimeMs != null ? Math.round(slo.avgResponseTimeMs) + 'ms' : '—'"></div>
                    <div class="text-xs text-slate-500">Resp. Média</div>
                </div>
                <div>
                    <div class="text-2xl font-bold"
                        :class="slo?.p95ResponseTimeMs != null ? 'text-orange-500' : 'text-slate-300'"
                        x-text="slo?.p95ResponseTimeMs != null ? Math.round(slo.p95ResponseTimeMs) + 'ms' : '—'"></div>
                    <div class="text-xs text-slate-500">P95</div>
                </div>
                <div>
                    <div class="text-2xl font-bold"
                        :class="slo?.errorRate != null ? (slo.errorRate < 0.01 ? 'text-green-600' : 'text-red-600') : 'text-slate-300'"
                        x-text="slo?.errorRate != null ? (slo.errorRate * 100).toFixed(2) + '%' : '—'"></div>
                    <div class="text-xs text-slate-500">Taxa de Erro</div>
                </div>
            </div>
        </div>

        <!-- Queries SQL Lentas -->
        <div class="bg-white rounded-xl border border-slate-200 p-4 mb-4">
            <div class="flex items-center justify-between mb-3">
                <h3 class="text-sm font-semibold text-slate-700 flex items-center gap-1.5">
                    <span class="material-icons-round text-base text-orange-500">query_stats</span>
                    Queries SQL Lentas (pg_stat_statements)
                </h3>
                <button @@click="fetchQueriesLentas()" class="text-xs text-indigo-600 hover:underline">Atualizar</button>
            </div>
            <div x-show="!queriesLentas" class="text-xs text-slate-400 flex items-center gap-1">
                <span class="material-icons-round text-xs animate-spin">hourglass_empty</span>carregando...
            </div>
            <div x-show="queriesLentas && !queriesLentas?.disponivel" class="text-xs text-slate-500 italic" x-text="queriesLentas?.motivo"></div>
            <div x-show="queriesLentas?.instrucoesPgStatStatements"
                class="text-xs bg-amber-50 border border-amber-200 rounded p-2 mt-1 font-mono"
                x-text="queriesLentas?.instrucoesPgStatStatements"></div>
            <div x-show="queriesLentas?.disponivel && queriesLentas?.queries?.length > 0" class="overflow-x-auto">
                <table class="w-full text-xs mt-1">
                    <thead><tr class="text-slate-500 border-b border-slate-100 text-right">
                        <th class="text-left py-1.5 pr-2 font-medium">Query</th>
                        <th class="py-1.5 px-2 font-medium">Calls</th>
                        <th class="py-1.5 px-2 font-medium">Avg ms</th>
                        <th class="py-1.5 px-2 font-medium">Stddev</th>
                        <th class="py-1.5 pl-2 font-medium">Avg rows</th>
                    </tr></thead>
                    <tbody>
                        <template x-for="(q, qi) in queriesLentas?.queries ?? []" :key="qi">
                            <tr class="border-b border-slate-50 hover:bg-slate-50">
                                <td class="py-1 pr-2 font-mono text-slate-600 max-w-xs truncate" x-text="q.query ? q.query.slice(0, 80) + (q.query.length > 80 ? '...' : '') : ''"></td>
                                <td class="py-1 px-2 text-right text-slate-600" x-text="q.calls"></td>
                                <td class="py-1 px-2 text-right font-semibold"
                                    :class="q.avgMs > 1000 ? 'text-red-600' : q.avgMs > 200 ? 'text-yellow-600' : 'text-green-600'"
                                    x-text="q.avgMs?.toFixed(1)"></td>
                                <td class="py-1 px-2 text-right text-slate-400" x-text="q.stddevMs?.toFixed(1) ?? '—'"></td>
                                <td class="py-1 pl-2 text-right text-slate-500" x-text="q.avgRows?.toFixed(1) ?? '—'"></td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
            <div x-show="queriesLentas?.disponivel && (!queriesLentas?.queries || queriesLentas.queries.length === 0)"
                class="text-xs text-green-600 mt-1">Nenhuma query lenta encontrada ✓</div>
        </div>

        <!-- Saúde por Empresa -->
        <div class="bg-white rounded-xl border border-slate-200 p-4 mb-4">
            <div class="flex items-center justify-between">
                <h3 class="text-sm font-semibold text-slate-700 flex items-center gap-1.5">
                    <span class="material-icons-round text-base text-teal-500">business</span>
                    Saúde por Empresa (sintético)
                </h3>
                <button @@click="fetchEmpresasHealth()" :disabled="loadingEmpresasHealth"
                    class="text-xs px-3 py-1 bg-teal-50 text-teal-700 rounded-lg hover:bg-teal-100 disabled:opacity-50 transition">
                    <span x-text="loadingEmpresasHealth ? 'Verificando...' : 'Verificar'"></span>
                </button>
            </div>
            <div x-show="empresasHealth" x-cloak class="mt-3">
                <div class="flex gap-3 text-xs text-slate-500 mb-2">
                    <span x-text="'Total: ' + (empresasHealth?.totalAnalisadas ?? 0)"></span>
                    <span class="text-green-600" x-text="'OK: ' + (empresasHealth?.ok ?? 0)"></span>
                    <span class="text-red-600" x-show="(empresasHealth?.degraded ?? 0) > 0" x-text="'Degraded: ' + empresasHealth.degraded"></span>
                </div>
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
                    <template x-for="e in empresasHealth?.empresas ?? []" :key="e.empresaId">
                        <div class="rounded-lg border p-2 text-xs"
                            :class="e.status === 'ok' ? 'border-green-200 bg-green-50' : 'border-red-200 bg-red-50'">
                            <div class="font-medium text-slate-700 truncate" x-text="e.nome"></div>
                            <div class="mt-0.5 flex items-center gap-1">
                                <span class="w-1.5 h-1.5 rounded-full shrink-0"
                                    :class="e.status === 'ok' ? 'bg-green-500' : 'bg-red-500'"></span>
                                <span :class="e.status === 'ok' ? 'text-green-700' : 'text-red-700'"
                                    x-text="e.status + ' (' + e.latenciaMs + 'ms)'"></span>
                            </div>
                            <div x-show="e.erro" class="text-red-600 truncate mt-0.5" x-text="e.erro"></div>
                        </div>
                    </template>
                </div>
            </div>
        </div>

        <!-- System Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
            @if (apiOk && Model is not null)
            {
                <!-- Banco -->
                <div class="bg-white rounded-xl border border-slate-200 p-4">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="font-semibold text-sm text-slate-700 flex items-center gap-1.5">
                            <span class="material-icons-round text-base text-blue-500">storage</span>Banco de Dados
                        </h3>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium @StatusClass(Model!.Banco.Conexao)">
                            <span class="w-1.5 h-1.5 rounded-full @DotClass(Model.Banco.Conexao)"></span>@Model.Banco.Conexao
                        </span>
                    </div>
                    <div class="space-y-1 text-xs text-slate-600">
                        <div class="flex justify-between"><span>Provider</span><span class="font-medium">@Model.Banco.Provider</span></div>
                        <div class="flex justify-between"><span>Latencia</span><span class="font-medium @LatBadgeClass(Model.Banco.LatenciaMs) px-1.5 rounded">@(Model.Banco.LatenciaMs)ms</span></div>
                        <div class="flex justify-between"><span>Migrations</span><span class="font-medium @(Model.Banco.MigrationsAplicadas == true ? "text-green-600" : "text-red-600")">@(Model.Banco.MigrationsAplicadas == true ? "OK" : "Falha")</span></div>
                        @if (Model.Banco.Fallback) { <div class="text-amber-600 font-medium mt-1">Modo Fallback (SQLite)</div> }
                    </div>
                </div>

                <!-- Redis -->
                <div class="bg-white rounded-xl border border-slate-200 p-4">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="font-semibold text-sm text-slate-700 flex items-center gap-1.5">
                            <span class="material-icons-round text-base text-red-400">memory</span>Redis
                        </h3>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium @StatusClass(Model.Redis.Conexao)">
                            <span class="w-1.5 h-1.5 rounded-full @DotClass(Model.Redis.Conexao)"></span>@Model.Redis.Conexao
                        </span>
                    </div>
                    <div class="space-y-1 text-xs text-slate-600">
                        <div class="flex justify-between"><span>Configurado</span><span class="font-medium">@(Model.Redis.Configurado ? "Sim" : "Nao")</span></div>
                        @if (Model.Redis.Configurado) { <div class="flex justify-between"><span>Latencia</span><span class="font-medium">@(Model.Redis.LatenciaMs)ms</span></div> }
                    </div>
                </div>

                <!-- SMTP -->
                <div class="bg-white rounded-xl border border-slate-200 p-4">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="font-semibold text-sm text-slate-700 flex items-center gap-1.5">
                            <span class="material-icons-round text-base text-purple-500">email</span>SMTP
                        </h3>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium @(Model.Smtp.Configurado ? "bg-green-100 text-green-800" : "bg-slate-100 text-slate-500")">
                            @(Model.Smtp.Configurado ? "Configurado" : "Console")
                        </span>
                    </div>
                    <div class="space-y-1 text-xs text-slate-600">
                        <div class="flex justify-between"><span>Tipo</span><span class="font-medium">@Model.Smtp.Tipo</span></div>
                        <div class="flex justify-between"><span>Host</span><span class="font-medium">@(Model.Smtp.Host ?? "N/A")</span></div>
                    </div>
                </div>

                <!-- Storage -->
                <div class="bg-white rounded-xl border border-slate-200 p-4">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="font-semibold text-sm text-slate-700 flex items-center gap-1.5">
                            <span class="material-icons-round text-base text-amber-500">folder</span>Storage
                        </h3>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium @(Model.Storage.Configurado ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">@Model.Storage.Provider</span>
                    </div>
                    <div class="space-y-1 text-xs text-slate-600">
                        <div class="flex justify-between"><span>Configurado</span><span class="font-medium @(Model.Storage.Configurado ? "text-green-600" : "text-red-600")">@(Model.Storage.Configurado ? "Sim" : "Não")</span></div>
                        <div class="flex justify-between">
                            <span>@(Model.Storage.Provider == "Local" ? "Diretório" : "Conexão")</span>
                            <span class="font-medium @(Model.Storage.DiretorioExiste == true ? "text-green-600" : Model.Storage.DiretorioExiste == false ? "text-red-600" : "text-slate-400")">
                                @(Model.Storage.DiretorioExiste == true ? "OK" : Model.Storage.DiretorioExiste == false ? "Falha" : "N/A")
                            </span>
                        </div>
                    </div>
                </div>

                <!-- IA -->
                <div class="bg-white rounded-xl border border-slate-200 p-4">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="font-semibold text-sm text-slate-700 flex items-center gap-1.5">
                            <span class="material-icons-round text-base text-violet-500">smart_toy</span>IA (Anthropic)
                        </h3>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium @(Model.Ia.Habilitado ? "bg-green-100 text-green-800" : "bg-slate-100 text-slate-500")">
                            @(Model.Ia.Habilitado ? "Ativo" : "Desabilitado")
                        </span>
                    </div>
                    <div class="space-y-1 text-xs text-slate-600">
                        <div class="flex justify-between"><span>API Key</span><span class="font-medium @(Model.Ia.ApiKeyPresente ? "text-green-600" : "text-slate-400")">@(Model.Ia.ApiKeyPresente ? "Presente" : "Ausente")</span></div>
                    </div>
                </div>

                <!-- Config -->
                <div class="bg-white rounded-xl border border-slate-200 p-4">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="font-semibold text-sm text-slate-700 flex items-center gap-1.5">
                            <span class="material-icons-round text-base text-slate-500">settings</span>Configuracao
                        </h3>
                    </div>
                    <div class="space-y-1 text-xs text-slate-600">
                        <div class="flex justify-between"><span>JWT Secret</span><span class="font-medium @(Model.Configuracoes.JwtSecretSeguro == true ? "text-green-600" : "text-red-600")">@(Model.Configuracoes.JwtSecretSeguro == true ? "Seguro" : Model.Configuracoes.JwtSecretPresente ? "Fraco" : "Ausente")</span></div>
                        <div class="flex justify-between"><span>Conn String</span><span class="font-medium @(Model.Configuracoes.ConnectionStringPresente ? "text-green-600" : "text-red-600")">@(Model.Configuracoes.ConnectionStringPresente ? "OK" : "Ausente")</span></div>
                        <div class="flex justify-between"><span>CORS</span><span class="font-medium">@(Model.Configuracoes.CorsOrigins.Length) origin(s)</span></div>
                    </div>
                </div>
            }
            else
            {
                <div class="col-span-full bg-red-50 border border-red-200 rounded-xl p-5">
                    <p class="font-semibold text-red-800 flex items-center gap-2">
                        <span class="material-icons-round">cloud_off</span>API Inacessivel
                    </p>
                    <p class="text-sm text-red-700 mt-1">URL: <code class="font-mono text-xs bg-red-100 px-1 py-0.5 rounded">@apiUrl</code></p>
                    <p class="text-xs text-red-600 mt-2">Verifique se a API esta no ar e se a URL em appsettings.json esta correta.</p>
                </div>
            }
        </div>

        <!-- Causas Provaveis -->
        @if (apiOk && Model is not null && Model!.CausasProvaveis.Count > 0)
        {
            <div class="bg-white border border-slate-200 rounded-xl p-5 mb-6">
                <h3 class="font-semibold text-sm text-slate-800 mb-3 flex items-center gap-1.5">
                    <span class="material-icons-round text-base text-amber-500">report_problem</span>
                    Causas Provaveis
                </h3>
                <div class="space-y-2">
                    @foreach (var causa in Model!.CausasProvaveis)
                    {
                        var sv = causa.Severidade == "critical" ? "border-l-red-500 bg-red-50" : "border-l-yellow-500 bg-yellow-50";
                        var tc = causa.Severidade == "critical" ? "text-red-800" : "text-yellow-800";
                        var bc = causa.Severidade == "critical" ? "text-red-600" : "text-yellow-700";
                        <div class="border-l-4 @sv rounded-r-lg px-4 py-2.5">
                            <p class="font-medium text-sm @tc">[@causa.Componente] @causa.Descricao</p>
                            <p class="text-xs @bc mt-0.5">@causa.Sugestao</p>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB 2: ENDPOINTS
         ══════════════════════════════════════════════════════════════════ -->
    <div x-show="activeTab==='endpoints'" x-cloak class="fade-in">
        <div class="flex items-center justify-between mb-4">
            <h2 class="font-semibold text-slate-800 flex items-center gap-2">
                <span class="material-icons-round text-indigo-500">api</span>Monitor de Endpoints
            </h2>
            <button @@click="fetchEndpoints()" :disabled="loadingEndpoints"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-indigo-600 hover:bg-indigo-700 disabled:bg-indigo-400 text-white text-sm font-medium rounded-lg transition">
                <span class="material-icons-round text-base" :class="loadingEndpoints && 'animate-spin'">refresh</span>
                <span x-text="loadingEndpoints ? 'Testando...' : 'Testar Todos'">Testar Todos</span>
            </button>
        </div>

        <!-- Loading -->
        <div x-show="loadingEndpoints && !endpoints" class="text-center py-12 text-slate-400">
            <span class="material-icons-round text-4xl animate-spin mb-2">hourglass_empty</span>
            <p>Testando endpoints...</p>
        </div>

        <!-- Erro: API inacessível -->
        <div x-show="!loadingEndpoints && !endpoints && endpointsError"
             class="bg-red-50 border border-red-200 rounded-xl p-8 text-center">
            <span class="material-icons-round text-4xl text-red-400 mb-2">cloud_off</span>
            <p class="text-red-700 font-medium">Não foi possível testar os endpoints</p>
            <p class="text-xs text-red-600 mt-1" x-text="endpointsError"></p>
            <button @@click="fetchEndpoints()" :disabled="loadingEndpoints"
                class="mt-4 inline-flex items-center gap-1.5 px-3 py-1.5 bg-red-600 hover:bg-red-700 text-white text-xs font-medium rounded-lg transition disabled:opacity-50">
                <span class="material-icons-round text-sm" :class="loadingEndpoints && 'animate-spin'">refresh</span>
                Tentar novamente
            </button>
        </div>

        <!-- Resultados vazios (API respondeu mas sem itens) -->
        <div x-show="!loadingEndpoints && endpoints && (endpoints.resultados?.length ?? 0) === 0"
             class="bg-slate-50 border border-slate-200 rounded-xl p-8 text-center">
            <span class="material-icons-round text-4xl text-slate-300 mb-2">inbox</span>
            <p class="text-slate-600 font-medium">Nenhum endpoint configurado para teste</p>
            <p class="text-xs text-slate-500 mt-1">A API respondeu, mas não retornou rotas para testar.</p>
        </div>

        <div x-show="endpoints && (endpoints.resultados?.length ?? 0) > 0" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
            <template x-for="ep in endpoints?.resultados || []" :key="ep.rota">
                <div class="bg-white rounded-xl border border-slate-200 p-4 hover:shadow-md transition-shadow">
                    <div class="flex items-center justify-between mb-2">
                        <code class="text-xs font-mono text-slate-700 truncate flex-1" x-text="ep.rota"></code>
                        <span class="w-2.5 h-2.5 rounded-full ml-2 shrink-0"
                            :class="ep.status === 'ok' ? 'bg-green-500' : ep.status === 'slow' || ep.status === 'very_slow' ? 'bg-yellow-500 pulse-dot' : 'bg-red-500 pulse-dot'"></span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs px-2 py-0.5 rounded font-medium"
                            :class="ep.statusCode >= 500 ? 'bg-red-100 text-red-700' : ep.statusCode >= 400 ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-700'"
                            x-text="ep.statusCode || 'ERR'"></span>
                        <span class="text-xs font-medium px-2 py-0.5 rounded"
                            :class="ep.latenciaMs < 200 ? 'bg-green-50 text-green-700' : ep.latenciaMs < 500 ? 'bg-yellow-50 text-yellow-700' : 'bg-red-50 text-red-700'"
                            x-text="ep.latenciaMs + 'ms'"></span>
                        <span class="text-xs text-slate-400" x-text="ep.metodo"></span>
                    </div>
                    <div x-show="ep.erro" class="mt-2 text-xs text-red-600 truncate" x-text="ep.erro"></div>
                </div>
            </template>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB 3: LOGS INTELIGENTES
         ══════════════════════════════════════════════════════════════════ -->
    <div x-show="activeTab==='logs'" x-cloak class="fade-in">
        @if (!isAdmin)
        {
            <div class="bg-slate-50 border border-slate-200 rounded-xl p-8 text-center">
                <span class="material-icons-round text-4xl text-slate-300 mb-2">lock</span>
                <p class="text-slate-500 font-medium">Logs requerem permissao Admin</p>
                <p class="text-xs text-slate-400 mt-1">Faca login como Admin ou SuperAdmin para acessar logs inteligentes.</p>
            </div>
        }
        else
        {
            <div>
                <!-- Filters -->
                <div class="flex flex-wrap items-center gap-3 mb-4">
                    <div class="flex bg-white border border-slate-200 rounded-lg overflow-hidden text-xs">
                        <button @@click="logFilter.level='ALL'" class="px-3 py-1.5 transition"
                            :class="logFilter.level==='ALL' ? 'bg-indigo-600 text-white' : 'text-slate-600 hover:bg-slate-50'">Todos</button>
                        <button @@click="logFilter.level='ERROR'" class="px-3 py-1.5 transition"
                            :class="logFilter.level==='ERROR' ? 'bg-red-600 text-white' : 'text-slate-600 hover:bg-slate-50'">Erros</button>
                        <button @@click="logFilter.level='WARN'" class="px-3 py-1.5 transition"
                            :class="logFilter.level==='WARN' ? 'bg-yellow-600 text-white' : 'text-slate-600 hover:bg-slate-50'">Warnings</button>
                        <button @@click="logFilter.level='INFO'" class="px-3 py-1.5 transition"
                            :class="logFilter.level==='INFO' ? 'bg-blue-600 text-white' : 'text-slate-600 hover:bg-slate-50'">Info</button>
                    </div>
                    <input type="text" x-model="logFilter.search" placeholder="Buscar nos logs..."
                        class="flex-1 min-w-[200px] px-3 py-1.5 text-sm border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-200 focus:border-indigo-400 outline-none" />
                    <label class="flex items-center gap-1.5 text-xs text-slate-600 cursor-pointer">
                        <input type="checkbox" x-model="logFilter.groupByCorrelation" class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-200" />
                        Agrupar por operacao
                    </label>
                    <span class="text-xs text-slate-400" x-text="filteredLogs.length + ' entradas'"></span>
                    <div class="ml-auto flex items-center gap-2">
                        <a href="/diagnostico/api/logs/exportar?hours=48"
                           class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-indigo-700 bg-indigo-50 border border-indigo-200 rounded-lg hover:bg-indigo-100 transition">
                            <span class="material-icons-round text-sm">download</span>
                            Exportar
                        </a>
                        <button @@click="salvarStorage()" :disabled="savingStorage"
                            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-teal-700 bg-teal-50 border border-teal-200 rounded-lg hover:bg-teal-100 disabled:opacity-50 transition">
                            <span class="material-icons-round text-sm" :class="savingStorage ? 'animate-spin' : ''">
                                <template x-if="savingStorage">sync</template>
                                <template x-if="!savingStorage">cloud_upload</template>
                            </span>
                            <span x-text="savingStorage ? 'Salvando...' : 'Salvar no storage'"></span>
                        </button>
                        <button @@click="limparLogs()" :disabled="clearingLogs"
                            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-orange-700 bg-orange-50 border border-orange-200 rounded-lg hover:bg-orange-100 disabled:opacity-50 transition">
                            <span class="material-icons-round text-sm" :class="clearingLogs ? 'animate-spin' : ''">
                                <template x-if="clearingLogs">sync</template>
                                <template x-if="!clearingLogs">delete</template>
                            </span>
                            <span x-text="clearingLogs ? 'Movendo...' : 'Mover para lixeira'"></span>
                        </button>
                        <button @@click="expurgarLogs()" :disabled="expurgandoLogs"
                            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-purple-700 bg-purple-50 border border-purple-200 rounded-lg hover:bg-purple-100 disabled:opacity-50 transition">
                            <span class="material-icons-round text-sm" :class="expurgandoLogs ? 'animate-spin' : ''">
                                <template x-if="expurgandoLogs">sync</template>
                                <template x-if="!expurgandoLogs">auto_delete</template>
                            </span>
                            <span x-text="expurgandoLogs ? 'Expurgando...' : 'Expurgar antigos'"></span>
                        </button>
                        <button @@click="esvaziarLixeira()" :disabled="clearingLogs"
                            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-red-700 bg-red-50 border border-red-200 rounded-lg hover:bg-red-100 disabled:opacity-50 transition">
                            <span class="material-icons-round text-sm">delete_forever</span>
                            <span>Esvaziar lixeira</span>
                        </button>
                        <span x-show="lixeiraFiles.length > 0" class="text-xs text-slate-500 flex items-center gap-1">
                            <span class="material-icons-round text-sm text-orange-400">folder_delete</span>
                            <span x-text="lixeiraFiles.length + ' na lixeira (' + (lixeiraTotalBytes / 1024 / 1024).toFixed(1) + ' MB)'"></span>
                        </span>
                    </div>
                </div>
                <!-- Limpar resultado -->
                <div x-show="clearLogsMsg" x-cloak x-transition
                    class="mb-2 px-4 py-2 rounded-lg text-sm flex items-center gap-2"
                    :class="clearLogsOk ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-red-50 text-red-700 border border-red-200'">
                    <span class="material-icons-round text-base" x-text="clearLogsOk ? 'check_circle' : 'error'"></span>
                    <span x-text="clearLogsMsg"></span>
                </div>
                <!-- Lixeira resultado -->
                <div x-show="esvaziarLixeiraMsg" x-cloak x-transition
                    class="mb-2 px-4 py-2 rounded-lg text-sm flex items-center gap-2"
                    :class="esvaziarLixeiraOk ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-red-50 text-red-700 border border-red-200'">
                    <span class="material-icons-round text-base" x-text="esvaziarLixeiraOk ? 'check_circle' : 'error'"></span>
                    <span x-text="esvaziarLixeiraMsg"></span>
                </div>
                <!-- Expurgar resultado -->
                <div x-show="expurgarMsg" x-cloak x-transition
                    class="mb-2 px-4 py-2 rounded-lg text-sm flex items-center gap-2"
                    :class="expurgarOk ? 'bg-purple-50 text-purple-700 border border-purple-200' : 'bg-red-50 text-red-700 border border-red-200'">
                    <span class="material-icons-round text-base" x-text="expurgarOk ? 'check_circle' : 'error'"></span>
                    <span x-text="expurgarMsg"></span>
                </div>
                <!-- Storage resultado -->
                <div x-show="saveStorageMsg" x-cloak x-transition
                    class="mb-3 px-4 py-2 rounded-lg text-sm flex items-center gap-2"
                    :class="saveStorageOk ? 'bg-teal-50 text-teal-700 border border-teal-200' : 'bg-red-50 text-red-700 border border-red-200'">
                    <span class="material-icons-round text-base" x-text="saveStorageOk ? 'cloud_done' : 'error'"></span>
                    <span x-text="saveStorageMsg"></span>
                </div>

                <!-- Storage Browser -->
                <div class="bg-white rounded-xl border border-slate-200 p-4 mb-4">
                    <div class="flex items-center justify-between mb-3">
                        <h4 class="font-semibold text-slate-800 text-sm flex items-center gap-1.5">
                            <span class="material-icons-round text-base text-teal-500">cloud</span>
                            Arquivos no Storage
                        </h4>
                        <button @@click="loadStorageFiles()" :disabled="loadingStorageFiles"
                            class="flex items-center gap-1 px-2.5 py-1 text-xs font-medium text-teal-700 bg-teal-50 border border-teal-200 rounded-lg hover:bg-teal-100 disabled:opacity-50 transition">
                            <span class="material-icons-round text-sm" :class="loadingStorageFiles ? 'animate-spin' : ''">
                                <template x-if="loadingStorageFiles">sync</template>
                                <template x-if="!loadingStorageFiles">refresh</template>
                            </span>
                            Listar
                        </button>
                    </div>
                    <template x-if="storageFiles.length > 0">
                        <div>
                            <div class="flex items-center gap-2 mb-2">
                                <select x-model="selectedStorageFile"
                                    class="flex-1 text-xs px-2 py-1.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-teal-200 focus:border-teal-400 outline-none">
                                    <option value="">Selecione um arquivo...</option>
                                    <template x-for="f in storageFiles" :key="f.storageKey">
                                        <option :value="f.storageKey" x-text="f.nome + ' (' + (f.tamanhoBytes / 1024).toFixed(0) + ' KB)'"></option>
                                    </template>
                                </select>
                                <button @@click="loadStorageFileContent(selectedStorageFile)" :disabled="!selectedStorageFile || loadingStorageContent"
                                    class="flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium text-teal-700 bg-teal-50 border border-teal-200 rounded-lg hover:bg-teal-100 disabled:opacity-50 transition">
                                    <span class="material-icons-round text-sm" :class="loadingStorageContent ? 'animate-spin' : ''">
                                        <template x-if="loadingStorageContent">sync</template>
                                        <template x-if="!loadingStorageContent">visibility</template>
                                    </span>
                                    Carregar
                                </button>
                            </div>
                            <div x-show="storageFileContent" x-cloak class="bg-slate-50 rounded-lg border border-slate-200 p-3 max-h-60 overflow-y-auto">
                                <div class="text-xs text-slate-500 mb-2" x-show="storageFileContent?.resumo">
                                    <span x-text="'Total: ' + (storageFileContent?.totalEntries ?? 0) + ' entradas'"></span>
                                    <span x-show="storageFileContent?.resumo?.totalErrors > 0" class="text-red-600 ml-2" x-text="'| ' + storageFileContent.resumo.totalErrors + ' erros'"></span>
                                </div>
                                <template x-for="(entry, i) in (storageFileContent?.entradas ?? []).slice(0, 200)" :key="i">
                                    <div class="text-xs font-mono py-0.5 border-b border-slate-100"
                                        :class="{ 'text-red-600': entry.level === 'ERROR' || entry.level === 'FATAL', 'text-yellow-600': entry.level === 'WARN', 'text-slate-600': entry.level === 'INFO' }">
                                        <span class="text-slate-400" x-text="entry.timestamp?.substring(11, 19) ?? ''"></span>
                                        <span class="font-semibold ml-1" x-text="entry.level"></span>
                                        <span class="ml-1" x-text="entry.message?.substring(0, 150)"></span>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </template>
                    <div x-show="storageFiles.length === 0 && !loadingStorageFiles" class="text-xs text-slate-400 text-center py-2">
                        Clique em "Listar" para ver arquivos no storage.
                    </div>
                </div>

                <!-- Log Volume Mini Chart -->
                <div class="bg-white rounded-xl border border-slate-200 p-4 mb-4">
                    <div class="h-24">
                        <canvas id="logVolumeChart"></canvas>
                    </div>
                </div>

                <!-- Loading -->
                <div x-show="loadingLogs" class="text-center py-12 text-slate-400">
                    <span class="material-icons-round text-4xl animate-spin mb-2">hourglass_empty</span>
                    <p>Carregando logs...</p>
                </div>

                <!-- Error / empty states -->
                <div x-show="!loadingLogs && !enhancedLogs" class="text-center py-12 text-slate-400">
                    <span class="material-icons-round text-4xl mb-2">cloud_off</span>
                    <p class="font-semibold text-slate-600">Não foi possível carregar os logs</p>
                    <p class="text-sm mt-1">Verifique a conexão com a API ou tente novamente.</p>
                    <button @@click="fetchEnhancedLogs()"
                            class="mt-3 px-4 py-2 text-sm bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors">
                        Tentar novamente
                    </button>
                </div>

                <div x-show="!loadingLogs && enhancedLogs && !enhancedLogs.disponivel && enhancedLogs.motivo" x-cloak
                     class="text-center py-12 text-slate-400">
                    <span class="material-icons-round text-4xl mb-2">info</span>
                    <p class="font-semibold text-slate-600">Logs indisponíveis</p>
                    <p class="text-sm mt-1" x-text="enhancedLogs.motivo"></p>
                </div>

                <!-- Log Entries -->
                <div x-show="!loadingLogs && enhancedLogs" class="bg-white rounded-xl border border-slate-200 overflow-hidden">
                    <div class="max-h-[600px] overflow-y-auto">
                        <template x-for="(entry, idx) in filteredLogs.slice(0, visibleLogs)" :key="idx">
                            <div class="border-b border-slate-100 last:border-0">
                                <div @@click="entry._expanded = !entry._expanded"
                                    class="flex items-start gap-2 px-4 py-2 cursor-pointer hover:bg-slate-50 transition-colors border-l-4"
                                    :class="{
                                        'border-l-red-500': entry.level === 'ERROR' || entry.level === 'FATAL',
                                        'border-l-yellow-400': entry.level === 'WARN',
                                        'border-l-blue-400': entry.categoria === 'startup',
                                        'border-l-orange-400': entry.categoria === 'http_request' && entry.elapsedMs > 1000,
                                        'border-l-transparent': !['ERROR','FATAL','WARN'].includes(entry.level) && entry.categoria !== 'startup'
                                    }">
                                    <span class="text-[10px] font-mono text-slate-400 shrink-0 mt-0.5 w-[110px]"
                                        x-text="new Date(entry.timestamp).toLocaleString('pt-BR', {hour:'2-digit',minute:'2-digit',second:'2-digit',day:'2-digit',month:'2-digit'})"></span>
                                    <span class="text-[10px] font-bold shrink-0 w-10 mt-0.5"
                                        :class="{
                                            'text-red-600': entry.level === 'ERROR' || entry.level === 'FATAL',
                                            'text-yellow-600': entry.level === 'WARN',
                                            'text-blue-600': entry.level === 'INFO',
                                            'text-slate-400': entry.level === 'DEBUG'
                                        }" x-text="entry.level"></span>
                                    <span class="text-xs text-slate-700 flex-1 truncate log-mono" x-text="entry.message"></span>
                                    <span x-show="entry.elapsedMs" class="text-[10px] font-medium shrink-0 px-1.5 py-0.5 rounded"
                                        :class="entry.elapsedMs < 200 ? 'bg-green-50 text-green-700' : entry.elapsedMs < 1000 ? 'bg-yellow-50 text-yellow-700' : 'bg-red-50 text-red-700'"
                                        x-text="entry.elapsedMs ? Math.round(entry.elapsedMs) + 'ms' : ''"></span>
                                    <span class="material-icons-round text-sm text-slate-400 shrink-0"
                                        x-text="entry._expanded ? 'expand_less' : 'expand_more'"></span>
                                </div>
                                <!-- Expanded Details -->
                                <div x-show="entry._expanded" x-cloak class="px-4 py-3 bg-slate-50 border-t border-slate-100 text-xs space-y-1">
                                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                                        <div x-show="entry.categoria"><span class="text-slate-400">Categoria:</span> <span class="font-medium" x-text="entry.categoria"></span></div>
                                        <div x-show="entry.httpMethod"><span class="text-slate-400">Metodo:</span> <span class="font-medium" x-text="entry.httpMethod + ' ' + (entry.endpoint || '')"></span></div>
                                        <div x-show="entry.statusCode"><span class="text-slate-400">Status:</span> <span class="font-medium" x-text="entry.statusCode"></span></div>
                                        <div x-show="entry.correlationId"><span class="text-slate-400">CorrelationId:</span> <span class="font-mono text-[10px]" x-text="entry.correlationId"></span></div>
                                    </div>
                                    <div x-show="entry.exception" class="mt-2">
                                        <p class="text-slate-500 font-medium mb-1">Stack Trace:</p>
                                        <pre class="log-mono text-red-700 bg-red-50 p-2 rounded overflow-x-auto max-h-48 whitespace-pre-wrap" x-text="entry.exception"></pre>
                                    </div>
                                    <p class="log-mono text-slate-600 mt-1" x-text="entry.message"></p>
                                </div>
                            </div>
                        </template>
                    </div>
                    <div x-show="filteredLogs.length > visibleLogs" class="px-4 py-3 border-t border-slate-200 text-center">
                        <button @@click="visibleLogs += 100" class="text-sm text-indigo-600 hover:text-indigo-700 font-medium">
                            Carregar mais (<span x-text="filteredLogs.length - visibleLogs"></span> restantes)
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB 4: INSIGHTS
         ══════════════════════════════════════════════════════════════════ -->
    <div x-show="activeTab==='insights'" x-cloak class="fade-in">
        <div class="flex items-center justify-between mb-4">
            <h2 class="font-semibold text-slate-800 flex items-center gap-2">
                <span class="material-icons-round text-indigo-500">psychology</span>Diagnosticos Inteligentes
            </h2>
            <span class="text-xs text-slate-400" x-text="patterns.length + ' padroes detectados'"></span>
        </div>

        <div x-show="loadingLogs && patterns.length === 0" class="text-center py-12 text-slate-400">
            <span class="material-icons-round text-4xl animate-spin mb-2">hourglass_empty</span>
            <p>Analisando padroes...</p>
        </div>

        @if (!apiOk)
        {
            <!-- API offline: análise indisponível -->
            <div class="bg-red-50 border border-red-200 rounded-xl p-8 text-center">
                <span class="material-icons-round text-4xl text-red-400 mb-2">cloud_off</span>
                <p class="text-red-700 font-medium">Análise indisponível — API inacessível</p>
                <p class="text-xs text-red-600 mt-1">Os algoritmos de detecção dependem de logs servidos pela API. Restaure a conexão para retomar a análise.</p>
            </div>
        }
        else if (overallStatus == "critical" || overallStatus == "degraded")
        {
            <!-- API ok mas status global crítico/degradado: mostrar causas provaveis vindas da API -->
            <div class="bg-red-50 border border-red-200 rounded-xl p-5 mb-4">
                <div class="flex items-start gap-3">
                    <span class="material-icons-round text-2xl @(overallStatus == "critical" ? "text-red-500" : "text-yellow-500")">@overallIcon</span>
                    <div class="flex-1">
                        <p class="text-sm font-semibold @(overallStatus == "critical" ? "text-red-800" : "text-yellow-800")">@overallText</p>
                        @if (Model is not null && Model.CausasProvaveis.Any())
                        {
                            <ul class="mt-2 space-y-1 text-xs text-slate-700">
                                @foreach (var causa in Model.CausasProvaveis)
                                {
                                    <li class="flex gap-1.5">
                                        <span class="material-icons-round text-sm @(causa.Severidade == "critical" ? "text-red-500" : causa.Severidade == "warning" ? "text-yellow-500" : "text-blue-500")">@(causa.Severidade == "critical" ? "error" : "warning")</span>
                                        <div>
                                            <span class="font-medium">@causa.Componente:</span>
                                            <span>@causa.Descricao</span>
                                            @if (!string.IsNullOrEmpty(causa.Sugestao))
                                            {
                                                <span class="text-slate-500"> &mdash; @causa.Sugestao</span>
                                            }
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-xs text-slate-600 mt-1">Verifique a aba "Visao Geral" para detalhes do componente afetado.</p>
                        }
                    </div>
                </div>
            </div>
            <div x-show="!loadingLogs && patterns.length === 0" class="bg-slate-50 border border-slate-200 rounded-xl p-6 text-center">
                <span class="material-icons-round text-3xl text-slate-300 mb-1">psychology_alt</span>
                <p class="text-slate-600 text-sm">Nenhum padrão recorrente adicional detectado nas últimas 48h.</p>
            </div>
        }
        else
        {
            <div x-show="!loadingLogs && patterns.length === 0" class="bg-green-50 border border-green-200 rounded-xl p-8 text-center">
                <span class="material-icons-round text-4xl text-green-400 mb-2">verified</span>
                <p class="text-green-700 font-medium">Nenhum problema detectado</p>
                <p class="text-xs text-green-600 mt-1">Os algoritmos de deteccao nao encontraram padroes anomalos nas ultimas 48h.</p>
            </div>
        }

        <!-- Patterns by Category -->
        <template x-for="category in patternCategories" :key="category.key">
            <div x-show="patternsForCategory(category.key).length > 0" class="mb-6">
                <h3 class="text-sm font-semibold text-slate-700 mb-3 flex items-center gap-1.5">
                    <span class="material-icons-round text-base" :class="category.iconColor" x-text="category.icon"></span>
                    <span x-text="category.label"></span>
                </h3>
                <div class="space-y-2">
                    <template x-for="(p, pidx) in patternsForCategory(category.key)" :key="pidx">
                        <div class="bg-white rounded-xl border border-slate-200 p-4 hover:shadow-sm transition-shadow"
                            :class="{
                                'border-l-4 border-l-red-500': p.severidade === 'critical',
                                'border-l-4 border-l-yellow-500': p.severidade === 'warning',
                                'border-l-4 border-l-blue-400': p.severidade === 'info'
                            }">
                            <div class="flex items-start justify-between gap-2">
                                <div class="flex-1">
                                    <p class="text-sm font-medium text-slate-800" x-text="p.descricao"></p>
                                    <p class="text-xs text-slate-500 mt-1" x-text="p.sugestao"></p>
                                </div>
                                <div class="text-right shrink-0">
                                    <span class="text-xs font-bold px-2 py-0.5 rounded-full"
                                        :class="{
                                            'bg-red-100 text-red-700': p.severidade === 'critical',
                                            'bg-yellow-100 text-yellow-700': p.severidade === 'warning',
                                            'bg-blue-100 text-blue-700': p.severidade === 'info'
                                        }" x-text="p.severidade"></span>
                                    <div class="text-[10px] text-slate-400 mt-1" x-text="p.ocorrencias + 'x'"></div>
                                </div>
                            </div>
                            <div x-show="p.primeiraOcorrencia" class="mt-2 text-[10px] text-slate-400">
                                <span x-text="p.primeiraOcorrencia ? new Date(p.primeiraOcorrencia).toLocaleString('pt-BR') : ''"></span>
                                <span x-show="p.ultimaOcorrencia && p.ultimaOcorrencia !== p.primeiraOcorrencia">
                                    &rarr; <span x-text="p.ultimaOcorrencia ? new Date(p.ultimaOcorrencia).toLocaleString('pt-BR') : ''"></span>
                                </span>
                            </div>
                            <!-- Ack buttons -->
                            <div x-show="p.alertaId" class="mt-3 pt-3 border-t border-slate-100 flex items-center gap-2 flex-wrap">
                                <span class="text-[10px] text-slate-400 mr-1">Marcar como:</span>
                                <template x-for="ackOpt in [
                                    { status: 'visto', label: 'Visto', icon: 'visibility', cls: 'text-slate-600 bg-slate-50 border-slate-200 hover:bg-slate-100' },
                                    { status: 'em_investigacao', label: 'Investigando', icon: 'manage_search', cls: 'text-amber-800 bg-amber-50 border-amber-200 hover:bg-amber-100' },
                                    { status: 'resolvido', label: 'Resolvido', icon: 'task_alt', cls: 'text-green-700 bg-green-50 border-green-200 hover:bg-green-100' }
                                ]" :key="ackOpt.status">
                                    <button @@click="ackAlerta(p, ackOpt.status)"
                                        class="flex items-center gap-1 px-2 py-1 text-[10px] font-medium border rounded-lg transition"
                                        :class="getAck(p) && getAck(p).status === ackOpt.status
                                            ? 'ring-2 ring-offset-1 ' + ackOpt.cls
                                            : ackOpt.cls">
                                        <span class="material-icons-round text-xs" x-text="ackOpt.icon"></span>
                                        <span x-text="ackOpt.label"></span>
                                        <span x-show="getAck(p) && getAck(p).status === ackOpt.status" class="ml-0.5">&#10003;</span>
                                    </button>
                                </template>
                                <span x-show="getAck(p)" class="text-[10px] text-slate-400 ml-auto" x-text="getAck(p) ? 'por ' + new Date(getAck(p).atualizadoEm).toLocaleDateString('pt-BR') : ''"></span>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </template>

        <!-- Quick Links -->
        <div class="mt-8 pt-6 border-t border-slate-200">
            <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Links Rapidos</h3>
            <div class="flex flex-wrap gap-2">
                <a href="/diagnostico/json" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1.5 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition text-slate-600">JSON Diagnostico</a>
                <a href="@(apiBase)/swagger" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1.5 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition text-slate-600">Swagger</a>
                <a href="@(apiBase)/api-docs/index.html" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1.5 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition text-slate-600">Console</a>
                <a href="@(apiBase)/health" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1.5 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition text-slate-600">/health</a>
                <a href="@(apiBase)/health/ready" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1.5 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition text-slate-600">/health/ready</a>
            </div>
        </div>
    </div>

</div>

<!-- ── ALPINE.JS APP ────────────────────────────────────────────────── -->
<script>
function diagApp() {
    return {
        activeTab: 'overview',
        refreshing: false,
        countdown: 60,
        countdownInterval: null,

        // Data
        endpoints: null,
        healthHistory: null,
        enhancedLogs: null,
        slo: null,
        eventos: null,
        acks: {},
        queriesLentas: null,
        empresasHealth: null,
        loadingEmpresasHealth: false,

        // Loading states
        loadingEndpoints: false,
        endpointsError: '',
        loadingLogs: false,
        clearingLogs: false,
        clearLogsMsg: '',
        clearLogsOk: true,
        savingStorage: false,
        saveStorageMsg: '',
        saveStorageOk: true,
        esvaziarLixeiraMsg: '',
        esvaziarLixeiraOk: true,
        zerandoMedidores: false,
        zerarMsg: '',
        zerarOk: true,
        expurgandoLogs: false,
        expurgarMsg: '',
        expurgarOk: true,
        lixeiraFiles: [],
        lixeiraTotalBytes: 0,
        storageFiles: [],
        loadingStorageFiles: false,
        selectedStorageFile: '',
        storageFileContent: null,
        loadingStorageContent: false,

        // Log filters
        logFilter: { level: 'ALL', search: '', groupByCorrelation: false },
        visibleLogs: 100,

        // Charts
        healthChartInstance: null,
        errorsChartInstance: null,
        logVolumeChartInstance: null,

        // Health-history auto-refresh interval (countdownInterval já declarado acima)
        healthRefreshInterval: null,

        // Admin flag
        isAdmin: @(isAdmin ? "true" : "false"),

        // Pattern categories
        patternCategories: [
            { key: 'deploy', label: 'Deploy & Restarts', icon: 'rocket_launch', iconColor: 'text-blue-500' },
            { key: 'migration', label: 'Migrations', icon: 'schema', iconColor: 'text-purple-500' },
            { key: 'error', label: 'Erros Recorrentes', icon: 'bug_report', iconColor: 'text-red-500' },
            { key: 'performance', label: 'Performance', icon: 'speed', iconColor: 'text-orange-500' },
            { key: 'config', label: 'Configuracao', icon: 'settings', iconColor: 'text-slate-500' },
        ],

        get errorCount24h() {
            return this.enhancedLogs?.resumo?.totalErrors ?? 0;
        },

        get endpointsFailed() {
            return this.endpoints?.falhas ?? 0;
        },

        get patterns() {
            return this.enhancedLogs?.padroes ?? [];
        },

        get filteredLogs() {
            if (!this.enhancedLogs?.entradas) return [];
            let entries = this.enhancedLogs.entradas;

            if (this.logFilter.level !== 'ALL') {
                if (this.logFilter.level === 'ERROR') {
                    entries = entries.filter(e => e.level === 'ERROR' || e.level === 'FATAL');
                } else {
                    entries = entries.filter(e => e.level === this.logFilter.level);
                }
            }

            if (this.logFilter.search) {
                const q = this.logFilter.search.toLowerCase();
                entries = entries.filter(e =>
                    e.message.toLowerCase().includes(q) ||
                    (e.endpoint && e.endpoint.toLowerCase().includes(q)) ||
                    (e.correlationId && e.correlationId.toLowerCase().includes(q))
                );
            }

            // Reverse to show newest first
            return [...entries].reverse();
        },

        patternsForCategory(catKey) {
            const typeMap = {
                deploy: ['deploy_restart'],
                migration: ['migration_failure'],
                error: ['repeated_error', 'error_spike'],
                performance: ['slow_endpoint', 'performance_regression'],
                config: ['config_warning'],
            };
            const types = typeMap[catKey] || [];
            return this.patterns.filter(p => types.includes(p.tipo));
        },

        getAck(p) { return this.acks[p.alertaId] ?? null; },

        async ackAlerta(p, status) {
            const r = await fetch(`/diagnostico/api/alertas/${p.alertaId}/ack`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            if (r.ok) {
                const data = await r.json();
                this.acks = { ...this.acks, [p.alertaId]: data };
            }
        },

        async init() {
            // Start countdown — guarda referencia para cleanup
            this.countdownInterval = setInterval(() => {
                if (this.refreshing) return; // evita disparo duplicado se refresh em andamento
                this.countdown--;
                if (this.countdown <= 0) {
                    this.countdown = 60;
                    this.refreshAll();
                }
            }, 1000);

            // Fetch data in parallel
            this.fetchEndpoints();
            this.fetchHealthHistory();
            this.fetchSlo();
            this.fetchEventos();
            this.fetchQueriesLentas();
            if (this.isAdmin) { this.fetchEnhancedLogs(); this.loadLixeira(); }

            // Auto-refresh health history every 60s — referencia preservada para cleanup
            this.healthRefreshInterval = setInterval(() => this.fetchHealthHistory(), 60000);

            // Limpa timers se a aba/janela for fechada para evitar fetch zumbi após o user sair
            window.addEventListener('beforeunload', () => this.cleanup());
        },

        cleanup() {
            if (this.countdownInterval) { clearInterval(this.countdownInterval); this.countdownInterval = null; }
            if (this.healthRefreshInterval) { clearInterval(this.healthRefreshInterval); this.healthRefreshInterval = null; }
        },

        async refreshAll() {
            this.refreshing = true;
            this.countdown = 60;
            await Promise.all([
                this.fetchEndpoints(),
                this.fetchHealthHistory(),
                this.fetchSlo(),
                this.fetchEventos(),
                this.isAdmin ? this.fetchEnhancedLogs() : Promise.resolve(),
            ]);
            this.refreshing = false;
        },

        async fetchEndpoints() {
            this.loadingEndpoints = true;
            this.endpointsError = '';
            try {
                const r = await fetch('/diagnostico/api/endpoints');
                if (r.ok) {
                    this.endpoints = await r.json();
                } else {
                    this.endpoints = null;
                    let msg = 'API inacessível (HTTP ' + r.status + ').';
                    try { const data = await r.json(); if (data?.error) msg = data.error; } catch (e) { /* ignora json malformado */ }
                    this.endpointsError = msg;
                }
            } catch (e) {
                console.error('endpoints fetch error', e);
                this.endpoints = null;
                this.endpointsError = 'Falha de rede ao consultar a API.';
                window.showToast && window.showToast('Erro ao carregar endpoints.', 'error');
            }
            this.loadingEndpoints = false;
        },

        async fetchHealthHistory() {
            try {
                const r = await fetch('/diagnostico/api/historico');
                if (r.ok) {
                    this.healthHistory = await r.json();
                    this.$nextTick(() => this.renderHealthChart());
                } else {
                    // 502 da API caiu — limpa para não exibir gráfico defasado como se fosse atual
                    this.healthHistory = null;
                }
            } catch (e) { console.error('historico fetch error', e); this.healthHistory = null; window.showToast && window.showToast('Erro ao carregar histórico.', 'error'); }
        },

        async fetchSlo() {
            try {
                const r = await fetch('/diagnostico/api/slo?hours=24');
                if (r.ok) this.slo = await r.json();
                else this.slo = null;
            } catch (e) { console.error('slo fetch error', e); this.slo = null; window.showToast && window.showToast('Erro ao carregar SLO.', 'error'); }
        },

        async fetchEventos() {
            try {
                const r = await fetch('/diagnostico/api/eventos?hours=48');
                if (r.ok) {
                    this.eventos = await r.json();
                    this.$nextTick(() => this.renderHealthChart());
                } else {
                    this.eventos = null;
                }
            } catch (e) { console.error('eventos fetch error', e); this.eventos = null; window.showToast && window.showToast('Erro ao carregar eventos.', 'error'); }
        },

        async fetchQueriesLentas() {
            try {
                const r = await fetch('/diagnostico/api/queries-lentas');
                if (r.ok) this.queriesLentas = await r.json();
                else this.queriesLentas = null;
            } catch (e) { console.error('queries-lentas fetch error', e); this.queriesLentas = null; window.showToast && window.showToast('Erro ao carregar queries lentas.', 'error'); }
        },

        async fetchAcks() {
            if (!this.patterns.length) return;
            // Deduplicar IDs antes do envio
            const ids = [...new Set(this.patterns.map(p => p.alertaId).filter(Boolean))];
            if (!ids.length) return;
            // Limitar a 200 IDs por request
            const batch = ids.slice(0, 200);
            try {
                const r = await fetch('/diagnostico/api/alertas/acks', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ids: batch })
                });
                if (r.ok) {
                    const data = await r.json();
                    const map = {};
                    (data.acks || []).forEach(a => { map[a.alertaId] = a; });
                    this.acks = map;
                }
            } catch (e) { console.error('acks fetch error', e); window.showToast && window.showToast('Erro ao carregar alertas.', 'error'); }
        },

        async fetchEmpresasHealth() {
            this.loadingEmpresasHealth = true;
            try {
                const r = await fetch('/diagnostico/api/health/empresas');
                if (r.ok) this.empresasHealth = await r.json();
            } catch (e) { console.error('empresas health fetch error', e); window.showToast && window.showToast('Erro ao carregar saúde das empresas.', 'error'); }
            this.loadingEmpresasHealth = false;
        },

        esvaziarLixeira() {
            const self = this;
            window.easyConfirm({
                titulo: 'Esvaziar lixeira de logs?',
                mensagem: 'Todos os logs na lixeira serão excluídos permanentemente. Esta ação não pode ser desfeita.',
                textoBotao: 'Esvaziar lixeira',
                classBotao: 'bg-red-600 hover:bg-red-700'
            }, () => self._esvaziarLixeira());
        },
        async _esvaziarLixeira() {
            try {
                const r = await fetch('/diagnostico/api/logs/lixeira/esvaziar', { method: 'POST' });
                if (r.ok) {
                    const data = await r.json();
                    this.esvaziarLixeiraOk = data.success !== false;
                    this.esvaziarLixeiraMsg = data.mensagem ?? 'Lixeira esvaziada.';
                } else {
                    this.esvaziarLixeiraOk = false;
                    this.esvaziarLixeiraMsg = 'Erro ao esvaziar lixeira (' + r.status + ').';
                }
            } catch (e) {
                this.esvaziarLixeiraOk = false;
                this.esvaziarLixeiraMsg = 'Erro de rede.';
            }
            setTimeout(() => { this.esvaziarLixeiraMsg = ''; }, 5000);
            this.loadLixeira();
        },

        zerarMedidores() {
            const self = this;
            window.easyConfirm({
                titulo: 'Zerar medidores e graficos?',
                mensagem: 'Todos os dados de health serao apagados. Novos dados comecam a ser coletados em ate 60 segundos.',
                textoBotao: 'Zerar medidores',
                classBotao: 'bg-amber-600 hover:bg-amber-700'
            }, () => self._zerarMedidores());
        },
        async _zerarMedidores() {
            this.zerandoMedidores = true;
            this.zerarMsg = '';
            try {
                const r = await fetch('/diagnostico/api/historico/zerar', { method: 'POST' });
                if (r.ok) {
                    const data = await r.json();
                    this.zerarOk = data.success !== false;
                    this.zerarMsg = data.mensagem ?? 'Medidores zerados.';
                    this.healthHistory = null;
                    await this.fetchHealthHistory();
                } else {
                    this.zerarOk = false;
                    this.zerarMsg = 'Erro ao zerar medidores (' + r.status + ').';
                }
            } catch (e) {
                this.zerarOk = false;
                this.zerarMsg = 'Erro de rede.';
            }
            this.zerandoMedidores = false;
            setTimeout(() => { this.zerarMsg = ''; }, 5000);
        },

        expurgarLogs() {
            // Admin-only: prompt nativo aceitavel para entrada numerica simples nesta tela.
            const dias = prompt('Quantos dias de logs manter? (1-30, padrão 3)', '3');
            if (dias === null) return;
            const n = parseInt(dias, 10);
            if (!Number.isFinite(n) || n < 1 || n > 30) {
                window.showToast && window.showToast('Valor deve ser entre 1 e 30.', 'warning');
                return;
            }
            const self = this;
            window.easyConfirm({
                titulo: 'Expurgar logs antigos?',
                mensagem: `Todos os logs com mais de ${n} dia(s) serao excluidos permanentemente.`,
                textoBotao: 'Expurgar',
                classBotao: 'bg-red-600 hover:bg-red-700'
            }, () => self._expurgarLogs(n));
        },
        async _expurgarLogs(n) {
            this.expurgandoLogs = true;
            this.expurgarMsg = '';
            try {
                const r = await fetch(`/diagnostico/api/logs/expurgar?diasManter=${n}`, { method: 'POST' });
                if (r.ok) {
                    const data = await r.json();
                    this.expurgarOk = data.success !== false;
                    this.expurgarMsg = data.mensagem ?? 'Expurgo concluído.';
                    await this.fetchEnhancedLogs();
                    this.loadLixeira();
                } else {
                    this.expurgarOk = false;
                    this.expurgarMsg = 'Erro ao expurgar (' + r.status + ').';
                }
            } catch (e) {
                this.expurgarOk = false;
                this.expurgarMsg = 'Erro de rede.';
            }
            this.expurgandoLogs = false;
            setTimeout(() => { this.expurgarMsg = ''; }, 5000);
        },

        async loadLixeira() {
            try {
                const r = await fetch('/diagnostico/api/logs/lixeira');
                if (r.ok) {
                    const data = await r.json();
                    this.lixeiraFiles = data.arquivos ?? [];
                    this.lixeiraTotalBytes = data.tamanhoTotalBytes ?? 0;
                }
            } catch (e) { console.error('lixeira fetch error', e); }
        },

        async loadStorageFiles() {
            this.loadingStorageFiles = true;
            try {
                const r = await fetch('/diagnostico/api/logs/storage');
                if (r.ok) {
                    const data = await r.json();
                    this.storageFiles = data.arquivos ?? [];
                }
            } catch (e) { console.error('storage files fetch error', e); }
            this.loadingStorageFiles = false;
        },

        async loadStorageFileContent(key) {
            if (!key) return;
            this.loadingStorageContent = true;
            this.storageFileContent = null;
            try {
                const r = await fetch(`/diagnostico/api/logs/storage/conteudo?file=${encodeURIComponent(key)}`);
                if (r.ok) {
                    this.storageFileContent = await r.json();
                }
            } catch (e) { console.error('storage content fetch error', e); }
            this.loadingStorageContent = false;
        },

        async fetchEnhancedLogs() {
            this.loadingLogs = true;
            const ac = new AbortController();
            const timeout = setTimeout(() => ac.abort(), 15000);
            try {
                const r = await fetch('/diagnostico/api/logs-enhanced?hours=48', { signal: ac.signal });
                clearTimeout(timeout);
                if (r.ok) {
                    this.enhancedLogs = await r.json();
                    if (this.enhancedLogs?.entradas) {
                        this.enhancedLogs.entradas.forEach(e => e._expanded = false);
                    }
                    this.$nextTick(() => {
                        this.renderErrorsChart();
                        this.renderLogVolumeChart();
                    });
                    this.$nextTick(() => this.fetchAcks());
                } else {
                    this.enhancedLogs = null;
                }
            } catch (e) {
                clearTimeout(timeout);
                console.error('enhanced logs fetch error', e);
                this.enhancedLogs = null;
            }
            this.loadingLogs = false;
        },

        limparLogs() {
            const self = this;
            window.easyConfirm({
                titulo: 'Mover logs para a lixeira?',
                mensagem: 'Todos os logs atuais serão movidos para a pasta lixeira. Você ainda pode excluí-los permanentemente em seguida.',
                textoBotao: 'Mover para lixeira',
                classBotao: 'bg-amber-600 hover:bg-amber-700'
            }, () => self._limparLogs());
        },
        async _limparLogs() {
            this.clearingLogs = true;
            this.clearLogsMsg = '';
            try {
                const r = await fetch('/diagnostico/api/logs/limpar', { method: 'POST' });
                if (r.ok) {
                    const data = await r.json();
                    this.clearLogsOk = data.success !== false;
                    this.clearLogsMsg = data.mensagem ?? 'Logs movidos para lixeira.';
                    this.enhancedLogs = null;
                    await this.fetchEnhancedLogs();
                    this.loadLixeira();
                } else if (r.status === 401 || r.status === 403) {
                    this.clearLogsOk = false;
                    this.clearLogsMsg = 'Sem permissão.';
                } else {
                    this.clearLogsOk = false;
                    this.clearLogsMsg = 'Erro ao comunicar com a API (' + r.status + ').';
                }
            } catch (e) {
                this.clearLogsOk = false;
                this.clearLogsMsg = 'Erro de rede.';
            }
            this.clearingLogs = false;
            setTimeout(() => { this.clearLogsMsg = ''; }, 5000);
        },

        salvarStorage() {
            const self = this;
            window.easyConfirm({
                titulo: 'Salvar logs no storage?',
                mensagem: 'Todos os logs atuais serao enviados para o storage configurado.',
                textoBotao: 'Salvar',
                classBotao: 'bg-indigo-600 hover:bg-indigo-700'
            }, () => self._salvarStorage());
        },
        async _salvarStorage() {
            this.savingStorage = true;
            this.saveStorageMsg = '';
            try {
                const r = await fetch('/diagnostico/api/logs/salvar-storage', { method: 'POST' });
                if (r.ok) {
                    const data = await r.json();
                    this.saveStorageOk = data.success !== false;
                    this.saveStorageMsg = data.mensagem + (data.url ? ' — ' + data.url : '');
                } else if (r.status === 401 || r.status === 403) {
                    this.saveStorageOk = false;
                    this.saveStorageMsg = 'Sem permissão para salvar logs no storage.';
                } else {
                    this.saveStorageOk = false;
                    this.saveStorageMsg = 'Erro ao comunicar com a API (' + r.status + ').';
                }
            } catch (e) {
                this.saveStorageOk = false;
                this.saveStorageMsg = 'Erro de rede ao salvar logs.';
            }
            this.savingStorage = false;
            setTimeout(() => { this.saveStorageMsg = ''; }, 8000);
        },

        renderHealthChart() {
            const canvas = document.getElementById('healthChart');
            if (!canvas || !this.healthHistory?.snapshots?.length) return;

            const snapshots = this.healthHistory.snapshots;
            const labels = snapshots.map(s => new Date(s.timestamp).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }));
            const apiData = snapshots.map(s => s.dbLatencyMs >= 0 ? s.dbLatencyMs : null);
            const errData = snapshots.map(s => s.errorCount);

            // Preparar eventos para overlay
            const eventosLista = this.eventos?.eventos ?? [];

            if (this.healthChartInstance) this.healthChartInstance.destroy();

            // Plugin inline para linhas verticais de eventos
            const eventLinesPlugin = {
                id: 'eventLines',
                afterDraw: (chart) => {
                    if (!eventosLista.length) return;
                    const ctx = chart.ctx;
                    const xAxis = chart.scales.x;
                    const yAxis = chart.scales.y;
                    if (!xAxis || !yAxis) return;

                    eventosLista.forEach(ev => {
                        const evTime = new Date(ev.timestamp).getTime();
                        // Encontrar label mais próximo
                        let nearestIdx = 0;
                        let minDiff = Infinity;
                        snapshots.forEach((s, i) => {
                            const diff = Math.abs(new Date(s.timestamp).getTime() - evTime);
                            if (diff < minDiff) { minDiff = diff; nearestIdx = i; }
                        });

                        const x = xAxis.getPixelForValue(nearestIdx);
                        const color = ev.tipo === 'error_spike' ? 'rgba(239,68,68,0.7)' : 'rgba(30, 72, 168,0.7)';
                        const label = ev.tipo === 'error_spike' ? '!' : '*';

                        ctx.save();
                        ctx.beginPath();
                        ctx.setLineDash([4, 3]);
                        ctx.strokeStyle = color;
                        ctx.lineWidth = 1.5;
                        ctx.moveTo(x, yAxis.top);
                        ctx.lineTo(x, yAxis.bottom);
                        ctx.stroke();
                        ctx.setLineDash([]);
                        ctx.fillStyle = color;
                        ctx.font = '11px sans-serif';
                        ctx.textAlign = 'center';
                        ctx.fillText(label, x, yAxis.top - 2);
                        ctx.restore();
                    });
                }
            };

            const css = getComputedStyle(document.documentElement);
            const navy = css.getPropertyValue('--navy-500').trim() || 'rgb(30, 72, 168)';
            const crit = css.getPropertyValue('--crit-600').trim() || 'rgb(239, 68, 68)';
            const grid = css.getPropertyValue('--ink-100').trim() || 'rgb(241, 245, 249)';
            this.healthChartInstance = new Chart(canvas, {
                type: 'line',
                data: {
                    labels,
                    datasets: [
                        {
                            label: 'DB Latencia (ms)',
                            data: apiData,
                            borderColor: navy,
                            backgroundColor: 'rgba(30, 72, 168, 0.1)',
                            fill: true,
                            tension: 0.3,
                            pointRadius: 1,
                            borderWidth: 2,
                        },
                        {
                            label: 'Erros/min',
                            data: errData,
                            borderColor: crit,
                            backgroundColor: 'rgba(239, 68, 68, 0.1)',
                            fill: true,
                            tension: 0.3,
                            pointRadius: 1,
                            borderWidth: 2,
                            yAxisID: 'y1',
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { position: 'top', labels: { boxWidth: 8, usePointStyle: true, font: { size: 10 } } },
                    },
                    scales: {
                        x: { ticks: { font: { size: 9 }, maxTicksLimit: 12 }, grid: { display: false } },
                        y: { beginAtZero: true, ticks: { font: { size: 9 }, callback: v => v + 'ms' }, grid: { color: grid } },
                        y1: { position: 'right', beginAtZero: true, ticks: { font: { size: 9 } }, grid: { display: false } },
                    }
                },
                plugins: [eventLinesPlugin]
            });
        },

        renderErrorsChart() {
            const canvas = document.getElementById('errorsChart');
            if (!canvas || !this.enhancedLogs?.resumo) return;

            const hours = this.enhancedLogs.resumo.errorsByHour || {};
            const reqHours = this.enhancedLogs.resumo.requestsByHour || {};
            const allHours = [...new Set([...Object.keys(hours), ...Object.keys(reqHours)])].sort();
            const labels = allHours.map(h => h + ':00');
            const errData = allHours.map(h => hours[h] || 0);
            const reqData = allHours.map(h => reqHours[h] || 0);

            if (this.errorsChartInstance) this.errorsChartInstance.destroy();

            const errCss = getComputedStyle(document.documentElement);
            const errNavy = errCss.getPropertyValue('--navy-500').trim() || 'rgb(30, 72, 168)';
            const errCrit = errCss.getPropertyValue('--crit-600').trim() || 'rgb(239, 68, 68)';
            const errGrid = errCss.getPropertyValue('--ink-100').trim() || 'rgb(241, 245, 249)';
            this.errorsChartInstance = new Chart(canvas, {
                type: 'bar',
                data: {
                    labels,
                    datasets: [
                        {
                            label: 'Requests',
                            data: reqData,
                            backgroundColor: 'rgba(30, 72, 168, 0.15)',
                            borderColor: errNavy,
                            borderWidth: 1,
                            borderRadius: 3,
                        },
                        {
                            label: 'Erros',
                            data: errData,
                            backgroundColor: 'rgba(239, 68, 68, 0.6)',
                            borderColor: errCrit,
                            borderWidth: 1,
                            borderRadius: 3,
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', labels: { boxWidth: 8, usePointStyle: true, font: { size: 10 } } },
                    },
                    scales: {
                        x: { ticks: { font: { size: 9 } }, grid: { display: false } },
                        y: { beginAtZero: true, ticks: { font: { size: 9 } }, grid: { color: errGrid } },
                    }
                }
            });
        },

        renderLogVolumeChart() {
            const canvas = document.getElementById('logVolumeChart');
            if (!canvas || !this.enhancedLogs?.resumo) return;

            const reqHours = this.enhancedLogs.resumo.requestsByHour || {};
            const errHours = this.enhancedLogs.resumo.errorsByHour || {};
            const allHours = [...new Set([...Object.keys(reqHours), ...Object.keys(errHours)])].sort();
            const labels = allHours.map(h => h + 'h');

            if (this.logVolumeChartInstance) this.logVolumeChartInstance.destroy();

            const volCss = getComputedStyle(document.documentElement);
            const volNavy = volCss.getPropertyValue('--navy-200').trim() || 'rgb(199, 210, 254)';
            const volCrit = volCss.getPropertyValue('--crit-200').trim() || 'rgb(252, 165, 165)';
            const volGrid = volCss.getPropertyValue('--ink-100').trim() || 'rgb(241, 245, 249)';
            this.logVolumeChartInstance = new Chart(canvas, {
                type: 'bar',
                data: {
                    labels,
                    datasets: [
                        {
                            label: 'Logs',
                            data: allHours.map(h => reqHours[h] || 0),
                            backgroundColor: volNavy,
                            borderRadius: 2,
                        },
                        {
                            label: 'Erros',
                            data: allHours.map(h => errHours[h] || 0),
                            backgroundColor: volCrit,
                            borderRadius: 2,
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { stacked: true, ticks: { font: { size: 8 } }, grid: { display: false } },
                        y: { stacked: true, ticks: { font: { size: 8 } }, grid: { color: volGrid } },
                    }
                }
            });
        },
    };
}
</script>
</body>
</html>
