@model LotesMobileViewModel
@{
    ViewBag.Title = "Lotes (mobile)";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Lotes do app</h1>
        <p>Revise lotes criados no app pelo operador e linke ao ERP</p>
    </div>
    <a href="/lotes" class="btn-outline-dark">← Lotes ERP</a>
</div>

<div class="ws mb-6">
    <form method="get" class="flex gap-3 items-center">
        <div class="filter-tab-group">
        @foreach (var (val, label) in new[] { ("false", "Todos"), ("true", "Pendentes") })
        {
            var isActive = (val == "true") == Model.PendingOnly;
            <a href="@Url.Action("Index", "LotesMobile", new { pendingOnly = val == "true" })"
               class="filter-tab @(isActive ? "active" : "")">@label</a>
        }
        </div>
        <span class="text-sm text-slate-500 ml-auto">@Model.Items.Count lote(s)</span>
    </form>
</div>

<div class="ws">
    @if (!Model.Items.Any())
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIllustration", "inbox" },
            { "EmptyTitle", "Nenhum lote do app" },
            { "EmptyDescription", "Lotes criados no app aparecem aqui para revisão." }
        })
    }
    else
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead><tr><th>Código</th><th>Lote</th><th>Data</th><th>Origem</th><th>ERP</th><th></th></tr></thead>
            <tbody>
            @foreach (var m in Model.Items)
            {
                <tr>
                    <td class="font-mono text-sm">@m.Code</td>
                    <td class="text-xs text-slate-500">@(m.Lote ?? "—")</td>
                    <td class="text-xs text-slate-500">@m.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                    <td class="text-xs text-slate-500">
                        @(m.LastOperatorName ?? "—")
                        @if (!string.IsNullOrEmpty(m.LastDeviceId)) { <div class="text-slate-400">@m.LastDeviceId</div> }
                    </td>
                    <td>
                        @if (m.Linked)
                        {
                            <span class="text-xs px-2 py-0.5 bg-green-100 text-green-700 rounded-full">✓ linkado</span>
                            <a href="/lotes/@m.ErpLoteId" class="text-xs text-indigo-600 hover:text-indigo-700 ml-1">abrir</a>
                        }
                        else
                        {
                            <span class="text-xs px-2 py-0.5 bg-amber-100 text-amber-800 rounded-full">pendente</span>
                        }
                    </td>
                    <td class="text-right">
                        @if (!m.Linked)
                        {
                            <div x-data="{ openLink: false }" class="inline-block relative">
                                <button type="button" @@click="openLink = !openLink" class="text-sm text-indigo-600 hover:text-indigo-700">Linkar / Promover</button>
                                <div x-show="openLink" x-cloak @@click.outside="openLink = false" class="absolute right-0 mt-1 w-72 bg-white border border-slate-200 rounded-lg shadow-lg z-10 p-3">
                                    <form asp-action="Promover" asp-controller="LotesMobile" asp-route-id="@m.Id" method="post" class="mb-3">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="w-full px-3 py-2 bg-indigo-600 text-white text-sm font-medium rounded hover:bg-indigo-700">➕ Promover (criar Lote ERP)</button>
                                    </form>
                                    <form asp-action="Link" asp-controller="LotesMobile" asp-route-id="@m.Id" method="post" class="border-t pt-3">
                                        @Html.AntiForgeryToken()
                                        <label class="block text-xs text-slate-600 mb-1">Linkar a Lote ERP existente:</label>
                                        <select name="erpLoteId" required class="ui-select w-full text-sm mb-2">
                                            <option value="">— escolha —</option>
                                            @foreach (var ep in Model.ErpLotes) { <option value="@ep.Id">@ep.Codigo · @ep.DataProducao.ToLocalTime().ToString("dd/MM")</option> }
                                        </select>
                                        <button type="submit" class="btn-outline-dark w-full justify-center">🔗 Linkar</button>
                                    </form>
                                </div>
                            </div>
                        }
                        else
                        {
                            <form asp-action="Unlink" asp-controller="LotesMobile" asp-route-id="@m.Id" method="post" data-confirm='{"titulo":"Desfazer link?","mensagem":"Este lote voltara a ser tratado como mobile-only.","textoBotao":"Desfazer","classBotao":"bg-red-600 hover:bg-red-700"}'>
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-sm text-red-600 hover:text-red-700">Desfazer link</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }
</div>
