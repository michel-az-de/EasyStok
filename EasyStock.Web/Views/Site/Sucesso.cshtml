@{
    Layout = "_LayoutSite";
    ViewBag.Title = "Mensagem enviada";
    ViewBag.Description = "Recebemos seu contato.";
}

<section class="site-section" style="padding-top:96px;text-align:center">
    <div class="site-container" style="max-width:640px">
        <div style="font-size:64px;line-height:1;margin-bottom:16px">✓</div>
        <h1 style="font-size:clamp(28px,3.6vw,42px);font-weight:800;letter-spacing:-0.02em;margin:0 0 16px">
            Recebemos sua mensagem.
        </h1>
        <p style="font-size:17px;color:var(--ink-700);line-height:1.55;margin:0 0 32px">
            A gente responde em ate 1 dia util. Se for urgente, fala no WhatsApp.
        </p>

        <div class="site-hero-ctas" style="justify-content:center">
            <a href="/" class="btn btn-secondary">Voltar ao inicio</a>
            <a href="/auth/registrar?origem=sucesso" class="btn btn-primary">Testar gratis enquanto isso</a>
        </div>
    </div>
</section>
