@model EasyStock.Web.Models.ViewModels.Site.ContatoViewModel
@inject Microsoft.Extensions.Options.IOptions<EasyStock.Web.Services.MarketingOptions> MarketingOpts
@{
    Layout = "_LayoutSite";
    ViewBag.Title = "Fale com a gente";
    ViewBag.Description = "Dúvida, parceria, suporte: a gente responde em até 1 dia útil.";
    var marketing = MarketingOpts.Value;
}

<section class="site-section" style="padding-top:64px">
    <div class="site-container">
        <div class="site-section-h">
            <span class="eyebrow">Fale com a gente</span>
            <h2>Sem formulário de 12 campos. <span class="hl">Direto ao ponto.</span></h2>
            <p>A gente responde em até 1 dia útil. Se for urgente, fala no <a href="@marketing.LinkWhatsApp" target="_blank" rel="noopener noreferrer" style="color:var(--orange-600);font-weight:600">WhatsApp</a>.</p>
        </div>

        <form asp-controller="Site" asp-action="Contato" method="post" class="site-form" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="site-form-error"></div>

            <div class="site-form-grid">
                <div class="site-form-field">
                    <label asp-for="Nome">Como te chamamos?</label>
                    <input asp-for="Nome" type="text" required maxlength="150" autocomplete="name" />
                    <span asp-validation-for="Nome" class="site-form-error"></span>
                </div>
                <div class="site-form-field">
                    <label asp-for="Email">E-mail</label>
                    <input asp-for="Email" type="email" required maxlength="255" autocomplete="email" />
                    <span asp-validation-for="Email" class="site-form-error"></span>
                </div>
                <div class="site-form-field">
                    <label asp-for="Telefone">Telefone (opcional)</label>
                    <input asp-for="Telefone" type="tel" maxlength="32" autocomplete="tel" />
                    <span asp-validation-for="Telefone" class="site-form-error"></span>
                </div>
                <div class="site-form-field">
                    <label asp-for="Empresa">Empresa (opcional)</label>
                    <input asp-for="Empresa" type="text" maxlength="150" autocomplete="organization" />
                    <span asp-validation-for="Empresa" class="site-form-error"></span>
                </div>
                <div class="site-form-field" style="grid-column:1/-1">
                    <label asp-for="TipoNegocio">Tipo de negócio (opcional)</label>
                    <select asp-for="TipoNegocio">
                        <option value="">Escolha...</option>
                        <option value="Marmitaria">Marmitaria</option>
                        <option value="Cafe">Café / cafeteria</option>
                        <option value="Hamburgueria">Hamburgueria</option>
                        <option value="Pizzaria">Pizzaria</option>
                        <option value="DarkKitchen">Dark kitchen</option>
                        <option value="Restaurante">Restaurante</option>
                        <option value="Conveniencia">Conveniência</option>
                        <option value="Outro">Outro</option>
                    </select>
                </div>
                <div class="site-form-field" style="grid-column:1/-1">
                    <label asp-for="Mensagem">Mensagem</label>
                    <textarea asp-for="Mensagem" required maxlength="2000" placeholder="Conta um pouco do seu cenário, da operação, da dúvida..."></textarea>
                    <span asp-validation-for="Mensagem" class="site-form-error"></span>
                </div>
            </div>

            @* Honeypot: bots preenchem; humanos não veem (CSS .site-honeypot esconde fora do viewport). *@
            <input asp-for="Website" type="text" tabindex="-1" autocomplete="off" class="site-honeypot" aria-hidden="true" />
            <input asp-for="UtmSource" type="hidden" />
            <input asp-for="UtmMedium" type="hidden" />
            <input asp-for="UtmCampaign" type="hidden" />

            <label class="site-form-check">
                <input asp-for="ReceberNewsletter" type="checkbox" />
                <span>Quero receber novidades do EasyStok no e-mail (sem spam, você sai quando quiser).</span>
            </label>
            <label class="site-form-check">
                <input asp-for="ConsentimentoLgpd" type="checkbox" required />
                <span>Concordo com a <a href="/privacidade" target="_blank" rel="noopener noreferrer">Política de Privacidade</a> e autorizo o EasyStok a entrar em contato.</span>
            </label>
            <span asp-validation-for="ConsentimentoLgpd" class="site-form-error"></span>

            <div class="site-form-actions">
                <button type="submit" class="btn btn-primary btn-lg">Enviar mensagem</button>
                <a href="@marketing.LinkWhatsApp" class="btn-link" target="_blank" rel="noopener noreferrer" style="border-color:var(--border-strong);color:var(--ink-700)" data-track="contato-whatsapp">
                    Prefiro WhatsApp →
                </a>
            </div>
        </form>
    </div>
</section>
