@model EasyStock.Web.Models.ViewModels.Site.ContatoViewModel
@{
    Layout = "_LayoutSite";
    ViewBag.Title = "Fale com a gente";
    ViewBag.Description = "Duvida, parceria, suporte: a gente responde em ate 1 dia util.";
    var marketing = (EasyStock.Web.Services.MarketingOptions)ViewBag.Marketing;
}

<section class="site-section" style="padding-top:64px">
    <div class="site-container">
        <div class="site-section-h">
            <span class="eyebrow">Fale com a gente</span>
            <h2>Sem formulario de 12 campos. <span class="hl">Direto ao ponto.</span></h2>
            <p>A gente responde em ate 1 dia util. Se for urgente, fala no <a href="@marketing.LinkWhatsApp" target="_blank" rel="noopener noreferrer" style="color:var(--orange-600);font-weight:600">WhatsApp</a>.</p>
        </div>

        <form asp-controller="Site" asp-action="Contato" method="post" class="site-form" novalidate>
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
            {
                <div class="site-form-error">
                    @foreach (var error in ViewData.ModelState[""].Errors)
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <div class="site-form-grid">
                <div class="site-form-field">
                    <label for="Nome">Como te chamamos?</label>
                    <input asp-for="Nome" id="Nome" type="text" required maxlength="150" autocomplete="name" />
                    <span asp-validation-for="Nome" class="site-form-error" style="display:@(ViewData.ModelState["Nome"]?.Errors.Count > 0 ? "block" : "none")"></span>
                </div>
                <div class="site-form-field">
                    <label for="Email">E-mail</label>
                    <input asp-for="Email" id="Email" type="email" required maxlength="255" autocomplete="email" />
                    <span asp-validation-for="Email" class="site-form-error" style="display:@(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "block" : "none")"></span>
                </div>
                <div class="site-form-field">
                    <label for="Telefone">Telefone (opcional)</label>
                    <input asp-for="Telefone" id="Telefone" type="tel" maxlength="32" autocomplete="tel" />
                </div>
                <div class="site-form-field">
                    <label for="Empresa">Empresa (opcional)</label>
                    <input asp-for="Empresa" id="Empresa" type="text" maxlength="150" autocomplete="organization" />
                </div>
                <div class="site-form-field" style="grid-column:1/-1">
                    <label for="TipoNegocio">Tipo de negocio (opcional)</label>
                    <select asp-for="TipoNegocio" id="TipoNegocio">
                        <option value="">Escolha...</option>
                        <option value="Marmitaria">Marmitaria</option>
                        <option value="Cafe">Cafe / cafeteria</option>
                        <option value="Hamburgueria">Hamburgueria</option>
                        <option value="Pizzaria">Pizzaria</option>
                        <option value="DarkKitchen">Dark kitchen</option>
                        <option value="Restaurante">Restaurante</option>
                        <option value="Conveniencia">Conveniencia</option>
                        <option value="Outro">Outro</option>
                    </select>
                </div>
                <div class="site-form-field" style="grid-column:1/-1">
                    <label for="Mensagem">Mensagem</label>
                    <textarea asp-for="Mensagem" id="Mensagem" required maxlength="2000" placeholder="Conta um pouco do seu cenario, da operacao, da duvida..."></textarea>
                    <span asp-validation-for="Mensagem" class="site-form-error" style="display:@(ViewData.ModelState["Mensagem"]?.Errors.Count > 0 ? "block" : "none")"></span>
                </div>
            </div>

            <input asp-for="Website" type="text" tabindex="-1" autocomplete="off" class="site-honeypot" aria-hidden="true" />
            <input asp-for="UtmSource" type="hidden" />
            <input asp-for="UtmMedium" type="hidden" />
            <input asp-for="UtmCampaign" type="hidden" />

            <label class="site-form-check">
                <input asp-for="ReceberNewsletter" type="checkbox" />
                <span>Quero receber novidades do EasyStok no e-mail (sem spam, voce sai quando quiser).</span>
            </label>
            <label class="site-form-check">
                <input asp-for="ConsentimentoLgpd" type="checkbox" required />
                <span>Concordo com a <a href="/privacidade" target="_blank" rel="noopener noreferrer">Politica de Privacidade</a> e autorizo o EasyStok a entrar em contato.</span>
            </label>
            <span asp-validation-for="ConsentimentoLgpd" class="site-form-error" style="display:@(ViewData.ModelState["ConsentimentoLgpd"]?.Errors.Count > 0 ? "block" : "none")"></span>

            <div class="site-form-actions">
                <button type="submit" class="btn btn-primary btn-lg">Enviar mensagem</button>
                <a href="@marketing.LinkWhatsApp" class="btn-link" target="_blank" rel="noopener noreferrer" style="border-color:var(--border-strong);color:var(--ink-700)" data-track="contato-whatsapp">
                    Prefiro WhatsApp →
                </a>
            </div>
        </form>
    </div>
</section>
