@model EasyStock.Web.Models.ViewModels.Site.LandingViewModel
@{
    Layout = "_LayoutSite";
    ViewBag.Title = "Estoque vivo para foodservice";
    ViewBag.Description = "EasyStok controla estoque, validade, lote, compras e movimentacao no celular para pequenos negocios de foodservice. Teste gratis por 14 dias.";
    var contatoFinalUrl = "/contato?origem=cta-final&assunto=" + Uri.EscapeDataString("Gostaria de saber mais sobre o EasyStok");
}

<section class="site-hero site-hero--production">
    <div class="site-container site-hero-grid">
        <div class="site-hero-copy">
            <span class="site-hero-pill"><span class="pulse"></span> SaaS de estoque para foodservice</span>
            <h1>Estoque, validade e compras sob controle antes da cozinha abrir.</h1>
            <p class="site-hero-lead">
                EasyStok tira a operacao da planilha e coloca entrada, saida, lote, validade, equipe e loja no celular.
                Feito para marmitaria, cafe, hamburgueria, dark kitchen e conveniencia que precisam decidir rapido.
            </p>
            <div class="site-hero-ctas">
                <a href="/auth/registrar?origem=hero-teste" class="btn btn-primary btn-lg" data-track="hero-teste">
                    Testar gratis por 14 dias
                </a>
                <a href="#produto" class="btn-link" data-track="hero-produto">
                    Ver produto
                </a>
            </div>
            <div class="site-hero-trust" aria-label="Garantias do teste">
                <span class="it"><span class="check">OK</span> Sem cartao</span>
                <span class="it"><span class="check">OK</span> Cancela quando quiser</span>
                <span class="it"><span class="check">OK</span> Onboarding com pessoa real</span>
            </div>
        </div>

        <aside class="site-product-visual" aria-label="EasyStok em operacao">
            <img src="~/img/landing-ops.jpg" alt="Celular com painel de estoque EasyStok em uma cozinha organizada" loading="eager" />
            <div class="site-visual-panel site-visual-panel--top">
                <span class="label">Alerta hoje</span>
                <strong>12 itens</strong>
                <span>validade proxima</span>
            </div>
            <div class="site-visual-panel site-visual-panel--bottom">
                <span class="label">Reposicao</span>
                <strong>R$ 1.560</strong>
                <span>risco mensal evitavel</span>
            </div>
        </aside>
    </div>
</section>

<section class="site-proof">
    <div class="site-container site-proof-grid">
        <div>
            <strong>7 dias</strong>
            <span>para sair da planilha</span>
        </div>
        <div>
            <strong>offline</strong>
            <span>no celular da equipe</span>
        </div>
        <div>
            <strong>multi-loja</strong>
            <span>com perfil de acesso</span>
        </div>
        <div>
            <strong>auditoria</strong>
            <span>de cada ajuste</span>
        </div>
    </div>
</section>

<section class="site-section" id="produto">
    <div class="site-container">
        <div class="site-section-h site-section-h--left">
            <span class="eyebrow">Produto</span>
            <h2>O controle diario que a planilha nao entrega.</h2>
            <p>As telas foram pensadas para a rotina de cozinha: registrar rapido, consultar sem friccao e enxergar problema antes de virar perda.</p>
        </div>

        <div class="site-feature-grid">
            <article class="site-feature-card accent">
                <span class="site-feature-icon">01</span>
                <h3>Validade e lote</h3>
                <p>Veja o que vence primeiro, acompanhe lote e reduza produto esquecido no fundo da geladeira.</p>
            </article>
            <article class="site-feature-card">
                <span class="site-feature-icon">02</span>
                <h3>Entrada e saida no celular</h3>
                <p>Equipe registra compra, consumo e perda sem depender de computador ou planilha aberta.</p>
            </article>
            <article class="site-feature-card">
                <span class="site-feature-icon">03</span>
                <h3>Reposicao e compras</h3>
                <p>Saiba o que esta acabando, evite compra duplicada e monte lista de reposicao com base no estoque real.</p>
            </article>
            <article class="site-feature-card">
                <span class="site-feature-icon">04</span>
                <h3>Auditoria de equipe</h3>
                <p>Cada ajuste mostra quem mexeu, quando mexeu e qual foi o motivo. Sem conversa perdida no WhatsApp.</p>
            </article>
        </div>
    </div>
</section>

<section class="site-section site-section--alt" id="como-funciona">
    <div class="site-container site-split">
        <div class="site-section-h site-section-h--left">
            <span class="eyebrow">Implantacao</span>
            <h2>Operacao rodando em uma semana.</h2>
            <p>Nada de projeto de tres meses. A implantacao comeca pequena, com os produtos que mais doem, e cresce com a rotina.</p>
        </div>

        <div class="site-days">
            <div class="site-day done">
                <div class="num"><strong>1-2</strong>dia</div>
                <div class="body">
                    <h4>Cadastro guiado</h4>
                    <p>Empresa, loja, usuarios e primeiros produtos. Foto da planilha ajuda no ponto de partida.</p>
                </div>
                <div class="out"><span>Base pronta</span>sem travar a rotina</div>
            </div>
            <div class="site-day done">
                <div class="num"><strong>3-4</strong>dia</div>
                <div class="body">
                    <h4>Equipe no celular</h4>
                    <p>Quem recebe compra, quem baixa consumo e quem acompanha validade aprende no fluxo real.</p>
                </div>
                <div class="out"><span>Uso real</span>no balcao</div>
            </div>
            <div class="site-day done">
                <div class="num"><strong>5-7</strong>dia</div>
                <div class="body">
                    <h4>Primeiros numeros</h4>
                    <p>Voce enxerga ruptura, validade proxima, excesso de compra e movimentacao da semana.</p>
                </div>
                <div class="out"><span>Decisao</span>com dado</div>
            </div>
        </div>
    </div>
</section>

<section class="site-section" id="para-quem">
    <div class="site-container">
        <div class="site-section-h">
            <span class="eyebrow">Encaixe</span>
            <h2>Feito para quem tem estoque pequeno, vivo e caro demais para errar.</h2>
        </div>
        <div class="site-fornot">
            <div class="col yes">
                <h3>Serve bem para</h3>
                <p class="sub">Foodservice com equipe enxuta e operacao acontecendo todo dia.</p>
                <ul>
                    <li>Marmitaria, cafe, dark kitchen, hamburgueria, pizzaria e conveniencia</li>
                    <li>1 a 5 lojas, equipe de 2 a 15 pessoas</li>
                    <li>Quem perde dinheiro com vencimento, ruptura ou compra duplicada</li>
                    <li>Quem precisa de celular, offline e trilha de auditoria</li>
                </ul>
            </div>
            <div class="col no">
                <h3>Nao e o foco hoje</h3>
                <p class="sub">Melhor ser direto antes do cadastro.</p>
                <ul>
                    <li>Emissao fiscal dentro do sistema</li>
                    <li>Marketplace como Mercado Livre, Shopee ou Magalu</li>
                    <li>BI avancado, OCR de nota ou automacao fiscal complexa</li>
                    <li>Operacao que so quer testar sem envolver a equipe</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="site-section site-section--alt" id="planos">
    <div class="site-container">
        <div class="site-section-h">
            <span class="eyebrow">Precos</span>
            <h2>Comece gratis. Pague quando o estoque ja estiver organizado.</h2>
            <p>14 dias gratis, sem cartao e sem fidelidade.</p>
        </div>
        <div class="site-pricing">
            <article class="site-plan">
                <span class="site-plan-name">Trial</span>
                <h3 class="site-plan-headline">Validar na rotina real.</h3>
                <div class="site-plan-price">
                    <span class="num">R$ 0</span>
                    <span class="per">/ 14 dias</span>
                </div>
                <p class="site-plan-meta">Tudo liberado para testar com equipe e loja real.</p>
                <ul>
                    <li>1 loja, ate 100 produtos</li>
                    <li>Validade, lote, entrada e saida</li>
                    <li>Web + celular PWA</li>
                    <li>Suporte por WhatsApp</li>
                </ul>
                <a href="/auth/registrar?origem=plano-inicial" class="btn btn-secondary" data-track="plano-inicial">Comecar gratis</a>
            </article>

            <article class="site-plan featured">
                <span class="site-plan-tag">Founder</span>
                <span class="site-plan-name">Foodservice</span>
                <h3 class="site-plan-headline">Operacao real, multi-loja, equipe.</h3>
                <div class="site-plan-price">
                    <span class="crossed">R$ 149</span>
                    <span class="num">R$ 79</span>
                    <span class="per">/ mes por 6 meses</span>
                </div>
                <p class="site-plan-meta">Vagas founder limitadas para negocios que vao usar e dar feedback.</p>
                <ul>
                    <li>Lojas e produtos ilimitados</li>
                    <li>Auditoria completa dos ajustes</li>
                    <li>Notificacao de validade por WhatsApp</li>
                    <li>Onboarding 1:1 com o fundador</li>
                    <li>Acesso direto ao roadmap</li>
                </ul>
                <a href="/auth/registrar?origem=plano-founder" class="btn btn-primary" data-track="plano-founder">Quero ser founder</a>
            </article>
        </div>
    </div>
</section>

<section class="site-section" id="faq">
    <div class="site-container">
        <div class="site-section-h">
            <span class="eyebrow">FAQ</span>
            <h2>Perguntas que valem antes de entrar.</h2>
        </div>
        <div class="site-faq">
            <details>
                <summary>EasyStok emite nota fiscal?</summary>
                <p>Nao. O foco atual e estoque operacional. Se voce precisa de NFe ou NFC-e dentro do sistema, hoje uma ferramenta fiscal dedicada e o caminho certo.</p>
            </details>
            <details>
                <summary>Funciona offline?</summary>
                <p>Sim. O PWA funciona no celular e sincroniza quando o sinal volta. Isso evita parar recebimento, contagem e baixa de produto por queda de internet.</p>
            </details>
            <details>
                <summary>Quanto tempo leva para implantar?</summary>
                <p>A meta e 7 dias para estar usando com dados reais. O primeiro ciclo cobre cadastro, equipe, rotina de entrada e saida, validade e primeiros relatorios.</p>
            </details>
            <details>
                <summary>Posso cancelar quando quiser?</summary>
                <p>Pode. Sem fidelidade e sem multa. Seus dados ficam exportaveis para voce nao ficar preso na ferramenta.</p>
            </details>
            <details>
                <summary>Meus dados ficam seguros?</summary>
                <p>O EasyStok usa login com JWT, separacao por empresa, banco PostgreSQL, criptografia em transito e trilha de auditoria nas operacoes sensiveis.</p>
            </details>
        </div>
    </div>
</section>

<section class="site-final">
    <div class="site-container site-final-inner">
        <h2>Coloque o estoque para trabalhar junto com a cozinha.</h2>
        <p>Comece pelo que mais vence, mais falta ou mais some. Em uma semana voce ja tem rotina, equipe e numero para decidir.</p>
        <div class="site-hero-ctas" style="justify-content:center">
            <a href="/auth/registrar?origem=cta-final" class="btn btn-primary btn-lg" data-track="cta-final-teste">
                Testar gratis por 14 dias
            </a>
            <a href="@contatoFinalUrl" class="btn-link" data-track="cta-final-fale">
                Falar com a gente
            </a>
        </div>
    </div>
</section>
