@using EasyStock.Web.Services
@model List<MobileDeviceApi>
@{
    ViewBag.Title = "Dispositivos";
    Layout = "_Layout";
    var pairingCode = TempData["PairingCode"] as string;
    var pairingExpiresAt = TempData["PairingExpiresAt"] as string;
    var ativos = Model.Where(d => !d.Revoked && !d.PendingPair).ToList();
    var pendentes = Model.Where(d => d.PendingPair && !d.Revoked).ToList();
    var revogados = Model.Where(d => d.Revoked).ToList();
    // Onda 7 — health agregada por id
    var healthById = ViewBag.HealthById as Dictionary<string, DeviceHealthApi>
                     ?? new Dictionary<string, DeviceHealthApi>();
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Dispositivos pareados</h1>
        <p>@ativos.Count ativo@(ativos.Count == 1 ? "" : "s") · @pendentes.Count aguardando · @revogados.Count revogado@(revogados.Count == 1 ? "" : "s")</p>
    </div>
    <button type="button"
            x-data @@click="$dispatch('open-modal', 'parear-device')"
            class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
        + Parear novo dispositivo
    </button>
</div>

@if (!string.IsNullOrEmpty(pairingCode))
{
    <div class="ws mb-6 p-6 border-2 border-indigo-500 bg-indigo-50 rounded-xl text-center">
        <h2 class="text-lg font-semibold text-slate-900 mb-2">Código de pareamento</h2>
        <p class="text-sm text-slate-600 mb-4">Digite no aplicativo. Válido por 10 minutos.</p>
        <div class="text-5xl font-mono font-bold tracking-widest text-indigo-700 my-4">@pairingCode</div>
        <p class="text-xs text-slate-500">Expira em @pairingExpiresAt</p>
    </div>
}

<div class="ws">
    @if (!Model.Any())
    {
        <div class="p-12 text-center">
            <div class="text-6xl mb-4">📱</div>
            <h2 class="text-lg font-semibold text-slate-900 mb-2">Nenhum dispositivo pareado</h2>
            <p class="text-sm text-slate-500 mb-4">Pareie um celular ou tablet pra começar a usar o app Casa da Baba.</p>
            <button type="button"
                    x-data @@click="$dispatch('open-modal', 'parear-device')"
                    class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                + Parear novo dispositivo
            </button>
        </div>
    }
    else
    {
        <table class="w-full">
            <thead>
                <tr class="text-left text-xs text-slate-500 uppercase tracking-wider border-b border-slate-200">
                    <th class="px-4 py-3">Dispositivo</th>
                    <th class="px-4 py-3">Operador padrão</th>
                    <th class="px-4 py-3">Última atividade</th>
                    <th class="px-4 py-3">Saúde</th>
                    <th class="px-4 py-3">Status</th>
                    <th class="px-4 py-3 text-right">Ações</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var d in Model.OrderBy(x => x.Revoked).ThenByDescending(x => x.LastSeenAt ?? x.PairedAt ?? DateTime.MinValue))
                {
                    <tr class="@(d.Revoked ? "opacity-50" : "")">
                        <td class="px-4 py-3">
                            <div class="font-medium text-slate-900">@(d.Label ?? "(sem rótulo)")</div>
                            <div class="text-xs text-slate-500 font-mono">@(d.Id.Length > 16 ? d.Id[..16] + "…" : d.Id)</div>
                        </td>
                        <td class="px-4 py-3 text-sm text-slate-700">@(d.DefaultOperatorName ?? "—")</td>
                        <td class="px-4 py-3 text-sm text-slate-700">
                            @if (d.LastSeenAt.HasValue)
                            {
                                <span title="@d.LastSeenAt">@d.LastSeenAt.Value.ToString("dd/MM HH:mm")</span>
                                if (!string.IsNullOrEmpty(d.LastSeenIp))
                                {
                                    <span class="text-xs text-slate-400 ml-1">(@d.LastSeenIp)</span>
                                }
                            }
                            else
                            {
                                <span class="text-slate-400">nunca</span>
                            }
                        </td>
                        <td class="px-4 py-3">
                            @{
                                healthById.TryGetValue(d.Id, out var h);
                                var healthBadgeClass = h?.Status switch
                                {
                                    "ok" => "bg-emerald-100 text-emerald-700",
                                    "warn" => "bg-amber-100 text-amber-700",
                                    "err" => "bg-red-100 text-red-700",
                                    _ => "bg-slate-100 text-slate-700"
                                };
                                var healthDot = h?.Status switch
                                {
                                    "ok" => "🟢",
                                    "warn" => "🟡",
                                    "err" => "🔴",
                                    _ => "⚪"
                                };
                                var healthTitle = h != null
                                    ? $"{h.StatusLabel}{(h.PendingCommands > 0 ? $" · {h.PendingCommands} comando(s) pendente(s)" : "")}{(h.StuckCommands > 0 ? $" · {h.StuckCommands} preso(s) >1h" : "")}"
                                    : "(sem dados)";
                            }
                            <span class="inline-flex items-center gap-1 px-2 py-1 text-xs font-semibold rounded @healthBadgeClass" title="@healthTitle">
                                <span>@healthDot</span>
                                <span>@(h?.StatusLabel ?? "—")</span>
                            </span>
                        </td>
                        <td class="px-4 py-3">
                            @if (d.Revoked)
                            {
                                <span class="inline-block px-2 py-1 text-xs font-semibold bg-red-100 text-red-700 rounded">Revogado</span>
                            }
                            else if (d.PendingPair)
                            {
                                <span class="inline-block px-2 py-1 text-xs font-semibold bg-amber-100 text-amber-700 rounded">Aguardando app</span>
                            }
                            else
                            {
                                <span class="inline-block px-2 py-1 text-xs font-semibold bg-green-100 text-green-700 rounded">Ativo</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-right">
                            <a href="/dispositivos/@d.Id/backups" class="text-xs text-slate-600 hover:text-indigo-700 font-medium mr-2" title="Ver snapshots do localStorage">
                                Backups
                            </a>
                            @if (!d.Revoked)
                            {
                                <span class="text-slate-200">·</span>
                                <form method="post" action="/dispositivos/@d.Id/revogar" class="inline ml-1"
                                      onsubmit="return confirm('Revogar este dispositivo? O app correspondente vai parar de funcionar.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-xs text-red-600 hover:text-red-800 font-medium">
                                        Revogar
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-xs text-slate-400">@d.RevokedAt?.ToString("dd/MM/yyyy")</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Modal: parear novo dispositivo -->
<div x-data="{ open: false }"
     x-show="open"
     x-on:open-modal.window="if ($event.detail === 'parear-device') open = true"
     x-on:keydown.escape.window="open = false"
     x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50">
    <div @@click.outside="open = false" class="bg-white rounded-xl shadow-xl max-w-md w-full p-6">
        <h3 class="text-lg font-semibold text-slate-900 mb-4">Parear novo dispositivo</h3>
        <form method="post" action="/dispositivos/parear" class="space-y-4">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Rótulo (opcional)</label>
                <input type="text" name="label" placeholder="Ex: iPhone Cozinha"
                       maxlength="120"
                       class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" />
                <p class="text-xs text-slate-500 mt-1">Ajuda a identificar o aparelho na lista.</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Operador padrão (opcional)</label>
                <input type="text" name="defaultOperatorName" placeholder="Ex: Felipe"
                       maxlength="64"
                       class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" />
            </div>
            <div class="bg-amber-50 border border-amber-200 rounded p-3 text-xs text-amber-800">
                Vamos gerar um código de 6 dígitos. Digite ele no app pareando — válido por 10 min.
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" @@click="open = false"
                        class="px-4 py-2 text-sm text-slate-700 hover:bg-slate-100 rounded-lg">Cancelar</button>
                <button type="submit"
                        class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                    Gerar código
                </button>
            </div>
        </form>
    </div>
</div>
