@model EasyStock.Web.Models.ViewModels.Financeiro.ContasPagarIndexViewModel
@{
    var statusOptions = new[] { "", "Rascunho", "Aberta", "ParcialmentePaga", "Paga", "Vencida", "Cancelada" };
}

<div class="page-content">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="page-heading">Contas a Pagar</h1>
            <p class="page-subheading">Despesas operacionais com parcelas e vencimentos.</p>
        </div>
        <a href="/contas-a-pagar/criar" class="btn btn-primary">+ Nova Conta a Pagar</a>
    </div>

    <form method="get" class="card mb-4">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-3">
            <div>
                <label class="form-label">Status</label>
                <select name="status" class="form-input">
                    @foreach (var s in statusOptions)
                    {
                        <option value="@s" selected="@(Model.FiltroStatus == s)">@(string.IsNullOrEmpty(s) ? "Todos" : s)</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label">Vencimento de</label>
                <input type="date" name="vencimentoDe" value="@Model.VencimentoDe?.ToString("yyyy-MM-dd")" class="form-input" />
            </div>
            <div>
                <label class="form-label">Vencimento ate</label>
                <input type="date" name="vencimentoAte" value="@Model.VencimentoAte?.ToString("yyyy-MM-dd")" class="form-input" />
            </div>
            <div class="md:col-span-1">
                <label class="form-label">Buscar</label>
                <input type="text" name="busca" value="@Model.Busca" placeholder="descrição, doc..." class="form-input" />
            </div>
            <div class="flex items-end gap-2">
                <button type="submit" class="btn btn-secondary">Filtrar</button>
                <a href="/contas-a-pagar" class="btn btn-ghost">Limpar</a>
            </div>
        </div>
    </form>

    @if (Model.Resultado is null || Model.Resultado.Itens.Count == 0)
    {
        <div class="card">
            @{ ViewData["EmptyTitle"] = "Nenhuma conta a pagar encontrada"; ViewData["EmptyDescription"] = "Crie a primeira conta para registrar suas despesas operacionais."; ViewData["EmptyCta"] = "Criar primeira conta"; ViewData["EmptyCtaHref"] = "/contas-a-pagar/criar"; }
            @await Html.PartialAsync("_EmptyState")
        </div>
    }
    else
    {
        <div class="card overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead>
                    <tr class="text-left text-xs font-medium text-gray-500 uppercase">
                        <th class="px-4 py-3">Descricao</th>
                        <th class="px-4 py-3">Status</th>
                        <th class="px-4 py-3 text-right">Valor</th>
                        <th class="px-4 py-3 text-right">Pago</th>
                        <th class="px-4 py-3 text-right">Pendente</th>
                        <th class="px-4 py-3">Emissao</th>
                        <th class="px-4 py-3">Parcelas</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var c in Model.Resultado.Itens)
                    {
                        var badge = c.Status switch
                        {
                            "Rascunho" => "bg-gray-100 text-gray-700",
                            "Aberta" => "bg-blue-100 text-blue-700",
                            "ParcialmentePaga" => "bg-yellow-100 text-yellow-700",
                            "Paga" => "bg-green-100 text-green-700",
                            "Vencida" => "bg-red-100 text-red-700",
                            "Cancelada" => "bg-gray-100 text-gray-500 line-through",
                            _ => "bg-gray-100 text-gray-700"
                        };
                        <tr>
                            <td class="px-4 py-3 font-medium">
                                <a href="/contas-a-pagar/@c.Id" class="text-blue-600 hover:underline">@c.Descricao</a>
                            </td>
                            <td class="px-4 py-3">
                                <span class="inline-block px-2 py-0.5 text-xs rounded @badge">@c.Status</span>
                            </td>
                            <td class="px-4 py-3 text-right">@c.ValorTotal.ToString("C")</td>
                            <td class="px-4 py-3 text-right text-green-700">@c.TotalPago.ToString("C")</td>
                            <td class="px-4 py-3 text-right text-red-700">@c.Pendente.ToString("C")</td>
                            <td class="px-4 py-3 text-sm text-gray-600">@c.DataEmissao.ToString("dd/MM/yyyy")</td>
                            <td class="px-4 py-3 text-sm">@c.Parcelas.Count</td>
                            <td class="px-4 py-3">
                                <a href="/contas-a-pagar/@c.Id" class="text-blue-600 text-sm hover:underline">Ver</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3 text-sm text-gray-500 flex items-center justify-between">
            <span>Total: @Model.Resultado.Total registro(s)</span>
            <span>Pagina @Model.Resultado.Page de @(Math.Max(1, (int)Math.Ceiling((double)Model.Resultado.Total / Math.Max(1, Model.Resultado.PageSize))))</span>
        </div>
    }
</div>
