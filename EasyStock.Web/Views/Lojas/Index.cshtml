@using EasyStock.Web.Models.Api
@model List<LojaApi>
@{
    ViewBag.Title = "Lojas";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Lojas</h1>
        <p>@Model.Count @(Model.Count == 1 ? "loja cadastrada" : "lojas cadastradas")</p>
    </div>
    <button type="button"
            x-data @@click="$dispatch('open-modal', 'criar-loja')"
            class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
        + Nova Loja
    </button>
</div>

<div class="ws">
    @if (!Model.Any())
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIcon", "🏪" },
            { "EmptyTitle", "Nenhuma loja cadastrada" },
            { "EmptyDescription", "Crie lojas para organizar seu estoque por localidade." },
            { "EmptyCta", "+ Nova Loja" },
            { "EmptyCtaModal", "criar-loja" }
        })
    }
    else
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead>
                <tr><th>Nome</th><th>Status</th><th>ID</th><th>Ações</th></tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    <tr x-data="{ editando: false, confirm: false, nomeEdit: '@l.Nome' }">
                        <td>
                            <div x-show="!editando" class="font-medium text-slate-900">@l.Nome</div>
                            <form action="/lojas/@l.Id/editar" method="post"
                                  x-show="editando" x-cloak class="flex gap-2 items-center">
                                @Html.AntiForgeryToken()
                                <input type="text" name="nome" x-model="nomeEdit"
                                       class="border border-slate-300 rounded px-2 py-1 text-sm" required />
                                <button type="submit"
                                        class="px-2 py-1 bg-indigo-600 text-white text-xs rounded hover:bg-indigo-700">
                                    Salvar
                                </button>
                                <button type="button" @@click="editando = false"
                                        class="px-2 py-1 text-xs text-slate-500 hover:text-slate-700">
                                    Cancelar
                                </button>
                            </form>
                        </td>
                        <td>
                            @if (l.Ativa)
                            {
                                <span class="badge-ok">Ativa</span>
                            }
                            else
                            {
                                <span class="badge-critical">Inativa</span>
                            }
                        </td>
                        <td class="text-slate-400 text-xs font-mono">@l.Id.ToString()[..8]...</td>
                        <td>
                            <div class="flex items-center gap-3">
                                <a href="/inteligencia-lojas/@l.Id"
                                   class="text-xs text-emerald-600 hover:text-emerald-700 font-medium">
                                    Inteligência
                                </a>
                                <button type="button" @@click="editando = !editando"
                                        class="text-xs text-indigo-600 hover:text-indigo-700"
                                        x-show="!editando">
                                    Editar
                                </button>
                                @if (l.Ativa)
                                {
                                    <button type="button" @@click="confirm = true"
                                            class="text-xs text-red-600 hover:text-red-700">
                                        Desativar
                                    </button>
                                }
                            </div>

                            <!-- Modal confirmar desativação -->
                            <div x-show="confirm" x-cloak
                                 class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                                 @@click.self="confirm = false">
                                <div class="bg-white rounded-xl p-6 w-80 shadow-xl">
                                    <h3 class="font-semibold text-slate-900 mb-2">Desativar loja</h3>
                                    <p class="text-sm text-slate-600 mb-4">
                                        Desativar <strong>@l.Nome</strong>? Itens de estoque nessa loja não aparecerão mais.
                                    </p>
                                    <div class="flex justify-end gap-3">
                                        <button type="button" @@click="confirm = false"
                                                class="px-3 py-1.5 text-sm border rounded-lg hover:bg-slate-50">
                                            Cancelar
                                        </button>
                                        <form action="/lojas/@l.Id/excluir" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="px-3 py-1.5 bg-red-600 text-white text-sm rounded-lg hover:bg-red-700">
                                                Desativar
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>

<!-- Modal criar loja -->
<div x-data="{ open: false }" @@open-modal.window="open = ($event.detail === 'criar-loja')"
     x-show="open" x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
     @@click.self="open = false">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-sm p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Nova Loja</h2>
        <form action="/lojas/criar" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Nome *</label>
                <input type="text" name="nome" required autofocus
                       class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            </div>
            <div class="flex justify-end gap-3">
                <button type="button" @@click="open = false"
                        class="px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                    Cancelar
                </button>
                <button type="submit" x-data="{ loading: false }" @@click="loading = true"
                        :disabled="loading" :class="{ 'opacity-50 cursor-not-allowed': loading }"
                        class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                    <span x-show="!loading">Criar</span>
                    <span x-show="loading" x-cloak class="flex items-center gap-2"><span class="spinner"></span> Salvando...</span>
                </button>
            </div>
        </form>
    </div>
</div>
