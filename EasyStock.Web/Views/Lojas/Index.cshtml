@using EasyStock.Web.Models.Api
@model List<LojaApi>
@{
    ViewBag.Title = "Lojas";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Lojas</h1>
        <p>@Model.Count @(Model.Count == 1 ? "loja cadastrada" : "lojas cadastradas")</p>
    </div>
    <button type="button"
            x-data @@click="$dispatch('open-modal', 'criar-loja')"
            class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
        + Nova Loja
    </button>
</div>

<div class="ws">
    @if (!Model.Any())
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIcon", "🏪" },
            { "EmptyTitle", "Nenhuma loja cadastrada" },
            { "EmptyDescription", "Crie lojas para organizar seu estoque por localidade." },
            { "EmptyCta", "+ Nova Loja" },
            { "EmptyCtaModal", "criar-loja" }
        })
    }
    else
    {
        <div class="overflow-x-auto">
        <table class="tbl-full">
            <thead>
                <tr><th>Nome</th><th>Status</th><th>ID</th><th>Ações</th></tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    <tr x-data="{ editando: false, nomeEdit: '@l.Nome' }">
                        <td>
                            <div x-show="!editando" class="font-medium text-slate-900">@l.Nome</div>
                            <form action="/lojas/@l.Id/editar" method="post"
                                  x-show="editando" x-cloak class="flex gap-2 items-center">
                                @Html.AntiForgeryToken()
                                <input type="text" name="nome" x-model="nomeEdit"
                                       class="border border-slate-300 rounded px-2 py-1 text-sm" required />
                                <button type="submit"
                                        class="px-2 py-1 bg-indigo-600 text-white text-xs rounded hover:bg-indigo-700">
                                    Salvar
                                </button>
                                <button type="button" @@click="editando = false"
                                        class="px-2 py-1 text-xs text-slate-500 hover:text-slate-700">
                                    Cancelar
                                </button>
                            </form>
                        </td>
                        <td>
                            @if (l.Ativa)
                            {
                                <span class="badge-ok">Ativa</span>
                            }
                            else
                            {
                                <span class="badge-critical">Inativa</span>
                            }
                        </td>
                        <td class="text-slate-400 text-xs font-mono">@l.Id.ToString()[..8]...</td>
                        <td>
                            <div class="flex items-center gap-3">
                                <a href="/inteligencia-lojas/@l.Id"
                                   class="grid-action-btn grid-action-btn--success">
                                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.79 2-4 2s-4-.895-4-2 1.79-2 4-2 4 .895 4 2zm12-2c0 1.105-1.79 2-4 2s-4-.895-4-2 1.79-2 4-2 4 .895 4 2zM9 10l12-3" />
                                    </svg>
                                    Inteligência
                                </a>
                                <button type="button" @@click="editando = !editando"
                                        class="grid-action-btn grid-action-btn--primary"
                                        x-show="!editando">
                                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                    Editar
                                </button>
                                @if (l.Ativa)
                                {
                                    <button type="button"
                                            @@click="$dispatch('confirm-action', { titulo: 'Desativar loja', mensagem: 'Desativar <strong>' + @Json.Serialize(l.Nome) + '</strong>? Itens de estoque nessa loja não aparecerão mais.', textoBotao: 'Desativar', classBotao: 'bg-red-600 hover:bg-red-700', formAction: '/lojas/@l.Id/excluir' })"
                                            class="grid-action-btn grid-action-btn--danger">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-12.728 12.728M6.343 6.343l11.314 11.314" />
                                        </svg>
                                        Desativar
                                    </button>
                                }
                            </div>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>

<!-- Modal criar loja -->
<div x-data="{ open: false }" @@open-modal.window="open = ($event.detail === 'criar-loja')"
     x-show="open" x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
     @@click.self="open = false">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-sm p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Nova Loja</h2>
        <form action="/lojas/criar" method="post" data-validate x-data="{ loading: false }" @@submit="loading = true">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Nome *</label>
                <input type="text" name="nome" required autofocus
                       minlength="2" maxlength="80"
                       data-error-message="Informe um nome de loja entre 2 e 80 caracteres."
                       class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Cidade <span class="text-slate-400 font-normal">(opcional)</span></label>
                <input type="text" name="cidade" maxlength="120"
                       class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Telefone <span class="text-slate-400 font-normal">(opcional)</span></label>
                <input type="tel" name="telefone" maxlength="20"
                       data-validate-phone
                       data-error-message="Telefone deve ter 10 ou 11 dígitos."
                       class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            </div>
            <div class="flex justify-end gap-3">
                <button type="button" @@click="open = false"
                        class="px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                    Cancelar
                </button>
                <button type="submit"
                        :disabled="loading" :class="{ 'opacity-50 cursor-not-allowed': loading }"
                        class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                    <span x-show="!loading">Criar</span>
                    <span x-show="loading" x-cloak class="flex items-center gap-2"><span class="spinner"></span> Salvando...</span>
                </button>
            </div>
        </form>
    </div>
</div>
