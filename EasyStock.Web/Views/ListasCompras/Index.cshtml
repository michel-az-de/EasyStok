@model ListasComprasIndexViewModel
@{
    ViewBag.Title = "Listas de compras";
    Layout = "_Layout";
}

<div class="flex items-center justify-between mb-6">
    <div class="pg-hd">
        <h1>Listas de compras</h1>
        <p>Liste o que falta comprar e vá marcando conforme passa pelo mercado</p>
    </div>
    <div class="flex items-center gap-2">
        <a href="/listas-compras/gerar"
           class="inline-flex items-center px-4 py-2 border border-indigo-200 text-indigo-700 bg-indigo-50 text-sm font-medium rounded-lg hover:bg-indigo-100">
            ✨ Gerar do estoque baixo
        </a>
        <button type="button" x-data @@click="$dispatch('open-modal', 'nova-lista')"
                class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">+ Nova lista</button>
    </div>
</div>

<div class="ws mb-6">
    <div class="filter-tab-group">
        @foreach (var (val, label) in new[] { ("", "Todas"), ("aberta", "Abertas"), ("arquivada", "Arquivadas") })
        {
            var isActive = Model.FiltroStatus == val || (val == "" && Model.FiltroStatus == null);
            <a href="@Url.Action("Index", "ListasCompras", new { status = val == "" ? null : val })"
               class="filter-tab @(isActive ? "active" : "")">@label</a>
        }
    </div>
</div>

<div class="ws">
    @if (!Model.Listas.Any())
    {
        @await Html.PartialAsync("_EmptyState", null, new ViewDataDictionary(ViewData) {
            { "EmptyIllustration", "inbox" },
            { "EmptyTitle", "Nenhuma lista de compras ainda" },
            { "EmptyDescription", "Gere a lista automaticamente a partir do que está acabando no estoque, ou crie uma lista em branco." },
            { "EmptyCta", "Criar primeira lista" },
            { "EmptyCtaModal", "nova-lista" }
        })
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var l in Model.Listas)
        {
            var pct = l.TotalItens > 0 ? (l.ItensFeitos * 100 / l.TotalItens) : 0;
            <a href="/listas-compras/@l.Id" class="block ws hover:bg-slate-50 transition-colors">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="font-semibold text-slate-900 truncate">@l.Nome</h3>
                    <span class="px-2 py-0.5 rounded-full text-xs font-medium @(l.Status == "aberta" ? "bg-green-100 text-green-700" : "bg-slate-100 text-slate-500")">@l.Status</span>
                </div>
                <div class="text-xs text-slate-500 mb-2">@l.CriadoEm.ToLocalTime().ToString("dd/MM/yyyy") @(string.IsNullOrEmpty(l.CriadaPorNome) ? "" : "· " + l.CriadaPorNome)</div>
                <div class="text-sm text-slate-700 mb-2">@l.ItensFeitos / @l.TotalItens itens</div>
                <div class="w-full bg-slate-100 rounded-full h-2">
                    <div class="bg-indigo-600 h-2 rounded-full" style="width: @pct%"></div>
                </div>
            </a>
        }
        </div>
    }
</div>

<!-- Modal: nova lista de compras -->
<div x-data="novaListaModal()"
     x-show="open" x-cloak
     x-transition:enter="transition duration-150 ease-out"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     @@keydown.escape.window="close()"
     @@click.self="close()"
     class="fm-overlay"
     role="dialog" aria-modal="true" aria-labelledby="fm-lista-title">
    <form x-ref="panel" class="fm-panel" style="max-width: 480px"
          asp-action="Criar" asp-controller="ListasCompras" method="post"
          x-transition:enter="transition duration-150 ease-out"
          x-transition:enter-start="opacity-0 scale-95"
          x-transition:enter-end="opacity-100 scale-100">
        @Html.AntiForgeryToken()
        <header class="fm-header">
            <div>
                <h2 id="fm-lista-title" class="fm-header__title">Nova lista de compras</h2>
                <p class="fm-header__subtitle">Dê um nome à lista. Você adiciona os itens depois, conforme lembra ou consulta o estoque.</p>
            </div>
            <button type="button" class="fm-close" aria-label="Fechar" @@click="close()">✕</button>
        </header>
        <div class="fm-body">
            <fieldset class="fm-section">
                <div class="fm-grid">
                    <div class="fm-field fm-col-2">
                        <label class="fm-field__label" for="lista-nome">
                            Nome da lista<span class="fm-field__required" aria-hidden="true">*</span>
                        </label>
                        <input id="lista-nome" type="text" name="nome" required maxlength="80"
                               placeholder="Ex: Compras de quarta, Reposição mercado..."
                               class="ui-field w-full text-sm" />
                    </div>
                    <div class="fm-field fm-col-2">
                        <label class="fm-field__label" for="lista-obs">Observações</label>
                        <textarea id="lista-obs" name="observacoes" rows="2"
                                  placeholder="Ex: lembrar do açougue, pegar nota..."
                                  class="ui-textarea w-full text-sm"></textarea>
                    </div>
                </div>
            </fieldset>
        </div>
        <footer class="fm-footer">
            <button type="button" @@click="close()"
                    class="ui-secondary-btn px-4 py-2 text-sm text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-50">
                Cancelar
            </button>
            <button type="submit"
                    class="app-primary-btn px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                Criar lista
            </button>
        </footer>
    </form>
</div>

@section Scripts {
<script>
function novaListaModal() {
    return {
        open: false,
        _previousFocus: null,
        init() {
            window.addEventListener('open-modal', (e) => {
                if (e.detail !== 'nova-lista') return;
                this._previousFocus = document.activeElement;
                this.open = true;
                this.$nextTick(() => this.$refs.panel?.querySelector('input[name=nome]')?.focus());
            });
            this.$watch('open', (v) => {
                document.body.style.overflow = v ? 'hidden' : '';
                if (!v && this._previousFocus) this._previousFocus.focus?.();
            });
        },
        close() { this.open = false; }
    };
}
</script>
}
