@model ListaComprasDetailViewModel
@{
    var l = Model.Detalhe.Lista;
    Layout = null;
    var lojaNome = ViewBag.LojaAtualNome as string ?? "";
    var lojaEmoji = ViewBag.LojaAtualEmoji as string ?? "";
    var grupos = Model.Detalhe.Itens
        .GroupBy(i => string.IsNullOrWhiteSpace(i.Categoria) ? "Outros" : i.Categoria)
        .OrderBy(g => g.Key == "Outros")
        .ThenBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
        .ToList();
}<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <title>Lista — @l.Nome</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/lista-print.css" asp-append-version="true" />
</head>
<body class="lp-body">
    <div class="lp-toolbar">
        <a href="/listas-compras/@l.Id" class="lp-btn">&larr; Voltar</a>
        <button type="button" class="lp-btn lp-btn-primary" onclick="window.print()">Imprimir / Salvar PDF</button>
    </div>

    <div class="lp-sheet">
        <div class="lp-head">
            <h1>@l.Nome</h1>
            <div class="lp-meta">
                @(string.IsNullOrWhiteSpace(lojaNome) ? "" : $"{lojaEmoji} {lojaNome} · ")@DateTime.Now.ToString("dd/MM/yyyy") · @l.TotalItens @(l.TotalItens == 1 ? "item" : "itens")
            </div>
        </div>

        @if (!Model.Detalhe.Itens.Any())
        {
            <p class="lp-empty">Lista sem itens.</p>
        }
        else
        {
            @foreach (var grupo in grupos)
            {
                <div class="lp-grupo">
                    <h2>@grupo.Key</h2>
                    @foreach (var it in grupo)
                    {
                        <div class="lp-item @(it.Done ? "done" : "")">
                            <span class="lp-box @(it.Done ? "done" : "")"></span>
                            <span class="lp-txt">@it.Texto</span>
                            @if (it.Quantidade.HasValue)
                            {
                                <span class="lp-qty">@it.Quantidade.Value.ToString("0.##") @it.Unidade</span>
                            }
                        </div>
                    }
                </div>
            }
        }

        <div class="lp-foot">Gerado em @DateTime.Now.ToString("dd/MM/yyyy HH:mm") · EasyStok</div>
    </div>
</body>
</html>
