@model AssinaturaViewModel
@{
    ViewBag.Title = "Assinatura";
    Layout = "_Layout";
}

<h1 class="text-2xl font-bold text-gray-900 mb-6">Assinatura</h1>

<!-- Plano atual -->
@if (Model.PlanoAtual != null)
{
    var p = Model.PlanoAtual;
    var statusColor = p.Status == "ativo" ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700";
    <div class="ws mb-6">
        <div class="flex items-start justify-between">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <h2 class="text-xl font-bold text-gray-900">@p.Plano</h2>
                    <span class="px-2 py-0.5 rounded-full text-xs font-medium @statusColor">@p.Status</span>
                </div>
                <p class="text-2xl font-bold text-indigo-600">R$ @p.Preco.ToString("N2")<span class="text-sm font-normal text-gray-500">/mês</span></p>
                <p class="text-sm text-gray-500 mt-1">Próxima cobrança: @p.ProxCobranca.ToString("dd/MM/yyyy")</p>
            </div>
        </div>

        <!-- Medidores de uso -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6">
            @{
                var uso = p.Uso;
                var usoItems = new[] {
                    (label: "Lojas", atual: uso.LojasAtual, max: uso.LojasMax),
                    (label: "Usuários", atual: uso.UsuariosAtual, max: uso.UsuariosMax),
                    (label: "Produtos", atual: uso.ProdutosAtual, max: uso.ProdutosMax),
                    (label: "Uso IA", atual: uso.IaAtual, max: uso.IaMax)
                };
            }
            @foreach (var (label, atual, max) in usoItems)
            {
                var pct = max > 0 ? Math.Min(100, atual * 100 / max) : 0;
                var barColor = pct >= 90 ? "bg-red-500" : pct >= 70 ? "bg-yellow-500" : "bg-green-500";
                <div>
                    <div class="flex justify-between text-sm mb-1">
                        <span class="text-gray-600">@label</span>
                        <span class="font-medium text-gray-900">@atual / @max</span>
                    </div>
                    <div class="w-full bg-gray-100 rounded-full h-2">
                        <div class="@barColor h-2 rounded-full" style="width: @pct%"></div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Comparação de planos -->
@if (Model.Planos.Any())
{
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Planos Disponíveis</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        @foreach (var plano in Model.Planos)
        {
            <div class="ws @(plano.Recomendado ? "border-2 border-indigo-500 relative" : "")">
                @if (plano.Recomendado)
                {
                    <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-0.5 bg-indigo-500 text-white text-xs font-medium rounded-full">
                        Recomendado
                    </div>
                }
                <h3 class="font-bold text-gray-900 text-lg">@plano.Nome</h3>
                <p class="text-2xl font-bold text-indigo-600 my-2">
                    R$ @plano.Preco.ToString("N2")
                    <span class="text-sm font-normal text-gray-500">/mês</span>
                </p>
                <ul class="space-y-1.5 mb-4">
                    @foreach (var f in plano.Features)
                    {
                        <li class="flex items-center gap-2 text-sm text-gray-600">
                            <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            @f
                        </li>
                    }
                </ul>
                @if (Model.PlanoAtual?.Plano != plano.Nome)
                {
                    <button type="button"
                            class="w-full py-2 @(plano.Recomendado ? "bg-indigo-600 text-white hover:bg-indigo-700" : "border border-indigo-600 text-indigo-600 hover:bg-indigo-50") text-sm font-medium rounded-lg">
                        Fazer Upgrade
                    </button>
                }
                else
                {
                    <div class="w-full py-2 text-center text-sm text-green-600 font-medium">Plano atual ✓</div>
                }
            </div>
        }
    </div>
}

<!-- Faturas -->
@if (Model.Faturas.Any())
{
    <div class="ws">
        <h2 class="font-semibold text-gray-900 mb-4">Histórico de Faturas</h2>
        <table class="tbl-full">
            <thead>
                <tr><th>Data</th><th>Descrição</th><th>Valor</th><th>Status</th></tr>
            </thead>
            <tbody>
                @foreach (var f in Model.Faturas)
                {
                    var fatStatusColor = f.Status switch {
                        "pago" => "bg-green-100 text-green-700",
                        "pendente" => "bg-yellow-100 text-yellow-700",
                        "vencido" => "bg-red-100 text-red-700",
                        _ => "bg-gray-100 text-gray-600"
                    };
                    <tr>
                        <td>@f.Data.ToString("dd/MM/yyyy")</td>
                        <td class="text-gray-700">@f.Descricao</td>
                        <td class="font-medium">R$ @f.Valor.ToString("N2")</td>
                        <td>
                            <span class="px-2 py-0.5 rounded-full text-xs font-medium @fatStatusColor">
                                @f.Status
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
