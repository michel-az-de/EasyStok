@model ProdutoDetailViewModel
@using System.Globalization
@{
    var ptBR = new CultureInfo("pt-BR");
    var p = Model.Produto;
}

<!-- Header -->
<div class="flex items-start justify-between mb-6">
    <div class="flex items-center gap-4">
        <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center justify-center text-3xl">
            @(string.IsNullOrEmpty(p.Emoji) ? "📦" : p.Emoji)
        </div>
        <div>
            <h1 class="text-2xl font-extrabold text-slate-900">@p.Nome</h1>
            <div class="flex items-center gap-3 mt-1">
                <span class="text-slate-400 text-sm font-mono">@p.Sku</span>
                <span class="text-slate-300">·</span>
                <span class="text-slate-500 text-sm">@p.Categoria</span>
                @{
                    var statusBadge = p.Status?.ToLower() switch
                    {
                        "ativo" => "badge-ok",
                        _ => "badge-warn"
                    };
                }
                <span class="badge @statusBadge px-2 py-0.5 rounded-full text-xs font-semibold">@p.Status</span>
            </div>
        </div>
    </div>
    <div class="flex items-center gap-2">
        <a href="/produtos/@p.Id/editar"
           class="px-4 py-2 text-sm font-semibold border border-indigo-300 text-indigo-600 rounded-lg hover:bg-indigo-50 transition-colors">
            Editar
        </a>
        <!-- Modal confirm excluir -->
        <div x-data="{ open: false }">
            <button @@click="open = true"
                    class="px-4 py-2 text-sm font-semibold border border-red-200 text-red-600 rounded-lg hover:bg-red-50 transition-colors">
                Excluir
            </button>
            <!-- Modal backdrop -->
            <div x-show="open" class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center" x-transition>
                <div @@click.stop class="bg-white rounded-2xl shadow-2xl p-6 max-w-sm w-full mx-4">
                    <h3 class="font-bold text-slate-900 text-lg mb-2">Excluir produto?</h3>
                    <p class="text-slate-500 text-sm mb-6">Esta ação é irreversível. O produto <strong>@p.Nome</strong> será excluído permanentemente.</p>
                    <div class="flex gap-3 justify-end">
                        <button @@click="open = false"
                                class="px-4 py-2 text-sm font-semibold border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
                            Cancelar
                        </button>
                        <form asp-action="Excluir" asp-controller="Produtos" asp-route-id="@p.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="px-4 py-2 text-sm font-semibold bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors">
                                Confirmar exclusão
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Abas -->
<div x-data="{ tab: 'info' }">
    <!-- Tab nav -->
    <div class="flex gap-1 border-b border-slate-200 mb-6">
        @{
            var tabs = new[] { ("info", "Informações"), ("estoque", "Estoque por variação"), ("historico", "Histórico") };
        }
        @foreach (var (tabId, tabLabel) in tabs)
        {
            <button @@click="tab = '@tabId'"
                    :class="tab === '@tabId' ? 'border-b-2 border-indigo-600 text-indigo-600 font-semibold' : 'text-slate-500 hover:text-slate-700'"
                    class="px-4 py-2 text-sm transition-colors">
                @tabLabel
            </button>
        }
    </div>

    <!-- Tab: Informações -->
    <div x-show="tab === 'info'">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="ws">
                <h3 class="font-bold text-slate-800 mb-4">Dados do produto</h3>
                <dl class="space-y-3">
                    <div class="flex justify-between">
                        <dt class="text-sm text-slate-500">Preço de venda</dt>
                        <dd class="text-sm font-semibold">@p.Preco.ToString("C", ptBR)</dd>
                    </div>
                    @if (p.Custo.HasValue)
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Custo</dt>
                            <dd class="text-sm font-semibold">@p.Custo.Value.ToString("C", ptBR)</dd>
                        </div>
                        @if (p.Preco > 0 && p.Custo > 0)
                        {
                            var margem = (p.Preco - p.Custo.Value) / p.Preco * 100;
                            <div class="flex justify-between">
                                <dt class="text-sm text-slate-500">Margem</dt>
                                <dd class="text-sm font-semibold text-emerald-600">@margem.ToString("F1")%</dd>
                            </div>
                        }
                    }
                    @if (!string.IsNullOrEmpty(p.Subcategoria))
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Subcategoria</dt>
                            <dd class="text-sm">@p.Subcategoria</dd>
                        </div>
                    }
                    @if (p.Peso.HasValue)
                    {
                        <div class="flex justify-between">
                            <dt class="text-sm text-slate-500">Peso</dt>
                            <dd class="text-sm">@p.Peso g</dd>
                        </div>
                    }
                </dl>
                @if (!string.IsNullOrEmpty(p.Descricao))
                {
                    <div class="mt-4 pt-4 border-t border-slate-100">
                        <p class="text-sm text-slate-500 font-medium mb-1">Descrição</p>
                        <p class="text-sm text-slate-700">@p.Descricao</p>
                    </div>
                }
            </div>

            <!-- Variações -->
            <div class="ws">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-bold text-slate-800">Variações (@p.Variacoes.Count)</h3>
                </div>
                @if (p.Variacoes.Any())
                {
                    <div class="space-y-2">
                        @foreach (var v in p.Variacoes)
                        {
                            <div class="flex items-center justify-between py-2 border-b border-slate-50">
                                <span class="text-sm text-slate-700">@v.Nome</span>
                                <form asp-action="RemoverVariacao" asp-controller="Produtos"
                                      asp-route-id="@p.Id" asp-route-vid="@v.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-xs text-red-500 hover:text-red-700">Remover</button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-slate-400">Nenhuma variação cadastrada.</p>
                }

                <!-- Add variação -->
                <form asp-action="AdicionarVariacao" asp-controller="Produtos" asp-route-id="@p.Id" method="post" class="mt-4 flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="text" name="nome" placeholder="Nova variação (ex: M, Azul...)"
                           class="flex-1 px-3 py-2 text-sm border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                    <button type="submit" class="px-3 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700">
                        Adicionar
                    </button>
                </form>

                <!-- Upload foto -->
                <div class="mt-6 pt-4 border-t border-slate-100">
                    <h4 class="text-sm font-semibold text-slate-700 mb-2">Foto do produto</h4>
                    <form asp-action="UploadFoto" asp-controller="Produtos" asp-route-id="@p.Id"
                          method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="file" name="foto" accept="image/jpeg,image/png,image/webp"
                               class="block text-sm text-slate-500 mb-2" />
                        <button type="submit" class="px-3 py-2 border border-slate-300 text-slate-700 text-sm rounded-lg hover:bg-slate-50">
                            Enviar foto
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Tab: Estoque por variação -->
    <div x-show="tab === 'estoque'">
        <div class="ws">
            @if (Model.EstoqueSkus.Any())
            {
                <table class="tbl-full">
                    <thead>
                        <tr>
                            <th>SKU</th>
                            <th>Variação</th>
                            <th class="text-center">Qtd</th>
                            <th>Lote</th>
                            <th>Validade</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sku in Model.EstoqueSkus)
                        {
                            var diasParaVencer = sku.Validade.HasValue
                                ? (sku.Validade.Value.ToDateTime(TimeOnly.MinValue) - DateTime.Today).Days
                                : (int?)null;
                            <tr>
                                <td class="font-mono text-xs">@sku.Sku</td>
                                <td>@(sku.Variacao?.Nome ?? "-")</td>
                                <td class="text-center">
                                    <span class="font-bold @(sku.Qty == 0 ? "text-red-600" : sku.Qty < 5 ? "text-amber-600" : "text-slate-900")">
                                        @sku.Qty
                                    </span>
                                </td>
                                <td class="text-slate-500">@(sku.Lote ?? "-")</td>
                                <td>
                                    @if (sku.Validade.HasValue)
                                    {
                                        <span class="@(diasParaVencer <= 7 ? "text-red-600 font-semibold" : "text-slate-600")">
                                            @sku.Validade.Value.ToString("dd/MM/yyyy")
                                            @if (diasParaVencer <= 7)
                                            {
                                                <span class="badge badge-critical ml-1 px-1.5 py-0.5 rounded text-xs">@diasParaVencer d</span>
                                            }
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-slate-400">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @{
                                        var sClass = sku.Status?.ToLower() switch
                                        {
                                            "ok" or "normal" => "badge-ok",
                                            "critico" or "crítico" => "badge-critical",
                                            "parado" => "badge-slow",
                                            _ => "badge-warn"
                                        };
                                    }
                                    <span class="badge @sClass px-2 py-0.5 rounded-full text-xs font-semibold">@sku.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-center py-8 text-slate-400 text-sm">Nenhum item de estoque encontrado para este produto.</p>
            }
        </div>
    </div>

    <!-- Tab: Histórico -->
    <div x-show="tab === 'historico'" x-init="tab === 'historico' && loadHistorico()">
        <div class="ws" id="historico-container">
            <div class="text-center py-8 text-slate-400">
                <div class="text-3xl mb-2">⏳</div>
                <p class="text-sm">Carregando histórico...</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadHistorico() {
            const container = document.getElementById('historico-container');
            if (container.dataset.loaded) return;
            container.dataset.loaded = '1';
            try {
                const r = await fetch('/api-proxy/produtos/@p.Id/historico');
                if (!r.ok) throw new Error();
                const data = await r.json();
                container.innerHTML = '<p class="text-sm text-slate-600">Histórico carregado. ' + JSON.stringify(data).substring(0, 100) + '...</p>';
            } catch {
                container.innerHTML = '<p class="text-center py-8 text-slate-400 text-sm">Não foi possível carregar o histórico.</p>';
            }
        }
    </script>
}
