@{
    ViewBag.Title = "Erro";
    Layout = "_Layout";
}

<div class="ws max-w-lg mx-auto mt-10 text-center">
    <div class="text-5xl mb-4">⚠️</div>
    <h1 class="text-xl font-bold text-slate-900 mb-2">Ocorreu um erro</h1>
