<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
    Tipografia base do PWA:
    - Manrope para body (400/500/600/700/800)
    - Fraunces para titles (400/600/800) e itálico (greeting/accent)
    Ambas variable fonts; o renderer Android usa o eixo wght.
    -->

    <!-- Page padrão: fundo PageBg, ink default -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource PageBgDark}, Light={StaticResource PageBgLight}}" />
        <Setter Property="Shell.NavBarIsVisible" Value="False" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgDark}, Light={StaticResource BgLight}}" />
        <Setter Property="Shell.ForegroundColor"
                Value="{AppThemeBinding Dark={StaticResource InkDark}, Light={StaticResource InkLight}}" />
        <Setter Property="Shell.TitleColor"
                Value="{AppThemeBinding Dark={StaticResource InkDark}, Light={StaticResource InkLight}}" />
        <Setter Property="Shell.UnselectedColor"
                Value="{AppThemeBinding Dark={StaticResource InkMuteDark}, Light={StaticResource InkMuteLight}}" />
        <Setter Property="Shell.TabBarBackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgElevDark}, Light={StaticResource BgElevLight}}" />
        <Setter Property="Shell.TabBarForegroundColor"
                Value="{AppThemeBinding Dark={StaticResource AccentDark}, Light={StaticResource AccentLight}}" />
        <Setter Property="Shell.TabBarTitleColor"
                Value="{AppThemeBinding Dark={StaticResource AccentDark}, Light={StaticResource AccentLight}}" />
        <Setter Property="Shell.TabBarUnselectedColor"
                Value="{AppThemeBinding Dark={StaticResource InkMuteDark}, Light={StaticResource InkMuteLight}}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource InkDark}, Light={StaticResource InkLight}}" />
    </Style>

    <!-- Variantes de texto -->
    <Style x:Key="LabelHero" TargetType="Label">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource InkDark}, Light={StaticResource InkLight}}" />
    </Style>

    <Style x:Key="LabelHeroAccent" TargetType="Label">
        <Setter Property="FontFamily" Value="FrauncesItalic" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Italic" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource AccentDark}, Light={StaticResource AccentLight}}" />
    </Style>

    <Style x:Key="LabelGreeting" TargetType="Label">
        <Setter Property="FontFamily" Value="FrauncesItalic" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Italic" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource InkDimDark}, Light={StaticResource InkDimLight}}" />
    </Style>

    <Style x:Key="LabelTitle" TargetType="Label">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource InkDark}, Light={StaticResource InkLight}}" />
    </Style>

    <Style x:Key="LabelSubtitle" TargetType="Label">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource InkDimDark}, Light={StaticResource InkDimLight}}" />
    </Style>

    <Style x:Key="LabelCaption" TargetType="Label">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource InkMuteDark}, Light={StaticResource InkMuteLight}}" />
    </Style>

    <!-- Suffix uppercase 800 (estilo "PRODUCAO" tag) -->
    <Style x:Key="LabelSuffix" TargetType="Label">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="1.2" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource InkMuteDark}, Light={StaticResource InkMuteLight}}" />
    </Style>

    <!-- Botão accent (CTA principal) -->
    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource AccentDark}, Light={StaticResource AccentLight}}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="18,12" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <Style x:Key="ButtonGhost" TargetType="Button">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource InkDark}, Light={StaticResource InkLight}}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Transparent}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="BorderColor"
                Value="{AppThemeBinding Dark={StaticResource BorderStrongDark}, Light={StaticResource BorderStrongLight}}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <!-- Card padrao (Border): bg-card + borda subtle + radius 18 -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgCardDark}, Light={StaticResource BgCardLight}}" />
        <Setter Property="Stroke"
                Value="{AppThemeBinding Dark={StaticResource BorderDark}, Light={StaticResource BorderLight}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style x:Key="CardElev" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgElevDark}, Light={StaticResource BgElevLight}}" />
        <Setter Property="Stroke"
                Value="{AppThemeBinding Dark={StaticResource BorderStrongDark}, Light={StaticResource BorderStrongLight}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource InkDark}, Light={StaticResource InkLight}}" />
        <Setter Property="PlaceholderColor"
                Value="{AppThemeBinding Dark={StaticResource InkMuteDark}, Light={StaticResource InkMuteLight}}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Transparent}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color"
                Value="{AppThemeBinding Dark={StaticResource AccentDark}, Light={StaticResource AccentLight}}" />
    </Style>

</ResourceDictionary>
