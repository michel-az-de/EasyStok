<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
    Tipografia oficial EasyStok:
      Inter (variable)        -> body / labels / botoes
      Fraunces (variable)     -> display / headings serif
    -->

    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgAppDark}, Light={StaticResource BgAppLight}}" />
        <Setter Property="Shell.NavBarIsVisible" Value="False" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgAppDark}, Light={StaticResource BgAppLight}}" />
        <Setter Property="Shell.ForegroundColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
        <Setter Property="Shell.TitleColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="1.5" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
    </Style>

    <Style x:Key="LabelDisplay" TargetType="Label">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.05" />
        <Setter Property="CharacterSpacing" Value="-0.5" />
    </Style>

    <Style x:Key="LabelH1" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.18" />
        <Setter Property="CharacterSpacing" Value="-0.4" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
    </Style>

    <Style x:Key="LabelH2" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.2" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
    </Style>

    <Style x:Key="LabelH3" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.3" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
    </Style>

    <Style x:Key="LabelLead" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="LineHeight" Value="1.5" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextSecondaryDark}, Light={StaticResource TextSecondaryLight}}" />
    </Style>

    <Style x:Key="LabelSmall" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="1.45" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextMutedDark}, Light={StaticResource TextMutedLight}}" />
    </Style>

    <Style x:Key="LabelEyebrow" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextMutedDark}, Light={StaticResource TextMutedLight}}" />
    </Style>

    <!-- Botoes -->

    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Orange600}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="18,14" />
        <Setter Property="MinimumHeightRequest" Value="48" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <Style x:Key="ButtonNavy" TargetType="Button">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Navy700}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="18,14" />
        <Setter Property="MinimumHeightRequest" Value="48" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <Style x:Key="ButtonGhost" TargetType="Button">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource Navy700}}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Transparent}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="BorderColor"
                Value="{AppThemeBinding Dark={StaticResource BorderStrongDark}, Light={StaticResource BorderStrongLight}}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <!-- Cards -->

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgSurfaceDark}, Light={StaticResource BgSurfaceLight}}" />
        <Setter Property="Stroke"
                Value="{AppThemeBinding Dark={StaticResource BorderSoftDark}, Light={StaticResource BorderSoftLight}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="CardElev" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgElevatedDark}, Light={StaticResource BgElevatedLight}}" />
        <Setter Property="Stroke"
                Value="{AppThemeBinding Dark={StaticResource BorderStrongDark}, Light={StaticResource BorderStrongLight}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <Style x:Key="FieldBox" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgSurfaceDark}, Light={StaticResource BgSurfaceLight}}" />
        <Setter Property="Stroke"
                Value="{AppThemeBinding Dark={StaticResource BorderSoftDark}, Light={StaticResource BorderSoftLight}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 10" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
        <Setter Property="PlaceholderColor"
                Value="{AppThemeBinding Dark={StaticResource TextMutedDark}, Light={StaticResource TextMutedLight}}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Transparent}" />
        <Setter Property="MinimumHeightRequest" Value="40" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Orange600}" />
    </Style>

</ResourceDictionary>
