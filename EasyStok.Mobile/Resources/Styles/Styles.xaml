<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
    Tipografia v1.2.1 — Fraunces serif dominante + sombras suaves PWA-style.
    -->

    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgAppDark}, Light={StaticResource BgAppLight}}" />
        <Setter Property="Shell.NavBarIsVisible" Value="False" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgAppDark}, Light={StaticResource BgAppLight}}" />
        <Setter Property="Shell.ForegroundColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
        <Setter Property="Shell.TitleColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="1.45" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
    </Style>

    <Style x:Key="LabelDisplay" TargetType="Label">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.05" />
        <Setter Property="CharacterSpacing" Value="-0.5" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
    </Style>

    <Style x:Key="LabelH1" TargetType="Label">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.12" />
        <Setter Property="CharacterSpacing" Value="-0.4" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
    </Style>

    <Style x:Key="LabelH2" TargetType="Label">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.18" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
    </Style>

    <Style x:Key="LabelH3" TargetType="Label">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.25" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
    </Style>

    <Style x:Key="LabelGreeting" TargetType="Label">
        <Setter Property="FontFamily" Value="FrauncesItalic" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Italic" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextSecondaryDark}, Light={StaticResource TextSecondaryLight}}" />
    </Style>

    <Style x:Key="LabelLead" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="LineHeight" Value="1.5" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextSecondaryDark}, Light={StaticResource TextSecondaryLight}}" />
    </Style>

    <Style x:Key="LabelSmall" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="1.45" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextMutedDark}, Light={StaticResource TextMutedLight}}" />
    </Style>

    <Style x:Key="LabelEyebrow" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="2.5" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextMutedDark}, Light={StaticResource TextMutedLight}}" />
    </Style>

    <!-- Aliases legados -->
    <Style x:Key="LabelHero" TargetType="Label" BasedOn="{StaticResource LabelH1}" />
    <Style x:Key="LabelHeroAccent" TargetType="Label">
        <Setter Property="FontFamily" Value="FrauncesItalic" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Italic" />
        <Setter Property="TextColor" Value="{StaticResource Gold500}" />
    </Style>
    <Style x:Key="LabelTitle" TargetType="Label" BasedOn="{StaticResource LabelH3}" />
    <Style x:Key="LabelSubtitle" TargetType="Label" BasedOn="{StaticResource LabelLead}" />
    <Style x:Key="LabelCaption" TargetType="Label" BasedOn="{StaticResource LabelSmall}" />
    <Style x:Key="LabelSuffix" TargetType="Label" BasedOn="{StaticResource LabelEyebrow}" />

    <!-- ===== Sombras reutilizaveis ===== -->
    <Shadow x:Key="ShadowCard"
            Brush="#0A1530"
            Offset="0,2"
            Radius="8"
            Opacity="0.08" />

    <Shadow x:Key="ShadowCardElev"
            Brush="#0A1530"
            Offset="0,6"
            Radius="18"
            Opacity="0.12" />

    <Shadow x:Key="ShadowHero"
            Brush="#5C3A00"
            Offset="0,8"
            Radius="22"
            Opacity="0.18" />

    <!-- ===== Botões ===== -->
    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Navy900}" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource Gold500}, Light={StaticResource Gold600}}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="22,14" />
        <Setter Property="MinimumHeightRequest" Value="50" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="Shadow" Value="{StaticResource ShadowCard}" />
    </Style>

    <Style x:Key="ButtonNavy" TargetType="Button">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Navy700}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="22,14" />
        <Setter Property="MinimumHeightRequest" Value="50" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="Shadow" Value="{StaticResource ShadowCard}" />
    </Style>

    <Style x:Key="ButtonGhost" TargetType="Button">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource Navy700}}" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource Transparent}, Light={StaticResource White}}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="BorderColor"
                Value="{AppThemeBinding Dark={StaticResource BorderStrongDark}, Light={StaticResource BorderSoftLight}}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style x:Key="ButtonOk" TargetType="Button">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Ok600}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="18,12" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="Shadow" Value="{StaticResource ShadowCard}" />
    </Style>

    <Style x:Key="ButtonCoral" TargetType="Button">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Orange500}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="18,12" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="Shadow" Value="{StaticResource ShadowCard}" />
    </Style>

    <!-- ===== Cards (com sombra agora) ===== -->

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgSurfaceDark}, Light={StaticResource BgSurfaceLight}}" />
        <Setter Property="Stroke"
                Value="{AppThemeBinding Dark={StaticResource BorderSoftDark}, Light={StaticResource BorderSoftLight}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Shadow" Value="{StaticResource ShadowCard}" />
    </Style>

    <Style x:Key="CardElev" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgElevatedDark}, Light={StaticResource BgElevatedLight}}" />
        <Setter Property="Stroke"
                Value="{AppThemeBinding Dark={StaticResource BorderStrongDark}, Light={StaticResource BorderSoftLight}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 22" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Shadow" Value="{StaticResource ShadowCardElev}" />
    </Style>

    <Style x:Key="CardHero" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource Gold700}, Light={StaticResource Gold200}}" />
        <Setter Property="Stroke"
                Value="{AppThemeBinding Dark={StaticResource Gold600}, Light={StaticResource Gold500}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 22" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Shadow" Value="{StaticResource ShadowHero}" />
    </Style>

    <Style x:Key="BannerDemo" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource Gold800}, Light={StaticResource Gold100}}" />
        <Setter Property="Stroke"
                Value="{AppThemeBinding Dark={StaticResource Gold600}, Light={StaticResource Gold400}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Shadow" Value="{StaticResource ShadowCard}" />
    </Style>

    <Style x:Key="FieldBox" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource BgSurfaceDark}, Light={StaticResource BgSurfaceLight}}" />
        <Setter Property="Stroke"
                Value="{AppThemeBinding Dark={StaticResource BorderSoftDark}, Light={StaticResource BorderSoftLight}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="14,10" />
    </Style>

    <!-- ===== Filter chip (ativo / inativo) ===== -->
    <Style x:Key="ChipFiltroAtivo" TargetType="Button">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Navy900}" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource Gold500}, Light={StaticResource Gold600}}" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinimumHeightRequest" Value="36" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="Shadow" Value="{StaticResource ShadowCard}" />
    </Style>

    <Style x:Key="ChipFiltroInativo" TargetType="Button">
        <Setter Property="FontFamily" Value="Fraunces" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextSecondaryDark}, Light={StaticResource Navy700}}" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource Transparent}, Light={StaticResource White}}" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinimumHeightRequest" Value="36" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="BorderColor"
                Value="{AppThemeBinding Dark={StaticResource BorderStrongDark}, Light={StaticResource BorderSoftLight}}" />
    </Style>

    <!-- ===== Status pills (Ok/Atencao/Critico/Vencido) ===== -->
    <Style x:Key="StatusPillOk" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource Ok100}, Light={StaticResource Ok50}}" />
        <Setter Property="Stroke" Value="{StaticResource Ok600}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 999" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="HorizontalOptions" Value="Start" />
    </Style>
    <Style x:Key="StatusPillWarn" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource Warn100}, Light={StaticResource Warn50}}" />
        <Setter Property="Stroke" Value="{StaticResource Warn600}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 999" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="HorizontalOptions" Value="Start" />
    </Style>
    <Style x:Key="StatusPillCrit" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Dark={StaticResource Crit100}, Light={StaticResource Crit50}}" />
        <Setter Property="Stroke" Value="{StaticResource Crit600}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 999" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="HorizontalOptions" Value="Start" />
    </Style>

    <!-- ===== Inputs ===== -->
    <Style TargetType="Entry">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
        <Setter Property="PlaceholderColor"
                Value="{AppThemeBinding Dark={StaticResource TextMutedDark}, Light={StaticResource TextMutedLight}}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Transparent}" />
        <Setter Property="MinimumHeightRequest" Value="40" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color"
                Value="{AppThemeBinding Dark={StaticResource Gold500}, Light={StaticResource Gold600}}" />
    </Style>

</ResourceDictionary>
