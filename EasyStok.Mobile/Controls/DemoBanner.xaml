<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EasyStok.Mobile.Controls.DemoBanner">
    <Border Style="{StaticResource BannerDemo}">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Label Grid.Column="0"
                   Text="MODO APRESENTAÇÃO ATIVO"
                   FontFamily="Inter"
                   FontSize="11"
                   FontAttributes="Bold"
                   CharacterSpacing="2.5"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Dark={StaticResource Gold200}, Light={StaticResource Gold700}}" />
            <Border Grid.Column="1"
                    BackgroundColor="{AppThemeBinding Dark={StaticResource Gold600}, Light={StaticResource Gold600}}"
                    StrokeShape="RoundRectangle 999"
                    StrokeThickness="0"
                    Padding="14,4">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSairTapped" />
                </Border.GestureRecognizers>
                <Label Text="Sair"
                       FontFamily="Fraunces"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Navy900}" />
            </Border>
        </Grid>
    </Border>
</ContentView>
