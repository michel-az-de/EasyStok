<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EasyStok.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:EasyStok.Mobile.Views"
    Title="EasyStok Mobile"
    FlyoutBehavior="Disabled">

    <!--
    Arquitetura hibrida v1.3:
    - Pre-login (Login/Tenant/Loja) e Suporte: telas MAUI nativas, TabBar oculta.
    - Pos-login: WebOpsPage (HybridWebView) carregando o PWA empacotado em
      Resources/Raw/pwa. PWA tem sua propria nav inferior, entao TabBar
      nativa fica oculta tambem. Bridge JS->Native: PWA chama
      window.HybridWebView.SendRawMessage('logout'|'ajustes') para acoes
      que precisam saltar pra MAUI.
    -->

    <TabBar Shell.TabBarIsVisible="False">
        <ShellContent Route="login" ContentTemplate="{DataTemplate views:LoginPage}" />
        <ShellContent Route="tenant-picker" ContentTemplate="{DataTemplate views:TenantPickerPage}" />
        <ShellContent Route="loja-picker" ContentTemplate="{DataTemplate views:LojaPickerPage}" />
        <ShellContent Route="web-ops" ContentTemplate="{DataTemplate views:WebOpsPage}" />
        <ShellContent Route="suporte" ContentTemplate="{DataTemplate views:SuportePage}" />
    </TabBar>

</Shell>
