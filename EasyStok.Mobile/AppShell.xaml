<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EasyStok.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:EasyStok.Mobile.Views"
    Title="EasyStok Mobile"
    FlyoutBehavior="Disabled"
    Shell.TabBarIsVisible="False">

    <!--
    Rotas declaradas como ShellContent para suportar navegacao absoluta
    (Shell.Current.GoToAsync("//rota")). LoginPage e a primeira para ser
    o landing default antes de OnNavigated redirecionar conforme sessao.
    Agrupado em <TabBar> com TabBarIsVisible=False para esconder a tab bar.
    -->
    <TabBar>
        <ShellContent Route="login" ContentTemplate="{DataTemplate views:LoginPage}" />
        <ShellContent Route="tenant-picker" ContentTemplate="{DataTemplate views:TenantPickerPage}" />
        <ShellContent Route="loja-picker" ContentTemplate="{DataTemplate views:LojaPickerPage}" />
        <ShellContent Route="home" ContentTemplate="{DataTemplate views:HomePage}" />
        <ShellContent Route="producao" ContentTemplate="{DataTemplate views:ProducaoPage}" />
        <ShellContent Route="pedidos" ContentTemplate="{DataTemplate views:PedidosPage}" />
        <ShellContent Route="caixa" ContentTemplate="{DataTemplate views:CaixaPage}" />
        <ShellContent Route="finalizados" ContentTemplate="{DataTemplate views:FinalizadosPage}" />
        <ShellContent Route="clientes" ContentTemplate="{DataTemplate views:ClientesPage}" />
        <ShellContent Route="suporte" ContentTemplate="{DataTemplate views:SuportePage}" />
        <ShellContent Route="conferencia" ContentTemplate="{DataTemplate views:ConferenciaPage}" />
        <ShellContent Route="compras" ContentTemplate="{DataTemplate views:ComprasPage}" />
        <ShellContent Route="historico" ContentTemplate="{DataTemplate views:HistoricoPage}" />
        <ShellContent Route="estoque" ContentTemplate="{DataTemplate views:EstoquePage}" />
    </TabBar>

</Shell>
