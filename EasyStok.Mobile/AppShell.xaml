<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EasyStok.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:EasyStok.Mobile.Views"
    Title="EasyStok Mobile"
    FlyoutBehavior="Disabled">

    <!--
    HomePage e a rota inicial. Demais rotas registradas em
    AppShell.xaml.cs para navegacao via Shell.Current.GoToAsync("rota").
    -->
    <ShellContent
        Title="Inicio"
        Route="home"
        ContentTemplate="{DataTemplate views:HomePage}" />

</Shell>
