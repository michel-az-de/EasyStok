<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyStok.Mobile.ViewModels"
             xmlns:storage="clr-namespace:EasyStok.Mobile.Storage"
             x:Class="EasyStok.Mobile.Views.FinalizadosPage"
             x:DataType="vm:FinalizadosViewModel"
             Title="Finalizados"
             Shell.NavBarIsVisible="False">
    <Grid Padding="20,16" RowDefinitions="Auto,Auto,*" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="Finalizados" Style="{StaticResource LabelH1}" />
            <Label Text="pedidos entregues por dia" Style="{StaticResource LabelSmall}" />
        </VerticalStackLayout>

        <Border Grid.Row="1" Style="{StaticResource FieldBox}">
            <Grid ColumnDefinitions="Auto,*">
                <Label Grid.Column="0" Text="DATA" Style="{StaticResource LabelEyebrow}" VerticalOptions="Center" Margin="0,0,8,0" />
                <DatePicker Grid.Column="1" Date="{Binding DataSelecionada}" />
            </Grid>
        </Border>

        <CollectionView Grid.Row="2" ItemsSource="{Binding Itens}" SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="Nenhum pedido entregue nesta data." Style="{StaticResource LabelSmall}" HorizontalOptions="Center" VerticalOptions="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="storage:CachedPedido">
                    <Border Style="{StaticResource Card}" Margin="0,4">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding ClienteNome}" Style="{StaticResource LabelH3}" />
                                <Label Text="{Binding ShortCode, StringFormat='código {0}'}" Style="{StaticResource LabelEyebrow}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                                <Label Text="{Binding Total, StringFormat='R$ {0:N2}'}" Style="{StaticResource LabelH3}" TextColor="{StaticResource Orange500}" />
                                <Label Text="{Binding AtualizadoUtc, StringFormat='{0:HH:mm}'}" Style="{StaticResource LabelEyebrow}" HorizontalTextAlignment="End" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
