<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="EasyStok.Mobile.Views.ProducaoCapturaPopup"
               CanBeDismissedByTappingOutsideOfPopup="True"
               Color="Transparent">

    <Border Style="{StaticResource Card}"
            BackgroundColor="{AppThemeBinding Dark={StaticResource BgElevDark}, Light={StaticResource BgElevLight}}"
            WidthRequest="320"
            Padding="18">
        <VerticalStackLayout Spacing="12">

            <VerticalStackLayout Spacing="2">
                <Label x:Name="TituloLabel"
                       Text="Registrar producao"
                       Style="{StaticResource LabelTitle}" />
                <Label x:Name="ProdutoLabel"
                       Text=""
                       Style="{StaticResource LabelGreeting}" />
            </VerticalStackLayout>

            <!-- Quantidade -->
            <VerticalStackLayout Spacing="4">
                <Label Text="QUANTIDADE" Style="{StaticResource LabelSuffix}" />
                <Entry x:Name="QuantidadeEntry"
                       Text="1"
                       Keyboard="Numeric" />
            </VerticalStackLayout>

            <!-- Peso (g) -->
            <VerticalStackLayout Spacing="4">
                <Label Text="PESO (G) — OPCIONAL" Style="{StaticResource LabelSuffix}" />
                <Entry x:Name="PesoEntry"
                       Text=""
                       Placeholder="ex. 250"
                       Keyboard="Numeric" />
            </VerticalStackLayout>

            <!-- Validade -->
            <VerticalStackLayout Spacing="4">
                <Label Text="VALIDADE — OPCIONAL" Style="{StaticResource LabelSuffix}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <DatePicker x:Name="ValidadePicker" Grid.Column="0" />
                    <Button Grid.Column="1"
                            Text="Limpar"
                            Style="{StaticResource ButtonGhost}"
                            FontSize="12"
                            Padding="10,4"
                            Clicked="OnLimparValidade" />
                </Grid>
            </VerticalStackLayout>

            <!-- Foto -->
            <VerticalStackLayout Spacing="4">
                <Label Text="FOTO — OPCIONAL" Style="{StaticResource LabelSuffix}" />
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Border Grid.Column="0"
                            WidthRequest="60"
                            HeightRequest="60"
                            Stroke="{AppThemeBinding Dark={StaticResource BorderStrongDark}, Light={StaticResource BorderStrongLight}}"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Dark={StaticResource BgElev2Dark}, Light={StaticResource BgElev2Light}}">
                        <Image x:Name="FotoPreview" Aspect="AspectFill" />
                    </Border>
                    <Button Grid.Column="1"
                            x:Name="FotoButton"
                            Text="Capturar foto"
                            Style="{StaticResource ButtonGhost}"
                            Clicked="OnCapturarFoto" />
                </Grid>
            </VerticalStackLayout>

            <Label x:Name="ErroLabel"
                   Text=""
                   TextColor="{AppThemeBinding Dark={StaticResource AccentDark}, Light={StaticResource AccentLight}}"
                   FontSize="12"
                   IsVisible="False" />

            <!-- Acoes -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
                <Button Grid.Column="0"
                        Text="Cancelar"
                        Style="{StaticResource ButtonGhost}"
                        Clicked="OnCancelar" />
                <Button Grid.Column="1"
                        Text="Confirmar"
                        Clicked="OnConfirmar" />
            </Grid>

        </VerticalStackLayout>
    </Border>

</toolkit:Popup>
