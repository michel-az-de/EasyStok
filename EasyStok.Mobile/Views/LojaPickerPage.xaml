<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyStok.Mobile.ViewModels"
             xmlns:models="clr-namespace:EasyStok.Mobile.Models"
             x:Class="EasyStok.Mobile.Views.LojaPickerPage"
             x:DataType="vm:LojaPickerViewModel"
             Title="Selecionar loja"
             Shell.NavBarIsVisible="False">
    <Grid Padding="22,32">
        <VerticalStackLayout Spacing="14">

            <VerticalStackLayout Spacing="2" HorizontalOptions="Center" Margin="0,0,0,12">
                <Label Text="Selecione a loja" Style="{StaticResource LabelHero}" HorizontalOptions="Center" />
                <Label Text="{Binding EmpresaLabel}" Style="{StaticResource LabelGreeting}" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HeightRequest="24" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{AppThemeBinding Dark={StaticResource AccentDark}, Light={StaticResource AccentLight}}"
                   FontSize="12"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}" />

            <Label Text="Nenhuma loja ativa nesta empresa."
                   Style="{StaticResource LabelSubtitle}"
                   IsVisible="{Binding SemLojas}"
                   HorizontalOptions="Center" />

            <CollectionView ItemsSource="{Binding Lojas}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Loja">
                        <Border Style="{StaticResource Card}" Margin="0,4">
                            <Border.GestureRecognizers>
                                <!-- RelativeSource AncestorType localiza o ContentPage cujo BindingContext é LojaPickerViewModel.
                                     Padrão canônico MAUI para compiled bindings dentro de DataTemplate (substitui o hack
                                     anterior com Source={x:Reference LojaPickerRoot} + LojaPickerRoot.BindingContext=vm).
                                     Comportamento runtime equivalente: dispara SelectCommand do VM ao tapar item. -->
                                <TapGestureRecognizer Command="{Binding Path=SelectCommand, Source={RelativeSource Mode=FindAncestorBindingContext, AncestorType={x:Type vm:LojaPickerViewModel}}, x:DataType=vm:LojaPickerViewModel}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding Nome}" Style="{StaticResource LabelTitle}" />
                                    <Label Text="LOJA" Style="{StaticResource LabelSuffix}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="22"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Dark={StaticResource AccentDark}, Light={StaticResource AccentLight}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Sair" Style="{StaticResource ButtonGhost}" Command="{Binding LogoutCommand}" />

        </VerticalStackLayout>
    </Grid>
</ContentPage>
