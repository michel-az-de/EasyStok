<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrls="clr-namespace:EasyStok.Mobile.Controls"
             x:Class="EasyStok.Mobile.Views.HomePage"
             Title="Hoje"
             Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,32" Spacing="16">

            <ctrls:BrandHeader x:Name="Header" />

            <ctrls:DemoBanner x:Name="DemoBannerCtrl" />

            <!-- Esteira de pedidos resumo -->
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="ESTEIRA DE PEDIDOS" Style="{StaticResource LabelEyebrow}" />
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource Orange500}"
                            StrokeShape="RoundRectangle 999"
                            StrokeThickness="0"
                            Padding="9,2"
                            VerticalOptions="Center">
                        <Label Text="3"
                               FontFamily="Fraunces" FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource White}" />
                    </Border>
                </Grid>

                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="AGUARDANDO" Style="{StaticResource LabelEyebrow}" TextColor="{StaticResource Gold600}" />
                            <Label Grid.Column="1" Text="2" Style="{StaticResource LabelEyebrow}" />
                        </Grid>
                        <Border BackgroundColor="{AppThemeBinding Dark={StaticResource BgElevatedDark}, Light={StaticResource BgElevatedLight}}"
                                Stroke="{StaticResource Gold500}"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="1"
                                Padding="14">
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="Luiz Fernando" Style="{StaticResource LabelH3}" />
                                    <Label Grid.Column="1" Text="R$ 58,00"
                                           FontFamily="Fraunces" FontSize="18" FontAttributes="Bold"
                                           TextColor="{StaticResource Gold600}" />
                                </Grid>
                                <Label Text="Apto 54 - Torre 2" Style="{StaticResource LabelSmall}" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,6,0,0">
                                    <Button Grid.Column="0" Text="▶  Iniciar preparo" Style="{StaticResource ButtonCoral}" />
                                    <Button Grid.Column="1" Text="Abrir" Style="{StaticResource ButtonGhost}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Os pedidos acima são de demonstração. Use a aba Pedidos para o kanban completo."
                       Style="{StaticResource LabelSmall}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- KPIs do dia -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="*,*" ColumnSpacing="10" RowSpacing="10">
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="ITENS EM ESTOQUE" Style="{StaticResource LabelEyebrow}" />
                        <Label x:Name="KpiItens" Text="—"
                               FontFamily="Fraunces" FontSize="32" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Dark={StaticResource Gold500}, Light={StaticResource Gold600}}" />
                        <Label Text="produtos cadastrados" Style="{StaticResource LabelSmall}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="ALERTAS" Style="{StaticResource LabelEyebrow}" />
                        <Label x:Name="KpiAlertas" Text="—"
                               FontFamily="Fraunces" FontSize="32" FontAttributes="Bold"
                               TextColor="{StaticResource Crit600}" />
                        <Label Text="críticos / vencidos" Style="{StaticResource LabelSmall}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="VENDAS HOJE" Style="{StaticResource LabelEyebrow}" />
                        <Label x:Name="KpiVendas" Text="R$ 0"
                               FontFamily="Fraunces" FontSize="22" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource Navy700}}" />
                        <Label Text="movimento bruto" Style="{StaticResource LabelSmall}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="PEDIDOS ABERTOS" Style="{StaticResource LabelEyebrow}" />
                        <Label x:Name="KpiPedidos" Text="0"
                               FontFamily="Fraunces" FontSize="22" FontAttributes="Bold"
                               TextColor="{StaticResource Orange500}" />
                        <Label Text="aguardando preparo" Style="{StaticResource LabelSmall}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
