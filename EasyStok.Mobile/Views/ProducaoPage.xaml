<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyStok.Mobile.ViewModels"
             xmlns:storage="clr-namespace:EasyStok.Mobile.Storage"
             xmlns:ctrls="clr-namespace:EasyStok.Mobile.Controls"
             x:Class="EasyStok.Mobile.Views.ProducaoPage"
             x:DataType="vm:ProducaoViewModel"
             Title="Produção"
             Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,32" Spacing="14">

            <ctrls:BrandHeader x:Name="Header" />

            <ctrls:DemoBanner />

            <!-- Card hero "Registrar lote" -->
            <Border Style="{StaticResource CardHero}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Registrar lote"
                           FontFamily="Fraunces"
                           FontSize="32"
                           FontAttributes="Bold"
                           CharacterSpacing="-0.5"
                           TextColor="{AppThemeBinding Dark={StaticResource Gold100}, Light={StaticResource Navy900}}" />
                    <Button Text="Cadastrar produto"
                            HorizontalOptions="Start"
                            BackgroundColor="{AppThemeBinding Dark={StaticResource Gold500}, Light={StaticResource Gold600}}"
                            TextColor="{StaticResource Navy900}" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="CATÁLOGO DE PRODUÇÃO" Style="{StaticResource LabelEyebrow}" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="{Binding StatusLine}" Style="{StaticResource LabelSmall}" VerticalOptions="Center" />
            </Grid>

            <!-- Tabs Catálogo / Lotes (placeholder visual; Lotes vai vir em v1.3) -->
            <Border BackgroundColor="{AppThemeBinding Dark={StaticResource BgSurfaceDark}, Light={StaticResource BgSurfaceLight}}"
                    Stroke="{AppThemeBinding Dark={StaticResource BorderSoftDark}, Light={StaticResource BorderSoftLight}}"
                    StrokeShape="RoundRectangle 14"
                    StrokeThickness="1"
                    Padding="4">
                <Grid ColumnDefinitions="*,*">
                    <Border Grid.Column="0"
                            BackgroundColor="{AppThemeBinding Dark={StaticResource Gold600}, Light={StaticResource Gold500}}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            Padding="14,10">
                        <Label Text="Catálogo"
                               FontFamily="Fraunces" FontSize="15" FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource Navy900}" />
                    </Border>
                    <Label Grid.Column="1" Text="Lotes (em breve)"
                           FontFamily="Fraunces" FontSize="15" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Dark={StaticResource TextMutedDark}, Light={StaticResource TextMutedLight}}" />
                </Grid>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HeightRequest="20" />

            <Label Text="Nenhum item de estoque por aqui ainda."
                   Style="{StaticResource LabelSmall}"
                   IsVisible="{Binding SemDados}"
                   HorizontalOptions="Center"
                   Margin="0,12,0,0" />

            <!-- Lista de produtos com stepper inline (não modal) -->
            <CollectionView x:Name="ProducaoList"
                            ItemsSource="{Binding Itens}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="storage:CachedItemEstoque">
                        <Border Style="{StaticResource Card}" Margin="0,4">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="{Binding Emoji}" FontSize="28" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding ProdutoNome}" Style="{StaticResource LabelH3}" LineBreakMode="TailTruncation" MaxLines="1" />
                                    <Label Text="{Binding Sku}" Style="{StaticResource LabelEyebrow}" />
                                    <Label Text="{Binding Status, StringFormat='{0}'}" Style="{StaticResource LabelEyebrow}" />

                                </VerticalStackLayout>
                                <!-- Stepper inline -->
                                <Border Grid.Column="2"
                                        BackgroundColor="{AppThemeBinding Dark={StaticResource BgElevatedDark}, Light={StaticResource BgElevatedLight}}"
                                        Stroke="{AppThemeBinding Dark={StaticResource BorderSoftDark}, Light={StaticResource BorderSoftLight}}"
                                        StrokeShape="RoundRectangle 12"
                                        StrokeThickness="1"
                                        Padding="2"
                                        VerticalOptions="Center">
                                    <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="0">
                                        <Button Grid.Column="0" Text="−"
                                                BackgroundColor="{StaticResource Transparent}"
                                                TextColor="{StaticResource Crit600}"
                                                FontSize="20" FontAttributes="Bold"
                                                Padding="10,4" MinimumHeightRequest="36" CornerRadius="8"
                                                Clicked="OnDecrementClicked"
                                                CommandParameter="{Binding .}" />
                                        <Label Grid.Column="1" Text="{Binding Qty}"
                                               FontFamily="Fraunces" FontSize="20" FontAttributes="Bold"
                                               VerticalOptions="Center" Margin="6,0"
                                               TextColor="{AppThemeBinding Dark={StaticResource TextPrimaryDark}, Light={StaticResource TextPrimaryLight}}" />
                                        <Button Grid.Column="2" Text="+"
                                                BackgroundColor="{StaticResource Transparent}"
                                                TextColor="{StaticResource Gold600}"
                                                FontSize="20" FontAttributes="Bold"
                                                Padding="10,4" MinimumHeightRequest="36" CornerRadius="8"
                                                Clicked="OnIncrementClicked"
                                                CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
