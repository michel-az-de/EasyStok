<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyStok.Mobile.ViewModels"
             xmlns:storage="clr-namespace:EasyStok.Mobile.Storage"
             x:Class="EasyStok.Mobile.Views.ProducaoPage"
             x:DataType="vm:ProducaoViewModel"
             Title="Producao"
             Shell.NavBarIsVisible="False">
    <Grid Padding="22,16" RowDefinitions="Auto,Auto,Auto,*">

        <!-- Header brand -->
        <VerticalStackLayout Grid.Row="0" Spacing="2" Margin="0,0,0,12">
            <Label Text="Producao" Style="{StaticResource LabelHero}" />
            <Label Text="estoque ativo" Style="{StaticResource LabelGreeting}" />
        </VerticalStackLayout>

        <!-- Status / refresh / pending count -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="0,0,0,8">
            <Label Grid.Column="0"
                   Text="{Binding StatusLine}"
                   Style="{StaticResource LabelCaption}"
                   VerticalOptions="Center" />
            <Border Grid.Column="1"
                    Style="{StaticResource CardElev}"
                    Padding="8,4"
                    IsVisible="{Binding PendingMutations, Converter={StaticResource IntGreaterThanZeroConverter}}">
                <Label Text="{Binding PendingMutations, StringFormat='{0} pendente(s)'}"
                       Style="{StaticResource LabelCaption}"
                       TextColor="{AppThemeBinding Dark={StaticResource GoldDark}, Light={StaticResource GoldLight}}" />
            </Border>
            <Button Grid.Column="2"
                    Text="Atualizar"
                    Style="{StaticResource ButtonGhost}"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
        </Grid>

        <VerticalStackLayout Grid.Row="2" Spacing="6">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HeightRequest="20" />
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{AppThemeBinding Dark={StaticResource AccentDark}, Light={StaticResource AccentLight}}"
                   FontSize="12"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
            <Label Text="Nenhum item de estoque para a empresa atual."
                   Style="{StaticResource LabelSubtitle}"
                   IsVisible="{Binding SemDados}"
                   HorizontalOptions="Center"
                   Margin="0,12,0,0" />
        </VerticalStackLayout>

        <!-- Grid 2 colunas com botoes +/- -->
        <CollectionView Grid.Row="3"
                        x:Name="ProducaoList"
                        ItemsSource="{Binding Itens}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="2"
                                 HorizontalItemSpacing="8"
                                 VerticalItemSpacing="8" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="storage:CachedItemEstoque">
                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding ProdutoNome}"
                                       Style="{StaticResource LabelTitle}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                                <Label Grid.Column="1"
                                       Text="{Binding Emoji}"
                                       FontSize="22"
                                       VerticalOptions="Start" />
                            </Grid>
                            <Label Text="{Binding Sku, StringFormat='SKU {0}'}"
                                   Style="{StaticResource LabelCaption}" />
                            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                <Label Grid.Column="0"
                                       Text="{Binding Qty, StringFormat='{0} un'}"
                                       FontFamily="Manrope"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Dark={StaticResource AccentDark}, Light={StaticResource AccentLight}}" />
                                <Label Grid.Column="1"
                                       Text="{Binding Status}"
                                       Style="{StaticResource LabelSuffix}"
                                       VerticalOptions="End" />
                            </Grid>

                            <!-- Botoes +/-  -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="6" Margin="0,8,0,0">
                                <Button Grid.Column="0"
                                        Text="−"
                                        FontSize="20"
                                        FontAttributes="Bold"
                                        Style="{StaticResource ButtonGhost}"
                                        HeightRequest="40"
                                        Command="{Binding Path=BindingContext.DecrementCommand, Source={x:Reference ProducaoList}}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="1"
                                        Text="+"
                                        FontSize="20"
                                        FontAttributes="Bold"
                                        HeightRequest="40"
                                        Command="{Binding Path=BindingContext.IncrementCommand, Source={x:Reference ProducaoList}}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
