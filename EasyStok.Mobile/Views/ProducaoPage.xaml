<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyStok.Mobile.ViewModels"
             xmlns:storage="clr-namespace:EasyStok.Mobile.Storage"
             x:Class="EasyStok.Mobile.Views.ProducaoPage"
             x:DataType="vm:ProducaoViewModel"
             Title="Produção"
             Shell.NavBarIsVisible="False">
    <Grid Padding="20,16" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Produção" Style="{StaticResource LabelH1}" />
                <Label Text="estoque ativo da loja" Style="{StaticResource LabelSmall}" />
            </VerticalStackLayout>
            <Border Grid.Column="1"
                    BackgroundColor="{StaticResource Orange600}"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0"
                    Padding="10,6"
                    VerticalOptions="Center"
                    IsVisible="{Binding PendingMutations, Converter={StaticResource IntGreaterThanZeroConverter}}">
                <Label Text="{Binding PendingMutations, StringFormat='{0} pendentes'}"
                       FontFamily="Inter"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}" />
            </Border>
        </Grid>

        <!-- Status + Atualizar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Label Grid.Column="0"
                   Text="{Binding StatusLine}"
                   Style="{StaticResource LabelSmall}"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="Atualizar"
                    Style="{StaticResource ButtonGhost}"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
        </Grid>

        <VerticalStackLayout Grid.Row="2" Spacing="6">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HeightRequest="20" />
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Crit600}"
                   FontFamily="Inter"
                   FontSize="13"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
            <Label Text="Nenhum item de estoque por aqui ainda."
                   Style="{StaticResource LabelSmall}"
                   IsVisible="{Binding SemDados}"
                   HorizontalOptions="Center"
                   Margin="0,12,0,0" />
        </VerticalStackLayout>

        <!-- Grid 2 colunas -->
        <CollectionView Grid.Row="3"
                        x:Name="ProducaoList"
                        ItemsSource="{Binding Itens}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="2"
                                 HorizontalItemSpacing="8"
                                 VerticalItemSpacing="8" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="storage:CachedItemEstoque">
                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding ProdutoNome}"
                                       Style="{StaticResource LabelH3}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                                <Label Grid.Column="1"
                                       Text="{Binding Emoji}"
                                       FontSize="22"
                                       VerticalOptions="Start" />
                            </Grid>
                            <Label Text="{Binding Sku, StringFormat='SKU {0}'}"
                                   Style="{StaticResource LabelEyebrow}" />
                            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                <Label Grid.Column="0"
                                       Text="{Binding Qty, StringFormat='{0} un'}"
                                       FontFamily="Inter"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Orange500}" />
                                <Label Grid.Column="1"
                                       Text="{Binding Status}"
                                       Style="{StaticResource LabelEyebrow}"
                                       VerticalOptions="End" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="6" Margin="0,8,0,0">
                                <Button Grid.Column="0"
                                        Text="−"
                                        FontSize="20"
                                        FontAttributes="Bold"
                                        Style="{StaticResource ButtonGhost}"
                                        HeightRequest="40"
                                        Clicked="OnDecrementClicked"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="1"
                                        Text="+"
                                        FontSize="20"
                                        FontAttributes="Bold"
                                        HeightRequest="40"
                                        Clicked="OnIncrementClicked"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
