<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrls="clr-namespace:EasyStok.Mobile.Controls"
             x:Class="EasyStok.Mobile.Views.MaisPage"
             Title="Mais"
             Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,32" Spacing="18">

            <ctrls:BrandHeader x:Name="Header" />

            <ctrls:DemoBanner />

            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="MAIS FERRAMENTAS" Style="{StaticResource LabelEyebrow}" VerticalOptions="Center" />
                <Border Grid.Column="1"
                        BackgroundColor="{AppThemeBinding Dark={StaticResource Gold700}, Light={StaticResource Gold100}}"
                        Stroke="{AppThemeBinding Dark={StaticResource Gold600}, Light={StaticResource Gold400}}"
                        StrokeShape="RoundRectangle 999"
                        StrokeThickness="1"
                        Padding="14,4">
                    <Label Text="SIMPLES"
                           FontFamily="Inter" FontSize="10" FontAttributes="Bold" CharacterSpacing="2"
                           TextColor="{AppThemeBinding Dark={StaticResource Gold200}, Light={StaticResource Gold700}}" />
                </Border>
            </Grid>

            <!-- Grid 3x3 — fonte menor + lineheight curto + permitir 2 linhas centralizadas -->
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*,*" ColumnSpacing="10" RowSpacing="10">
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Padding="10" HeightRequest="92">
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnTapHistorico" /></Border.GestureRecognizers>
                    <Label Text="Histórico" FontFamily="Fraunces" FontSize="15" FontAttributes="Bold" LineHeight="1" HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Padding="10" HeightRequest="92">
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnTapEstoque" /></Border.GestureRecognizers>
                    <Label Text="Estoque" FontFamily="Fraunces" FontSize="15" FontAttributes="Bold" LineHeight="1" HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource Card}" Padding="10" HeightRequest="92">
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnTapClientes" /></Border.GestureRecognizers>
                    <Label Text="Clientes" FontFamily="Fraunces" FontSize="15" FontAttributes="Bold" LineHeight="1" HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}" Padding="10" HeightRequest="92">
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnTapCompras" /></Border.GestureRecognizers>
                    <Label Text="Compras" FontFamily="Fraunces" FontSize="15" FontAttributes="Bold" LineHeight="1" HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Padding="10" HeightRequest="92">
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnTapCaixa" /></Border.GestureRecognizers>
                    <Label Text="Caixa" FontFamily="Fraunces" FontSize="15" FontAttributes="Bold" LineHeight="1" HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource Card}" Padding="10" HeightRequest="92">
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnTapFinalizados" /></Border.GestureRecognizers>
                    <Label Text="Finalizados" FontFamily="Fraunces" FontSize="13" FontAttributes="Bold" LineHeight="1" HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}" Padding="10" HeightRequest="92">
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnTapSuporte" /></Border.GestureRecognizers>
                    <Label Text="Suporte" FontFamily="Fraunces" FontSize="15" FontAttributes="Bold" LineHeight="1" HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource Card}" Padding="10" HeightRequest="92">
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnTapSuporte" /></Border.GestureRecognizers>
                    <Label Text="Ajustes" FontFamily="Fraunces" FontSize="15" FontAttributes="Bold" LineHeight="1" HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource Card}" Padding="10" HeightRequest="92">
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnTapConferencia" /></Border.GestureRecognizers>
                    <Label Text="Busca" FontFamily="Fraunces" FontSize="15" FontAttributes="Bold" LineHeight="1" HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
