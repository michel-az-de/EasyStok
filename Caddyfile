# Caddyfile — reverse proxy com HTTPS automatico (Let's Encrypt).
# Os hostnames vem do .env (sslip.io baseado no IP publico da VM).
# Caddy emite e renova os certificados sozinho.

{
	email {$ACME_EMAIL}
}

# Web (MVC) — pagina publica/app
{$APP_HOST} {
	reverse_proxy web:8081
}

# Admin (Razor Pages)
{$ADMIN_HOST} {
	reverse_proxy admin:8080
}

# API (.NET) — backend + endpoints mobile/PWA
{$API_HOST} {
	reverse_proxy api:8080
}

# Casa da Baba — atalho dedicado: raiz abre o PWA; o resto proxia pra API
# (mesma origem preservada => os fetch relativos /api/... continuam funcionando).
{$CASA_HOST} {
	@root path /
	redir @root /pwa/
	reverse_proxy api:8080
}

# casadababa.com (storefront Vite/Alpine) — site estatico + API na MESMA origem
# (handle /api/* -> api; resto -> container storefront). Dispensa CORS/cookie cross-site.
{$CASADABABA_HOST} {
	handle /api/* {
		reverse_proxy api:8080
	}
	handle {
		reverse_proxy storefront:8080
	}
}

# casadababa.com (dominio real) - host explicito; mesma config do storefront sslip.
# handle /api/* -> api; resto -> storefront (mesma origem, sem CORS). Cert LE via HTTP-01. refs #703
casadababa.com, www.casadababa.com {
	handle /api/* {
		reverse_proxy api:8080
	}
	handle {
		reverse_proxy storefront:8080
	}
}
