  "apiGroups": [
    {
      "id": "auth-api",
      "icon": "🔐",
      "title": { "pt": "Autenticação", "en": "Authentication" },
      "baseUrl": "/api/auth",
      "endpoints": [
        { "method": "POST", "path": "/login",           "description": { "pt": "Login do usuário (retorna JWT)",             "en": "User login (returns JWT)" } },
        { "method": "POST", "path": "/register",        "description": { "pt": "Registro de novo usuário",                   "en": "Register new user" } },
        { "method": "POST", "path": "/refresh",         "description": { "pt": "Renovar token JWT",                          "en": "Refresh JWT token" } },
        { "method": "POST", "path": "/logout",          "description": { "pt": "Logout e invalidar token",                   "en": "Logout & invalidate token" } },
        { "method": "POST", "path": "/forgot-password", "description": { "pt": "Iniciar redefinição de senha",               "en": "Initiate password reset" } },
        { "method": "POST", "path": "/reset-password",  "description": { "pt": "Concluir redefinição de senha",              "en": "Complete password reset" } },
        { "method": "GET",  "path": "/me",              "description": { "pt": "Obter usuário atual",                        "en": "Get current user" } },
        { "method": "PATCH","path": "/me",              "description": { "pt": "Atualizar perfil do usuário atual",          "en": "Update current user profile" } },
        { "method": "PATCH","path": "/me/password",     "description": { "pt": "Alterar senha",                              "en": "Change password" } }
      ]
    },
    {
      "id": "products-api",
      "icon": "📦",
      "title": { "pt": "Produtos", "en": "Products" },
      "baseUrl": "/api/produtos",
      "endpoints": [
        { "method": "GET",   "path": "",                  "description": { "pt": "Listar produtos (paginado)",               "en": "List products (paginated)" } },
        { "method": "POST",  "path": "",                  "description": { "pt": "Criar produto",                            "en": "Create product" } },
        { "method": "GET",   "path": "/{id}",             "description": { "pt": "Obter produto com variações",              "en": "Get product with variations" } },
        { "method": "PATCH", "path": "/{id}",             "description": { "pt": "Atualizar produto",                        "en": "Update product" } },
        { "method": "GET",   "path": "/search",           "description": { "pt": "Pesquisar produtos por termo",             "en": "Search products by term" } },
        { "method": "POST",  "path": "/{id}/variacoes",   "description": { "pt": "Adicionar variação ao produto",            "en": "Add product variation" } },
        { "method": "POST",  "path": "/{id}/embalagens",  "description": { "pt": "Adicionar embalagem/SKU",                  "en": "Add packaging/SKU" } }
      ]
    },
    {
      "id": "stock-api",
      "icon": "🏭",
      "title": { "pt": "Estoque", "en": "Stock" },
      "baseUrl": "/api/estoque",
      "endpoints": [
        { "method": "GET",  "path": "",              "description": { "pt": "Listar itens de estoque (paginado)",            "en": "List stock items (paginated)" } },
        { "method": "GET",  "path": "/{id}",         "description": { "pt": "Obter detalhes do item",                       "en": "Get item details" } },
        { "method": "GET",  "path": "/buscar",       "description": { "pt": "Busca inteligente (texto, SKU, código barras)","en": "Intelligent search (text, SKU, barcode)" } },
        { "method": "POST", "path": "/entrada",      "description": { "pt": "Registrar entrada de estoque",                 "en": "Register stock entry" } },
        { "method": "POST", "path": "/saida",        "description": { "pt": "Registrar saída de estoque/venda",             "en": "Register stock exit / sale" } },
        { "method": "GET",  "path": "/{id}/para-reposicao", "description": { "pt": "Sugestões de reposição",                "en": "Replenishment suggestions" } }
      ]
    },
    {
      "id": "analytics-api",
      "icon": "📊",
      "title": { "pt": "Analytics", "en": "Analytics" },
      "baseUrl": "/api/analytics",
      "endpoints": [
        { "method": "GET", "path": "/dashboard",    "description": { "pt": "Dashboard resumido (período 30 dias)",          "en": "Summary dashboard (30-day period)" } },
        { "method": "GET", "path": "/projecoes",    "description": { "pt": "Projeções de ruptura de estoque",               "en": "Stock rupture projections" } },
        { "method": "GET", "path": "/reposicao",    "description": { "pt": "Análise detalhada de reposição",                "en": "Detailed replenishment analysis" } },
        { "method": "GET", "path": "/sazonalidade", "description": { "pt": "Tendências de sazonalidade por produto",        "en": "Seasonality trends by product" } },
        { "method": "GET", "path": "/alertas",      "description": { "pt": "Alertas de vencimento",                        "en": "Expiry alerts" } },
        { "method": "GET", "path": "/receita",      "description": { "pt": "Receita por período (mensal)",                  "en": "Revenue by period (monthly)" } },
        { "method": "GET", "path": "/margem",       "description": { "pt": "Análise de margem de lucro",                   "en": "Profit margin analysis" } }
      ]
    },
    {
      "id": "ai-api",
      "icon": "🤖",
      "title": { "pt": "Inteligência IA", "en": "AI Intelligence" },
      "baseUrl": "/api/ia",
      "endpoints": [
        { "method": "POST",   "path": "/anuncio",      "description": { "pt": "Gerar anúncio do produto (SSE streaming)",  "en": "Generate product announcement (SSE streaming)" } },
        { "method": "POST",   "path": "/rascunho",     "description": { "pt": "Salvar rascunho de anúncio",                "en": "Save draft announcement" } },
        { "method": "GET",    "path": "/anuncios",     "description": { "pt": "Listar anúncios gerados por IA",            "en": "List AI-generated announcements" } },
        { "method": "DELETE", "path": "/anuncios/{id}","description": { "pt": "Excluir anúncio",                           "en": "Delete announcement" } },
        { "method": "GET",    "path": "/uso",          "description": { "pt": "Obter estatísticas de uso de IA",           "en": "Get AI usage stats" } }
      ]
    }
  ],

