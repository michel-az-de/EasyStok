  "changelog": [
    {
      "version": "1.0.0",
      "date": "2025-04-05",
      "changes": {
        "pt": [
          "Lançamento inicial da plataforma EasyStok",
          "Gestão completa de produtos com variações e embalagens",
          "Controle de estoque com rastreamento de lotes e validade",
          "Gestão de vendas multi-canal",
          "Alertas inteligentes (estoque baixo, vencimento, itens parados)",
          "Analytics preditivo e análise de sazonalidade",
          "Geração de anúncios via IA com streaming SSE",
          "Multi-tenancy com isolamento por empresa",
          "Autenticação JWT com rotação de refresh token",
          "Suporte dual a PostgreSQL e MongoDB"
        ],
        "en": [
          "Initial release of EasyStok platform",
          "Complete product management with variations and packaging",
          "Stock control with lot and expiry tracking",
          "Multi-channel sales management",
          "Smart alerts (low stock, expiry, stalled items)",
          "Predictive analytics and seasonality analysis",
          "AI announcement generation with SSE streaming",
          "Multi-tenancy with company-level isolation",
          "JWT authentication with refresh token rotation",
          "Dual support for PostgreSQL and MongoDB"
        ]
      }
    }
  ]
