@page
@model EasyStock.Admin.Pages.Storefronts.CreateModel
@{
    ViewData["Title"] = "Novo storefront";
}

<es-breadcrumb>
    <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
    <es-breadcrumb-item href="/Storefronts">Storefronts</es-breadcrumb-item>
    <es-breadcrumb-item>Novo</es-breadcrumb-item>
</es-breadcrumb>

<es-card padding="lg" card-class="mt-4" style="max-width:640px;">
    <h2 style="margin:0 0 4px; font-size:18px; font-weight:600; color:var(--text-primary);">Novo storefront</h2>
    <p style="margin:0 0 20px; color:var(--text-muted); font-size:13px;">
        Storefront é criado <strong>inativo</strong> por padrão. Após criar, edite branding,
        configure cardápio (cardápio aqui mesmo), frete e Mercado Pago (ADMIN-002) — depois ative.
    </p>

    <form method="post"
          x-data="{ submitting: false, slugTouched: false }"
          x-on:submit="submitting = true">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:rgba(239,68,68,.10); border:1px solid rgba(239,68,68,.30); color:var(--erro-600); border-radius:var(--r-md); padding:10px 14px; margin-bottom:16px; font-size:13px;">
                @foreach (var entry in ViewData.ModelState)
                {
                    foreach (var err in entry.Value!.Errors)
                    {
                        <div>• @err.ErrorMessage</div>
                    }
                }
            </div>
        }

        <div style="display:flex; flex-direction:column; gap:16px;">
            <es-select asp-for="Input.EmpresaId" label="Empresa" required="true">
                <option value="">— Escolha a empresa —</option>
                @foreach (var emp in Model.Empresas)
                {
                    <option value="@emp.Id" disabled="@(emp.JaTemStorefront ? "disabled" : null)">
                        @emp.Nome @(emp.Documento != null ? $"({emp.Documento})" : "")
                        @(emp.JaTemStorefront ? " — já tem storefront" : "")
                    </option>
                }
            </es-select>

            <es-input asp-for="Input.Slug"
                      label="Slug"
                      placeholder="ex: casa-da-baba"
                      help-text="Aparece na URL: /api/storefront/{slug}. Use minúsculas, números e hífen. Não muda depois."
                      required="true"
                      x-on:blur="$el.querySelector('input').value = $el.querySelector('input').value.trim().toLowerCase(); slugTouched = true"
                      maxlength="40" />

            <es-input asp-for="Input.TituloPublico"
                      label="Título público"
                      placeholder="ex: Casa da Babá — Comida caseira"
                      help-text="Exibido no topo do site público."
                      required="true"
                      maxlength="120" />

            <es-input asp-for="Input.PedidoMinimoEntrega"
                      type="number"
                      step="0.01"
                      min="0"
                      label="Pedido mínimo para entrega (R$)"
                      help-text="0 = sem mínimo. Pode ser ajustado depois." />

            <es-input asp-for="Input.Motivo"
                      label="Motivo (opcional)"
                      placeholder="Ex.: novo cliente onboarding, demo, etc."
                      help-text="Registrado no audit log." />
        </div>

        <div style="display:flex; gap:8px; justify-content:flex-end; margin-top:24px;">
            <es-button variant="ghost" href="/Storefronts" :disabled="submitting">Cancelar</es-button>
            <button type="submit" class="btn btn-primary btn-md" :disabled="submitting">
                <span x-show="!submitting">Criar storefront</span>
                <span x-show="submitting" x-cloak>Criando…</span>
            </button>
        </div>
    </form>
</es-card>
