@page "{storefrontId:guid}/Cardapio/Create"
@model EasyStock.Admin.Pages.Storefronts.Cardapio.CreateModel
@{
    ViewData["Title"] = "Adicionar item ao cardápio";
}

<es-breadcrumb>
    <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
    <es-breadcrumb-item href="/Storefronts">Storefronts</es-breadcrumb-item>
    <es-breadcrumb-item href="/Storefronts/Detail/@Model.StorefrontId">@Model.StorefrontSlug</es-breadcrumb-item>
    <es-breadcrumb-item href="/Storefronts/@Model.StorefrontId/Cardapio">Cardápio</es-breadcrumb-item>
    <es-breadcrumb-item>Adicionar</es-breadcrumb-item>
</es-breadcrumb>

<es-card padding="lg" card-class="mt-4" style="max-width:720px;">
    <h2 style="margin:0 0 4px; font-size:18px; font-weight:600;">Adicionar item ao cardápio</h2>
    <p style="margin:0 0 20px; color:var(--text-muted); font-size:13px;">
        Item entra <strong>oculto</strong> por padrão — torne visível depois de revisar foto e descrição.
    </p>

    @if (!Model.Produtos.Any())
    {
        <div style="background:rgba(245,158,11,.10); border:1px solid rgba(245,158,11,.30); border-radius:var(--r-md); padding:12px 16px; color:var(--warn-700); font-size:13px;">
            Nenhum produto disponível para adicionar — todos da empresa já estão no cardápio,
            ou a empresa não tem produtos cadastrados. Cadastre produtos no ERP primeiro.
        </div>
    }
    else
    {
        <form method="post" novalidate x-data="{ submitting: false }" x-on:submit="submitting = true">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div style="background:rgba(239,68,68,.10); border:1px solid rgba(239,68,68,.30); color:var(--erro-600); border-radius:var(--r-md); padding:10px 14px; margin-bottom:16px; font-size:13px;">
                    @foreach (var entry in ViewData.ModelState)
                    {
                        foreach (var err in entry.Value!.Errors)
                        {
                            <div>• @err.ErrorMessage</div>
                        }
                    }
                </div>
            }

            <div style="display:flex; flex-direction:column; gap:16px;">
                <es-select asp-for="Input.ProdutoId" label="Produto" required="true">
                    <option value="">— Escolha o produto —</option>
                    @foreach (var p in Model.Produtos)
                    {
                        <option value="@p.Id">
                            @p.Nome
                            @(p.PrecoReferencia.HasValue ? $" (R$ {p.PrecoReferencia.Value:F2})" : "")
                        </option>
                    }
                </es-select>

                <es-input asp-for="Input.OrdemExibicao" type="number" step="0.5" min="0"
                          label="Ordem de exibição" help-text="Use 0.5 entre 1 e 2 para reordenar sem renumerar." />

                <es-checkbox asp-for="Input.Visivel" label="Tornar visível imediatamente"
                             help-text="Por padrão entra oculto." />

                <es-input asp-for="Input.PrecoStorefront" type="number" step="0.01" min="0"
                          label="Preço override (R$)" help-text="Deixe vazio para usar o PreçoReferência do Produto." />

                <es-input asp-for="Input.FotoUrl" type="url" label="URL da foto" placeholder="https://cdn.exemplo.com/foto.webp"
                          help-text="Upload de imagem para R2 está em pós-MVP. Por enquanto use URL externa." />

                <es-input asp-for="Input.DescricaoPublica" label="Descrição pública"
                          placeholder="Massa fresca em camadas com molho de tomate caseiro..." maxlength="240" />

                <es-input asp-for="Input.Ingredientes" label="Ingredientes" maxlength="500" />

                <es-input asp-for="Input.Alergenos" label="Alergênicos" placeholder="contém glúten, leite, ovo" maxlength="200" />

                <es-input asp-for="Input.SugestaoMolho" label="Sugestão de molho" maxlength="200" />

                <es-input asp-for="Input.TempoPreparo" label="Tempo de preparo" placeholder="ex: 25 min" maxlength="50" />

                <es-input asp-for="Input.PesoExibicao" label="Peso de exibição" placeholder="ex: 500g" maxlength="50" />

                <es-select asp-for="Input.Tag" label="Tag (opcional)">
                    <option value="">— Sem tag —</option>
                    <option value="assinatura">Assinatura</option>
                    <option value="novo">Novo</option>
                    <option value="vegetariano">Vegetariano</option>
                </es-select>

                <es-input asp-for="Input.Motivo" label="Motivo (opcional)" placeholder="Ex.: nova receita, demo" />
            </div>

            <div style="display:flex; gap:8px; justify-content:flex-end; margin-top:24px;">
                <es-button variant="ghost" href="/Storefronts/@Model.StorefrontId/Cardapio" :disabled="submitting">Cancelar</es-button>
                <button type="submit" class="btn btn-primary btn-md" :disabled="submitting">
                    <span x-show="!submitting">Adicionar ao cardápio</span>
                    <span x-show="submitting" x-cloak>Adicionando…</span>
                </button>
            </div>
        </form>
    }
</es-card>
