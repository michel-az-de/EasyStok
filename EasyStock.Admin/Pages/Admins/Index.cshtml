@page
@model EasyStock.Admin.Pages.Admins.IndexModel
@{
    ViewData["Title"] = "Gestão de Admins";
    var novaSenha = TempData["NovaSenha"] as string;
    var loggedEmail = HttpContext.Session.GetString("admin_email");
    var orderBy = Request.Query["orderBy"].FirstOrDefault();
    var dir = Request.Query["dir"].FirstOrDefault();
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:24px;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item>Admins</es-breadcrumb-item>
        </es-breadcrumb>
        <div style="margin-top:4px; color: var(--text-muted); font-size: 13px;">
            <strong style="color: var(--text-primary);">@Model.Admins.Count()</strong> administrador(es) ativos
        </div>
    </div>
    <es-button variant="primary" icon="plus" x-on:click="$dispatch('open-modal-novo-admin')">Novo admin</es-button>
</div>

@if (!string.IsNullOrEmpty(novaSenha))
{
    <div style="background:rgba(240,184,74,.10); border:1px solid rgba(240,184,74,.30); border-left:3px solid var(--warn-600); border-radius:var(--r-md); padding:14px 18px; margin-bottom:16px;">
        <div style="font-weight:600; color:var(--text-primary); margin-bottom:4px;">
            <es-icon name="alert-triangle" size="16" /> Senha temporária — anote agora, não será exibida novamente:
        </div>
        <code style="font-family:var(--font-mono); font-size:15px; user-select:all; color:var(--warn-600);">@novaSenha</code>
    </div>
}

<es-data-table sort-key="@orderBy" sort-dir="@dir" is-empty="@(!Model.Admins.Any())">
    <es-data-table-column key="nome" label="Nome" sortable="true" />
    <es-data-table-column key="email" label="Email" sortable="true" />
    <es-data-table-column label="Status" />
    <es-data-table-column label="Último acesso" align="right" />
    <es-data-table-column label="Criado em" align="right" />
    <es-data-table-column label="" actions="true" width="220px" />

    @foreach (var a in Model.Admins)
    {
        var id = a.TryGetProperty("id", out var idP) ? idP.GetString() : "";
        var nome = a.TryGetProperty("nome", out var nP) ? nP.GetString() : "—";
        var email = a.TryGetProperty("email", out var eP) ? eP.GetString() : "—";
        var ativo = a.TryGetProperty("ativo", out var atP) && atP.GetBoolean();
        var ultimoAcesso = a.TryGetProperty("ultimoAcessoEm", out var uP) && uP.ValueKind != System.Text.Json.JsonValueKind.Null ? uP.GetString() : null;
        var criadoEm = a.TryGetProperty("criadoEm", out var cP) ? cP.GetString() : null;
        DateTime.TryParse(criadoEm, out var criadoDt);
        DateTime.TryParse(ultimoAcesso, out var ultimoAcessoDt);
        var isMe = email == loggedEmail;
        var initial = !string.IsNullOrEmpty(nome) ? nome.Substring(0, 1).ToUpper() : "A";

        <tr>
            <td data-label="Nome">
                <div style="display:flex; align-items:center; gap:10px;">
                    <span class="es-avatar es-avatar-sm">@initial</span>
                    <strong style="color:var(--text-primary);">@nome</strong>
                </div>
            </td>
            <td data-label="Email">
                <span style="color:var(--text-secondary); font-size:13px;">@email</span>
                @if (isMe) { <es-badge variant="accent">você</es-badge> }
            </td>
            <td data-label="Status">
                <es-badge variant="@(ativo ? "ok" : "crit")" with-dot="true">@(ativo ? "ATIVO" : "INATIVO")</es-badge>
            </td>
            <td data-label="Último acesso" class="es-data-table-td-numeric" style="color:var(--text-muted); font-size:12px;">
                @(ultimoAcesso != null ? ultimoAcessoDt.ToLocalTime().ToString("dd/MM/yy HH:mm") : "—")
            </td>
            <td data-label="Criado em" class="es-data-table-td-numeric" style="color:var(--text-muted); font-size:12px;">
                @criadoDt.ToLocalTime().ToString("dd/MM/yy")
            </td>
            <td class="es-data-table-td-actions">
                <div class="es-row-actions">
                    @if (!isMe)
                    {
                        <form method="post" asp-page-handler="Toggle" style="display:inline;">
                            <input type="hidden" name="id" value="@id" />
                            @Html.AntiForgeryToken()
                            <es-button type="submit" variant="ghost" size="xs">@(ativo ? "Desativar" : "Ativar")</es-button>
                        </form>
                    }
                    <form method="post" asp-page-handler="ResetSenha" style="display:inline;"
                          onsubmit="return confirm('Resetar senha de @email?')">
                        <input type="hidden" name="id" value="@id" />
                        @Html.AntiForgeryToken()
                        <es-button type="submit" variant="ghost" size="xs" icon="alert-triangle">Reset senha</es-button>
                    </form>
                </div>
            </td>
        </tr>
    }

    <es-data-table-empty>
        <es-empty-state icon="users"
                        title="Nenhum administrador"
                        description="Cadastre admins para acessar este painel.">
            <es-button variant="primary" icon="plus" x-on:click="$dispatch('open-modal-novo-admin')">Novo admin</es-button>
        </es-empty-state>
    </es-data-table-empty>
</es-data-table>

<!-- Modal Novo Admin -->
<es-modal id="novo-admin" title="Novo administrador" description="O usuário receberá acesso completo ao painel admin." size="sm">
    <form method="post" asp-page-handler="Criar" style="display:flex; flex-direction:column; gap:14px;">
        @Html.AntiForgeryToken()
        <es-input name="nome" label="Nome" required="true" placeholder="Nome completo" />
        <es-input name="email" type="email" label="Email" required="true" placeholder="admin@easystock.com.br" />
        <es-input name="senha" type="password" label="Senha inicial" required="true" minlength="8"
                  helper="Mínimo 8 caracteres. Use uma senha forte." />

        <es-modal-footer>
            <es-button variant="ghost" x-on:click="close()">Cancelar</es-button>
            <es-button type="submit" variant="primary" icon="check">Criar admin</es-button>
        </es-modal-footer>
    </form>
</es-modal>
