@page
@model EasyStock.Admin.Pages.AuditLogs.IndexModel
@{
    ViewData["Title"] = "Audit Log Admin";
}

<div class="flex items-center gap-3 mb-6 flex-wrap">
    <form method="get" class="flex items-center gap-3 flex-wrap flex-1">
        <input type="text" name="acao" value="@Model.Acao" placeholder="Filtrar por ação..."
               class="form-input max-w-xs" />
        <input type="date" name="de" value="@Model.De" class="form-input max-w-[160px]" />
        <input type="date" name="ate" value="@Model.Ate" class="form-input max-w-[160px]" />
        <button type="submit" class="btn-primary">Filtrar</button>
        @if (!string.IsNullOrEmpty(Model.Acao) || !string.IsNullOrEmpty(Model.De) || !string.IsNullOrEmpty(Model.Ate))
        {
            <a href="/AuditLogs" class="btn-secondary">Limpar</a>
        }
    </form>
    <div class="text-es-ink-mute text-sm">@Model.Total registro(s)</div>
</div>

@if (Model.Erro != null)
{
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-4 py-3 text-sm mb-4">@Model.Erro</div>
}

<div class="card p-0 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="table-admin">
            <thead>
                <tr>
                    <th>Data/Hora</th>
                    <th>Admin</th>
                    <th>Ação</th>
                    <th>Detalhes</th>
                    <th>Tenant</th>
                    <th>IP</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in Model.Logs)
                {
                    var adminEmail = l.TryGetProperty("adminEmail", out var aeP) ? aeP.GetString() : "—";
                    var acao       = l.TryGetProperty("acao", out var aP) ? aP.GetString() : "—";
                    var detalhes   = l.TryGetProperty("detalhes", out var dP) && dP.ValueKind != System.Text.Json.JsonValueKind.Null ? dP.GetString() : "—";
                    var tenantId   = l.TryGetProperty("tenantId", out var tP) && tP.ValueKind != System.Text.Json.JsonValueKind.Null ? tP.GetString() : null;
                    var ip         = l.TryGetProperty("ip", out var iP) && iP.ValueKind != System.Text.Json.JsonValueKind.Null ? iP.GetString() : "—";
                    var criadoEm   = l.TryGetProperty("criadoEm", out var cP) ? cP.GetString() : null;
                    DateTime.TryParse(criadoEm, out var criadoDt);
                    <tr>
                        <td class="text-es-ink-dim text-xs whitespace-nowrap">@criadoDt.ToLocalTime().ToString("dd/MM/yy HH:mm:ss")</td>
                        <td class="text-es-ink-dim text-xs">@adminEmail</td>
                        <td><span class="font-mono text-xs text-es-accent">@acao</span></td>
                        <td class="text-es-ink-dim text-xs max-w-xs truncate" title="@detalhes">@detalhes</td>
                        <td class="text-xs">
                            @if (tenantId != null)
                            {
                                <a href="/Tenants/Detail/@tenantId" class="text-es-accent hover:text-es-cream text-xs">Ver →</a>
                            }
                            else { <span class="text-es-ink-mute">—</span> }
                        </td>
                        <td class="text-es-ink-mute text-xs">@ip</td>
                    </tr>
                }
                @if (!Model.Logs.Any())
                {
                    <tr><td colspan="6" class="text-center text-es-ink-mute py-8">Nenhum registro encontrado.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <div class="flex items-center justify-center gap-2 mt-6">
        @if (Model.Page > 1)
        {
            <a href="?page=@(Model.Page - 1)&acao=@Model.Acao&de=@Model.De&ate=@Model.Ate" class="btn-secondary text-sm">← Anterior</a>
        }
        <span class="text-es-ink-mute text-sm">@Model.Page / @Model.TotalPages</span>
        @if (Model.Page < Model.TotalPages)
        {
            <a href="?page=@(Model.Page + 1)&acao=@Model.Acao&de=@Model.De&ate=@Model.Ate" class="btn-secondary text-sm">Próximo →</a>
        }
    </div>
}
