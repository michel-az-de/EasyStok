@page
@model EasyStock.Admin.Pages.AuditLogs.IndexModel
@{
    ViewData["Title"] = "Audit Log Admin";
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item>Audit Logs</es-breadcrumb-item>
        </es-breadcrumb>
        <div style="margin-top:4px; color:var(--text-muted); font-size:13px;">
            <strong style="color:var(--text-primary);">@Model.Total</strong> registro(s) — todas as ações administrativas auditadas
        </div>
    </div>
</div>

<es-card padding="md" card-class="mb-4">
    <form method="get" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:12px; align-items:end;">
        <es-input name="acao" label="Ação" value="@Model.Acao" placeholder="suspender, reativar..." prefix-icon="search" field-class="md:col-span-2" />
        <es-input name="de" type="date" label="De" value="@Model.De" />
        <es-input name="ate" type="date" label="Até" value="@Model.Ate" />
        <div style="display:flex; gap:8px;">
            <es-button type="submit" variant="primary" icon="filter">Filtrar</es-button>
            <es-button variant="ghost" href="/AuditLogs">Limpar</es-button>
        </div>
    </form>
</es-card>

<es-filter-bar>
    @if (!string.IsNullOrEmpty(Model.Acao)) { <es-filter-chip label="Ação" remove-param="acao">@Model.Acao</es-filter-chip> }
    @if (!string.IsNullOrEmpty(Model.De)) { <es-filter-chip label="De" remove-param="de">@Model.De</es-filter-chip> }
    @if (!string.IsNullOrEmpty(Model.Ate)) { <es-filter-chip label="Até" remove-param="ate">@Model.Ate</es-filter-chip> }
</es-filter-bar>

<es-data-table is-empty="@(!Model.Logs.Any())">
    <es-data-table-column label="Data/Hora" />
    <es-data-table-column label="Admin" />
    <es-data-table-column label="Ação" />
    <es-data-table-column label="Detalhes" />
    <es-data-table-column label="Tenant" />
    <es-data-table-column label="IP" align="right" />

    @foreach (var l in Model.Logs)
    {
        var adminEmail = l.TryGetProperty("adminEmail", out var aeP) ? aeP.GetString() : "—";
        var acao = l.TryGetProperty("acao", out var aP) ? aP.GetString() : "—";
        var detalhes = l.TryGetProperty("detalhes", out var dP) && dP.ValueKind != System.Text.Json.JsonValueKind.Null ? dP.GetString() : "—";
        var tenantId = l.TryGetProperty("tenantId", out var tP) && tP.ValueKind != System.Text.Json.JsonValueKind.Null ? tP.GetString() : null;
        var ip = l.TryGetProperty("ip", out var iP) && iP.ValueKind != System.Text.Json.JsonValueKind.Null ? iP.GetString() : "—";
        var criadoEm = l.TryGetProperty("criadoEm", out var cP) ? cP.GetString() : null;
        DateTime.TryParse(criadoEm, out var criadoDt);

        // Pequena heurística de variant pela palavra-chave da ação
        var acaoLower = (acao ?? "").ToLower();
        var acaoVariant = acaoLower.Contains("suspend") || acaoLower.Contains("delet") || acaoLower.Contains("revog") ? "crit"
            : acaoLower.Contains("reativ") || acaoLower.Contains("ativ") || acaoLower.Contains("cre") ? "ok"
            : acaoLower.Contains("login") || acaoLower.Contains("imperson") ? "warn"
            : "neutral";

        <tr>
            <td data-label="Data/Hora" style="white-space:nowrap; color:var(--text-muted); font-size:12px; font-family:var(--font-mono);">@criadoDt.ToLocalTime().ToString("dd/MM/yy HH:mm:ss")</td>
            <td data-label="Admin" style="font-size:13px; color:var(--text-secondary);">@adminEmail</td>
            <td data-label="Ação"><es-badge variant="@acaoVariant">@acao</es-badge></td>
            <td data-label="Detalhes" style="color:var(--text-muted); font-size:12px; max-width:340px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@detalhes">@detalhes</td>
            <td data-label="Tenant">
                @if (tenantId != null)
                {
                    <es-button variant="ghost" size="xs" href="/Tenants/Detail/@tenantId" icon-trailing="arrow-right">Ver</es-button>
                }
                else
                {
                    <span style="color:var(--text-muted);">—</span>
                }
            </td>
            <td data-label="IP" class="es-data-table-td-numeric" style="font-family:var(--font-mono); font-size:11px; color:var(--text-muted);">@ip</td>
        </tr>
    }

    <es-data-table-empty>
        <es-empty-state icon="search"
                        title="Nenhum registro encontrado"
                        description="Ajuste os filtros ou aguarde novas ações administrativas." />
    </es-data-table-empty>
</es-data-table>

@if (Model.TotalPages > 1)
{
    <es-pagination page="@Model.Page" page-size="50" total="@(Model.TotalPages * 50)" />
}
