@page
@model EasyStock.Admin.Pages.Cupons.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Cupons";
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:24px;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item>Cupons</es-breadcrumb-item>
        </es-breadcrumb>
        <div style="margin-top:4px; color: var(--text-muted); font-size: 13px;">
            <strong style="color: var(--text-primary);">@Model.Cupons.Count()</strong> cupom(ns) cadastrados
        </div>
    </div>
    <es-button variant="primary" icon="plus" x-on:click="$dispatch('open-modal-novo-cupom')">Novo cupom</es-button>
</div>

@if (!Model.Cupons.Any())
{
    <es-card>
        <es-empty-state icon="tag"
                        title="Nenhum cupom cadastrado"
                        description="Crie cupons para oferecer descontos em planos. Você pode definir percentual, valor fixo ou meses grátis.">
            <es-button variant="primary" icon="plus" x-on:click="$dispatch('open-modal-novo-cupom')">Criar primeiro cupom</es-button>
        </es-empty-state>
    </es-card>
}
else
{
    <div style="display:grid; gap:12px;" x-data="{ editingId: '', deletarId: '', deletarCodigo: '' }">
        @foreach (var c in Model.Cupons)
        {
            var cid = c.TryGetProperty("id", out var cidP) ? cidP.GetString() : "";
            var codigo = c.TryGetProperty("codigo", out var codigoP) ? codigoP.GetString() : "";
            var tipo = c.TryGetProperty("tipoDesconto", out var tipoP) ? tipoP.GetString() : "";
            var valor = c.TryGetProperty("valor", out var valorP) ? valorP.GetDecimal() : 0m;
            var limiteUsos = c.TryGetProperty("limiteUsos", out var luP) && luP.ValueKind != JsonValueKind.Null ? (int?)luP.GetInt32() : null;
            var totalUsos = c.TryGetProperty("totalUsos", out var tuP) ? tuP.GetInt32() : 0;
            var validoAte = c.TryGetProperty("validoAte", out var vaP) && vaP.ValueKind != JsonValueKind.Null ? vaP.GetString() : null;
            var ativo = c.TryGetProperty("ativo", out var atP) && atP.GetBoolean();
            var planoId = c.TryGetProperty("planoId", out var plP) && plP.ValueKind != JsonValueKind.Null ? plP.GetString() : null;
            DateTime.TryParse(validoAte, out var validoAteDt);
            var tipoLabel = tipo switch { "Percentual" => $"{valor:N0}%", "ValorFixo" => $"R$ {valor:N2}", "MesesGratis" => $"{valor:N0} mês(es) grátis", _ => tipo };
            var usoPct = limiteUsos.HasValue && limiteUsos.Value > 0 ? Math.Min(100, totalUsos * 100 / limiteUsos.Value) : 0;

            <es-card padding="md">
                <div style="display:flex; justify-content:space-between; gap:16px; align-items:flex-start; flex-wrap:wrap;">
                    <div style="flex:1; min-width:240px;">
                        <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap; margin-bottom:8px;">
                            <span style="font-family:var(--font-mono); font-weight:700; font-size:18px; letter-spacing:.08em; color:var(--text-primary);">@codigo</span>
                            <es-badge variant="@(ativo ? "ok" : "neutral")" with-dot="true">@(ativo ? "ATIVO" : "INATIVO")</es-badge>
                            <span style="color:var(--orange-500); font-weight:700; font-size:14px;">@tipoLabel</span>
                        </div>
                        <div style="display:flex; gap:16px; font-size:12px; color:var(--text-muted); flex-wrap:wrap;">
                            <span>Usos: <strong style="color:var(--text-primary);">@totalUsos@(limiteUsos.HasValue ? $"/{limiteUsos}" : "")</strong></span>
                            @if (validoAte != null)
                            {
                                <span>Válido até: <strong style="color:var(--text-primary);">@validoAteDt.ParaBrasilia().ToString("dd/MM/yyyy")</strong></span>
                            }
                            else
                            {
                                <span>Sem expiração</span>
                            }
                            @if (planoId != null)
                            {
                                <span>· Restrito a 1 plano</span>
                            }
                        </div>
                        @if (limiteUsos.HasValue && limiteUsos.Value > 0)
                        {
                            <div style="margin-top:8px; height:4px; background:var(--surface-sunken); border-radius:999px; overflow:hidden; max-width:280px;">
                                <div style="height:100%; width:@(usoPct)%; background:@(usoPct > 80 ? "var(--crit-600)" : usoPct > 50 ? "var(--warn-600)" : "var(--orange-500)"); transition: width var(--duration-base) var(--ease-out);"></div>
                            </div>
                        }
                    </div>

                    <div style="display:flex; gap:6px; flex-wrap:wrap;">
                        <es-button variant="ghost" size="sm" icon="edit-2"
                                   x-on:click="editingId = (editingId === '@cid' ? '' : '@cid')">
                            <span x-text="editingId === '@cid' ? 'Cancelar' : 'Editar'"></span>
                        </es-button>
                        <form method="post" asp-page-handler="Toggle" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@cid" />
                            <input type="hidden" name="codigo" value="@codigo" />
                            <input type="hidden" name="atualmenteAtivo" value="@ativo.ToString().ToLower()" />
                            <es-button type="submit" variant="@(ativo ? "ghost" : "primary")" size="sm">@(ativo ? "Desativar" : "Ativar")</es-button>
                        </form>
                        <es-button variant="danger" size="sm" icon="trash-2" icon-only="true"
                                   aria-label="Excluir cupom @codigo"
                                   disabled="@(totalUsos > 0)"
                                   x-on:click="deletarId = '@cid'; deletarCodigo = '@codigo'; $dispatch('open-modal-deletar-cupom')" />
                    </div>
                </div>

                <!-- Inline edit -->
                <div x-show="editingId === '@cid'" x-cloak style="margin-top:16px; padding-top:16px; border-top:1px solid var(--border-soft);">
                    <form method="post" asp-page-handler="Editar" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:12px; align-items:end;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@cid" />
                        <es-input name="codigo" label="Código" value="@codigo" required="true" pattern="[A-Za-z0-9_-]+" minlength="3" maxlength="50" />
                        <es-select name="tipoDesconto" label="Tipo">
                            <option value="Percentual" selected="@(tipo == "Percentual")">Percentual (%)</option>
                            <option value="ValorFixo" selected="@(tipo == "ValorFixo")">Valor fixo (R$)</option>
                            <option value="MesesGratis" selected="@(tipo == "MesesGratis")">Meses grátis</option>
                        </es-select>
                        <es-input name="valor" type="number" label="Valor" value="@valor.ToString(System.Globalization.CultureInfo.InvariantCulture)" step="0.01" required="true" />
                        <es-input name="limiteUsos" type="number" label="Limite de usos" value="@(limiteUsos?.ToString() ?? "")" min="1" label-optional="true" />
                        <es-input name="validoAte" type="date" label="Válido até" value="@(validoAte != null ? validoAteDt.ToString("yyyy-MM-dd") : "")" label-optional="true" />
                        <es-select name="planoId" label="Restringir a plano" label-optional="true">
                            <option value="">Todos os planos</option>
                            @foreach (var p in Model.Planos)
                            {
                                var pid = p.TryGetProperty("id", out var pidP) ? pidP.GetString() : "";
                                var pnome = p.TryGetProperty("nome", out var pnP) ? pnP.GetString() : "";
                                <option value="@pid" selected="@(pid == planoId)">@pnome</option>
                            }
                        </es-select>
                        <div style="grid-column:1/-1; display:flex; justify-content:flex-end;">
                            <es-button type="submit" variant="primary" icon="check">Salvar alterações</es-button>
                        </div>
                    </form>
                </div>
            </es-card>
        }

        <!-- Modal Excluir Cupom -->
        <es-modal id="deletar-cupom" title="Excluir cupom?" size="sm"
                  description="Esta ação não pode ser desfeita.">
            <form method="post" asp-page-handler="Deletar"
                  x-data="{ loading: false }" x-on:submit="loading = true">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" x-bind:value="deletarId" />
                <p style="margin:0 0 14px; color:var(--text-muted); font-size:13px;">
                    Deseja excluir permanentemente o cupom <strong><span x-text="deletarCodigo"></span></strong>?
                </p>
                <es-modal-footer>
                    <es-button variant="ghost" x-on:click="close()" :disabled="loading">Cancelar</es-button>
                    <es-button type="submit" variant="danger" icon="trash-2" :disabled="loading">
                        <span x-show="!loading">Excluir</span>
                        <span x-show="loading" x-cloak>Excluindo…</span>
                    </es-button>
                </es-modal-footer>
            </form>
        </es-modal>
    </div>
}

<!-- Modal Novo Cupom -->
<es-modal id="novo-cupom" title="Novo cupom" description="Configure os detalhes do desconto." size="md">
    <form method="post" asp-page-handler="Criar" style="display:flex; flex-direction:column; gap:14px;"
          x-data="{ loading: false, erro: '' }"
          x-on:submit="
            erro = '';
            let bloquear = false;
            try {
                const f = $event.target;
                const tipo = f.tipoDesconto ? f.tipoDesconto.value : '';
                const valor = f.valor ? parseFloat(f.valor.value) : NaN;
                if (tipo === 'Percentual' && !isNaN(valor) && valor > 100) { erro = 'Desconto percentual não pode passar de 100%.'; bloquear = true; }
                else if (f.validoAte && f.validoAte.value) { const d = new Date(f.validoAte.value + 'T00:00:00'); const hoje = new Date(); hoje.setHours(0,0,0,0); if (d < hoje) { erro = 'Data de validade não pode estar no passado.'; bloquear = true; } }
            } catch (e) { }
            if (bloquear) { $event.preventDefault(); } else { loading = true; }
          ">
        @Html.AntiForgeryToken()
        @* BUG-09 (issue #632): valida cross-field no cliente (percentual maior que 100, data passada) *@
        @* pra nao perder os dados digitados num RedirectToPage; o servidor segue validando como backstop. *@
        <div x-show="erro" x-cloak
             style="background:rgba(248,113,113,0.12); border:1px solid rgba(248,113,113,0.40); border-radius:8px; padding:8px 12px; font-size:13px; color:var(--text-primary);"
             x-text="erro"></div>
        <es-input name="codigo" label="Código" placeholder="PROMO10" required="true"
                  pattern="[A-Za-z0-9_-]+" minlength="3" maxlength="50"
                  helper="3 a 50 caracteres: letras, números, hífen e underscore." input-class="uppercase" />

        <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:12px;">
            <es-select name="tipoDesconto" label="Tipo de desconto" required="true">
                <option value="Percentual">Percentual (%)</option>
                <option value="ValorFixo">Valor fixo (R$)</option>
                <option value="MesesGratis">Meses grátis</option>
            </es-select>
            <es-input name="valor" type="number" label="Valor" step="0.01" min="0" required="true" />
        </div>

        <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:12px;">
            <es-input name="limiteUsos" type="number" label="Limite de usos" min="1"
                      helper="Vazio = ilimitado." label-optional="true" />
            <es-input name="validoAte" type="date" label="Válido até"
                      helper="Vazio = sem expiração." label-optional="true" />
        </div>

        <es-select name="planoId" label="Restringir a plano" label-optional="true"
                   helper="Vazio = aplicável a qualquer plano.">
            <option value="">Todos os planos</option>
            @foreach (var p in Model.Planos)
            {
                var pid = p.TryGetProperty("id", out var pidP) ? pidP.GetString() : "";
                var pnome = p.TryGetProperty("nome", out var pnP) ? pnP.GetString() : "";
                <option value="@pid">@pnome</option>
            }
        </es-select>

        <es-modal-footer>
            <es-button variant="ghost" x-on:click="close()" :disabled="loading">Cancelar</es-button>
            <es-button type="submit" variant="primary" icon="check" :disabled="loading">
                <span x-show="!loading">Criar cupom</span>
                <span x-show="loading" x-cloak>Criando…</span>
            </es-button>
        </es-modal-footer>
    </form>
</es-modal>
