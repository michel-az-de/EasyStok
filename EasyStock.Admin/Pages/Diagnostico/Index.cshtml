        formatDate(iso) {
            if (!iso) return '—';
            return new Date(iso).toLocaleString('pt-BR', { dateStyle: 'short', timeStyle: 'short' });
        }
    };
}

// ─── Factory: Tab Erros (filtros + paginação + copy markdown) ─────────────
function errosState() {
    const root = this;
    return {
        _loadedOnce: false,
        loading: false,
        erro: '',
        items: [],
        total: 0,
        page: 1,
        pageSize: 50,
        endpointsTop: [],
        expanded: {},
        copyFeedback: -1,
        exportando: false,

        filtros: {
            levels: ['ERROR', 'FATAL'],   // default: só erros, nada de poluir com INFO/WARN
            endpoint: '',
            search: ''
        },

        toggleLevel(lv) {
            const i = this.filtros.levels.indexOf(lv);
            if (i >= 0) this.filtros.levels.splice(i, 1);
            else this.filtros.levels.push(lv);
            this.refresh();
        },

        limparFiltros() {
            this.filtros = { levels: ['ERROR', 'FATAL'], endpoint: '', search: '' };
            this.page = 1;
            this.refresh();
        },

        _buildQs() {
            const params = new URLSearchParams();
            if (this.filtros.levels.length) params.set('level', this.filtros.levels.join(','));
            params.set('hours', root.rangeHours);
            if (this.filtros.endpoint) params.set('endpoint', this.filtros.endpoint);
            if (this.filtros.search) params.set('search', this.filtros.search);
            if (root.stickyCid) params.set('cid', root.stickyCid);
            params.set('page', this.page);
            params.set('pageSize', this.pageSize);
            return params.toString();
        },

        async refresh() {
            this.loading = true;
            this.erro = '';
            this._loadedOnce = true;
            try {
                const r = await fetch('/api-proxy/diag/search?' + this._buildQs(),
                    { credentials: 'same-origin', cache: 'no-store' });
                if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                if (!r.ok) {
                    this.erro = `HTTP ${r.status} ao buscar logs. Se a API está dormindo (Render), pode levar 30-60s pra acordar.`;
                    return;
                }
                const d = await r.json();
                if (d.disponivel === false) {
                    this.erro = d.motivo || 'Logs indisponíveis no momento.';
                    this.items = []; this.total = 0;
                    return;
                }
                this.items = d.items || [];
                this.total = d.total || 0;
                this.endpointsTop = d.endpointsTop || [];
                this.expanded = {};
            } catch (e) {
                this.erro = 'Falha de rede: ' + (e.message || e);
                sendFrontendError('admin_frontend', 'component_load', e.message, e.stack, '/Diagnostico?tab=erros');
            } finally {
                this.loading = false;
            }
        },

        prevPage() { if (this.page > 1) { this.page--; this.refresh(); } },
        nextPage() { if (this.page * this.pageSize < this.total) { this.page++; this.refresh(); } },

        toggleExpand(i) {
            // Truque pra reatividade do Alpine — toggle via spread.
            this.expanded = { ...this.expanded, [i]: !this.expanded[i] };
        },

        levelClass(lv) {
            const v = (lv || '').toUpperCase();
            if (v === 'FATAL') return 'bg-red-600 text-white';
            if (v === 'ERROR') return 'bg-red-500/20 text-red-300';
            if (v === 'WARN' || v === 'WARNING') return 'bg-amber-500/20 text-amber-300';
            return 'bg-es-surface-2 text-es-ink-mute';
        },

        formatTime(iso) {
            if (!iso) return '—';
            const d = new Date(iso);
            return d.toLocaleString('pt-BR', { dateStyle: 'short', timeStyle: 'medium' });
        },

        shortCid(cid) {
            if (!cid) return '—';
            return cid.length > 8 ? cid.slice(0, 8) + '…' : cid;
        },

        shortMessage(msg) {
            if (!msg) return '—';
            return msg.length > 100 ? msg.slice(0, 100) + '…' : msg;
        },

        copyMarkdown(item) {
            const idx = this.items.indexOf(item);
            const lines = [
                `**Quando**: ${this.formatTime(item.timestamp)} (UTC)`,
                `**Endpoint**: ${(item.httpMethod || '?')} ${item.endpoint || '—'}`,
                `**Status**: ${item.statusCode ?? '—'} — ${item.elapsedMs != null ? Math.round(item.elapsedMs) + 'ms' : '—'}`,
                `**Nível**: ${item.level}`,
                `**CID**: ${item.correlationId || '—'}`,
                `**User**: ${item.userId || '—'} (empresa ${item.empresaId || '—'})`,
                `**IP**: ${item.clientIp || '—'}`,
                ``,
                `**Mensagem**:`,
                '```',
                item.message || '',
                '```'
            ];
            if (item.exception) {
                lines.push('', '**Stack**:', '```', item.exception, '```');
            }
            const md = lines.join('\n');
            try {
                navigator.clipboard.writeText(md);
                this.copyFeedback = idx;
                setTimeout(() => { this.copyFeedback = -1; }, 1500);
            } catch {
                this.erro = 'Não foi possível copiar — selecione o texto manualmente.';
            }
        },

        async exportarJson() {
            this.exportando = true;
            try {
                const url = '/api-proxy/diag/export?format=json&' + this._buildQs();
                const r = await fetch(url, { credentials: 'same-origin' });
                if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                if (!r.ok) { this.erro = `HTTP ${r.status} ao exportar.`; return; }
                const blob = await r.blob();
                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob);
                link.download = `easystock-logs-${new Date().toISOString().slice(0,16).replace(/[:T]/g,'')}.json`;
                document.body.appendChild(link);
                link.click();
                link.remove();
                URL.revokeObjectURL(link.href);
            } catch (e) {
                this.erro = 'Falha de rede ao exportar: ' + (e.message || e);
            } finally {
                this.exportando = false;
            }
        }
    };
}

// ─── Helper global: envia erros de JS para o servidor ─────────────────────
function sendFrontendError(source, category, message, details, url) {
    try {
        fetch('/api-proxy/diag/frontend-error', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ source, category, message: String(message).slice(0, 1500), details: String(details || '').slice(0, 7000), url: url || window.location.pathname })
        }).catch(() => {}); // fire-and-forget, nunca quebra o UI
    } catch {}
}

// Captura global de erros JS não tratados — registra em SystemErrorLog.
window.addEventListener('unhandledrejection', (ev) => {
    const msg = ev.reason?.message || String(ev.reason || 'UnhandledRejection');
    sendFrontendError('admin_frontend', 'js_error', msg, ev.reason?.stack, window.location.pathname);
});
window.addEventListener('error', (ev) => {
    if (!ev.message || ev.message === 'Script error.') return; // cross-origin ruído
    sendFrontendError('admin_frontend', 'js_error', ev.message, ev.error?.stack, window.location.pathname);
});

