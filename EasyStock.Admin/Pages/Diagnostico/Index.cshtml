// ═══════════════════════════════════════════════════════════════════════════
// Painel Seed V2 — progresso em tempo real via polling, modal overlay,
// histórico de runs e preservação de dados reais (IsSeedData).
// ═══════════════════════════════════════════════════════════════════════════
function seedPanelV2() {
    return {
        // Status check
        enabled: null, loadingStatus: false, statusErro: '', diagnostico: null, counts: null,
        volume: 'large',
        // Modal de confirmação (Azure-style: digitar palavra-chave)
        confirmModal: false,
        confirmTipo: '',
        confirmKeyword: '',
        confirmDesc: '',
        confirmInput: '',
        // Modal de progresso
        modal: false, runId: null, poller: null,
        progress: 0, currentStep: 'Iniciando…', runStatus: 'Running',
        etapas: [],
        // Histórico
        historico: [], carregandoHistorico: false,

        async inicializar() {
            await this.carregarStatus();
            this.carregarHistorico();
        },

        // ── Confirmação Azure-style ──────────────────────────────────────────
        solicitarConfirmacao(tipo) {
            if (this.enabled === false) {
                alert('Seed via API está desabilitado.\nDefina SEED_API_ENABLED=true (env) ou Seed:ApiEnabled=true (config) e reinicie a API.');
                return;
            }
            const cfg = {
                adminTestScenarios: {
                    keyword: 'cenarios-admin',
                    desc: 'Vai recriar 4 tenants de teste (Bistrô, Padaria, Café, Loja Do Zé) com tickets, notas e usuários — todos com email .test e flag IsSeedData=true.'
                },
                demo: {
                    keyword: 'seed-demo-' + (this.volume || 'large'),
                    desc: `Vai recriar empresas demo completas (PastaBella, Cantina Maurício, CasaDaBaba, MassasVeneza) — volume "${this.volume}". Inclui produtos, movimentações e vendas.`
                },
                minimal: {
                    keyword: 'seed-minimal',
                    desc: 'Vai recriar 1 admin + 1 empresa + 1 loja. Cenário mínimo de acesso.'
                }
            };
            const c = cfg[tipo];
            if (!c) return;
            this.confirmTipo = tipo;
            this.confirmKeyword = c.keyword;
            this.confirmDesc = c.desc;
            this.confirmInput = '';
            this.confirmModal = true;
            this.$nextTick(() => this.$refs.confirmInputRef?.focus());
        },

        cancelarConfirmacao() {
            this.confirmModal = false;
            this.confirmInput = '';
            this.confirmTipo = '';
        },

        async confirmarEExecutar() {
            if (this.confirmInput !== this.confirmKeyword) return;
            const tipo = this.confirmTipo;
            this.confirmModal = false;
            this.confirmInput = '';
            await this.iniciarSeed(tipo);
        },

        async carregarStatus() {
            this.loadingStatus = true; this.statusErro = '';
            try {
                const r = await fetch('/Diagnostico?handler=SeedStatus', { credentials: 'same-origin', cache: 'no-store' });
                if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                const d = await r.json().catch(() => null);
                if (!r.ok) {
                    this.statusErro = (d && (d.error || d.message)) || `HTTP ${r.status}`;
                    return;
                }
                const data = (d && (d.data || d)) || {};
                this.enabled = !!data.enabled;
                this.counts = data.counts || null;
                this.diagnostico = data.diagnostico || null;
            } catch (e) {
                this.statusErro = 'Falha de rede: ' + (e.message || e);
            } finally {
                this.loadingStatus = false;
            }
        },

        async iniciarSeed(tipo) {
            // Confirmação já foi feita via modal Azure-style. Aqui só dispara o run.
            this.modal = true;
            this.runId = null;
            this.progress = 0;
            this.currentStep = 'Enviando requisição…';
            this.runStatus = 'Running';
            this.etapas = [];

            try {
                const qs = new URLSearchParams({ tipo, volume: this.volume });
                const r = await fetch(`/api-proxy/seed/run-async?${qs}`, {
                    method: 'POST',
                    credentials: 'same-origin'
                });
                if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                const d = await r.json().catch(() => null);
                if (!r.ok) {
                    this.runStatus = 'Failed';
                    this.currentStep = (d && (d.error || d.message)) || `HTTP ${r.status}`;
                    return;
                }
                this.runId = d.runId;
                this.currentStep = 'Seed iniciado, aguardando progresso…';
                this._startPolling();
            } catch (e) {
                this.runStatus = 'Failed';
                this.currentStep = 'Falha de rede: ' + (e.message || e);
            }
        },

        _startPolling() {
            if (this.poller) clearInterval(this.poller);
            this.poller = setInterval(() => this._poll(), 500);
        },

        async _poll() {
            if (!this.runId) return;
            try {
                const r = await fetch(`/api-proxy/seed/run/${this.runId}`, { credentials: 'same-origin', cache: 'no-store' });
                if (!r.ok) return;
                const d = await r.json().catch(() => null);
                if (!d) return;
                if (d.percent !== undefined) this.progress = d.percent;
                if (d.currentStep) this.currentStep = d.currentStep;
                if (d.status) this.runStatus = d.status;
                if (Array.isArray(d.etapas)) this.etapas = d.etapas;
                // Auto-scroll pro final do feed
                this.$nextTick(() => {
                    const feed = this.$refs.logFeed;
                    if (feed) feed.scrollTop = feed.scrollHeight;
                });
                if (this.runStatus !== 'Running') {
                    clearInterval(this.poller);
                    this.poller = null;
                    // Atualiza counts e histórico ao final
                    await this.carregarStatus();
                    this.carregarHistorico();
                }
            } catch {}
        },

        fecharModal() {
            if (this.runStatus === 'Running') return;
            if (this.poller) { clearInterval(this.poller); this.poller = null; }
            this.modal = false;
        },

        async carregarHistorico() {
            this.carregandoHistorico = true;
            try {
                const r = await fetch('/api-proxy/seed/runs?pageSize=10', { credentials: 'same-origin', cache: 'no-store' });
                if (!r.ok) return;
                const d = await r.json().catch(() => null);
                this.historico = (d && d.items) || [];
            } catch {} finally {
                this.carregandoHistorico = false;
            }
        }
    };
}
</script>
}
