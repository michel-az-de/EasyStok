@page
@model EasyStock.Admin.Pages.Diagnostico.IndexModel
@using System.Text.Json
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Diagnóstico";
    var afToken = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}

@*
    Página única de diagnóstico, substitui o antigo /Status. Arquitetura:
    - 3 tabs no MVP (Resumo / Erros / Operações). Live + Insights chegam em P1/P2.
    - URL persiste tab via ?tab=...
    - Header sticky compartilhado entre tabs (counters, range, CID sticky filter).
    - Lazy-load: Resumo hidratado via SSR (StatusData); demais tabs disparam fetch
      quando ativadas (evita 3 chamadas pesadas no GET).
*@

<div style="margin-bottom:12px;">
    <es-breadcrumb>
        <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
        <es-breadcrumb-item>Diagnóstico</es-breadcrumb-item>
    </es-breadcrumb>
</div>

@if (Model.Erro != null)
{
    <div style="background:rgba(192,59,42,.10); border:1px solid rgba(192,59,42,.35); border-left:3px solid var(--crit-600); border-radius:var(--r-md); padding:12px 16px; font-size:13px; color:var(--crit-700); margin-bottom:14px; display:flex; align-items:center; gap:10px;">
        <es-icon name="alert-triangle" size="16" />
        <span>@Model.Erro</span>
    </div>
}

<div x-data="diagnosticoPage()" x-init="init()">

    <!-- ────────────────────── HEADER STICKY ────────────────────── -->
    <div class="sticky top-0 z-30 -mx-4 px-4 py-3 mb-4"
         style="background: rgba(13, 17, 23, 0.92); backdrop-filter: blur(8px); border-bottom: 1px solid rgba(247,242,232,0.06);">
        <div class="flex flex-wrap gap-3 items-center justify-between">

            <!-- 3 counters -->
            <div class="flex gap-3 flex-wrap">
                <div class="px-3 py-1.5 rounded-lg" :style="header.ultimaHora > 0 ? 'background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.3)' : 'background:rgba(247,242,232,.04)'">
                    <div class="text-[10px] uppercase tracking-wide text-es-ink-mute">Última hora</div>
                    <div class="text-lg font-bold" :class="header.ultimaHora > 0 ? 'text-red-400' : 'text-es-ink'" x-text="header.ultimaHora ?? '—'">—</div>
                </div>
                <div class="px-3 py-1.5 rounded-lg" :style="header.total24h > 0 ? 'background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.3)' : 'background:rgba(247,242,232,.04)'">
                    <div class="text-[10px] uppercase tracking-wide text-es-ink-mute">Erros 24h</div>
                    <div class="text-lg font-bold" :class="header.total24h > 0 ? 'text-red-400' : 'text-es-ink'" x-text="header.total24h ?? '—'">—</div>
                </div>
                <div class="px-3 py-1.5 rounded-lg" style="background:rgba(247,242,232,.04)">
                    <div class="text-[10px] uppercase tracking-wide text-es-ink-mute">Última atualização</div>
                    <div class="text-xs font-mono text-es-ink" x-text="header.lastUpdated || '—'">—</div>
                </div>
            </div>

            <!-- Toggle verbose logging -->
            <div class="flex items-center gap-2" x-show="logMode.loaded" x-cloak>
                <button type="button" @@click="logMode.toggle()"
                        :class="logMode.verbose ? 'bg-amber-500/20 border border-amber-500/40 text-amber-300' : 'bg-es-surface-2 text-es-ink-mute hover:text-es-ink'"
                        class="px-2.5 py-1 rounded text-[11px] font-semibold transition flex items-center gap-1.5"
                        :title="logMode.verbose ? 'Verbose ativo — clique para desligar' : 'Ativar logging verbose (Debug+)'">
                    <span>📡</span>
                    <span x-text="logMode.verbose ? 'Verbose ON' : 'Verbose'"></span>
                </button>
            </div>

            <!-- Atender chamado (CID sticky filter) -->
            <div class="flex gap-2 items-center">
                <template x-if="stickyCid">
                    <span class="px-2 py-1 rounded-full bg-es-accent/20 text-es-accent text-xs flex items-center gap-1.5 font-mono">
                        🔗 <span x-text="stickyCid"></span>
                        <button type="button" @@click="clearStickyCid()" class="hover:text-es-cream" title="Remover filtro">✕</button>
                    </span>
                </template>
                <div class="relative">
                    <input type="text" x-model="cidInput" placeholder="CID do cliente…"
                           @@keydown.enter.prevent="setStickyCidFromInput()"
                           class="form-input text-xs w-48 pr-7" style="font-family:'JetBrains Mono',monospace">
                    <button type="button" @@click="setStickyCidFromInput()" class="absolute right-1 top-1/2 -translate-y-1/2 text-es-ink-mute hover:text-es-accent text-xs px-1.5" title="Atender chamado">→</button>
                </div>
                <select x-model="rangeHours" @@change="onRangeChange()" class="form-input text-xs w-20" title="Janela de tempo">
                    <option value="1">1h</option>
                    <option value="6">6h</option>
                    <option value="24">24h</option>
                    <option value="72">3d</option>
                    <option value="168">7d</option>
                </select>
            </div>
        </div>
    </div>

    <!-- ────────────────────── TABS ────────────────────── -->
    <div class="flex gap-1 mb-6 border-b" style="border-color: rgba(247,242,232,0.08)">
        <button type="button" @@click="setTab('resumo')"
                :class="tab === 'resumo' ? 'text-es-ink border-es-accent' : 'text-es-ink-mute border-transparent hover:text-es-ink'"
                class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors">
            🩺 Resumo
        </button>
        <button type="button" @@click="setTab('erros')"
                :class="tab === 'erros' ? 'text-es-ink border-es-accent' : 'text-es-ink-mute border-transparent hover:text-es-ink'"
                class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors">
            🚨 Erros
            <span x-show="header.total24h > 0" x-cloak class="ml-1 px-1.5 py-0.5 rounded-full bg-red-500/20 text-red-400 text-[10px] font-bold" x-text="header.total24h"></span>
        </button>
        <button type="button" @@click="setTab('sistema')"
                :class="tab === 'sistema' ? 'text-es-ink border-es-accent' : 'text-es-ink-mute border-transparent hover:text-es-ink'"
                class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors">
            🗄 Sistema
            <span x-show="sysErros.total > 0" x-cloak class="ml-1 px-1.5 py-0.5 rounded-full bg-amber-500/20 text-amber-300 text-[10px] font-bold" x-text="sysErros.total"></span>
        </button>
        <button type="button" @@click="setTab('operacoes')"
                :class="tab === 'operacoes' ? 'text-es-ink border-es-accent' : 'text-es-ink-mute border-transparent hover:text-es-ink'"
                class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors">
            🛠 Operações
        </button>
        <button type="button" @@click="setTab('infra')"
                :class="tab === 'infra' ? 'text-es-ink border-es-accent' : 'text-es-ink-mute border-transparent hover:text-es-ink'"
                class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors">
            🔧 Infraestrutura
        </button>
        <button type="button" @@click="setTab('performance')"
                :class="tab === 'performance' ? 'text-es-ink border-es-accent' : 'text-es-ink-mute border-transparent hover:text-es-ink'"
                class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors">
            📊 Performance
        </button>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- TAB: RESUMO (default — antigo /Status)                                   -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div x-show="tab === 'resumo'" x-cloak>

        <div class="flex items-center justify-between mb-4">
            <div class="text-es-ink-mute text-sm">
                Health-check da infra. Auto-refresh a cada 30s.
            </div>
            <button type="button" @@click="resumo.refresh()" class="btn-secondary text-sm">↻ Atualizar</button>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            <!-- Database -->
            <div class="card">
                <div class="flex items-center gap-2 mb-3">
                    <span :class="resumo.dbDotClass()" class="w-2.5 h-2.5 rounded-full inline-block"></span>
                    <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">Database</span>
                </div>
                <div class="text-2xl font-bold text-es-ink" x-text="resumo.data.database?.latencyMs != null ? (resumo.data.database.latencyMs + ' ms') : '—'">—</div>
                <div class="text-xs mt-1" :class="resumo.dbTextClass()" x-text="resumo.data.database?.status ?? '—'"></div>
            </div>

            <!-- API -->
            <div class="card">
                <div class="flex items-center gap-2 mb-3">
                    <span class="w-2.5 h-2.5 rounded-full bg-green-400 inline-block"></span>
                    <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">API</span>
                </div>
                <div class="text-2xl font-bold text-es-ink" x-text="resumo.formatUptime(resumo.data.api?.uptimeSeconds)">—</div>
                <div class="text-xs text-es-basil mt-1" x-text="resumo.data.api?.version ? ('v' + resumo.data.api.version) : 'v—'"></div>
            </div>

            <!-- Erros 24h (com CTA pra tab Erros) -->
            <div class="card cursor-pointer hover:ring-1 hover:ring-es-accent/50 transition" @@click="setTab('erros')">
                <div class="flex items-center gap-2 mb-3">
                    <span :class="resumo.errorDotClass()" class="w-2.5 h-2.5 rounded-full inline-block"></span>
                    <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">Erros (24h)</span>
                </div>
                <div class="text-2xl font-bold" :class="(resumo.data.erros24h?.total ?? 0) > 0 ? 'text-red-400' : 'text-es-ink'" x-text="resumo.data.erros24h?.total ?? 0">—</div>
                <div class="text-xs text-es-accent mt-1">Ver todos →</div>
            </div>

            <!-- Uso -->
            <div class="card">
                <div class="flex items-center gap-2 mb-3">
                    <span class="w-2.5 h-2.5 rounded-full bg-es-accent inline-block"></span>
                    <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">Uso</span>
                </div>
                <div class="text-2xl font-bold text-es-ink" x-text="resumo.data.uso?.usuariosAtivos24h ?? 0">—</div>
                <div class="text-xs text-es-ink-mute mt-1">usuários ativos (24h)</div>
                <div class="flex gap-3 mt-2 text-xs text-es-ink-mute">
                    <span>IA: <b class="text-es-ink" x-text="resumo.data.uso?.iaGeracoesMes ?? 0"></b>/mês</span>
                    <span>Tickets: <b class="text-es-ink" x-text="resumo.data.uso?.ticketsAbertos ?? 0"></b></span>
                </div>
            </div>
        </div>

        <!-- Erros recentes (tabela curta — link pra tab Erros pra explorar) -->
        <div class="card">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-es-ink font-semibold text-sm">Erros Recentes</h3>
                <button type="button" @@click="setTab('erros')" class="text-xs text-es-accent hover:text-es-cream">Ver tudo →</button>
            </div>
            <template x-if="(resumo.data.errosRecentes ?? []).length === 0">
                <p class="text-es-ink-mute text-sm text-center py-4">Nenhum erro recente. ✓</p>
            </template>
            <table class="table-admin" x-show="(resumo.data.errosRecentes ?? []).length > 0">
                <thead>
                    <tr><th>Ação</th><th>Detalhes</th><th>Data/Hora</th></tr>
                </thead>
                <tbody>
                    <template x-for="e in (resumo.data.errosRecentes ?? [])" :key="e.dataHora">
                        <tr>
                            <td class="font-mono text-xs text-es-ink" x-text="e.acao"></td>
                            <td class="text-es-ink-dim text-xs max-w-xs truncate" x-text="e.detalhes ?? '—'"></td>
                            <td class="text-es-ink-dim text-xs" x-text="resumo.formatDate(e.dataHora)"></td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- TAB: ERROS (lista paginada server-side com filtros + copy/export)        -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div x-show="tab === 'erros'" x-cloak>

        <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-4">

            <!-- Sidebar filtros -->
            <aside class="card h-fit lg:sticky lg:top-32">
                <h4 class="text-xs uppercase tracking-wide font-bold text-es-ink-mute mb-3">Filtros</h4>

                <div class="space-y-3">
                    <div>
                        <label class="text-[11px] text-es-ink-mute block mb-1">Nível</label>
                        <div class="flex flex-wrap gap-1">
                            <template x-for="lv in ['ERROR', 'FATAL', 'WARN', 'INFO']" :key="lv">
                                <button type="button" @@click="erros.toggleLevel(lv)"
                                        :class="erros.filtros.levels.includes(lv) ? 'bg-es-accent text-es-ink' : 'bg-es-surface-2 text-es-ink-mute hover:text-es-ink'"
                                        class="px-2 py-1 rounded text-[10px] font-bold tracking-wide transition" x-text="lv"></button>
                            </template>
                        </div>
                    </div>

                    <div>
                        <label class="text-[11px] text-es-ink-mute block mb-1">Endpoint contém</label>
                        <input type="text" x-model.debounce.500ms="erros.filtros.endpoint" @@input.debounce.500ms="erros.refresh()"
                               list="endpoints-datalist" placeholder="ex: /api/auth/login"
                               class="form-input text-xs w-full" style="font-family:'JetBrains Mono',monospace">
                        <datalist id="endpoints-datalist">
                            <template x-for="ep in erros.endpointsTop" :key="ep">
                                <option :value="ep"></option>
                            </template>
                        </datalist>
                    </div>

                    <div>
                        <label class="text-[11px] text-es-ink-mute block mb-1">Buscar (msg + exception)</label>
                        <input type="text" x-model.debounce.500ms="erros.filtros.search" @@input.debounce.500ms="erros.refresh()"
                               placeholder="texto livre…"
                               class="form-input text-xs w-full">
                    </div>

                    <div class="pt-2 border-t border-es-ink-mute/10">
                        <button type="button" @@click="erros.limparFiltros()" class="btn-secondary text-xs w-full mb-2">Limpar filtros</button>
                        <button type="button" @@click="erros.exportarJson()" :disabled="erros.exportando" class="btn-primary text-xs w-full">
                            <span x-show="!erros.exportando">💾 Exportar JSON</span>
                            <span x-show="erros.exportando" x-cloak>Exportando…</span>
                        </button>
                    </div>
                </div>
            </aside>

            <!-- Tabela -->
            <div>
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <div class="text-sm text-es-ink-mute">
                        <span x-show="!erros.loading"><b class="text-es-ink" x-text="erros.total"></b> resultado<span x-show="erros.total !== 1">s</span></span>
                        <span x-show="erros.loading" x-cloak class="flex items-center gap-2">
                            <span class="inline-block w-2 h-2 rounded-full bg-es-accent animate-pulse"></span> Carregando…
                        </span>
                    </div>
                    <div class="flex gap-2">
                        <button type="button" @@click="erros.refresh()" class="btn-secondary text-xs">↻</button>
                    </div>
                </div>

                <template x-if="erros.erro">
                    <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-3 py-2 text-sm mb-3" x-text="erros.erro"></div>
                </template>

                <template x-if="!erros.loading && erros.items.length === 0 && !erros.erro">
                    <div class="card text-center py-12">
                        <div class="text-5xl mb-3">✓</div>
                        <h3 class="text-es-ink font-semibold mb-1">Nenhum erro no período</h3>
                        <p class="text-es-ink-mute text-sm">Ajuste os filtros ou aumente a janela de tempo no header.</p>
                    </div>
                </template>

                <div x-show="erros.items.length > 0" class="card p-0 overflow-hidden">
                    <table class="w-full text-xs">
                        <thead class="bg-es-surface-2 text-es-ink-mute uppercase tracking-wide">
                            <tr>
                                <th class="px-3 py-2 text-left">Quando</th>
                                <th class="px-3 py-2 text-left">Nv</th>
                                <th class="px-3 py-2 text-left">Endpoint</th>
                                <th class="px-3 py-2 text-right">St</th>
                                <th class="px-3 py-2 text-right">ms</th>
                                <th class="px-3 py-2 text-left">CID</th>
                                <th class="px-3 py-2 text-left">Mensagem</th>
                                <th></th>
                            </tr>
                        </thead>
                        @* Múltiplos <tbody> são HTML válido — usado pra contornar a restrição
                           do x-for do Alpine que precisa de single-root child. Cada item vira
                           um tbody com 2 trs (linha principal + linha expandida). *@
                        <template x-for="(item, i) in erros.items" :key="i + '-' + item.timestamp">
                            <tbody>
                                <tr class="hover:bg-es-surface-2/40 transition cursor-pointer"
                                    @@click="erros.toggleExpand(i)" style="border-top:1px solid rgba(247,242,232,0.04)">
                                    <td class="px-3 py-2 font-mono text-es-ink-mute whitespace-nowrap" x-text="erros.formatTime(item.timestamp)"></td>
                                    <td class="px-3 py-2"><span :class="erros.levelClass(item.level)" class="px-1.5 py-0.5 rounded text-[10px] font-bold" x-text="item.level"></span></td>
                                    <td class="px-3 py-2 font-mono text-es-ink" x-text="(item.httpMethod ? item.httpMethod + ' ' : '') + (item.endpoint || '—')"></td>
                                    <td class="px-3 py-2 text-right font-mono text-es-ink-mute" x-text="item.statusCode ?? '—'"></td>
                                    <td class="px-3 py-2 text-right font-mono" :class="(item.elapsedMs > 1000) ? 'text-amber-400' : 'text-es-ink-mute'" x-text="item.elapsedMs != null ? Math.round(item.elapsedMs) : '—'"></td>
                                    <td class="px-3 py-2 font-mono text-es-ink-dim">
                                        <button type="button" x-show="item.correlationId" @@click.stop="setStickyCid(item.correlationId)"
                                                class="hover:text-es-accent" :title="'Filtrar por CID ' + item.correlationId" x-text="erros.shortCid(item.correlationId)"></button>
                                        <span x-show="!item.correlationId">—</span>
                                    </td>
                                    <td class="px-3 py-2 text-es-ink truncate max-w-[300px]" x-text="erros.shortMessage(item.message)"></td>
                                    <td class="px-3 py-2 text-es-ink-mute text-base" x-text="erros.expanded[i] ? '▼' : '▶'"></td>
                                </tr>
                                <tr x-show="erros.expanded[i]" x-cloak style="border-top:1px solid rgba(247,242,232,0.04)">
                                    <td colspan="8" class="bg-black/30 p-4">
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs">
                                            <div>
                                                <div class="text-es-ink-mute uppercase tracking-wide text-[10px] mb-1">Detalhes</div>
                                                <div class="font-mono text-es-ink-dim space-y-0.5">
                                                    <div><span class="text-es-ink-mute">Categoria:</span> <span x-text="item.categoria"></span></div>
                                                    <div><span class="text-es-ink-mute">UserId:</span> <span x-text="item.userId ?? '—'"></span></div>
                                                    <div><span class="text-es-ink-mute">EmpresaId:</span> <span x-text="item.empresaId ?? '—'"></span></div>
                                                    <div><span class="text-es-ink-mute">IP:</span> <span x-text="item.clientIp ?? '—'"></span></div>
                                                    <div><span class="text-es-ink-mute">CorrelationId:</span> <span class="text-es-accent" x-text="item.correlationId ?? '—'"></span></div>
                                                </div>
                                            </div>
                                            <div>
                                                <div class="text-es-ink-mute uppercase tracking-wide text-[10px] mb-1">Mensagem</div>
                                                <pre class="text-es-ink whitespace-pre-wrap break-all font-mono text-[11px]" x-text="item.message"></pre>
                                            </div>
                                        </div>
                                        <template x-if="item.exception">
                                            <div class="mt-3">
                                                <div class="text-es-ink-mute uppercase tracking-wide text-[10px] mb-1">Stack trace</div>
                                                <pre class="text-red-300 whitespace-pre-wrap break-all font-mono text-[10px] max-h-64 overflow-auto p-2 rounded bg-black/40" x-text="item.exception"></pre>
                                            </div>
                                        </template>
                                        <div class="mt-3 flex gap-2 flex-wrap">
                                            <button type="button" @@click.stop="erros.copyMarkdown(item)" class="btn-secondary text-xs">📋 Copiar Markdown</button>
                                            <button type="button" x-show="item.correlationId" @@click.stop="setStickyCid(item.correlationId)" class="btn-secondary text-xs">🔗 Filtrar por CID</button>
                                            <span x-show="erros.copyFeedback === i" x-cloak class="text-es-basil text-xs flex items-center">✓ Copiado</span>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </template>
                    </table>
                </div>

                <!-- Paginação -->
                <div x-show="erros.total > erros.pageSize" x-cloak class="flex items-center justify-between mt-3 text-sm">
                    <div class="text-es-ink-mute text-xs">
                        Página <b class="text-es-ink" x-text="erros.page"></b> de <b class="text-es-ink" x-text="Math.ceil(erros.total / erros.pageSize)"></b>
                    </div>
                    <div class="flex gap-1">
                        <button type="button" @@click="erros.prevPage()" :disabled="erros.page === 1" class="btn-secondary text-xs">← Anterior</button>
                        <button type="button" @@click="erros.nextPage()" :disabled="erros.page * erros.pageSize >= erros.total" class="btn-secondary text-xs">Próxima →</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- TAB: SISTEMA — erros persistidos no banco (SystemErrorLog)               -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div x-show="tab === 'sistema'" x-cloak>

        <div class="flex items-center justify-between mb-4">
            <div class="text-es-ink-mute text-sm">
                Erros persistidos no banco (API 5xx, falhas de seed e erros de frontend). Independente de rotação de logs.
            </div>
            <div class="flex gap-2 items-center">
                <button type="button" @@click="sysErros.refresh()" class="btn-secondary text-xs">↻ Atualizar</button>
                <button type="button" @@click="sysErros.purgar()" :disabled="sysErros.purgando"
                        class="btn-secondary text-xs text-amber-300 hover:text-amber-200">
                    <span x-show="!sysErros.purgando">🗑 Purgar</span>
                    <span x-show="sysErros.purgando" x-cloak>Purgando…</span>
                </button>
            </div>
        </div>

        <!-- Filtros inline -->
        <div class="flex flex-wrap gap-2 mb-4">
            <select x-model="sysErros.filtros.source" @@change="sysErros.refresh()" class="form-input text-xs w-40">
                <option value="">Todas as origens</option>
                <option value="api_backend">API Backend</option>
                <option value="seed">Seed</option>
                <option value="admin_frontend">Admin Frontend</option>
                <option value="web_frontend">Web Frontend</option>
                <option value="background">Background</option>
            </select>
            <select x-model="sysErros.filtros.level" @@change="sysErros.refresh()" class="form-input text-xs w-32">
                <option value="">Todos os níveis</option>
                <option value="error">Error</option>
                <option value="fatal">Fatal</option>
                <option value="warning">Warning</option>
            </select>
            <select x-model="sysErros.filtros.hours" @@change="sysErros.refresh()" class="form-input text-xs w-24">
                <option value="6">6h</option>
                <option value="24">24h</option>
                <option value="72">3 dias</option>
                <option value="168">7 dias</option>
                <option value="720">30 dias</option>
            </select>
        </div>

        <template x-if="sysErros.erro">
            <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-3 py-2 text-sm mb-3" x-text="sysErros.erro"></div>
        </template>

        <template x-if="!sysErros.loading && sysErros.items.length === 0 && !sysErros.erro">
            <div class="card text-center py-12">
                <div class="text-5xl mb-3">✓</div>
                <h3 class="text-es-ink font-semibold mb-1">Nenhum erro no período</h3>
                <p class="text-es-ink-mute text-sm">Sem erros no banco para os filtros selecionados.</p>
            </div>
        </template>

        <div x-show="sysErros.items.length > 0" class="card p-0 overflow-hidden">
            <table class="w-full text-xs">
                <thead class="bg-es-surface-2 text-es-ink-mute uppercase tracking-wide">
                    <tr>
                        <th class="px-3 py-2 text-left">Quando</th>
                        <th class="px-3 py-2 text-left">Origem</th>
                        <th class="px-3 py-2 text-left">Categoria</th>
                        <th class="px-3 py-2 text-left">Mensagem</th>
                        <th></th>
                    </tr>
                </thead>
                <template x-for="(item, i) in sysErros.items" :key="item.id">
                    <tbody>
                        <tr class="hover:bg-es-surface-2/40 transition cursor-pointer"
                            @@click="sysErros.toggleExpand(i)" style="border-top:1px solid rgba(247,242,232,0.04)">
                            <td class="px-3 py-2 font-mono text-es-ink-mute whitespace-nowrap" x-text="sysErros.formatTime(item.criadoEm)"></td>
                            <td class="px-3 py-2"><span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-es-surface-2 text-es-ink-mute" x-text="item.source"></span></td>
                            <td class="px-3 py-2 text-es-ink-dim" x-text="item.category ?? '—'"></td>
                            <td class="px-3 py-2 text-es-ink truncate max-w-[350px]" x-text="sysErros.shortMsg(item.message)"></td>
                            <td class="px-3 py-2 text-es-ink-mute text-base" x-text="sysErros.expanded[i] ? '▼' : '▶'"></td>
                        </tr>
                        <tr x-show="sysErros.expanded[i]" x-cloak style="border-top:1px solid rgba(247,242,232,0.04)">
                            <td colspan="5" class="bg-black/30 p-4">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs">
                                    <div>
                                        <div class="text-es-ink-mute uppercase tracking-wide text-[10px] mb-1">Info</div>
                                        <div class="font-mono text-es-ink-dim space-y-0.5">
                                            <div><span class="text-es-ink-mute">URL:</span> <span x-text="item.url ?? '—'"></span></div>
                                            <div><span class="text-es-ink-mute">CorrelationId:</span> <span class="text-es-accent" x-text="item.correlationId ?? '—'"></span></div>
                                            <div><span class="text-es-ink-mute">AdminEmail:</span> <span x-text="item.adminEmail ?? '—'"></span></div>
                                            <div><span class="text-es-ink-mute">TenantId:</span> <span x-text="item.tenantId ?? '—'"></span></div>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="text-es-ink-mute uppercase tracking-wide text-[10px] mb-1">Mensagem</div>
                                        <pre class="text-es-ink whitespace-pre-wrap break-all font-mono text-[11px]" x-text="item.message"></pre>
                                    </div>
                                </div>
                                <template x-if="item.details">
                                    <div class="mt-3">
                                        <div class="text-es-ink-mute uppercase tracking-wide text-[10px] mb-1">Detalhes (JSON)</div>
                                        <pre class="text-amber-200 whitespace-pre-wrap break-all font-mono text-[10px] max-h-48 overflow-auto p-2 rounded bg-black/40" x-text="sysErros.prettyJson(item.details)"></pre>
                                    </div>
                                </template>
                            </td>
                        </tr>
                    </tbody>
                </template>
            </table>
        </div>

        <!-- Paginação -->
        <div x-show="sysErros.total > sysErros.pageSize" x-cloak class="flex items-center justify-between mt-3 text-sm">
            <div class="text-es-ink-mute text-xs">
                Página <b class="text-es-ink" x-text="sysErros.page"></b> de <b class="text-es-ink" x-text="Math.ceil(sysErros.total / sysErros.pageSize)"></b>
                · <b class="text-es-ink" x-text="sysErros.total"></b> registros
            </div>
            <div class="flex gap-1">
                <button type="button" @@click="sysErros.prevPage()" :disabled="sysErros.page === 1" class="btn-secondary text-xs">← Anterior</button>
                <button type="button" @@click="sysErros.nextPage()" :disabled="sysErros.page * sysErros.pageSize >= sysErros.total" class="btn-secondary text-xs">Próxima →</button>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- TAB: OPERAÇÕES (seed migrado do /Status)                                  -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div x-show="tab === 'operacoes'" x-cloak>

        <!-- Painel Seed V2 — com modal de progresso em tempo real -->
        <div class="card mb-6" x-data="seedPanelV2()" x-init="inicializar()">
            <div class="flex items-center justify-between mb-3">
                <div>
                    <h3 class="text-es-ink font-semibold text-sm">🌱 Seed de dados</h3>
                    <p class="text-es-ink-mute text-xs mt-0.5">
                        Popula o banco com dados de demonstração/teste.
                        <span x-show="enabled === false" x-cloak class="text-amber-300 font-semibold">
                            Desabilitado (defina <code>Seed:ApiEnabled=true</code> ou <code>SEED_API_ENABLED=true</code>).
                        </span>
                    </p>
                </div>
                <button type="button" @@click="inicializar()" class="btn-secondary text-xs">↻</button>
            </div>

            <div x-show="loadingStatus" x-cloak class="text-es-ink-mute text-sm py-3 flex items-center gap-2">
                <span class="inline-block w-3 h-3 rounded-full bg-es-accent animate-pulse"></span>
                Consultando status do seed na API…
            </div>

            <div x-show="statusErro" x-cloak class="bg-amber-500/10 border border-amber-500/30 text-amber-300 rounded-lg px-3 py-2 text-sm mb-3 flex items-start gap-2">
                <span>⚠</span>
                <div class="flex-1">
                    <div class="font-semibold">Não foi possível consultar a API</div>
                    <div class="text-xs mt-1" x-text="statusErro"></div>
                </div>
                <button type="button" @@click="carregarStatus()" class="text-xs underline hover:text-amber-200">↻ Tentar</button>
            </div>

            <template x-if="!loadingStatus && diagnostico">
                <div class="rounded-lg p-3 mb-4 text-xs"
                     :style="enabled ? 'background:rgba(79,191,159,.06);border:1px solid rgba(79,191,159,.2)' : 'background:rgba(247,144,9,.06);border:1px solid rgba(247,144,9,.25)'">
                    <div class="flex items-center gap-2 mb-1">
                        <span x-show="enabled" x-cloak class="text-es-basil">●</span>
                        <span x-show="!enabled" x-cloak class="text-amber-400">●</span>
                        <span class="font-semibold text-es-ink" x-text="enabled ? 'Seed liberado' : 'Seed bloqueado'"></span>
                    </div>
                    <div class="font-mono text-es-ink-mute mt-1 grid grid-cols-2 gap-x-3 gap-y-0.5">
                        <span>SEED_API_ENABLED (env):</span>
                        <span class="text-es-ink" x-text="diagnostico.fonteEnv"></span>
                        <span>Seed:ApiEnabled (config):</span>
                        <span class="text-es-ink" x-text="diagnostico.fonteConfig"></span>
                    </div>
                    <div class="text-es-ink-dim mt-2" x-text="diagnostico.hint"></div>
                </div>
            </template>

            <template x-if="!loadingStatus && counts">
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
                    <div class="rounded-lg p-3 text-center" style="background:rgba(247,242,232,0.04)">
                        <div class="text-2xl font-bold text-es-ink" x-text="counts.empresas ?? 0"></div>
                        <div class="text-[10px] uppercase tracking-wide text-es-ink-mute">Empresas</div>
                    </div>
                    <div class="rounded-lg p-3 text-center" style="background:rgba(247,242,232,0.04)">
                        <div class="text-2xl font-bold text-es-ink" x-text="counts.usuarios ?? 0"></div>
                        <div class="text-[10px] uppercase tracking-wide text-es-ink-mute">Usuários</div>
                    </div>
                    <div class="rounded-lg p-3 text-center" style="background:rgba(247,242,232,0.04)">
                        <div class="text-2xl font-bold text-es-ink" x-text="counts.lojas ?? 0"></div>
                        <div class="text-[10px] uppercase tracking-wide text-es-ink-mute">Lojas</div>
                    </div>
                    <div class="rounded-lg p-3 text-center" style="background:rgba(247,242,232,0.04)">
                        <div class="text-2xl font-bold text-es-ink" x-text="counts.planos ?? 0"></div>
                        <div class="text-[10px] uppercase tracking-wide text-es-ink-mute">Planos</div>
                    </div>
                </div>
            </template>

            <div class="flex flex-wrap gap-2 items-center">
                <select x-model="volume" class="form-input text-sm max-w-[200px]">
                    <option value="small">Small (2 tenants)</option>
                    <option value="medium">Medium (3 tenants)</option>
                    <option value="large">Large (4 tenants — padrão)</option>
                </select>
                <button type="button" @@click="solicitarConfirmacao('adminTestScenarios')" class="btn-secondary text-sm"
                        title="4 tenants variados, 5 tickets, 3 notas. Sem produtos.">
                    🧪 Cenários Admin
                </button>
                <button type="button" @@click="solicitarConfirmacao('demo')" class="btn-primary text-sm">
                    🚀 Seed demo
                </button>
                <button type="button" @@click="solicitarConfirmacao('minimal')" class="btn-secondary text-sm">
                    ⚡ Seed mínimo
                </button>
                <a href="/Tenants" class="text-es-accent hover:text-es-cream text-xs ml-auto">→ Ver clientes</a>
            </div>

            <div class="text-es-ink-mute text-[11px] mt-3 space-y-1">
                <p><strong class="text-es-ink">🧪 Cenários Admin</strong> — 4 tenants variados (Ativa/Suspensa/Cancelada), 5 tickets, 3 notas + audit logs. Senha padrão: <code class="text-es-accent">Teste@123</code>.</p>
                <p><strong class="text-es-ink">🚀 Seed demo</strong> — empresas completas com produtos e movimentações. Carga maior, útil pra testar EasyStock.Web.</p>
                <p><strong class="text-es-ink">⚡ Seed mínimo</strong> — apenas 1 admin + 1 empresa + 1 loja.</p>
                <p>Todos os seeds são <strong>idempotentes</strong> e <strong>preservam dados reais</strong> — apenas registros marcados como seed são sobrescritos.</p>
            </div>

            <!-- Histórico de execuções -->
            <div class="mt-5" style="border-top:1px solid rgba(247,242,232,0.06); padding-top:12px;">
                <div class="flex items-center justify-between mb-2">
                    <h4 class="text-xs font-semibold text-es-ink-mute uppercase tracking-wide">Histórico de execuções</h4>
                    <button type="button" @@click="carregarHistorico()" class="text-[10px] text-es-ink-mute hover:text-es-accent">↻ Atualizar</button>
                </div>
                <div x-show="carregandoHistorico" x-cloak class="text-es-ink-mute text-xs py-2">Carregando…</div>
                <div x-show="!carregandoHistorico && historico.length === 0" x-cloak class="text-es-ink-mute text-xs py-2">Nenhuma execução registrada ainda.</div>
                <div x-show="!carregandoHistorico && historico.length > 0" x-cloak class="space-y-1.5">
                    <template x-for="run in historico" :key="run.id">
                        <div class="rounded-lg px-3 py-2 text-xs flex items-start gap-3 flex-wrap"
                             style="background:rgba(247,242,232,0.03); border:1px solid rgba(247,242,232,0.07)">
                            <span class="text-lg shrink-0" x-text="run.status === 'Success' ? '✅' : run.status === 'Running' ? '⏳' : run.status === 'RolledBack' ? '↩️' : '❌'"></span>
                            <div class="flex-1 min-w-0">
                                <div class="font-semibold text-es-ink" x-text="run.tipoSeed + (run.volume ? ' · ' + run.volume : '')"></div>
                                <div class="text-es-ink-mute" x-text="run.adminEmail + ' · ' + new Date(run.startedAt).toLocaleString('pt-BR')"></div>
                                <div x-show="run.resumo" x-cloak class="text-es-ink-dim text-[10px] mt-0.5" x-text="run.resumo"></div>
                                <div x-show="run.erro" x-cloak class="text-red-400 text-[10px] mt-0.5" x-text="run.erro"></div>
                            </div>
                            <span class="px-2 py-0.5 rounded text-[10px] font-bold shrink-0"
                                  :class="run.status === 'Success' ? 'bg-es-basil/20 text-es-basil' : run.status === 'Running' ? 'bg-es-accent/20 text-es-accent' : 'bg-red-500/20 text-red-400'"
                                  x-text="run.status"></span>
                        </div>
                    </template>
                </div>
            </div>

            <!-- ─── Modal de confirmação (estilo Azure — digitar nome para confirmar) ───── -->
            <div x-show="confirmModal" x-cloak
                 class="fixed inset-0 z-50 flex items-center justify-center p-4"
                 style="background:rgba(0,0,0,.78); backdrop-filter:blur(4px)"
                 @@keydown.escape.window="cancelarConfirmacao()">
                <div class="rounded-2xl w-full max-w-lg flex flex-col"
                     style="background:#1c1a17; border:1px solid rgba(247,242,232,0.12)">
                    <!-- Cabeçalho com ícone de aviso -->
                    <div class="flex items-start gap-3 px-6 py-4"
                         style="border-bottom:1px solid rgba(247,242,232,0.08)">
                        <div class="text-3xl shrink-0">⚠️</div>
                        <div class="flex-1">
                            <h3 class="text-es-ink font-bold text-base">Confirmar ação destrutiva</h3>
                            <p class="text-es-ink-mute text-xs mt-1" x-text="confirmDesc"></p>
                        </div>
                    </div>
                    <!-- Corpo: instrução + input -->
                    <div class="px-6 py-4 space-y-3">
                        <div class="rounded-lg px-3 py-2.5 text-xs"
                             style="background:rgba(247,144,9,.06); border:1px solid rgba(247,144,9,.25)">
                            <div class="text-amber-300 font-semibold mb-1">Esta ação é potencialmente destrutiva</div>
                            <ul class="text-es-ink-mute text-[11px] space-y-0.5 list-disc pl-4">
                                <li>Todos os registros marcados como <code class="text-es-accent">IsSeedData=true</code> serão deletados</li>
                                <li>Dados reais de clientes <strong class="text-es-basil">não serão afetados</strong></li>
                                <li>Operação transacional — rollback automático em caso de erro</li>
                                <li>Log de auditoria completo será registrado em <code>SeedRunLogs</code></li>
                            </ul>
                        </div>
                        <div>
                            <label class="block text-xs font-mono uppercase tracking-wide text-es-ink-mute mb-1.5">
                                Para confirmar, digite <code class="text-es-accent font-bold" x-text="confirmKeyword"></code> abaixo:
                            </label>
                            <input type="text"
                                   x-model="confirmInput"
                                   x-ref="confirmInputRef"
                                   class="form-input w-full font-mono text-sm"
                                   :class="confirmInput === confirmKeyword ? 'border-es-basil' : ''"
                                   :placeholder="confirmKeyword"
                                   autocomplete="off"
                                   spellcheck="false"
                                   @@keydown.enter="confirmInput === confirmKeyword && confirmarEExecutar()" />
                            <div class="flex items-center gap-2 mt-1.5 text-[10px]"
                                 :class="confirmInput.length === 0 ? 'text-es-ink-mute' : confirmInput === confirmKeyword ? 'text-es-basil' : 'text-amber-300'">
                                <span x-show="confirmInput.length === 0" x-cloak>Aguardando entrada…</span>
                                <span x-show="confirmInput.length > 0 && confirmInput !== confirmKeyword" x-cloak>✗ Não corresponde — verifique maiúsculas/minúsculas</span>
                                <span x-show="confirmInput === confirmKeyword" x-cloak>✓ Correspondência exata — pode prosseguir</span>
                            </div>
                        </div>
                    </div>
                    <!-- Rodapé -->
                    <div class="px-6 py-4 flex items-center justify-end gap-2"
                         style="border-top:1px solid rgba(247,242,232,0.08)">
                        <button type="button" @@click="cancelarConfirmacao()" class="btn-secondary text-sm">
                            Cancelar
                        </button>
                        <button type="button"
                                @@click="confirmarEExecutar()"
                                :disabled="confirmInput !== confirmKeyword"
                                class="btn-primary text-sm disabled:opacity-30 disabled:cursor-not-allowed">
                            Executar <span x-text="confirmKeyword"></span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- ─── Modal de progresso (overlay fixed) ───────────────────────────── -->
            <div x-show="modal" x-cloak
                 class="fixed inset-0 z-50 flex items-center justify-center p-4"
                 style="background:rgba(0,0,0,.78); backdrop-filter:blur(4px)">
                <div class="rounded-2xl w-full max-w-2xl flex flex-col"
                     style="background:#1c1a17; border:1px solid rgba(247,242,232,0.12); max-height:88vh">
                    <!-- Cabeçalho -->
                    <div class="flex items-start justify-between px-6 py-4 shrink-0"
                         style="border-bottom:1px solid rgba(247,242,232,0.08)">
                        <div>
                            <h3 class="text-es-ink font-bold text-base"
                                x-text="runStatus === 'Running' ? '⏳ Executando seed…' : runStatus === 'Success' ? '✅ Seed concluído com sucesso' : runStatus === 'RolledBack' ? '↩️ Revertido (rollback automático)' : '❌ Falha na execução'"></h3>
                            <p class="text-es-ink-mute text-xs mt-1" x-text="currentStep"></p>
                        </div>
                        <button type="button" @@click="fecharModal()" :disabled="runStatus === 'Running'"
                                class="ml-4 text-es-ink-mute hover:text-es-ink disabled:opacity-30 disabled:cursor-not-allowed text-2xl leading-none shrink-0 mt-0.5">✕</button>
                    </div>
                    <!-- Barra de progresso -->
                    <div class="px-6 py-3 shrink-0" style="border-bottom:1px solid rgba(247,242,232,0.06)">
                        <div class="flex items-center justify-between text-xs text-es-ink-mute mb-2">
                            <span x-text="currentStep"></span>
                            <span class="font-mono font-bold" x-text="progress + '%'"></span>
                        </div>
                        <div class="rounded-full overflow-hidden" style="height:8px; background:rgba(247,242,232,0.08)">
                            <div class="h-full rounded-full transition-all duration-500"
                                 :style="'width:' + progress + '%; background:' + (runStatus === 'Success' ? '#4fbf9f' : runStatus === 'Running' ? '#e85814' : '#f87171')"
                                 :class="runStatus === 'Running' ? 'animate-pulse' : ''"></div>
                        </div>
                    </div>
                    <!-- Feed de logs em tempo real -->
                    <div class="flex-1 overflow-y-auto px-4 py-3 font-mono text-[11px] leading-5"
                         style="background:rgba(0,0,0,.25); min-height:180px"
                         x-ref="logFeed">
                        <div x-show="etapas.length === 0" x-cloak class="text-es-ink-mute text-xs py-6 text-center">Aguardando logs…</div>
                        <template x-for="(e, i) in etapas" :key="i">
                            <div class="flex gap-2 py-0.5"
                                 :class="e.level === 'error' ? 'text-red-400' : e.level === 'warn' ? 'text-amber-300' : e.level === 'success' ? 'text-es-basil' : 'text-es-ink-mute'">
                                <span class="text-es-ink-dim shrink-0 tabular-nums" x-text="(e.ts || '').slice(11, 19)"></span>
                                <span class="shrink-0 uppercase text-[9px] pt-px w-12 text-right opacity-60" x-text="e.level"></span>
                                <span class="flex-1 break-words" x-text="e.mensagem"></span>
                            </div>
                        </template>
                    </div>
                    <!-- Rodapé -->
                    <div class="px-6 py-4 flex items-center justify-between shrink-0"
                         style="border-top:1px solid rgba(247,242,232,0.08)">
                        <div class="text-[10px] text-es-ink-mute font-mono" x-show="runId" x-cloak>
                            Run: <span x-text="runId ? runId.slice(0, 8) + '…' : ''"></span>
                        </div>
                        <button type="button" @@click="fecharModal()" :disabled="runStatus === 'Running'"
                                class="btn-primary text-sm disabled:opacity-40 disabled:cursor-not-allowed ml-auto">
                            <span x-show="runStatus === 'Running'" x-cloak>Aguarde…</span>
                            <span x-show="runStatus !== 'Running'">Fechar</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>


    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- TAB: INFRAESTRUTURA — snapshot completo de infra (banco, redis, etc.)   -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div x-show="tab === 'infra'" x-cloak>

        <div class="flex items-center justify-between mb-4">
            <div class="text-es-ink-mute text-sm">Status detalhado de cada componente de infra. Auto-refresh a cada 60s.</div>
            <button type="button" @@click="infra.refresh()" class="btn-secondary text-sm">↻ Atualizar</button>
        </div>

        <template x-if="infra.erro">
            <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-4 py-3 text-sm mb-4" x-text="infra.erro"></div>
        </template>

        <div x-show="infra.loading && !infra.data" x-cloak class="flex items-center gap-2 text-es-ink-mute text-sm py-8 justify-center">
            <span class="inline-block w-2.5 h-2.5 rounded-full bg-es-accent animate-pulse"></span> Carregando…
        </div>

        <!-- Banner de causas prováveis quando há problemas -->
        <template x-if="(infra.data.causasProvaveis ?? []).length > 0">
            <div class="mb-4 rounded-lg px-4 py-3 text-sm" style="background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.25)">
                <div class="text-red-400 font-semibold mb-1.5">⚠ Causas prováveis detectadas</div>
                <ul class="text-red-300 text-xs space-y-0.5 list-disc pl-4">
                    <template x-for="causa in (infra.data.causasProvaveis ?? [])" :key="causa">
                        <li x-text="causa"></li>
                    </template>
                </ul>
            </div>
        </template>

        <div x-show="infra.data.status" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">

            <!-- Database -->
            <div class="card">
                <div class="flex items-center gap-2 mb-3">
                    <span :class="infra.dotClass(infra.data.banco?.conexao)" class="w-2.5 h-2.5 rounded-full inline-block shrink-0"></span>
                    <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">Database</span>
                    <span class="ml-auto text-[10px] font-mono text-es-ink-mute" x-text="infra.data.banco?.provider ?? '—'"></span>
                </div>
                <div class="text-2xl font-bold text-es-ink" x-text="infra.data.banco?.latenciaMs != null ? (infra.data.banco.latenciaMs + ' ms') : '—'">—</div>
                <div class="text-xs mt-1.5 space-y-0.5 font-mono text-es-ink-mute">
                    <div>Conexão: <span :class="infra.data.banco?.conexao ? 'text-es-basil' : 'text-red-400'" x-text="infra.data.banco?.conexao ? 'ok' : 'falha'"></span></div>
                    <div x-show="infra.data.banco?.migracoesAplicadas != null">Migrations: <span class="text-es-ink" x-text="infra.data.banco?.migracoesAplicadas"></span></div>
                    <div x-show="infra.data.banco?.fallback" class="text-amber-300">⚠ Usando fallback</div>
                    <div x-show="infra.data.banco?.erro" class="text-red-400 truncate" x-text="infra.data.banco?.causaProvavel ?? infra.data.banco?.erro"></div>
                </div>
            </div>

            <!-- Redis -->
            <div class="card">
                <div class="flex items-center gap-2 mb-3">
                    <span :class="infra.dotClassRedis()" class="w-2.5 h-2.5 rounded-full inline-block shrink-0"></span>
                    <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">Redis</span>
                </div>
                <template x-if="!infra.data.redis?.configurado">
                    <div class="text-es-ink-mute text-sm">Não configurado</div>
                </template>
                <template x-if="infra.data.redis?.configurado">
                    <div>
                        <div class="text-2xl font-bold text-es-ink" x-text="infra.data.redis?.latenciaMs != null ? (infra.data.redis.latenciaMs + ' ms') : '—'">—</div>
                        <div class="text-xs mt-1.5 font-mono text-es-ink-mute">
                            Conexão: <span :class="infra.data.redis?.conexao ? 'text-es-basil' : 'text-red-400'" x-text="infra.data.redis?.conexao ? 'ok' : 'falha'"></span>
                        </div>
                        <div x-show="infra.data.redis?.erro" class="text-red-400 text-xs mt-1 truncate" x-text="infra.data.redis?.causaProvavel ?? infra.data.redis?.erro"></div>
                    </div>
                </template>
            </div>

            <!-- SMTP -->
            <div class="card">
                <div class="flex items-center gap-2 mb-3">
                    <span :class="infra.data.smtp?.configurado ? 'bg-green-400' : 'bg-es-ink-mute/30'" class="w-2.5 h-2.5 rounded-full inline-block shrink-0"></span>
                    <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">SMTP</span>
                </div>
                <div class="text-sm font-semibold text-es-ink" x-text="infra.data.smtp?.configurado ? 'Configurado' : 'Não configurado'">—</div>
                <div class="text-xs mt-1.5 font-mono text-es-ink-mute space-y-0.5">
                    <div x-show="infra.data.smtp?.tipo">Tipo: <span class="text-es-ink" x-text="infra.data.smtp?.tipo"></span></div>
                    <div x-show="infra.data.smtp?.host">Host: <span class="text-es-ink" x-text="infra.data.smtp?.host"></span></div>
                </div>
            </div>

            <!-- Storage -->
            <div class="card">
                <div class="flex items-center gap-2 mb-3">
                    <span :class="infra.dotClassStorage()" class="w-2.5 h-2.5 rounded-full inline-block shrink-0"></span>
                    <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">Storage</span>
                    <span class="ml-auto text-[10px] font-mono text-es-ink-mute" x-text="infra.data.storage?.provider ?? '—'"></span>
                </div>
                <div class="text-sm font-semibold text-es-ink" x-text="infra.data.storage?.configurado ? 'Configurado' : 'Não configurado'">—</div>
                <div class="text-xs mt-1.5 font-mono text-es-ink-mute space-y-0.5">
                    <div x-show="infra.data.storage?.configurado">
                        Diretório: <span :class="infra.data.storage?.diretorioExiste ? 'text-es-basil' : 'text-red-400'" x-text="infra.data.storage?.diretorioExiste ? 'existe' : 'não encontrado'"></span>
                    </div>
                    <div x-show="infra.data.storage?.erro" class="text-red-400 truncate" x-text="infra.data.storage?.erro"></div>
                </div>
            </div>

            <!-- IA -->
            <div class="card">
                <div class="flex items-center gap-2 mb-3">
                    <span :class="infra.data.ia?.habilitado ? 'bg-green-400' : 'bg-es-ink-mute/30'" class="w-2.5 h-2.5 rounded-full inline-block shrink-0"></span>
                    <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">IA</span>
                </div>
                <div class="text-sm font-semibold text-es-ink" x-text="infra.data.ia?.habilitado ? 'Habilitada' : 'Desabilitada'">—</div>
                <div class="text-xs mt-1.5 font-mono text-es-ink-mute">
                    API Key: <span :class="infra.data.ia?.apiKeyPresente ? 'text-es-basil' : 'text-red-400'" x-text="infra.data.ia?.apiKeyPresente ? 'presente' : 'ausente'"></span>
                </div>
            </div>

            <!-- Configurações -->
            <div class="card">
                <div class="flex items-center gap-2 mb-3">
                    <span :class="infra.dotClassConfig()" class="w-2.5 h-2.5 rounded-full inline-block shrink-0"></span>
                    <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">Configurações</span>
                </div>
                <div class="text-xs font-mono text-es-ink-mute space-y-0.5">
                    <div>JWT Secret: <span :class="infra.data.configuracoes?.jwtSecretPresente ? (infra.data.configuracoes?.jwtSecretSeguro ? 'text-es-basil' : 'text-amber-300') : 'text-red-400'"
                        x-text="infra.data.configuracoes?.jwtSecretPresente ? (infra.data.configuracoes?.jwtSecretSeguro ? 'seguro' : 'fraco') : 'ausente'"></span></div>
                    <div>ConnString: <span :class="infra.data.configuracoes?.connectionStringPresente ? 'text-es-basil' : 'text-red-400'"
                        x-text="infra.data.configuracoes?.connectionStringPresente ? 'presente' : 'ausente'"></span></div>
                    <div x-show="(infra.data.configuracoes?.corsOrigins ?? []).length > 0" class="text-es-ink-mute">
                        CORS: <span class="text-es-ink" x-text="(infra.data.configuracoes?.corsOrigins ?? []).join(', ')"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Rodapé: versão + ambiente + uptime -->
        <div x-show="infra.data.status" class="flex flex-wrap gap-4 text-xs text-es-ink-mute font-mono">
            <span>Status geral: <b :class="infra.data.status === 'ok' ? 'text-es-basil' : infra.data.status === 'degraded' ? 'text-amber-300' : 'text-red-400'" x-text="infra.data.status ?? '—'"></b></span>
            <span x-show="infra.data.versao">v<span x-text="infra.data.versao"></span></span>
            <span x-show="infra.data.ambiente">Env: <span x-text="infra.data.ambiente"></span></span>
            <span x-show="infra.data.uptime">Uptime: <span x-text="infra.formatUptime(infra.data.uptime)"></span></span>
            <span x-show="infra.lastUpdated" class="ml-auto text-es-ink-mute">Atualizado às <span x-text="infra.lastUpdated"></span></span>
        </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- TAB: PERFORMANCE — SLO + endpoint health + queries lentas               -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div x-show="tab === 'performance'" x-cloak>

        <div class="flex items-center justify-between mb-4">
            <div class="text-es-ink-mute text-sm">SLO, health de endpoints e queries lentas no PostgreSQL.</div>
            <div class="flex gap-2 items-center">
                <select x-model="perf.sloHours" @@change="perf.refreshSlo()" class="form-input text-xs w-20">
                    <option value="6">6h</option>
                    <option value="24">24h</option>
                    <option value="72">3d</option>
                </select>
                <button type="button" @@click="perf.refreshAll()" class="btn-secondary text-sm">↻ Tudo</button>
            </div>
        </div>

        <!-- ── SLO ── -->
        <h3 class="text-es-ink font-semibold text-sm mb-3">📈 SLO</h3>
        <template x-if="perf.sloErro">
            <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-3 py-2 text-sm mb-4" x-text="perf.sloErro"></div>
        </template>
        <div x-show="perf.sloLoading && !perf.slo" x-cloak class="flex items-center gap-2 text-es-ink-mute text-sm py-4 mb-4">
            <span class="inline-block w-2 h-2 rounded-full bg-es-accent animate-pulse"></span> Carregando SLO…
        </div>
        <div x-show="perf.slo" class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
            <div class="card text-center">
                <div class="text-[10px] uppercase tracking-wide text-es-ink-mute mb-1">Uptime</div>
                <div class="text-2xl font-bold" :class="(perf.slo?.uptime24h ?? 100) >= 99.9 ? 'text-es-basil' : (perf.slo?.uptime24h ?? 100) >= 99 ? 'text-amber-300' : 'text-red-400'"
                     x-text="perf.slo?.uptime24h != null ? perf.slo.uptime24h.toFixed(2) + '%' : '—'">—</div>
                <div class="text-[10px] text-es-ink-mute mt-1" x-text="perf.slo?.periodoHoras ? perf.slo.periodoHoras + 'h' : ''"></div>
            </div>
            <div class="card text-center">
                <div class="text-[10px] uppercase tracking-wide text-es-ink-mute mb-1">Avg Response</div>
                <div class="text-2xl font-bold" :class="(perf.slo?.avgResponseTimeMs ?? 0) < 300 ? 'text-es-ink' : (perf.slo?.avgResponseTimeMs ?? 0) < 800 ? 'text-amber-300' : 'text-red-400'"
                     x-text="perf.slo?.avgResponseTimeMs != null ? Math.round(perf.slo.avgResponseTimeMs) + ' ms' : '—'">—</div>
                <div class="text-[10px] text-es-ink-mute mt-1">média</div>
            </div>
            <div class="card text-center">
                <div class="text-[10px] uppercase tracking-wide text-es-ink-mute mb-1">P95</div>
                <div class="text-2xl font-bold" :class="(perf.slo?.p95ResponseTimeMs ?? 0) < 800 ? 'text-es-ink' : (perf.slo?.p95ResponseTimeMs ?? 0) < 2000 ? 'text-amber-300' : 'text-red-400'"
                     x-text="perf.slo?.p95ResponseTimeMs != null ? Math.round(perf.slo.p95ResponseTimeMs) + ' ms' : '—'">—</div>
                <div class="text-[10px] text-es-ink-mute mt-1">percentil 95</div>
            </div>
            <div class="card text-center">
                <div class="text-[10px] uppercase tracking-wide text-es-ink-mute mb-1">Error Rate</div>
                <div class="text-2xl font-bold" :class="(perf.slo?.errorRate ?? 0) < 1 ? 'text-es-ink' : (perf.slo?.errorRate ?? 0) < 5 ? 'text-amber-300' : 'text-red-400'"
                     x-text="perf.slo?.errorRate != null ? perf.slo.errorRate.toFixed(2) + '%' : '—'">—</div>
                <div class="text-[10px] text-es-ink-mute mt-1" x-text="perf.slo?.totalRequests != null ? perf.slo.totalRequests + ' reqs' : ''"></div>
            </div>
        </div>

        <!-- ── Endpoint Health ── -->
        <div class="flex items-center justify-between mb-3">
            <h3 class="text-es-ink font-semibold text-sm">🔌 Health de Endpoints</h3>
            <button type="button" @@click="perf.refreshEndpoints()" class="btn-secondary text-xs">↻</button>
        </div>
        <template x-if="perf.endpointsErro">
            <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-3 py-2 text-sm mb-4" x-text="perf.endpointsErro"></div>
        </template>
        <div x-show="perf.endpointsLoading && !perf.endpoints" x-cloak class="flex items-center gap-2 text-es-ink-mute text-sm py-4 mb-4">
            <span class="inline-block w-2 h-2 rounded-full bg-es-accent animate-pulse"></span> Testando endpoints…
        </div>
        <div x-show="perf.endpoints" class="card p-0 overflow-hidden mb-6">
            <div class="flex gap-4 px-4 py-2.5 text-xs text-es-ink-mute" style="background:rgba(247,242,232,.03);border-bottom:1px solid rgba(247,242,232,.06)">
                <span>✅ Saudáveis: <b class="text-es-basil" x-text="perf.endpoints?.saudaveis ?? 0"></b></span>
                <span>🐢 Lentos: <b class="text-amber-300" x-text="perf.endpoints?.lentos ?? 0"></b></span>
                <span title="Endpoints autenticados — testados sem credenciais, só verificamos que a auth está protegida.">🔒 Auth-protegidos: <b class="text-amber-300" x-text="perf.endpoints?.degradados ?? 0"></b></span>
                <span>❌ Falhas: <b class="text-red-400" x-text="perf.endpoints?.falhas ?? 0"></b></span>
                <span class="ml-auto font-mono text-[10px]" x-show="perf.endpoints?.testadoEm" x-text="new Date(perf.endpoints.testadoEm).toLocaleTimeString('pt-BR')"></span>
            </div>
            <table class="w-full text-xs">
                <thead class="bg-es-surface-2 text-es-ink-mute uppercase tracking-wide">
                    <tr>
                        <th class="px-3 py-2 text-left">Método</th>
                        <th class="px-3 py-2 text-left">Rota</th>
                        <th class="px-3 py-2 text-right">HTTP</th>
                        <th class="px-3 py-2 text-right">ms</th>
                        <th class="px-3 py-2 text-left">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <template x-for="(ep, i) in (perf.endpoints?.resultados ?? [])" :key="i">
                        <tr style="border-top:1px solid rgba(247,242,232,0.04)">
                            <td class="px-3 py-2 font-mono text-es-ink-mute" x-text="ep.metodo ?? '—'"></td>
                            <td class="px-3 py-2 font-mono text-es-ink" x-text="ep.rota ?? '—'"></td>
                            <td class="px-3 py-2 text-right font-mono text-es-ink-mute" x-text="ep.statusCode ?? '—'"></td>
                            <td class="px-3 py-2 text-right font-mono" :class="(ep.latenciaMs ?? 0) > 1000 ? 'text-amber-400' : 'text-es-ink-mute'" x-text="ep.latenciaMs != null ? Math.round(ep.latenciaMs) : '—'"></td>
                            <td class="px-3 py-2">
                                <span class="px-1.5 py-0.5 rounded text-[10px] font-bold"
                                      :class="ep.status === 'ok' ? 'bg-es-basil/20 text-es-basil' : (ep.status === 'slow' || ep.status === 'degraded') ? 'bg-amber-500/20 text-amber-300' : ep.status === 'very_slow' ? 'bg-orange-500/20 text-orange-300' : 'bg-red-500/20 text-red-400'"
                                      x-text="ep.status === 'degraded' ? 'auth-protegido' : (ep.status ?? '—')"></span>
                                <span x-show="ep.erro" class="ml-1 text-amber-300 text-[10px]" :class="ep.status === 'degraded' ? 'text-amber-300' : 'text-red-400'" x-text="ep.erro"></span>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>

        <!-- ── Queries Lentas ── -->
        <div class="flex items-center justify-between mb-3">
            <h3 class="text-es-ink font-semibold text-sm">🐢 Queries Lentas</h3>
            <button type="button" @@click="perf.refreshQueries()" class="btn-secondary text-xs">↻</button>
        </div>
        <template x-if="perf.queriesErro">
            <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-3 py-2 text-sm mb-4" x-text="perf.queriesErro"></div>
        </template>
        <div x-show="perf.queriesLoading && !perf.queries" x-cloak class="flex items-center gap-2 text-es-ink-mute text-sm py-4">
            <span class="inline-block w-2 h-2 rounded-full bg-es-accent animate-pulse"></span> Consultando pg_stat_statements…
        </div>
        <template x-if="perf.queries && perf.queries.disponivel === false">
            <div class="card text-sm text-es-ink-mute" x-text="perf.queries.instrucoesPgStatStatements ?? 'pg_stat_statements não disponível.'"></div>
        </template>
        <div x-show="perf.queries?.disponivel && (perf.queries?.queries ?? []).length === 0" x-cloak class="card text-center py-8">
            <div class="text-3xl mb-2">✓</div>
            <p class="text-es-ink-mute text-sm">Nenhuma query lenta registrada.</p>
        </div>
        <div x-show="perf.queries?.disponivel && (perf.queries?.queries ?? []).length > 0" class="card p-0 overflow-hidden">
            <table class="w-full text-xs">
                <thead class="bg-es-surface-2 text-es-ink-mute uppercase tracking-wide">
                    <tr>
                        <th class="px-3 py-2 text-left">Query</th>
                        <th class="px-3 py-2 text-right">Calls</th>
                        <th class="px-3 py-2 text-right">Avg ms</th>
                        <th class="px-3 py-2 text-right">Stddev</th>
                        <th class="px-3 py-2 text-right">Avg rows</th>
                    </tr>
                </thead>
                <tbody>
                    <template x-for="(q, i) in (perf.queries?.queries ?? [])" :key="i">
                        <tr class="hover:bg-es-surface-2/40 cursor-pointer" @@click="perf.toggleQuery(i)"
                            style="border-top:1px solid rgba(247,242,232,0.04)">
                            <td class="px-3 py-2 font-mono text-es-ink max-w-xs">
                                <span x-text="perf.shortQuery(q.query)"></span>
                                <span x-show="perf.queries.queries.length > 0" class="ml-1 text-es-ink-mute text-[10px]" x-text="perf.expandedQueries[i] ? '▼' : '▶'"></span>
                            </td>
                            <td class="px-3 py-2 text-right font-mono text-es-ink-mute" x-text="q.calls ?? '—'"></td>
                            <td class="px-3 py-2 text-right font-mono" :class="(q.avgMs ?? 0) > 500 ? 'text-red-400' : (q.avgMs ?? 0) > 100 ? 'text-amber-300' : 'text-es-ink'" x-text="q.avgMs != null ? Math.round(q.avgMs) : '—'"></td>
                            <td class="px-3 py-2 text-right font-mono text-es-ink-mute" x-text="q.stddevMs != null ? Math.round(q.stddevMs) : '—'"></td>
                            <td class="px-3 py-2 text-right font-mono text-es-ink-mute" x-text="q.avgRows != null ? Math.round(q.avgRows) : '—'"></td>
                        </tr>
                        <tr x-show="perf.expandedQueries[i]" x-cloak style="border-top:1px solid rgba(247,242,232,0.04)">
                            <td colspan="5" class="bg-black/30 px-4 py-3">
                                <pre class="text-es-ink-dim whitespace-pre-wrap break-all font-mono text-[11px] max-h-48 overflow-auto" x-text="q.query"></pre>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
<script>
// ═══════════════════════════════════════════════════════════════════════════
// Página Diagnóstico — root Alpine factory.
// ═══════════════════════════════════════════════════════════════════════════
function diagnosticoPage() {
    return {
        // Tab inicial: vem do QS (?tab=...) com fallback "resumo".
        tab: new URLSearchParams(location.search).get('tab') || 'resumo',
        rangeHours: localStorage.getItem('diag.range') || '24',
        stickyCid: '',
        cidInput: '',

        header: {
            ultimaHora: 0,
            total24h: 0,
            lastUpdated: null
        },

        // ── Sub-states (factories internas) ──────────────────────────────────
        // Stub mínimo para evitar `Cannot read properties of null` quando Alpine
        // avalia bindings reativos antes do init() trocar pelos factories reais.
        resumo: { data: {}, loading: false },
        erros: { _loadedOnce: false, items: [], total: 0 },
        sysErros: { _loadedOnce: false, total: 0 },
        logMode: { loaded: false, verbose: false },
        infra: { _loadedOnce: false, data: {}, lastUpdated: null, erro: '' },
        perf: { _loadedOnce: false, slo: null, endpoints: null, queries: null },

        init() {
            this.resumo = resumoState.call(this);
            this.erros = errosState.call(this);
            this.sysErros = systemErrosState.call(this);
            this.logMode = loggingModeState.call(this);
            this.infra = infraState.call(this);
            this.perf = perfState.call(this);

            this.resumo.init();
            this.logMode.init();

            // Carrega header counters (compartilhado entre tabs).
            this.loadHeaderCounters();
            setInterval(() => this.loadHeaderCounters(), 60_000);

            // Lazy-load de tabs ao primeiro acesso.
            this.$watch('tab', (val) => {
                this._syncUrl();
                if (val === 'erros' && !this.erros._loadedOnce) this.erros.refresh();
                if (val === 'sistema' && !this.sysErros._loadedOnce) this.sysErros.refresh();
                if (val === 'infra' && !this.infra._loadedOnce) this.infra.refresh();
                if (val === 'performance' && !this.perf._loadedOnce) this.perf.refreshAll();
            });

            // Hidrata erros se entrou direto na tab.
            if (this.tab === 'erros') this.erros.refresh();
            if (this.tab === 'sistema') this.sysErros.refresh();
        },

        setTab(t) { this.tab = t; },

        _syncUrl() {
            const url = new URL(location.href);
            url.searchParams.set('tab', this.tab);
            history.replaceState(null, '', url);
        },

        async loadHeaderCounters() {
            try {
                const r = await fetch('/api-proxy/diag/summary?hours=24', { credentials: 'same-origin', cache: 'no-store' });
                if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                if (!r.ok) return;
                const d = await r.json();
                const resumo = d.resumo || {};
                this.header.total24h = resumo.totalErrors ?? 0;
                // Última hora: soma dos buckets ErrorsByHour da hora atual e anterior parcial.
                // ErrorsByHour key = "yyyy-MM-dd HH"; pega chave da hora atual.
                const now = new Date();
                const key = now.toISOString().slice(0, 13).replace('T', ' ');
                this.header.ultimaHora = (resumo.errorsByHour && resumo.errorsByHour[key]) || 0;
                this.header.lastUpdated = now.toLocaleTimeString('pt-BR');
            } catch { this.header.lastUpdated = 'Erro ao atualizar'; }
        },

        onRangeChange() {
            localStorage.setItem('diag.range', this.rangeHours);
            if (this.erros._loadedOnce) this.erros.refresh();
        },

        setStickyCid(cid) {
            this.stickyCid = cid || '';
            this.cidInput = '';
            if (this.tab !== 'erros') this.tab = 'erros';
            this.$nextTick(() => this.erros.refresh());
        },
        setStickyCidFromInput() {
            const v = (this.cidInput || '').trim();
            if (!v) return;
            this.setStickyCid(v);
        },
        clearStickyCid() {
            this.stickyCid = '';
            if (this.erros._loadedOnce) this.erros.refresh();
        }
    };
}

// ─── Factory: Tab Resumo (idêntico ao /Status antigo) ─────────────────────
function resumoState() {
