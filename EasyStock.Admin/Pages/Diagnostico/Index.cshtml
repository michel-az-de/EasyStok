                this.purgando = false;
            }
        },

        prevPage() { if (this.page > 1) { this.page--; this.refresh(); } },
        nextPage() { if (this.page * this.pageSize < this.total) { this.page++; this.refresh(); } },
        toggleExpand(i) { this.expanded = { ...this.expanded, [i]: !this.expanded[i] }; },
        shortMsg(msg) { return msg && msg.length > 120 ? msg.slice(0, 120) + '…' : (msg || '—'); },
        formatTime(iso) { if (!iso) return '—'; return new Date(iso).toLocaleString('pt-BR', { dateStyle: 'short', timeStyle: 'medium' }); },
        prettyJson(s) { try { return JSON.stringify(JSON.parse(s), null, 2); } catch { return s; } }
    };
}

