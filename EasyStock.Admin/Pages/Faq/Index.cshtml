@page
@model EasyStock.Admin.Pages.Faq.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "FAQ — Base de conhecimento";
    var orderBy = Request.Query["orderBy"].FirstOrDefault();
    var dir = Request.Query["dir"].FirstOrDefault();
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item>FAQ</es-breadcrumb-item>
        </es-breadcrumb>
        <div style="margin-top:4px; color:var(--text-muted); font-size:13px;">
            Base de conhecimento para clientes e equipe interna
        </div>
    </div>
    <div style="display:flex; gap:8px;">
        <es-button variant="ghost" href="/Faq/Categorias" icon="bookmark">Categorias</es-button>
        <es-button variant="primary" href="/Faq/Edit" icon="plus">Novo item</es-button>
    </div>
</div>

<es-card padding="md" card-class="mb-4">
    <form method="get" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:12px; align-items:end;">
        <es-input name="busca" label="Buscar" value="@Model.Busca" placeholder="Por título ou conteúdo..." prefix-icon="search" field-class="md:col-span-2" />
        <es-select name="status" label="Status">
            <option value="">Todos</option>
            <option value="Rascunho" selected="@(Model.Status == "Rascunho")">Rascunho</option>
            <option value="Publicado" selected="@(Model.Status == "Publicado")">Publicado</option>
            <option value="Arquivado" selected="@(Model.Status == "Arquivado")">Arquivado</option>
        </es-select>
        <es-select name="categoriaId" label="Categoria">
            <option value="">Todas</option>
            @foreach (var cat in Model.Categorias)
            {
                var id = cat.GetProperty("id").GetGuid();
                var nome = cat.GetProperty("nome").GetString();
                <option value="@id" selected="@(Model.CategoriaId == id)">@nome</option>
            }
        </es-select>
        <div style="display:flex; gap:8px;">
            <es-button type="submit" variant="primary" icon="filter">Filtrar</es-button>
            <es-button variant="ghost" href="/Faq">Limpar</es-button>
        </div>
    </form>
</es-card>

<es-filter-bar>
    @if (!string.IsNullOrEmpty(Model.Busca)) { <es-filter-chip label="Busca" remove-param="busca">@Model.Busca</es-filter-chip> }
    @if (!string.IsNullOrEmpty(Model.Status)) { <es-filter-chip label="Status" remove-param="status">@Model.Status</es-filter-chip> }
    @if (Model.CategoriaId.HasValue) { <es-filter-chip label="Categoria" remove-param="categoriaId">filtrada</es-filter-chip> }
</es-filter-bar>

<es-data-table sort-key="@orderBy" sort-dir="@dir" is-empty="@(!Model.Itens.Any())">
    <es-data-table-column key="titulo" label="Título" sortable="true" />
    <es-data-table-column label="Categoria" />
    <es-data-table-column label="Status" />
    <es-data-table-column label="Vis." align="right" />
    <es-data-table-column label="Útil / Não útil" align="right" />
    <es-data-table-column label="Atualizado" align="right" />
    <es-data-table-column label="" actions="true" width="220px" />

    @foreach (var item in Model.Itens)
    {
        var id = item.GetProperty("id").GetGuid();
        var status = item.GetProperty("status").GetString();
        var titulo = item.GetProperty("titulo").GetString();
        var catNome = item.GetProperty("categoriaNome").GetString();
        var vis = item.GetProperty("visualizacoes").GetInt32();
        var ok = item.GetProperty("utilCount").GetInt32();
        var nok = item.GetProperty("naoUtilCount").GetInt32();
        var atualizadoEm = item.TryGetProperty("publicadoEm", out var pe) && pe.ValueKind != JsonValueKind.Null ? pe.GetDateTime() : (DateTime?)null;
        var statusVariant = status switch
        {
            "Publicado" => "ok",
            "Arquivado" => "neutral",
            "Rascunho" => "warn",
            _ => "neutral"
        };

        <tr>
            <td data-label="Título" style="font-weight:500; color:var(--text-primary);">@titulo</td>
            <td data-label="Categoria" style="color:var(--text-secondary); font-size:13px;">@catNome</td>
            <td data-label="Status"><es-badge variant="@statusVariant" with-dot="true">@status</es-badge></td>
            <td data-label="Vis." class="es-data-table-td-numeric" style="font-weight:500;">@vis</td>
            <td data-label="Útil / Não útil" class="es-data-table-td-numeric">
                <span style="color:var(--ok-600);">@ok</span> /
                <span style="color:var(--crit-600);">@nok</span>
            </td>
            <td data-label="Atualizado" class="es-data-table-td-numeric" style="color:var(--text-muted); font-size:12px;">
                @(atualizadoEm?.ToString("dd/MM/yy HH:mm") ?? "—")
            </td>
            <td class="es-data-table-td-actions">
                <div class="es-row-actions">
                    <es-button variant="ghost" size="xs" icon="edit-2" href="/Faq/Edit/@id">Editar</es-button>
                    @if (status == "Rascunho" || status == "Arquivado")
                    {
                        <form method="post" asp-page-handler="Publicar" asp-route-id="@id" style="display:inline;">
                            <es-button type="submit" variant="ghost" size="xs" icon="check">Publicar</es-button>
                        </form>
                    }
                    @if (status == "Publicado")
                    {
                        <form method="post" asp-page-handler="Arquivar" asp-route-id="@id" style="display:inline;">
                            <es-button type="submit" variant="ghost" size="xs">Arquivar</es-button>
                        </form>
                    }
                </div>
            </td>
        </tr>
    }

    <es-data-table-empty>
        <es-empty-state icon="bookmark"
                        title="Nenhum item de FAQ"
                        description="Crie artigos para responder dúvidas frequentes dos clientes.">
            <es-button variant="primary" icon="plus" href="/Faq/Edit">Criar primeiro item</es-button>
        </es-empty-state>
    </es-data-table-empty>
</es-data-table>

@if (Model.TotalPages > 1)
{
    <es-pagination page="@Model.Page" page-size="20" total="@(Model.TotalPages * 20)" />
}
