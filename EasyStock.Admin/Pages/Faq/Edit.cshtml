@page "{id?}"
@model EasyStock.Admin.Pages.Faq.EditModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Editar FAQ" : "Novo FAQ";
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item href="/Faq">FAQ</es-breadcrumb-item>
            <es-breadcrumb-item>@(Model.Id.HasValue ? "Editar" : "Novo")</es-breadcrumb-item>
        </es-breadcrumb>
        <div style="display:flex; align-items:center; gap:10px; margin-top:6px;">
            <h2 class="admin-page-title" style="margin:0;">@ViewData["Title"]</h2>
            @if (Model.Status != null)
            {
                var sv = Model.Status switch { "Publicado" => "ok", "Arquivado" => "neutral", "Rascunho" => "warn", _ => "neutral" };
                <es-badge variant="@sv" with-dot="true">@(Model.Status.ToUpper())</es-badge>
            }
        </div>
    </div>
    <es-button variant="ghost" href="/Faq" icon="arrow-left">Voltar</es-button>
</div>

<div style="max-width:880px;">
    <es-card>
        <form method="post" style="display:flex; flex-direction:column; gap:14px;">
            <es-select asp-for="CategoriaId" label="Categoria" required="true" disabled="@Model.Id.HasValue">
                <option value="">— selecione —</option>
                @foreach (var cat in Model.Categorias)
                {
                    var id = cat.GetProperty("id").GetGuid();
                    var nome = cat.GetProperty("nome").GetString();
                    <option value="@id" selected="@(Model.CategoriaId == id)">@nome</option>
                }
            </es-select>

            <es-input asp-for="Titulo" label="Título" required="true" maxlength="200" />

            @if (!Model.Id.HasValue)
            {
                <es-input asp-for="Slug" label="Slug" required="true" maxlength="200"
                          placeholder="ex.: como-cadastrar-produto"
                          helper="Use letras minúsculas, números e hífen. Sem espaços." />
            }

            <es-textarea asp-for="Conteudo" label="Conteúdo (Markdown)" required="true"
                         rows="14" input-class="font-mono" />

            <es-textarea asp-for="ConteudoBusca" label="Conteúdo de busca (texto plano)"
                         rows="3" label-optional="true"
                         helper="Se vazio, será derivado do Markdown automaticamente." />

            <div style="display:grid; grid-template-columns:2fr 1fr; gap:12px;">
                <es-input asp-for="Tags" label="Tags" maxlength="500" label-optional="true"
                          helper="Separadas por vírgula." />
                <es-input asp-for="Ordem" type="number" label="Ordem" />
            </div>

            <div style="display:flex; gap:8px; padding-top:6px;">
                <es-button type="submit" variant="primary" icon="check">Salvar</es-button>
                <es-button variant="ghost" href="/Faq">Cancelar</es-button>
            </div>
        </form>
    </es-card>
</div>
