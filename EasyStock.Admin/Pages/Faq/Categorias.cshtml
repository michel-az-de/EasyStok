@page
@model EasyStock.Admin.Pages.Faq.CategoriasModel
@{
    ViewData["Title"] = "FAQ - Categorias";
}

<div class="flex items-center justify-between mb-4">
    <h1 class="text-es-ink text-xl font-semibold">FAQ - Categorias</h1>
    <a asp-page="/Faq/Index" class="btn-secondary text-sm">Voltar para itens</a>
</div>

@if (!string.IsNullOrEmpty(Model.Erro))
{
    <div class="mb-4 rounded bg-red-100 px-4 py-2 text-red-800">@Model.Erro</div>
}

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <section>
        <h2 class="text-base font-semibold mb-2">Categorias existentes</h2>
        <div class="rounded border border-es-border bg-es-surface overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-es-surface-2 text-es-ink-2 text-left">
                    <tr>
                        <th class="p-3">Nome</th>
                        <th class="p-3">Slug</th>
                        <th class="p-3">Ordem</th>
                        <th class="p-3">Publica</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Categorias.Any())
                    {
                        <tr><td colspan="4" class="p-4 text-center text-es-ink-2">Nenhuma categoria.</td></tr>
                    }
                    else
                    {
                        @foreach (var cat in Model.Categorias)
                        {
                            <tr class="border-t border-es-border">
                                <td class="p-3 font-medium">@cat.GetProperty("nome").GetString()</td>
                                <td class="p-3 font-mono text-xs">@cat.GetProperty("slug").GetString()</td>
                                <td class="p-3">@cat.GetProperty("ordem").GetInt32()</td>
                                <td class="p-3">@(cat.GetProperty("publica").GetBoolean() ? "Sim" : "Nao")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section>
        <h2 class="text-base font-semibold mb-2">Nova categoria</h2>
        <form method="post" asp-page-handler="Criar" class="space-y-3">
            <div>
                <label class="block text-sm mb-1">Nome *</label>
                <input asp-for="Nome" class="form-input w-full" maxlength="80" required />
            </div>
            <div>
                <label class="block text-sm mb-1">Slug *</label>
                <input asp-for="Slug" class="form-input w-full" maxlength="80" required
                       placeholder="ex: cadastros" />
            </div>
            <div>
                <label class="block text-sm mb-1">Descricao</label>
                <input asp-for="Descricao" class="form-input w-full" maxlength="500" />
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm mb-1">Icone</label>
                    <input asp-for="Icone" class="form-input w-full" maxlength="60"
                           placeholder="emoji ou nome de icone" />
                </div>
                <div>
                    <label class="block text-sm mb-1">Ordem</label>
                    <input asp-for="Ordem" type="number" class="form-input w-full" />
                </div>
            </div>
            <button type="submit" class="btn-primary">Criar categoria</button>
        </form>
    </section>
</div>
