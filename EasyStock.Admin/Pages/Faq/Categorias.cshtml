@page
@model EasyStock.Admin.Pages.Faq.CategoriasModel
@{
    ViewData["Title"] = "FAQ — Categorias";
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item href="/Faq">FAQ</es-breadcrumb-item>
            <es-breadcrumb-item>Categorias</es-breadcrumb-item>
        </es-breadcrumb>
    </div>
    <es-button variant="ghost" href="/Faq" icon="arrow-left">Voltar para itens</es-button>
</div>

<div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:16px;">
    <es-card title="Categorias existentes" description="@(Model.Categorias.Count() + " categoria(s)")">
        @if (!Model.Categorias.Any())
        {
            <es-empty-state icon="bookmark" title="Nenhuma categoria" description="Crie sua primeira no formulário ao lado." />
        }
        else
        {
            <div class="es-data-table-scroll">
                <table class="es-data-table">
                    <thead>
                        <tr>
                            <th scope="col">Nome</th>
                            <th scope="col">Slug</th>
                            <th scope="col" class="es-data-table-td-numeric">Ordem</th>
                            <th scope="col">Pública</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in Model.Categorias)
                        {
                            var publica = cat.GetProperty("publica").GetBoolean();
                            <tr>
                                <td data-label="Nome" style="font-weight:500;">@cat.GetProperty("nome").GetString()</td>
                                <td data-label="Slug" style="font-family:var(--font-mono); font-size:12px; color:var(--text-muted);">@cat.GetProperty("slug").GetString()</td>
                                <td data-label="Ordem" class="es-data-table-td-numeric">@cat.GetProperty("ordem").GetInt32()</td>
                                <td data-label="Pública">
                                    <es-badge variant="@(publica ? "ok" : "neutral")">@(publica ? "SIM" : "NÃO")</es-badge>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </es-card>

    <es-card title="Nova categoria" description="Slug é usado em URLs públicas; sem espaços nem acentos.">
        <form method="post" asp-page-handler="Criar" style="display:flex; flex-direction:column; gap:14px;">
            <es-input asp-for="Nome" label="Nome" required="true" maxlength="80" />
            <es-input asp-for="Slug" label="Slug" required="true" maxlength="80" placeholder="ex.: cadastros" />
            <es-input asp-for="Descricao" label="Descrição" label-optional="true" maxlength="500" />
            <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:10px;">
                <es-input asp-for="Icone" label="Ícone" label-optional="true" maxlength="60" placeholder="emoji ou nome" />
                <es-input asp-for="Ordem" type="number" label="Ordem" />
            </div>
            <es-button type="submit" variant="primary" icon="plus" block="true">Criar categoria</es-button>
        </form>
    </es-card>
</div>
