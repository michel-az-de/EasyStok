@page "{id:guid?}"
@model EasyStock.Admin.Pages.Notificacoes.Rotinas.EditModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Editar Rotina" : "Nova Rotina";
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item href="/Notificacoes/Rotinas">Rotinas</es-breadcrumb-item>
            <es-breadcrumb-item>@(Model.Id.HasValue ? "Editar" : "Nova")</es-breadcrumb-item>
        </es-breadcrumb>
        <h2 style="margin:6px 0 0; font-size:24px; font-weight:700; color:var(--text-primary); letter-spacing:-0.01em;">@ViewData["Title"]</h2>
    </div>
    <es-button variant="ghost" href="/Notificacoes/Rotinas" icon="arrow-left">Voltar</es-button>
</div>

<div style="max-width:720px;">
    <es-card>
        <form method="post" style="display:flex; flex-direction:column; gap:14px;">
            @if (!Model.Id.HasValue)
            {
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <es-input asp-for="Codigo" label="Código" required="true"
                              placeholder="produto_vencendo_cron"
                              input-class="font-mono" />
                    <es-input asp-for="Nome" label="Nome" required="true"
                              placeholder="Produto Vencendo — Diário" />
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <es-select asp-for="TipoEvento" label="Tipo de evento">
                        <option value="ProdutoVencendo">Produto Vencendo</option>
                        <option value="AssinaturaExpirando">Assinatura Expirando</option>
                        <option value="AlertaEstoqueCritico">Alerta Estoque</option>
                        <option value="BroadcastSuperAdmin">Broadcast</option>
                    </es-select>
                    <es-select asp-for="TriggerTipo" label="Trigger">
                        <option value="Cron">Cron</option>
                        <option value="Evento">Evento (imediato)</option>
                    </es-select>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <es-input asp-for="TemplateCodigo" label="Código do template"
                              placeholder="produto_vencendo_email_v1"
                              input-class="font-mono" />
                    <es-select asp-for="Categoria" label="Categoria">
                        <option value="Transacional">Transacional</option>
                        <option value="Operacional">Operacional</option>
                        <option value="Marketing">Marketing</option>
                    </es-select>
                </div>
            }

            <es-input asp-for="CronExpression" label="Expressão Cron"
                      placeholder="0 8 * * *"
                      input-class="font-mono"
                      helper="Formato padrão de 5 campos. Ex.: 0 8 * * * = diariamente às 8h UTC" />

            <es-textarea asp-for="ParametrosJson" label="Parâmetros (JSON)"
                         rows="4"
                         placeholder='{"diasAntes": [7, 3, 1]}'
                         input-class="font-mono"
                         label-optional="true" />

            <div style="display:flex; gap:8px; padding-top:6px;">
                <es-button type="submit" variant="primary" icon="check">Salvar</es-button>
                <es-button variant="ghost" href="/Notificacoes/Rotinas">Cancelar</es-button>
            </div>
        </form>
    </es-card>
</div>
