@page "{id:guid?}"
@model EasyStock.Admin.Pages.Notificacoes.Rotinas.EditModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Editar Rotina" : "Nova Rotina";
}

<div class="space-y-6 max-w-2xl">
    <div class="flex items-center gap-3">
        <a href="/Notificacoes/Rotinas" class="text-slate-400 hover:text-white">&larr;</a>
        <h1 class="text-2xl font-bold text-white">@ViewData["Title"]</h1>
    </div>

    @if (Model.Erro != null)
    {
        <div class="bg-red-900/50 border border-red-500 text-red-200 rounded-lg p-4 text-sm">@Model.Erro</div>
    }

    <form method="post" class="card p-6 space-y-5"
          x-data="{ trigger: '@Model.TriggerTipo', tipoEvento: '@Model.TipoEvento' }">
        @if (!Model.Id.HasValue)
        {
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="label-dark">Código</label>
                    <input asp-for="Codigo" class="input-dark w-full font-mono" placeholder="produto_vencendo_cron" />
                </div>
                <div>
                    <label class="label-dark">Nome</label>
                    <input asp-for="Nome" class="input-dark w-full" placeholder="Produto Vencendo — Diário" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="label-dark">Tipo de Evento</label>
                    <select asp-for="TipoEvento" class="input-dark w-full" @@change="tipoEvento = $event.target.value">
                        <option value="ProdutoVencendo">Produto Vencendo</option>
                        <option value="AssinaturaExpirando">Assinatura Expirando</option>
                        <option value="AlertaEstoqueCritico">Alerta Estoque</option>
                        <option value="BroadcastSuperAdmin">Broadcast</option>
                    </select>
                </div>
                <div>
                    <label class="label-dark">Trigger</label>
                    <select asp-for="TriggerTipo" class="input-dark w-full" @@change="trigger = $event.target.value">
                        <option value="Cron">Cron</option>
                        <option value="Evento">Evento (imediato)</option>
                    </select>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="label-dark">Código do Template</label>
                    <select asp-for="TemplateCodigo" class="input-dark w-full font-mono">
                        <option value="">— selecione um template —</option>
                        @foreach (var tpl in Model.TemplatesDisponiveis)
                        {
                            <option value="@tpl.Codigo"
                                    data-evento="@tpl.TipoEvento"
                                    x-show="!tipoEvento || tipoEvento === '@tpl.TipoEvento'">
                                @tpl.Codigo — @tpl.Nome (@tpl.Canal)
                            </option>
                        }
                    </select>
                    <p class="text-slate-500 text-xs mt-1">Filtrado pelo Tipo de Evento selecionado.</p>
                </div>
                <div>
                    <label class="label-dark">Categoria</label>
                    <select asp-for="Categoria" class="input-dark w-full">
                        <option value="Transacional">Transacional</option>
                        <option value="Operacional">Operacional</option>
                        <option value="Marketing">Marketing</option>
                    </select>
                </div>
            </div>
        }

        <div x-show="trigger === 'Cron'" x-transition>
            <label class="label-dark">Expressão Cron</label>
            <input asp-for="CronExpression" class="input-dark w-full font-mono" placeholder="0 8 * * *" />
            <details class="text-slate-500 text-xs mt-1 cursor-pointer">
                <summary class="hover:text-slate-300">Formato padrão de 5 campos — clique para ver exemplos</summary>
                <ul class="mt-2 space-y-1 pl-2">
                    <li><code class="text-amber-400">0 8 * * *</code> &nbsp;→&nbsp; todo dia às 8h UTC</li>
                    <li><code class="text-amber-400">0 9 * * 1</code> &nbsp;→&nbsp; toda segunda às 9h UTC</li>
                    <li><code class="text-amber-400">0 */2 * * *</code> &nbsp;→&nbsp; a cada 2 horas</li>
                    <li><code class="text-amber-400">*/15 * * * *</code> &nbsp;→&nbsp; a cada 15 minutos</li>
                    <li><code class="text-amber-400">0 0 1 * *</code> &nbsp;→&nbsp; primeiro dia de cada mês, meia-noite</li>
                </ul>
                <p class="mt-2 text-slate-500">Campos: <code>minuto hora dia-mês mês dia-semana</code> (0–6, dom=0).</p>
            </details>
        </div>

        <div x-show="trigger === 'Evento'" x-transition x-cloak class="bg-slate-800/40 border border-slate-700 rounded p-3 text-slate-400 text-sm">
            Disparada imediatamente quando o evento <code class="text-amber-400" x-text="tipoEvento"></code> é publicado. Sem cron necessário.
        </div>

        <div>
            <label class="label-dark">Parâmetros (JSON)</label>
            <textarea asp-for="ParametrosJson" class="input-dark w-full font-mono text-xs" rows="4"
                      placeholder='{"diasAntes": [7, 3, 1]}'></textarea>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="btn-primary px-6 py-2">Salvar</button>
            <a href="/Notificacoes/Rotinas" class="btn-ghost px-6 py-2">Cancelar</a>
        </div>
    </form>
</div>
