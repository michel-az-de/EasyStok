@page
@model EasyStock.Admin.Pages.Notificacoes.Rotinas.IndexModel
@{
    ViewData["Title"] = "Rotinas de Notificação";
}

<partial name="../_Subnav" />

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-white">Rotinas</h1>
            <p class="text-slate-400 text-sm mt-1">Configure triggers e canais de fallback para cada evento</p>
        </div>
        <a href="/Notificacoes/Rotinas/Edit" class="btn-primary px-4 py-2 text-sm">+ Nova Rotina</a>
    </div>

    <form method="get" class="flex gap-3">
        <select name="ativa" class="input-dark text-sm">
            <option value="">Todas</option>
            <option value="true">Ativas</option>
            <option value="false">Inativas</option>
        </select>
        <button type="submit" class="btn-secondary px-4 py-2 text-sm">Filtrar</button>
    </form>

    @if (Model.Erro != null)
    {
        <div class="bg-red-900/50 border border-red-500 text-red-200 rounded-lg p-4 text-sm">@Model.Erro</div>
    }

    <div class="card overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-slate-700 text-slate-400 text-xs uppercase">
                    <th class="px-4 py-3 text-left">Código / Nome</th>
                    <th class="px-4 py-3 text-left">Evento</th>
                    <th class="px-4 py-3 text-left">Trigger</th>
                    <th class="px-4 py-3 text-left">Template</th>
                    <th class="px-4 py-3 text-left">Status</th>
                    <th class="px-4 py-3 text-left">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.ValueKind == System.Text.Json.JsonValueKind.Array)
                {
                    @foreach (var r in Model.Data.EnumerateArray())
                    {
                        var id = r.TryGetProperty("id", out var idEl) ? idEl.GetString() : "";
                        var codigo = r.TryGetProperty("codigo", out var c) ? c.GetString() : "";
                        var nome = r.TryGetProperty("nome", out var n) ? n.GetString() : "";
                        var evento = r.TryGetProperty("tipoEvento", out var ev) ? ev.GetString() : "";
                        var trigger = r.TryGetProperty("triggerTipo", out var tr) ? tr.GetString() : "";
                        var cron = r.TryGetProperty("cronExpression", out var ce) ? ce.GetString() : "";
                        var template = r.TryGetProperty("templateCodigo", out var tc) ? tc.GetString() : "";
                        var ativa = r.TryGetProperty("ativa", out var at) && at.GetBoolean();

                        <tr class="border-b border-slate-800 hover:bg-slate-800/40">
                            <td class="px-4 py-3">
                                <div class="font-mono text-amber-400 text-xs">@codigo</div>
                                <div class="text-white">@nome</div>
                            </td>
                            <td class="px-4 py-3 text-slate-300 text-xs">@evento</td>
                            <td class="px-4 py-3 text-slate-300 text-xs">
                                @trigger
                                @if (!string.IsNullOrWhiteSpace(cron))
                                {
                                    <br /><code class="text-slate-500">@cron</code>
                                }
                            </td>
                            <td class="px-4 py-3 text-slate-400 font-mono text-xs">@template</td>
                            <td class="px-4 py-3">
                                @if (ativa)
                                {
                                    <span class="badge-green">Ativa</span>
                                }
                                else
                                {
                                    <span class="badge-gray">Inativa</span>
                                }
                            </td>
                            <td class="px-4 py-3 flex gap-2">
                                <a href="/Notificacoes/Rotinas/Edit?id=@id" class="text-blue-400 hover:text-blue-300 text-xs">Editar</a>
                                <form method="post" asp-page-handler="Toggle" class="inline">
                                    <input type="hidden" name="id" value="@id" />
                                    <input type="hidden" name="ativa" value="@ativa.ToString().ToLower()" />
                                    <button type="submit" class="text-xs @(ativa ? "text-red-400 hover:text-red-300" : "text-green-400 hover:text-green-300")">
                                        @(ativa ? "Desativar" : "Ativar")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
