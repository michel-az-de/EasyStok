@page
@model EasyStock.Admin.Pages.Notificacoes.Rotinas.IndexModel
@{
    ViewData["Title"] = "Rotinas de Notificação";
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item href="/Notificacoes/Templates">Notificações</es-breadcrumb-item>
            <es-breadcrumb-item>Rotinas</es-breadcrumb-item>
        </es-breadcrumb>
        <h2 style="margin:6px 0 0; font-size:24px; font-weight:700; color:var(--text-primary); letter-spacing:-0.01em;">Rotinas</h2>
        <p style="margin:4px 0 0; color:var(--text-muted); font-size:13px;">Configure triggers e canais de fallback para cada evento</p>
    </div>
    <es-button variant="primary" icon="plus" href="/Notificacoes/Rotinas/Edit">Nova rotina</es-button>
</div>

<es-card padding="md" card-class="mb-4">
    <form method="get" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:12px; align-items:end;">
        <es-select name="ativa" label="Status">
            <option value="">Todas</option>
            <option value="true">Ativas</option>
            <option value="false">Inativas</option>
        </es-select>
        <es-button type="submit" variant="primary" icon="filter">Filtrar</es-button>
    </form>
</es-card>

<es-data-table is-empty="@(Model.Data.ValueKind != System.Text.Json.JsonValueKind.Array || !Model.Data.EnumerateArray().Any())">
    <es-data-table-column label="Código / Nome" />
    <es-data-table-column label="Evento" />
    <es-data-table-column label="Trigger" />
    <es-data-table-column label="Template" />
    <es-data-table-column label="Status" />
    <es-data-table-column label="" actions="true" width="200px" />

    @if (Model.Data.ValueKind == System.Text.Json.JsonValueKind.Array)
    {
        @foreach (var r in Model.Data.EnumerateArray())
        {
            var id = r.TryGetProperty("id", out var idEl) ? idEl.GetString() : "";
            var codigo = r.TryGetProperty("codigo", out var c) ? c.GetString() : "";
            var nome = r.TryGetProperty("nome", out var n) ? n.GetString() : "";
            var evento = r.TryGetProperty("tipoEvento", out var ev) ? ev.GetString() : "";
            var trigger = r.TryGetProperty("triggerTipo", out var tr) ? tr.GetString() : "";
            var cron = r.TryGetProperty("cronExpression", out var ce) ? ce.GetString() : "";
            var template = r.TryGetProperty("templateCodigo", out var tc) ? tc.GetString() : "";
            var ativa = r.TryGetProperty("ativa", out var at) && at.GetBoolean();

            <tr>
                <td data-label="Código / Nome">
                    <div style="font-family:var(--font-mono); color:var(--orange-500); font-size:11px;">@codigo</div>
                    <div style="color:var(--text-primary); font-weight:500;">@nome</div>
                </td>
                <td data-label="Evento" style="color:var(--text-muted); font-size:12px;">@evento</td>
                <td data-label="Trigger" style="color:var(--text-secondary); font-size:12px;">
                    @trigger
                    @if (!string.IsNullOrWhiteSpace(cron))
                    {
                        <br /><code style="font-family:var(--font-mono); font-size:11px; color:var(--text-muted);">@cron</code>
                    }
                </td>
                <td data-label="Template" style="font-family:var(--font-mono); font-size:12px; color:var(--text-muted);">@template</td>
                <td data-label="Status">
                    <es-badge variant="@(ativa ? "ok" : "neutral")" with-dot="true">@(ativa ? "ATIVA" : "INATIVA")</es-badge>
                </td>
                <td class="es-data-table-td-actions">
                    <div class="es-row-actions">
                        <es-button variant="ghost" size="xs" icon="edit-2" href="/Notificacoes/Rotinas/Edit?id=@id">Editar</es-button>
                        <form method="post" asp-page-handler="Toggle" style="display:inline;">
                            <input type="hidden" name="id" value="@id" />
                            <input type="hidden" name="ativa" value="@ativa.ToString().ToLower()" />
                            <es-button type="submit" variant="ghost" size="xs">@(ativa ? "Desativar" : "Ativar")</es-button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    }

    <es-data-table-empty>
        <es-empty-state icon="clock"
                        title="Nenhuma rotina configurada"
                        description="Crie rotinas para automatizar disparos por evento ou cron.">
            <es-button variant="primary" icon="plus" href="/Notificacoes/Rotinas/Edit">Nova rotina</es-button>
        </es-empty-state>
    </es-data-table-empty>
</es-data-table>
