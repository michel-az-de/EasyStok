@page
@model EasyStock.Admin.Pages.Notificacoes.Canais.IndexModel
@{
    ViewData["Title"] = "Canais de Notificação";
}

<div style="margin-bottom:20px;">
    <es-breadcrumb>
        <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
        <es-breadcrumb-item href="/Notificacoes/Templates">Notificações</es-breadcrumb-item>
        <es-breadcrumb-item>Canais</es-breadcrumb-item>
    </es-breadcrumb>
    <h2 class="admin-page-title">Canais</h2>
    <p style="margin:4px 0 0; color:var(--text-muted); font-size:13px;">Configuração de provedores e kill-switches globais</p>
</div>

@if (Model.Configs.HasValue && Model.Configs.Value.ValueKind == System.Text.Json.JsonValueKind.Array)
{
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:16px; margin-bottom:24px;">
        @foreach (var cfg in Model.Configs.Value.EnumerateArray())
        {
            var canal = cfg.TryGetProperty("canal", out var c) ? c.GetString() : "";
            var provider = cfg.TryGetProperty("providerAtivo", out var p) ? p.GetString() : "stub";
            var ativo = cfg.TryGetProperty("ativoNoTenant", out var a) && a.GetBoolean();
            var iconName = canal switch
            {
                "Email" => "bell",
                "Sms" => "smartphone",
                "WhatsApp" => "smartphone",
                "InApp" => "bell",
                _ => "bell"
            };

            <es-card padding="md">
                <div style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <span style="display:inline-grid; place-items:center; width:36px; height:36px; border-radius:var(--r-md); background:var(--surface-sunken); color:var(--text-muted);">
                            <es-icon name="@iconName" size="18" />
                        </span>
                        <h3 style="margin:0; font-size:15px; font-weight:600; color:var(--text-primary);">@canal</h3>
                    </div>
                    <es-badge variant="@(ativo ? "ok" : "neutral")" with-dot="true">@(ativo ? "ATIVO" : "INATIVO")</es-badge>
                </div>
                <div style="margin-top:10px; padding-top:10px; border-top:1px solid var(--border-soft); font-size:12px; color:var(--text-muted);">
                    Provider: <code style="font-family:var(--font-mono); color:var(--orange-500);">@provider</code>
                </div>
            </es-card>
        }
    </div>
}

<es-card title="Kill-switches" description="Bloqueia disparos no canal indicado até remoção manual ou expiração.">
    @if (Model.Bloqueios.HasValue && Model.Bloqueios.Value.ValueKind == System.Text.Json.JsonValueKind.Array && Model.Bloqueios.Value.EnumerateArray().Any())
    {
        <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:18px;">
            @foreach (var b in Model.Bloqueios.Value.EnumerateArray())
            {
                var bId = b.TryGetProperty("id", out var bi) ? bi.GetString() : "";
                var motivo = b.TryGetProperty("motivo", out var bm) ? bm.GetString() : "";
                var canal = b.TryGetProperty("canal", out var bc) ? bc.GetString() : "Todos";
                var expira = b.TryGetProperty("expiraEm", out var be) && be.ValueKind != System.Text.Json.JsonValueKind.Null ? be.GetString() : null;

                <div style="display:flex; align-items:center; justify-content:space-between; padding:10px 14px; background:rgba(192,59,42,.10); border:1px solid rgba(192,59,42,.30); border-left:3px solid var(--crit-600); border-radius:var(--r-md); gap:12px;">
                    <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                        <es-icon name="alert-triangle" size="16" />
                        <es-badge variant="crit">@canal</es-badge>
                        <span style="font-size:13px; color:var(--text-primary);">@motivo</span>
                        @if (expira != null)
                        {
                            <span style="font-size:11px; color:var(--text-muted);">expira: @expira</span>
                        }
                    </div>
                    <form method="post" asp-page-handler="RemoverKillSwitch" style="display:inline;">
                        <input type="hidden" name="id" value="@bId" />
                        <es-button type="submit" variant="ghost" size="xs" icon="x">Remover</es-button>
                    </form>
                </div>
            }
        </div>
    }
    else
    {
        <p style="color:var(--text-muted); font-size:13px; margin-bottom:18px;">Nenhum kill-switch ativo no momento.</p>
    }

    <h3 style="margin:0 0 12px; font-size:14px; font-weight:600; color:var(--text-primary);">Ativar novo kill-switch</h3>
    <form method="post" asp-page-handler="KillSwitch" style="display:grid; grid-template-columns:auto 1fr auto; gap:10px; align-items:end;">
        <es-select name="canal" label="Canal">
            <option value="">Todos os canais</option>
            <option value="Email">Email</option>
            <option value="Sms">SMS</option>
            <option value="WhatsApp">WhatsApp</option>
            <option value="InApp">In-App</option>
        </es-select>
        <es-input name="motivo" label="Motivo" required="true" placeholder="Ex.: manutenção programada" />
        <es-button type="submit" variant="danger" icon="alert-triangle">Ativar</es-button>
    </form>
</es-card>
