@page
@model EasyStock.Admin.Pages.Notificacoes.BroadcastModel
@{
    ViewData["Title"] = "Broadcast — Super Admin";
}

<partial name="_Subnav" />

<div class="space-y-6 max-w-2xl">
    <div>
        <h1 class="text-2xl font-bold text-white">Broadcast</h1>
        <p class="text-slate-400 text-sm mt-1">Envio ad-hoc de notificação para usuários selecionados</p>
    </div>

    <div class="bg-amber-900/30 border border-amber-500/40 rounded-lg p-4 text-sm text-amber-200">
        ⚠️ Esta ação envia notificações reais. Confirme os destinatários antes de enviar.
    </div>

    <form method="post" class="card p-6 space-y-5">
        <div>
            <label class="form-label">EmpresaId</label>
            <input asp-for="EmpresaId" class="form-input w-full font-mono" placeholder="00000000-0000-0000-0000-000000000000" />
        </div>

        <div>
            <label class="form-label">UsuarioIds (um por linha, ou separados por vírgula)</label>
            <textarea asp-for="UsuariosIds" class="form-input w-full font-mono text-xs" rows="6"
                      placeholder="00000000-0000-0000-0000-000000000001&#10;00000000-0000-0000-0000-000000000002"></textarea>
        </div>

        <div>
            <label class="form-label">Título</label>
            <input asp-for="Titulo" class="form-input w-full" placeholder="Comunicado importante" />
        </div>
        <div>
            <label class="form-label">Mensagem</label>
            <textarea asp-for="Mensagem" class="form-input w-full" rows="4"
                      placeholder="Detalhes do comunicado..."></textarea>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="bg-amber-600 hover:bg-amber-700 text-white px-6 py-2 rounded font-medium transition-colors">
                Enviar Broadcast
            </button>
            <a href="/Notificacoes/Templates" class="btn-ghost px-6 py-2">Cancelar</a>
        </div>
    </form>
</div>
