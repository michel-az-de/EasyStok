@page
@model EasyStock.Admin.Pages.Notificacoes.Consentimentos.IndexModel
@{
    ViewData["Title"] = "Consentimentos LGPD";
}

<div style="margin-bottom:20px;">
    <es-breadcrumb>
        <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
        <es-breadcrumb-item href="/Notificacoes/Templates">Notificações</es-breadcrumb-item>
        <es-breadcrumb-item>Consentimentos</es-breadcrumb-item>
    </es-breadcrumb>
    <h2 class="admin-page-title">Consentimentos LGPD</h2>
    <p style="margin:4px 0 0; color:var(--text-muted); font-size:13px;">Histórico de opt-in/out por usuário (read-only — auditoria LGPD)</p>
</div>

<es-card padding="md" card-class="mb-4">
    <form method="get" style="display:grid; grid-template-columns:1fr auto; gap:10px; align-items:end;">
        <es-input name="usuarioId" label="UsuarioId (GUID)" value="@Model.UsuarioId" placeholder="00000000-0000-..." />
        <es-button type="submit" variant="primary" icon="search">Buscar</es-button>
    </form>
</es-card>

@if (Model.Data.HasValue && Model.Data.Value.ValueKind == System.Text.Json.JsonValueKind.Array && Model.Data.Value.EnumerateArray().Any())
{
    <es-data-table>
        <es-data-table-column label="Canal" />
        <es-data-table-column label="Categoria" />
        <es-data-table-column label="Estado" />
        <es-data-table-column label="Atualizado em" align="right" />
        <es-data-table-column label="IP" />
        <es-data-table-column label="Motivo opt-out" />

        @foreach (var c in Model.Data.Value.EnumerateArray())
        {
            var canal = c.TryGetProperty("canal", out var ca) ? ca.GetString() : "";
            var categoria = c.TryGetProperty("categoria", out var cat) ? cat.GetString() : "";
            var optIn = c.TryGetProperty("optIn", out var oi) && oi.GetBoolean();
            var atualizado = c.TryGetProperty("atualizadoEm", out var at) ? at.GetString() : "";
            var ip = c.TryGetProperty("ipOrigem", out var ip_) && ip_.ValueKind != System.Text.Json.JsonValueKind.Null ? ip_.GetString() : "—";
            var motivo = c.TryGetProperty("motivoOptOut", out var m) && m.ValueKind != System.Text.Json.JsonValueKind.Null ? m.GetString() : "—";
            DateTime.TryParse(atualizado, out var atualizadoDt);

            <tr>
                <td data-label="Canal" style="color:var(--text-secondary);">@canal</td>
                <td data-label="Categoria" style="color:var(--text-secondary);">@categoria</td>
                <td data-label="Estado">
                    <es-badge variant="@(optIn ? "ok" : "neutral")" with-dot="true">@(optIn ? "OPT-IN" : "OPT-OUT")</es-badge>
                </td>
                <td data-label="Atualizado" class="es-data-table-td-numeric" style="color:var(--text-muted); font-size:12px;">@atualizadoDt.ParaBrasilia().ToString("dd/MM/yy HH:mm")</td>
                <td data-label="IP" style="font-family:var(--font-mono); color:var(--text-muted); font-size:11px;">@ip</td>
                <td data-label="Motivo" style="color:var(--text-muted); font-size:12px;">@motivo</td>
            </tr>
        }
    </es-data-table>
}
else if (Model.UsuarioId.HasValue)
{
    <es-card>
        <es-empty-state icon="shield"
                        title="Nenhum consentimento encontrado"
                        description="Este usuário ainda não tem registros de opt-in/out." />
    </es-card>
}
else
{
    <es-card>
        <es-empty-state icon="shield"
                        title="Informe um UsuarioId"
                        description="Cole o GUID do usuário no campo acima para ver o histórico de consentimentos." />
    </es-card>
}
