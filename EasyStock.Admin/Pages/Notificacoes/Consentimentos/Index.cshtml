@page
@model EasyStock.Admin.Pages.Notificacoes.Consentimentos.IndexModel
@{
    ViewData["Title"] = "Consentimentos LGPD";
}

<partial name="../_Subnav" />

<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-bold text-white">Consentimentos</h1>
        <p class="text-slate-400 text-sm mt-1">Histórico de opt-in/out por usuário (read-only — auditoria LGPD)</p>
    </div>

    <form method="get" class="flex gap-3">
        <input type="text" name="usuarioId" value="@Model.UsuarioId"
               class="input-dark text-sm flex-1 font-mono" placeholder="UsuarioId (GUID)" />
        <button type="submit" class="btn-secondary px-4 py-2 text-sm">Buscar</button>
    </form>

    @if (Model.Erro != null)
    {
        <div class="bg-red-900/50 border border-red-500 text-red-200 rounded-lg p-4 text-sm">@Model.Erro</div>
    }

    @if (Model.Data.HasValue && Model.Data.Value.ValueKind == System.Text.Json.JsonValueKind.Array)
    {
        <div class="card overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-700 text-slate-400 text-xs uppercase">
                        <th class="px-4 py-3 text-left">Canal</th>
                        <th class="px-4 py-3 text-left">Categoria</th>
                        <th class="px-4 py-3 text-left">Opt-In</th>
                        <th class="px-4 py-3 text-left">Atualizado em</th>
                        <th class="px-4 py-3 text-left">IP</th>
                        <th class="px-4 py-3 text-left">Motivo opt-out</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Data.Value.EnumerateArray())
                    {
                        var canal = c.TryGetProperty("canal", out var ca) ? ca.GetString() : "";
                        var categoria = c.TryGetProperty("categoria", out var cat) ? cat.GetString() : "";
                        var optIn = c.TryGetProperty("optIn", out var oi) && oi.GetBoolean();
                        var atualizado = c.TryGetProperty("atualizadoEm", out var at) ? at.GetString() : "";
                        var ip = c.TryGetProperty("ipOrigem", out var ip_) && ip_.ValueKind != System.Text.Json.JsonValueKind.Null ? ip_.GetString() : "-";
                        var motivo = c.TryGetProperty("motivoOptOut", out var m) && m.ValueKind != System.Text.Json.JsonValueKind.Null ? m.GetString() : "-";

                        <tr class="border-b border-slate-800">
                            <td class="px-4 py-3 text-slate-300">@canal</td>
                            <td class="px-4 py-3 text-slate-300">@categoria</td>
                            <td class="px-4 py-3">
                                @if (optIn) { <span class="badge-green">Opt-In</span> }
                                else { <span class="badge-gray">Opt-Out</span> }
                            </td>
                            <td class="px-4 py-3 text-slate-400 text-xs">@atualizado</td>
                            <td class="px-4 py-3 text-slate-500 text-xs font-mono">@ip</td>
                            <td class="px-4 py-3 text-slate-500 text-xs">@motivo</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (Model.UsuarioId.HasValue)
    {
        <p class="text-slate-500 text-sm">Nenhum consentimento encontrado para este usuário.</p>
    }
</div>
