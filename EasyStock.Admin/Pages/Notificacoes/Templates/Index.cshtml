@page
@model EasyStock.Admin.Pages.Notificacoes.Templates.IndexModel
@{
    ViewData["Title"] = "Templates de Notificação";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-white">Templates</h1>
            <p class="text-slate-400 text-sm mt-1">Modelos de mensagem por canal e tipo de evento</p>
        </div>
        <a href="/Notificacoes/Templates/Edit" class="btn-primary px-4 py-2 text-sm">+ Novo Template</a>
    </div>

    <form method="get" class="flex gap-3 flex-wrap items-center">
        <select name="canal" class="form-input text-sm">
            <option value="">Todos os canais</option>
            <option value="Email" selected="@(Model.Canal == "Email" ? "selected" : null)">Email</option>
            <option value="Sms" selected="@(Model.Canal == "Sms" ? "selected" : null)">SMS</option>
            <option value="WhatsApp" selected="@(Model.Canal == "WhatsApp" ? "selected" : null)">WhatsApp</option>
            <option value="InApp" selected="@(Model.Canal == "InApp" ? "selected" : null)">In-App</option>
        </select>
        <select name="tipoEvento" class="form-input text-sm">
            <option value="">Todos os eventos</option>
            <option value="ProdutoVencendo" selected="@(Model.TipoEvento == "ProdutoVencendo" ? "selected" : null)">Produto Vencendo</option>
            <option value="ProdutoVencido" selected="@(Model.TipoEvento == "ProdutoVencido" ? "selected" : null)">Produto Vencido</option>
            <option value="AssinaturaExpirando" selected="@(Model.TipoEvento == "AssinaturaExpirando" ? "selected" : null)">Assinatura Expirando</option>
            <option value="AssinaturaExpirada" selected="@(Model.TipoEvento == "AssinaturaExpirada" ? "selected" : null)">Assinatura Expirada</option>
            <option value="TarefaPendente" selected="@(Model.TipoEvento == "TarefaPendente" ? "selected" : null)">Tarefa Pendente</option>
            <option value="ResetSenha" selected="@(Model.TipoEvento == "ResetSenha" ? "selected" : null)">Reset de Senha</option>
            <option value="ConfirmacaoEmail" selected="@(Model.TipoEvento == "ConfirmacaoEmail" ? "selected" : null)">Confirmação de Email</option>
            <option value="AlertaEstoqueCritico" selected="@(Model.TipoEvento == "AlertaEstoqueCritico" ? "selected" : null)">Alerta Estoque</option>
            <option value="BroadcastSuperAdmin" selected="@(Model.TipoEvento == "BroadcastSuperAdmin" ? "selected" : null)">Broadcast</option>
        </select>
        <select name="ativo" class="form-input text-sm">
            <option value="">Todos</option>
            <option value="true" selected="@(Model.Ativo == true ? "selected" : null)">Ativos</option>
            <option value="false" selected="@(Model.Ativo == false ? "selected" : null)">Inativos</option>
        </select>
        <button type="submit" class="btn-secondary px-4 py-2 text-sm">Filtrar</button>

        <input type="text" id="busca-textual" placeholder="Buscar nesta página (código ou nome)..."
               class="form-input text-sm flex-1 min-w-[16rem]"
               @@input="$dispatch('busca', $event.target.value)" x-data />
    </form>

    @if (Model.Erro != null)
    {
        <div class="bg-red-900/50 border border-red-500 text-red-200 rounded-lg p-4 text-sm">@Model.Erro</div>
    }

    <div class="card overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-slate-700 text-slate-400 text-xs uppercase">
                    <th class="px-4 py-3 text-left">Código / Nome</th>
                    <th class="px-4 py-3 text-left">Canal</th>
                    <th class="px-4 py-3 text-left">Evento</th>
                    <th class="px-4 py-3 text-left">Versão</th>
                    <th class="px-4 py-3 text-left">Status</th>
                    <th class="px-4 py-3 text-left">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.ValueKind == System.Text.Json.JsonValueKind.Array)
                {
                    @foreach (var t in Model.Data.EnumerateArray())
                    {
                        var id = t.TryGetProperty("id", out var idEl) ? idEl.GetString() : "";
                        var codigo = t.TryGetProperty("codigo", out var c) ? c.GetString() : "";
                        var nome = t.TryGetProperty("nome", out var n) ? n.GetString() : "";
                        var canal = t.TryGetProperty("canal", out var ca) ? ca.GetString() : "";
                        var evento = t.TryGetProperty("tipoEvento", out var ev) ? ev.GetString() : "";
                        var versao = t.TryGetProperty("versao", out var v) ? v.GetInt32() : 0;
                        var ativo = t.TryGetProperty("ativo", out var at) && at.GetBoolean();
                        var aprovado = t.TryGetProperty("aprovado", out var ap) && ap.GetBoolean();
                        var atualizadoEm = t.TryGetProperty("atualizadoEm", out var aem) ? aem.GetString() : null;
                        var atualizadoPor = t.TryGetProperty("atualizadoPor", out var apr) ? apr.GetString() : null;

                        <tr class="border-b border-slate-800 hover:bg-slate-800/40 transition-colors busca-linha"
                            data-codigo="@(codigo?.ToLowerInvariant())" data-nome="@(nome?.ToLowerInvariant())">
                            <td class="px-4 py-3">
                                <div class="font-mono text-amber-400 text-xs">@codigo</div>
                                <div class="text-white">@nome</div>
                            </td>
                            <td class="px-4 py-3 text-slate-300">@canal</td>
                            <td class="px-4 py-3 text-slate-300 text-xs">@evento</td>
                            <td class="px-4 py-3 text-slate-400">v@(versao)</td>
                            <td class="px-4 py-3">
                                @if (ativo && aprovado)
                                {
                                    <span class="badge-green">Ativo</span>
                                }
                                else if (ativo && !aprovado)
                                {
                                    <span class="badge-yellow">Aguardando aprovação</span>
                                }
                                else
                                {
                                    <span class="badge-gray">Inativo</span>
                                }
                                @if (aprovado && !string.IsNullOrWhiteSpace(atualizadoEm))
                                {
                                    <div class="text-xs text-slate-500 mt-1" title="@atualizadoEm — @atualizadoPor"
                                         x-data x-init="$el.textContent = 'aprovado há ' + tempoDecorrido('@atualizadoEm') + (('@atualizadoPor') ? ' · ' + '@atualizadoPor' : '')"></div>
                                }
                                else if (!aprovado && !string.IsNullOrWhiteSpace(atualizadoEm))
                                {
                                    <div class="text-xs text-slate-500 mt-1" title="@atualizadoEm"
                                         x-data x-init="$el.textContent = 'editado há ' + tempoDecorrido('@atualizadoEm')"></div>
                                }
                            </td>
                            <td class="px-4 py-3 flex gap-2 items-center">
                                <a href="/Notificacoes/Templates/Edit?id=@id" class="text-blue-400 hover:text-blue-300 text-xs">Editar</a>
                                @if (ativo && !aprovado)
                                {
                                    <button type="button"
                                            @@click="$dispatch('open-justificar', {
                                                endpoint: '?handler=Aprovar',
                                                acao: 'Aprovar template',
                                                resumo: 'O template @nome (@codigo v@(versao)) ficará disponível para envio.',
                                                variant: 'primary',
                                                confirmLabel: 'Aprovar (auditado)',
                                                extraFields: '<input type=&quot;hidden&quot; name=&quot;id&quot; value=&quot;@id&quot; />'
                                            })"
                                            class="text-green-400 hover:text-green-300 text-xs">Aprovar</button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="flex justify-center gap-2">
            @for (var p = 1; p <= Model.TotalPages; p++)
            {
                <a href="?page=@p&canal=@Model.Canal&tipoEvento=@Model.TipoEvento&ativo=@Model.Ativo"
                   class="px-3 py-1 rounded text-sm @(p == Model.Page ? "bg-blue-600 text-white" : "text-slate-400 hover:text-white")">@p</a>
            }
        </div>
    }
</div>

@await Html.PartialAsync("_ModalJustificativa")

<script>
function tempoDecorrido(iso) {
    if (!iso) return '';
    const diff = Date.now() - new Date(iso).getTime();
    if (isNaN(diff) || diff < 0) return '';
    const s = Math.floor(diff / 1000);
    if (s < 60) return s + 's';
    const m = Math.floor(s / 60);
    if (m < 60) return m + ' min';
    const h = Math.floor(m / 60);
    if (h < 24) return h + 'h';
    const d = Math.floor(h / 24);
    if (d < 30) return d + 'd';
    return Math.floor(d / 30) + ' mês(es)';
}

window.addEventListener('busca', (e) => {
    const termo = (e.detail || '').toString().trim().toLowerCase();
    document.querySelectorAll('.busca-linha').forEach(row => {
        if (!termo) { row.style.display = ''; return; }
        const codigo = row.getAttribute('data-codigo') || '';
        const nome = row.getAttribute('data-nome') || '';
        row.style.display = (codigo.includes(termo) || nome.includes(termo)) ? '' : 'none';
    });
});
</script>
