@page
@model EasyStock.Admin.Pages.Notificacoes.Templates.IndexModel
@{
    ViewData["Title"] = "Templates de Notificação";
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item>Templates</es-breadcrumb-item>
        </es-breadcrumb>
        <h2 class="admin-page-title">Templates</h2>
        <p style="margin:4px 0 0; color:var(--text-muted); font-size:13px;">Modelos de mensagem por canal e tipo de evento</p>
    </div>
    <es-button variant="primary" icon="plus" href="/Notificacoes/Templates/Edit">Novo template</es-button>
</div>

<es-card padding="md" card-class="mb-4">
    <form method="get" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:12px; align-items:end;">
        <es-select name="canal" label="Canal">
            <option value="">Todos os canais</option>
            <option value="Email" selected="@(Model.Canal == "Email")">Email</option>
            <option value="Sms" selected="@(Model.Canal == "Sms")">SMS</option>
            <option value="WhatsApp" selected="@(Model.Canal == "WhatsApp")">WhatsApp</option>
            <option value="InApp" selected="@(Model.Canal == "InApp")">In-App</option>
        </es-select>
        <es-select name="tipoEvento" label="Evento">
            <option value="">Todos</option>
            <option value="ProdutoVencendo">Produto Vencendo</option>
            <option value="ProdutoVencido">Produto Vencido</option>
            <option value="AssinaturaExpirando">Assinatura Expirando</option>
            <option value="AssinaturaExpirada">Assinatura Expirada</option>
            <option value="TarefaPendente">Tarefa Pendente</option>
            <option value="ResetSenha">Reset de Senha</option>
            <option value="ConfirmacaoEmail">Confirmação de Email</option>
            <option value="AlertaEstoqueCritico">Alerta Estoque</option>
            <option value="BroadcastSuperAdmin">Broadcast</option>
        </es-select>
        <es-select name="ativo" label="Status">
            <option value="">Todos</option>
            <option value="true">Ativos</option>
            <option value="false">Inativos</option>
        </es-select>
        <es-button type="submit" variant="primary" icon="filter">Filtrar</es-button>
    </form>
</es-card>

<es-data-table is-empty="@(Model.Data.ValueKind != System.Text.Json.JsonValueKind.Array || !Model.Data.EnumerateArray().Any())">
    <es-data-table-column label="Código / Nome" />
    <es-data-table-column label="Canal" />
    <es-data-table-column label="Evento" />
    <es-data-table-column label="Versão" align="right" />
    <es-data-table-column label="Status" />
    <es-data-table-column label="" actions="true" width="200px" />

    @if (Model.Data.ValueKind == System.Text.Json.JsonValueKind.Array)
    {
        @foreach (var t in Model.Data.EnumerateArray())
        {
            var id = t.TryGetProperty("id", out var idEl) ? idEl.GetString() : "";
            var codigo = t.TryGetProperty("codigo", out var c) ? c.GetString() : "";
            var nome = t.TryGetProperty("nome", out var n) ? n.GetString() : "";
            var canal = t.TryGetProperty("canal", out var ca) ? ca.GetString() : "";
            var evento = t.TryGetProperty("tipoEvento", out var ev) ? ev.GetString() : "";
            var versao = t.TryGetProperty("versao", out var v) ? v.GetInt32() : 0;
            var ativo = t.TryGetProperty("ativo", out var at) && at.GetBoolean();
            var aprovado = t.TryGetProperty("aprovado", out var ap) && ap.GetBoolean();

            <tr>
                <td data-label="Código / Nome">
                    <div style="font-family:var(--font-mono); color:var(--orange-500); font-size:11px;">@codigo</div>
                    <div style="color:var(--text-primary); font-weight:500;">@nome</div>
                </td>
                <td data-label="Canal" style="color:var(--text-secondary);">@canal</td>
                <td data-label="Evento" style="color:var(--text-muted); font-size:12px;">@evento</td>
                <td data-label="Versão" class="es-data-table-td-numeric" style="font-family:var(--font-mono); color:var(--text-muted);">v@versao</td>
                <td data-label="Status">
                    @if (ativo && aprovado)
                    {
                        <es-badge variant="ok" with-dot="true">ATIVO</es-badge>
                    }
                    else if (ativo && !aprovado)
                    {
                        <es-badge variant="warn" with-dot="true">PENDENTE APROVAÇÃO</es-badge>
                    }
                    else
                    {
                        <es-badge variant="neutral">INATIVO</es-badge>
                    }
                </td>
                <td class="es-data-table-td-actions">
                    <div class="es-row-actions">
                        <es-button variant="ghost" size="xs" icon="edit-2" href="/Notificacoes/Templates/Edit?id=@id">Editar</es-button>
                        @if (ativo && !aprovado)
                        {
                            <form method="post" asp-page-handler="Aprovar" style="display:inline;">
                                <input type="hidden" name="id" value="@id" />
                                <es-button type="submit" variant="ghost" size="xs" icon="check">Aprovar</es-button>
                            </form>
                        }
                    </div>
                </td>
            </tr>
        }
    }

    <es-data-table-empty>
        <es-empty-state icon="bell"
                        title="Nenhum template"
                        description="Crie templates para padronizar mensagens enviadas aos clientes.">
            <es-button variant="primary" icon="plus" href="/Notificacoes/Templates/Edit">Novo template</es-button>
        </es-empty-state>
    </es-data-table-empty>
</es-data-table>

@if (Model.TotalPages > 1)
{
    <es-pagination page="@Model.Page" page-size="20" total="@(Model.TotalPages * 20)" />
}
