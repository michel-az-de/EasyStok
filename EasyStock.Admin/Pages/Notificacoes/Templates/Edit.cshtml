@page "{id:guid?}"
@using EasyStock.Admin.Pages.Notificacoes
@model EasyStock.Admin.Pages.Notificacoes.Templates.EditModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Editar Template" : "Novo Template";
    var ehNovo = !Model.Id.HasValue;
    var catalogoJson = System.Text.Json.JsonSerializer.Serialize(
        NotificacoesVariaveisCatalogo.PorEvento.ToDictionary(
            kv => kv.Key,
            kv => kv.Value.Select(v => new { v.Nome, v.Descricao, v.Exemplo })));
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item href="/Notificacoes/Templates">Templates</es-breadcrumb-item>
            <es-breadcrumb-item>@(Model.Id.HasValue ? "Editar" : "Novo")</es-breadcrumb-item>
        </es-breadcrumb>
        <div style="display:flex; align-items:center; gap:10px; margin-top:6px;">
            <h2 class="admin-page-title" style="margin:0;">@ViewData["Title"]</h2>
            @if (Model.Id.HasValue)
            {
                <es-badge variant="warn">Nova versão ao salvar</es-badge>
            }
        </div>
    </div>
    <es-button variant="ghost" href="/Notificacoes/Templates" icon="arrow-left">Voltar</es-button>
</div>

<div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(420px,1fr)); gap:16px;">
    <form method="post" style="display:flex; flex-direction:column; gap:16px;">
        @if (!Model.Id.HasValue)
        {
            <es-card title="Identificação">
                <div style="display:flex; flex-direction:column; gap:12px;">
                    <es-input asp-for="Codigo" label="Código" required="true"
                              placeholder="produto_vencendo_email_v1"
                              input-class="font-mono"
                              helper="Snake case com versão. Único no sistema." />
                    <es-input asp-for="Nome" label="Nome" required="true" placeholder="Produto Vencendo — Email" />
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                        <es-select asp-for="Canal" label="Canal">
                            <option value="Email">Email</option>
                            <option value="Sms">SMS</option>
                            <option value="WhatsApp">WhatsApp</option>
                            <option value="InApp">In-App</option>
                        </es-select>
                        <es-select asp-for="TipoEvento" label="Tipo de evento">
                            <option value="ProdutoVencendo">Produto Vencendo</option>
                            <option value="ProdutoVencido">Produto Vencido</option>
                            <option value="AssinaturaExpirando">Assinatura Expirando</option>
                            <option value="ResetSenha">Reset de Senha</option>
                            <option value="AlertaEstoqueCritico">Alerta Estoque</option>
                            <option value="BroadcastSuperAdmin">Broadcast</option>
                        </es-select>
                    </div>
                </div>
            </es-card>
        }

        <es-card title="Conteúdo" description="Use {{ variavel }} para variáveis Scriban">
            <div style="display:flex; flex-direction:column; gap:14px;">
                <es-input asp-for="AssuntoTemplate" label="Assunto"
                          placeholder="{{ nomeProduto }} vence em {{ diasRestantes }} dias"
                          input-class="font-mono" />
                <es-textarea asp-for="CorpoTemplate" label="Corpo (HTML)"
                             rows="12"
                             input-class="font-mono"
                             placeholder="<p>Olá! O produto <strong>{{ nomeProduto }}</strong> vence em {{ diasRestantes }} dias.</p>" />
            </div>
        </es-card>

        <div style="display:flex; gap:8px;">
            <es-button type="submit" variant="primary" icon="check">Salvar</es-button>
            <es-button variant="ghost" href="/Notificacoes/Templates">Cancelar</es-button>
        </div>
    </form>

</div>

@section Scripts {
<script>
    window.__notifVarCatalogo = @Html.Raw(catalogoJson);

    function templateEditor() {
        return {
            codigo: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Codigo ?? "")),
            canal: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Canal ?? "Email")),
            evento: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TipoEvento ?? "AlertaEstoqueCritico")),
            assunto: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AssuntoTemplate ?? "")),
            corpo: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CorpoTemplate ?? "")),

            assuntoRenderizado: '',
            corpoRenderizado: '',
            erroPreview: '',
            loadingPreview: false,
            modoPreview: 'desktop',
            varsDoEvento: [],
            varsDesconhecidas: [],
            ultimoCampoFocado: 'corpo',

            init() {
                this.atualizarVarsDoEvento();
                this.detectarVarsDesconhecidas();
                this.$nextTick(() => {
                    const ass = document.querySelector('[name="AssuntoTemplate"]');
                    const cor = document.querySelector('[name="CorpoTemplate"]');
                    if (ass) ass.addEventListener('focus', () => this.ultimoCampoFocado = 'assunto');
                    if (cor) cor.addEventListener('focus', () => this.ultimoCampoFocado = 'corpo');
                });
                this.atualizarPreview();
            },

            aoMudarCanal() {
                if (!this.codigo || this.codigo.match(/_(email|inapp|sms|whatsapp)_v\d+$/i)) this.sugerirCodigo();
            },
            aoMudarEvento() {
                this.atualizarVarsDoEvento();
                this.detectarVarsDesconhecidas();
                this.atualizarPreview();
                this.sugerirCodigo();
            },

            sugerirCodigo() {
                const ev = this.evento.replace(/([A-Z])/g, '_$1').replace(/^_/, '').toLowerCase();
                this.codigo = ev + '_' + this.canal.toLowerCase() + '_v1';
            },

            atualizarVarsDoEvento() {
                this.varsDoEvento = (window.__notifVarCatalogo[this.evento] || []).slice();
            },

            detectarVarsDesconhecidas() {
                const reservadas = new Set(['if','else','end','for','in','this','true','false','null','and','or','not','with','unless','case','when','capture','assign']);
                const texto = (this.assunto + ' ' + this.corpo);
                const matches = [...texto.matchAll(/\{\{\s*([a-zA-Z_][\w\.]*)/g)];
                const conhecidas = new Set(this.varsDoEvento.map(v => v.nome));
                conhecidas.add('__unsubscribe_url');
                const descs = new Set();
                for (const m of matches) {
                    const nome = m[1].split('.')[0];
                    if (reservadas.has(nome.toLowerCase())) continue;
                    if (!conhecidas.has(nome)) descs.add(nome);
                }
                this.varsDesconhecidas = [...descs];
            },

            inserirVar(nome) { this.inserirNoCampoFocado('{{ ' + nome + ' }}'); },

            inserirNoCampoFocado(texto) {
                const seletor = this.ultimoCampoFocado === 'assunto' ? '[name="AssuntoTemplate"]' : '[name="CorpoTemplate"]';
                const el = document.querySelector(seletor);
                if (!el) return;
                const start = el.selectionStart ?? el.value.length;
                const end = el.selectionEnd ?? el.value.length;
                const novo = el.value.substring(0, start) + texto + el.value.substring(end);
                el.value = novo;
                if (this.ultimoCampoFocado === 'assunto') this.assunto = novo;
                else this.corpo = novo;
                el.focus();
                const cursor = start + texto.length;
                el.setSelectionRange(cursor, cursor);
                this.atualizarPreview();
            },

            inserirSnippet(tipo) {
                const snips = {
                    cabecalho: `<div style="background:#0E2A6E;padding:20px;text-align:center;border-radius:8px 8px 0 0">
  <h1 style="color:#fff;font-family:sans-serif;margin:0;font-size:24px">Easy<span style="color:#F26B25">Stok</span></h1>
</div>
<div style="font-family:sans-serif;max-width:600px;margin:auto;padding:24px;background:#fff;border-radius:0 0 8px 8px">
  <!-- corpo aqui -->
</div>`,
                    botao_cta: `<p style="text-align:center;margin:24px 0">
  <a href="{{ link_pagamento }}" style="display:inline-block;background:#E85814;color:#fff;padding:12px 28px;border-radius:6px;text-decoration:none;font-weight:600">Acessar EasyStok</a>
</p>`,
                    caixa_destaque: `<div style="background:#f3f4f6;border-left:4px solid #E85814;padding:16px;border-radius:4px;margin:16px 0">
  <p style="margin:0;color:#374151">Texto importante aqui.</p>
</div>`,
                    rodape_lgpd: `<hr style="border:none;border-top:1px solid #e5e7eb;margin:24px 0" />
<p style="color:#6b7280;font-size:11px;text-align:center;line-height:1.6">
  Voce esta recebendo este email porque possui uma conta na plataforma EasyStok.<br/>
  <a href="{{ __unsubscribe_url }}" style="color:#6b7280">Cancelar inscricao</a> &middot; EasyStok &middot; CNPJ 00.000.000/0001-00
</p>`
                };
                const c = snips[tipo];
                if (!c) return;
                this.ultimoCampoFocado = 'corpo';
                this.inserirNoCampoFocado(c);
            },

            async atualizarPreview() {
                this.detectarVarsDesconhecidas();
                this.loadingPreview = true;
                this.erroPreview = '';
                try {
                    const variaveis = {};
                    for (const v of this.varsDoEvento) variaveis[v.nome] = v.exemplo;
                    variaveis.__unsubscribe_url = '#';
                    const r = await fetch('/api-proxy/notif/preview-draft', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'same-origin',
                        body: JSON.stringify({
                            assuntoTemplate: this.assunto,
                            corpoTemplate: this.corpo,
                            variaveis: variaveis
                        })
                    });
                    if (!r.ok) {
                        const t = await r.text();
                        try {
                            const j = JSON.parse(t);
                            this.erroPreview = j.error?.message || j.error?.detail || ('HTTP ' + r.status);
                        } catch { this.erroPreview = 'HTTP ' + r.status; }
                        return;
                    }
                    const j = await r.json();
                    const d = j.data || j;
                    this.assuntoRenderizado = d.assuntoRenderizado || '';
                    this.corpoRenderizado = d.corpoRenderizado || '';
                } catch (e) {
                    this.erroPreview = e.message || 'Falha de rede';
                } finally {
                    this.loadingPreview = false;
                }
            }
        };
    }
</script>
}
