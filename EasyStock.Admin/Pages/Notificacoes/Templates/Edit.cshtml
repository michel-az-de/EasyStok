@page "{id:guid?}"
@model EasyStock.Admin.Pages.Notificacoes.Templates.EditModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Editar Template" : "Novo Template";
}

<div class="space-y-6 max-w-4xl">
    <div class="flex items-center gap-3">
        <a href="/Notificacoes/Templates" class="text-slate-400 hover:text-white">&larr;</a>
        <h1 class="text-2xl font-bold text-white">@ViewData["Title"]</h1>
        @if (Model.Id.HasValue)
        {
            <span class="badge-yellow text-xs">Nova versão será criada ao salvar</span>
        }
    </div>

    @if (Model.Erro != null)
    {
        <div class="bg-red-900/50 border border-red-500 text-red-200 rounded-lg p-4 text-sm">@Model.Erro</div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="space-y-4">
            <form method="post">
                @if (!Model.Id.HasValue)
                {
                    <div class="card p-4 space-y-4">
                        <h2 class="text-white font-semibold">Identificação</h2>
                        <div>
                            <label class="form-label">Código</label>
                            <input asp-for="Codigo" class="form-input w-full font-mono" placeholder="produto_vencendo_email_v1" />
                        </div>
                        <div>
                            <label class="form-label">Nome</label>
                            <input asp-for="Nome" class="form-input w-full" placeholder="Produto Vencendo — Email" />
                        </div>
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="form-label">Canal</label>
                                <select asp-for="Canal" class="form-input w-full">
                                    <option value="Email">Email</option>
                                    <option value="Sms">SMS</option>
                                    <option value="WhatsApp">WhatsApp</option>
                                    <option value="InApp">In-App</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label">Tipo de Evento</label>
                                <select asp-for="TipoEvento" class="form-input w-full">
                                    <option value="ProdutoVencendo">Produto Vencendo</option>
                                    <option value="ProdutoVencido">Produto Vencido</option>
                                    <option value="AssinaturaExpirando">Assinatura Expirando</option>
                                    <option value="ResetSenha">Reset de Senha</option>
                                    <option value="AlertaEstoqueCritico">Alerta Estoque</option>
                                    <option value="BroadcastSuperAdmin">Broadcast</option>
                                </select>
                            </div>
                        </div>
                    </div>
                }

                <div class="card p-4 space-y-4">
                    <h2 class="text-white font-semibold">Conteúdo</h2>
                    @if (Model.Id.HasValue)
                    {
                        <div class="flex flex-wrap gap-4 text-xs text-slate-400 pb-3 border-b border-slate-700">
                            <span><span class="text-slate-500">Código</span> <code class="text-amber-400 ml-1">@Model.Codigo</code></span>
                            <span><span class="text-slate-500">Canal</span> <span class="text-white ml-1">@Model.Canal</span></span>
                            <span><span class="text-slate-500">Evento</span> <span class="text-white ml-1">@Model.TipoEvento</span></span>
                        </div>
                    }
                    <div>
                        <label class="form-label">Assunto</label>
                        <input asp-for="AssuntoTemplate" class="form-input w-full" id="campo-assunto"
                               placeholder="{{ nomeProduto }} vence em {{ diasRestantes }} dias" />
                        <p class="text-slate-500 text-xs mt-1">Use <code class="text-amber-400">{{ variavel }}</code> para variáveis Scriban</p>
                    </div>
                    <div>
                        <label class="form-label">Corpo (HTML)</label>
                        <textarea asp-for="CorpoTemplate" class="form-input w-full font-mono text-xs" id="campo-corpo"
                                  rows="12" placeholder="<p>Olá! O produto <strong>{{ nomeProduto }}</strong> vence em {{ diasRestantes }} dias.</p>"></textarea>
                    </div>

                    @if (Model.VariaveisDisponiveis.Count > 0)
                    {
                        <div>
                            <label class="form-label">Variáveis disponíveis para @Model.TipoEvento</label>
                            <p class="text-slate-500 text-xs mb-2">Clique para inserir no campo focado (assunto ou corpo).</p>
                            <div class="flex flex-wrap gap-2">
                                @foreach (var v in Model.VariaveisDisponiveis)
                                {
                                    <button type="button"
                                            class="px-2 py-1 rounded bg-slate-800 hover:bg-amber-900/40 border border-slate-700 hover:border-amber-500 text-amber-400 font-mono text-xs transition-colors"
                                            title="@v.Tipo — @v.Descricao @(string.IsNullOrEmpty(v.Exemplo) ? "" : $"(ex: {v.Exemplo})")"
                                            onclick="inserirVariavel('@v.Nome')">{{ @v.Nome }}</button>
                                }
                            </div>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(Model.TipoEvento))
                    {
                        <p class="text-slate-500 text-xs">Nenhuma variável catalogada para <code class="text-amber-400">@Model.TipoEvento</code>. Você pode usar qualquer nome Scriban — verifique no preview.</p>
                    }
                </div>

                <div class="flex gap-3">
                    <button type="submit" class="btn-primary px-6 py-2">Salvar</button>
                    @if (Model.Id.HasValue)
                    {
                        <button type="submit" asp-page-handler="Preview" class="btn-secondary px-6 py-2">Preview</button>
                    }
                    <a href="/Notificacoes/Templates" class="btn-ghost px-6 py-2">Cancelar</a>
                </div>
            </form>
        </div>

        <script>
            let _campoFocado = null;
            document.addEventListener('focusin', (e) => {
                if (e.target.id === 'campo-assunto' || e.target.id === 'campo-corpo') {
                    _campoFocado = e.target;
                }
            });
            function inserirVariavel(nome) {
                const alvo = _campoFocado || document.getElementById('campo-corpo');
                if (!alvo) return;
                const texto = '{{ ' + nome + ' }}';
                const inicio = alvo.selectionStart ?? alvo.value.length;
                const fim = alvo.selectionEnd ?? alvo.value.length;
                alvo.value = alvo.value.slice(0, inicio) + texto + alvo.value.slice(fim);
                alvo.focus();
                const pos = inicio + texto.length;
                alvo.setSelectionRange(pos, pos);
                alvo.dispatchEvent(new Event('input', { bubbles: true }));
            }
        </script>

        @if (Model.PreviewResult.HasValue)
        {
            <div class="space-y-4">
                <h2 class="text-white font-semibold">Preview</h2>
                <div class="card p-4">
                    <p class="text-slate-400 text-xs mb-1">ASSUNTO</p>
                    <p class="text-white font-medium">
                        @(Model.PreviewResult.Value.TryGetProperty("assuntoRenderizado", out var a) ? a.GetString() : "")
                    </p>
                </div>
                <div class="card p-4">
                    <p class="text-slate-400 text-xs mb-2">CORPO</p>
                    @* sandbox sem nenhuma flag bloqueia scripts/forms/popups dentro do iframe.
                       Se um template HTML contiver <script>, ele será renderizado mas inerte —
                       evita execução acidental de JS injetado em variáveis. *@
                    <iframe class="w-full h-80 bg-white rounded"
                            sandbox=""
                            title="Preview do corpo do template"
                            srcdoc="@(Model.PreviewResult.Value.TryGetProperty("corpoRenderizado", out var b) ? b.GetString() ?? "" : "")">
                    </iframe>
                </div>
            </div>
        }
    </div>
</div>
