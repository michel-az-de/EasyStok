@page
@model EasyStock.Admin.Pages.Dispositivos.IndexModel
@{
    ViewData["Title"] = "Dispositivos";
}

<div x-data="dispositivosPage()" x-init="init()" style="display:flex; flex-direction:column; gap:20px;">

    <div style="display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;">
        <div>
            <es-breadcrumb>
                <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
                <es-breadcrumb-item>Dispositivos</es-breadcrumb-item>
            </es-breadcrumb>
            <h2 class="admin-page-title">Dispositivos</h2>
            <p style="margin:4px 0 0; color:var(--text-muted); font-size:13px;">PWAs pareados, saúde, comandos remotos e atualização OTA.</p>
        </div>
        <div style="display:flex; align-items:center; gap:8px;">
            <span style="font-size:11px; color:var(--text-muted);">Bundle:</span>
            <code style="font-family:var(--font-mono); font-size:11px; padding:4px 8px; border-radius:var(--r-sm); background:var(--surface-sunken); color:var(--text-primary);"
                  x-text="serverPwaVersion || '…'"></code>
        </div>
    </div>

    <template x-if="!empresaId">
        <es-card>
            <es-empty-state icon="building-2"
                            title="Selecione uma empresa"
                            description="Para listar dispositivos, abra o detalhe de um cliente em /Tenants ou informe ?empresaId=<guid> na URL.">
                <es-button variant="primary" href="/Tenants" icon="building-2">Ir para clientes</es-button>
            </es-empty-state>
        </es-card>
    </template>

    <template x-if="empresaId">
        <div style="display:flex; flex-direction:column; gap:16px;">

            <!-- Toolbar -->
            <es-card padding="md">
                <div style="display:flex; flex-wrap:wrap; align-items:center; gap:12px;">
                    <div style="flex:1; min-width:200px;">
                        <div style="font:600 10px/1 var(--font-mono); text-transform:uppercase; letter-spacing:0.10em; color:var(--text-muted);">Empresa</div>
                        <code style="font-size:12px; color:var(--text-primary); font-family:var(--font-mono); display:block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" x-text="empresaId"></code>
                    </div>
                    <es-button variant="primary" icon="plus" x-on:click="abrirNovoCodigo()">Novo código de pareamento</es-button>
                    <button type="button" class="btn btn-secondary btn-md" :disabled="loading || !devices.length" @@click="broadcastPwaUpdate()">
                        <es-icon name="download" size="16" />
                        Forçar atualização (todos)
                    </button>
                    <button type="button" class="btn btn-ghost btn-sm" :disabled="loading" @@click="recarregar()" aria-label="Atualizar">
                        <span x-show="!loading"><es-icon name="arrow-up-down" size="16" /></span>
                        <span x-show="loading">…</span>
                    </button>
                </div>
            </es-card>

            <!-- Lista de devices -->
            <es-card padding="none">
                <div style="display:grid; grid-template-columns:3fr 2fr 2fr 2fr 3fr; gap:8px; padding:12px 16px; font:600 10px/1 var(--font-mono); text-transform:uppercase; letter-spacing:0.12em; color:var(--text-muted); border-bottom:1px solid var(--border-soft);">
                    <div>Device</div>
                    <div>Saúde</div>
                    <div>Última atividade</div>
                    <div>Loja</div>
                    <div style="text-align:right;">Ações</div>
                </div>

                <template x-if="!devices.length && !loading">
                    <div style="padding:40px 16px;">
                        <es-empty-state icon="smartphone" title="Nenhum dispositivo pareado" description="Gere um código de pareamento para conectar o primeiro PWA." />
                    </div>
                </template>

                <template x-for="d in devices" :key="d.id">
                    <div style="display:grid; grid-template-columns:3fr 2fr 2fr 2fr 3fr; gap:8px; padding:12px 16px; align-items:center; border-bottom:1px solid var(--border-soft);">
                        <div>
                            <div style="font-size:13px; font-weight:500; color:var(--text-primary); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" x-text="d.label || '(sem rótulo)'"></div>
                            <div style="font-size:11px; color:var(--text-muted); font-family:var(--font-mono); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" x-text="d.id"></div>
                        </div>
                        <div>
                            <span class="badge" :class="badgeClass(d.health?.status)">
                                <span class="dot"></span>
                                <span x-text="d.health?.statusLabel || statusFor(d)"></span>
                            </span>
                        </div>
                        <div style="font-size:12px; color:var(--text-muted);" x-text="formatLastSeen(d.lastSeenAt)"></div>
                        <div style="font-size:11px; color:var(--text-muted); font-family:var(--font-mono); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" x-text="(d.lojaId || '').slice(0,8)"></div>
                        <div style="display:flex; align-items:center; justify-content:flex-end; gap:4px; flex-wrap:wrap;">
                            <button class="btn btn-ghost btn-xs" :disabled="d.revoked" @@click="cmd(d.id, 'pwa_update')">Atualizar</button>
                            <button class="btn btn-ghost btn-xs" :disabled="d.revoked" @@click="cmd(d.id, 'reload')">Reload</button>
                            <button class="btn btn-ghost btn-xs" :disabled="d.revoked" @@click="cmd(d.id, 'flush_now')">Flush</button>
                            <button class="btn btn-ghost btn-xs" :disabled="d.revoked" @@click="enviarMsg(d.id)">Msg</button>
                            <button class="btn btn-danger btn-xs" :disabled="d.revoked" @@click="revogar(d.id)">Revogar</button>
                        </div>
                    </div>
                </template>
            </es-card>

            <p x-show="erro" x-cloak style="color:var(--crit-600); font-size:13px;" x-text="erro"></p>
        </div>
    </template>

    <!-- Modal: gerar pair-code -->
    <es-modal id="dispositivos-pair" title="Novo código de pareamento" description="Mostre o código pro operador digitar no PWA. Válido por 10 min." size="sm" persistent="true" show-close="false">
        <template x-if="!modalCodigo.codigo">
            <div style="display:flex; flex-direction:column; gap:14px;">
                <es-input field-class="" name="lojaId" label="Loja (UUID)" placeholder="00000000-0000-..." required="true" />
                <input type="hidden" id="dispositivos-pair-loja" />
                <es-input name="label" label="Rótulo" label-optional="true" placeholder="Ex.: Tablet Caixa 1" />
                <es-input name="defaultOperatorName" label="Operador padrão" label-optional="true" placeholder="Ex.: Maria" />

                <div x-init="
                    $watch('modalCodigo.lojaId', () => {});
                    setTimeout(() => {
                        const root = $el.closest('.es-modal-panel');
                        const lojaInput = root.querySelector('input[name=lojaId]');
                        const labelInput = root.querySelector('input[name=label]');
                        const opInput = root.querySelector('input[name=defaultOperatorName]');
                        if (lojaInput) lojaInput.addEventListener('input', e => modalCodigo.lojaId = e.target.value);
                        if (labelInput) labelInput.addEventListener('input', e => modalCodigo.label = e.target.value);
                        if (opInput) opInput.addEventListener('input', e => modalCodigo.defaultOperatorName = e.target.value);
                    }, 30);
                "></div>

                <div style="display:flex; justify-content:flex-end; gap:8px;">
                    <es-button variant="ghost" x-on:click="modalCodigo.open = false; close()">Cancelar</es-button>
                    <button type="button" class="btn btn-primary btn-md" :disabled="modalCodigo.loading" @@click="gerarCodigo()">
                        <span x-show="!modalCodigo.loading">Gerar código</span>
                        <span x-show="modalCodigo.loading">…</span>
                    </button>
                </div>
                <p x-show="modalCodigo.erro" x-cloak style="color:var(--crit-600); font-size:13px;" x-text="modalCodigo.erro"></p>
            </div>
        </template>

        <template x-if="modalCodigo.codigo">
            <div style="text-align:center; display:flex; flex-direction:column; gap:12px;">
                <div style="font:600 10px/1 var(--font-mono); text-transform:uppercase; letter-spacing:0.12em; color:var(--text-muted);">Código</div>
                <div style="font-family:var(--font-mono); font-weight:700; font-size:48px; color:var(--orange-500); letter-spacing:0.16em;" x-text="modalCodigo.codigo"></div>
                <div style="font-size:12px; color:var(--text-muted);" x-text="'expira em ' + modalCodigo.expiraEm"></div>
                <es-button variant="primary" icon="check" x-on:click="modalCodigo.open = false; close(); recarregar();">Pronto</es-button>
            </div>
        </template>
    </es-modal>
</div>

@section Scripts {
<script>
function dispositivosPage() {
    return {
        empresaId: '@(Model.EmpresaId?.ToString() ?? "")',
        lojaId: '@(Model.LojaId?.ToString() ?? "")',
        devices: [],
        healthByDevice: {},
        loading: false,
        erro: '',
        serverPwaVersion: '',
        modalCodigo: {
            open: false, loading: false, codigo: '', expiraEm: '', erro: '',
            lojaId: '', label: '', defaultOperatorName: ''
        },

        async init() {
            this.fetchVersion();
            if (this.empresaId) {
                await this.recarregar();
                setInterval(() => { this.recarregar(); }, 15000);
            }
        },

        async fetchVersion() {
            try {
                const r = await fetch('/api-proxy/mobile/version', { credentials: 'same-origin' });
                if (!r.ok) return;
                const d = await r.json();
                this.serverPwaVersion = d?.ota?.pwaCacheVersion || d?.Ota?.PwaCacheVersion || '';
            } catch {}
        },

        async recarregar() {
            if (!this.empresaId) return;
            this.loading = true; this.erro = '';
            try {
                const r1 = await fetch('/api-proxy/mobile/devices?empresaId=' + this.empresaId, { credentials: 'same-origin' });
                if (r1.status === 401) { window.location.href = '/Auth/Login'; return; }
                if (!r1.ok) throw new Error('devices: HTTP ' + r1.status);
                const list = await r1.json();
                this.devices = Array.isArray(list) ? list : [];

                const r2 = await fetch('/api-proxy/mobile/operacao/devices-health?empresaId=' + this.empresaId, { credentials: 'same-origin' });
                if (r2.ok) {
                    const health = await r2.json();
                    this.healthByDevice = {};
                    if (Array.isArray(health)) health.forEach(h => { this.healthByDevice[h.id] = h; });
                    this.devices.forEach(d => { d.health = this.healthByDevice[d.id]; });
                }
            } catch (e) {
                this.erro = 'Falha ao carregar: ' + (e.message || e);
            } finally {
                this.loading = false;
            }
        },

        statusFor(d) {
            if (d.revoked) return 'revogado';
            if (d.pendingPair) return 'aguardando';
            if (!d.lastSeenAt) return 'nunca conectou';
            return 'ativo';
        },

        badgeClass(status) {
            return {
                'badge-ok': status === 'ok',
                'badge-warn': status === 'warn',
                'badge-crit': status === 'err',
                'badge-neutral': !status
            };
        },

        formatLastSeen(iso) {
            if (!iso) return '—';
            try {
                const d = new Date(iso);
                const min = Math.floor((Date.now() - d.getTime()) / 60000);
                if (min < 1) return 'agora';
                if (min < 60) return min + ' min atrás';
                if (min < 60 * 24) return Math.floor(min / 60) + ' h atrás';
                return Math.floor(min / (60 * 24)) + ' d atrás';
            } catch { return iso; }
        },

        async cmd(id, type, payload) {
            if (!confirm('Enviar "' + type + '" pra ' + (id || '').slice(0, 12) + '...?')) return;
            try {
                const body = { commandType: type, payloadJson: payload ? JSON.stringify(payload) : null };
                const r = await fetch('/api-proxy/mobile/devices/' + encodeURIComponent(id) + '/commands', {
                    method: 'POST', credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                if (!r.ok) throw new Error('HTTP ' + r.status);
                this.erro = '';
                if (window.toast) window.toast.success('Comando enfileirado.');
            } catch (e) {
                this.erro = 'Falha: ' + (e.message || e);
            }
        },

        async enviarMsg(id) {
            const text = window.prompt('Mensagem (até 200 chars):');
            if (!text) return;
            await this.cmd(id, 'message', { text: text.slice(0, 200) });
        },

        async revogar(id) {
            if (!confirm('Revogar este device? O PWA correspondente vai parar de sincronizar.')) return;
            try {
                const r = await fetch('/api-proxy/mobile/devices/' + encodeURIComponent(id), {
                    method: 'DELETE', credentials: 'same-origin'
                });
                if (!r.ok && r.status !== 204) throw new Error('HTTP ' + r.status);
                await this.recarregar();
                if (window.toast) window.toast.warn('Device revogado.');
            } catch (e) {
                this.erro = 'Falha: ' + (e.message || e);
            }
        },

        async broadcastPwaUpdate() {
            if (!confirm('Forçar atualização do PWA em TODOS os dispositivos desta empresa?')) return;
            try {
                const body = { empresaId: this.empresaId, lojaId: this.lojaId || null, commandType: 'pwa_update' };
                const r = await fetch('/api-proxy/mobile/devices/broadcast', {
                    method: 'POST', credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                if (!r.ok) throw new Error('HTTP ' + r.status);
                const data = await r.json();
                if (window.toast) window.toast.success('Atualização enfileirada pra ' + (data.enqueued || 0) + ' device(s).');
            } catch (e) {
                this.erro = 'Falha: ' + (e.message || e);
            }
        },

        abrirNovoCodigo() {
            this.modalCodigo = {
                open: true, loading: false, codigo: '', expiraEm: '', erro: '',
                lojaId: this.lojaId || '', label: '', defaultOperatorName: ''
            };
            window.dispatchEvent(new CustomEvent('open-modal-dispositivos-pair'));
        },

        async gerarCodigo() {
            this.modalCodigo.loading = true; this.modalCodigo.erro = '';
            try {
                const body = {
                    empresaId: this.empresaId,
                    lojaId: this.modalCodigo.lojaId,
                    label: this.modalCodigo.label || null,
                    defaultOperatorName: this.modalCodigo.defaultOperatorName || null
                };
                const r = await fetch('/api-proxy/mobile/devices/pair-codes', {
                    method: 'POST', credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                if (!r.ok) {
                    const txt = await r.text();
                    throw new Error('HTTP ' + r.status + ' ' + txt.slice(0, 120));
                }
                const data = await r.json();
                this.modalCodigo.codigo = data.pairingCode || data.PairingCode;
                const exp = data.expiresAt || data.ExpiresAt;
                if (exp) {
                    const d = new Date(exp);
                    this.modalCodigo.expiraEm = d.toLocaleTimeString();
                }
            } catch (e) {
                this.modalCodigo.erro = 'Falha: ' + (e.message || e);
            } finally {
                this.modalCodigo.loading = false;
            }
        }
    };
}
</script>
}
