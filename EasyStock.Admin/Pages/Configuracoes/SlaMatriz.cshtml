@page
@model EasyStock.Admin.Pages.Configuracoes.SlaMatrizModel
@using System.Text.Json
@{
    ViewData["Title"] = "Matriz SLA";

    var prioridadesOrdenadas = new[] { "Critica", "Alta", "Normal", "Baixa" };
    var existentesGlobais = Model.Itens
        .Where(i => (!i.TryGetProperty("empresaId", out var ep) || ep.ValueKind == JsonValueKind.Null)
                 && (!i.TryGetProperty("planoId", out var pp) || pp.ValueKind == JsonValueKind.Null))
        .ToDictionary(i => i.GetProperty("prioridade").GetString() ?? "", i => i);

    var overrides = Model.Itens.Where(i =>
        (i.TryGetProperty("empresaId", out var ep2) && ep2.ValueKind != JsonValueKind.Null)
        || (i.TryGetProperty("planoId", out var pp2) && pp2.ValueKind != JsonValueKind.Null)).ToList();
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item href="/Configuracoes">Configurações</es-breadcrumb-item>
            <es-breadcrumb-item>Matriz SLA</es-breadcrumb-item>
        </es-breadcrumb>
        <h2 style="margin:6px 0 0; font-size:24px; font-weight:700; color:var(--text-primary); letter-spacing:-0.01em;">Matriz de SLA</h2>
        <p style="margin:4px 0 0; color:var(--text-muted); font-size:13px;">Tempos default de resposta e resolução por prioridade</p>
    </div>
    <es-button variant="ghost" href="/Tickets" icon="arrow-left">Voltar para tickets</es-button>
</div>

<es-card title="SLAs globais" description="Aplicado a todos os tenants/planos quando não há override específico">
    <form method="post" style="display:flex; flex-direction:column; gap:14px;">
        @Html.AntiForgeryToken()

        <div style="margin:-20px;">
            <table class="es-data-table">
                <thead>
                    <tr>
                        <th scope="col">Escopo</th>
                        <th scope="col">Prioridade</th>
                        <th scope="col" class="es-data-table-td-numeric">Resposta (min)</th>
                        <th scope="col" class="es-data-table-td-numeric">Resolução (min)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var prio in prioridadesOrdenadas)
                    {
                        var minResp = existentesGlobais.TryGetValue(prio, out var ex) && ex.TryGetProperty("minutosResposta", out var mr) ? mr.GetInt32() : 0;
                        var minResol = existentesGlobais.TryGetValue(prio, out var ex2) && ex2.TryGetProperty("minutosResolucao", out var mres) ? mres.GetInt32() : 0;
                        var prioVariant = prio == "Critica" ? "crit" : prio == "Alta" ? "warn" : "neutral";
                        <tr>
                            <td data-label="Escopo" style="color:var(--text-muted); font-size:13px;">Global (default)</td>
                            <td data-label="Prioridade">
                                <input type="hidden" name="Prioridades" value="@prio" />
                                <es-badge variant="@prioVariant">@prio</es-badge>
                            </td>
                            <td data-label="Resposta (min)" class="es-data-table-td-numeric" style="display:flex; gap:8px; align-items:center; justify-content:flex-end;">
                                <input type="number" name="MinutosResposta" value="@minResp" min="1" class="es-form-input" style="max-width:120px;" />
                                <span style="color:var(--text-muted); font-size:11px;">(@(minResp / 60)h @(minResp % 60)m)</span>
                            </td>
                            <td data-label="Resolução (min)" class="es-data-table-td-numeric" style="display:flex; gap:8px; align-items:center; justify-content:flex-end;">
                                <input type="number" name="MinutosResolucao" value="@minResol" min="1" class="es-form-input" style="max-width:120px;" />
                                <span style="color:var(--text-muted); font-size:11px;">(@(minResol / 60)h)</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div style="display:flex; justify-content:flex-end;">
            <es-button type="submit" variant="primary" icon="check">Salvar matriz</es-button>
        </div>
    </form>
</es-card>

<es-card title="Overrides por plano ou empresa" description="Personalizações que substituem o default global" card-class="mt-4">
    @if (!overrides.Any())
    {
        <es-empty-state icon="shield" title="Nenhum override" description="Tudo segue o default global. Crie overrides via API quando necessário." />
    }
    else
    {
        <div style="margin:-20px;">
            <table class="es-data-table">
                <thead>
                    <tr>
                        <th scope="col">EmpresaId</th>
                        <th scope="col">PlanoId</th>
                        <th scope="col">Prioridade</th>
                        <th scope="col" class="es-data-table-td-numeric">Resposta</th>
                        <th scope="col" class="es-data-table-td-numeric">Resolução</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in overrides)
                    {
                        var emp = o.TryGetProperty("empresaId", out var ep2) && ep2.ValueKind != JsonValueKind.Null ? ep2.GetString() : "—";
                        var pl = o.TryGetProperty("planoId", out var pp2) && pp2.ValueKind != JsonValueKind.Null ? pp2.GetString() : "—";
                        var pr = o.TryGetProperty("prioridade", out var prp) ? prp.GetString() : "";
                        var mr = o.TryGetProperty("minutosResposta", out var mrp) ? mrp.GetInt32() : 0;
                        var mres = o.TryGetProperty("minutosResolucao", out var mrep) ? mrep.GetInt32() : 0;
                        <tr>
                            <td data-label="EmpresaId" style="font-family:var(--font-mono); font-size:11px; color:var(--text-muted);">@emp</td>
                            <td data-label="PlanoId" style="font-family:var(--font-mono); font-size:11px; color:var(--text-muted);">@pl</td>
                            <td data-label="Prioridade" style="color:var(--text-secondary);">@pr</td>
                            <td data-label="Resposta" class="es-data-table-td-numeric" style="color:var(--text-secondary);">@mr min</td>
                            <td data-label="Resolução" class="es-data-table-td-numeric" style="color:var(--text-secondary);">@mres min</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</es-card>
