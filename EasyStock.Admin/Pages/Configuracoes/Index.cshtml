@page
@model EasyStock.Admin.Pages.Configuracoes.IndexModel
@{
    ViewData["Title"] = "Configurações do Sistema";
    var manutencaoAtiva = Model.Get("manutencao_ativa") == "true";
    var avisoGlobal = Model.Get("aviso_global");
    var avisoCor = Model.Get("aviso_cor", "gold");
    var diasTrial = Model.Get("dias_trial_padrao", "30");
    var emailSuporte = Model.Get("email_suporte", "suporte@easystock.com.br");
    var versaoPwa = Model.Get("versao_minima_pwa", "1.0.0");
}

<div style="margin-bottom:20px;">
    <es-breadcrumb>
        <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
        <es-breadcrumb-item>Configurações</es-breadcrumb-item>
    </es-breadcrumb>
    <h2 style="margin:6px 0 0; font-size:24px; font-weight:700; color:var(--text-primary); letter-spacing:-0.01em;">Configurações do sistema</h2>
    <p style="margin:4px 0 0; color:var(--text-muted); font-size:13px;">Disponibilidade, onboarding e parâmetros globais do produto</p>
</div>

<es-tabs default-tab="disponibilidade">

    <es-tab key="disponibilidade" label="Disponibilidade" icon="alert-triangle">
        <es-card title="Disponibilidade" description="Modo manutenção e banner de aviso global">
            <form method="post" asp-page-handler="Disponibilidade" style="display:flex; flex-direction:column; gap:18px;">
                @Html.AntiForgeryToken()

                <div style="display:flex; align-items:center; justify-content:space-between; gap:16px; padding:14px; background:var(--surface-sunken); border-radius:var(--r-md);">
                    <div>
                        <div style="font-weight:600; color:var(--text-primary);">Modo manutenção</div>
                        <div style="font-size:12px; color:var(--text-muted); margin-top:2px;">Bloqueia login de todos os tenants</div>
                    </div>
                    <label class="es-switch" style="margin:0;">
                        @* Pattern checkbox+hidden — preserva semântica de POST com false explícito quando off. *@
                        <input type="checkbox" name="manutencao_ativa" value="true" @(manutencaoAtiva ? "checked" : "")
                               role="switch"
                               onchange="var h=this.form.querySelector('input[type=hidden][name=manutencao_ativa]'); if(h){ h.disabled = this.checked; }" />
                        <input type="hidden" name="manutencao_ativa" value="false" @(manutencaoAtiva ? "disabled" : "") />
                    </label>
                </div>

                <es-textarea name="aviso_global" label="Aviso global" label-optional="true" rows="2"
                             placeholder="Texto do banner exibido no app..."
                             helper="Vazio = banner oculto.">@avisoGlobal</es-textarea>

                <div>
                    <label class="es-form-label">Cor do aviso</label>
                    <div style="display:flex; gap:14px; padding-top:6px; flex-wrap:wrap;">
                        @foreach (var (cor, label, hex) in new[] { ("gold", "Dourado", "#f0b84a"), ("red", "Vermelho", "#ef4444"), ("basil", "Verde", "#4fbf9f") })
                        {
                            <label style="display:flex; align-items:center; gap:6px; cursor:pointer;">
                                <input type="radio" name="aviso_cor" value="@cor" @(avisoCor == cor ? "checked" : "")
                                       style="appearance:auto; accent-color:@hex; cursor:pointer;" />
                                <span style="display:inline-block; width:16px; height:16px; border-radius:999px; background:@hex;"></span>
                                <span style="font-size:13px; color:var(--text-secondary);">@label</span>
                            </label>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(avisoGlobal))
                {
                    <div style="border-radius:var(--r-md); padding:10px 14px; font-size:13px; font-weight:500;
                                background:@(avisoCor == "red" ? "rgba(239,68,68,.15)" : avisoCor == "basil" ? "rgba(79,191,159,.15)" : "rgba(240,184,74,.15)");
                                color:@(avisoCor == "red" ? "#ef4444" : avisoCor == "basil" ? "#4fbf9f" : "#f0b84a");
                                border:1px solid @(avisoCor == "red" ? "rgba(239,68,68,.3)" : avisoCor == "basil" ? "rgba(79,191,159,.3)" : "rgba(240,184,74,.3)");">
                        Preview: @avisoGlobal
                    </div>
                }

                <div style="display:flex; justify-content:flex-end;">
                    <es-button type="submit" variant="primary" icon="check">Salvar disponibilidade</es-button>
                </div>
            </form>
        </es-card>
    </es-tab>

    <es-tab key="onboarding" label="Onboarding" icon="user">
        <es-card title="Onboarding" description="Trial padrão e contato de suporte">
            <form method="post" asp-page-handler="Onboarding" style="display:flex; flex-direction:column; gap:14px;">
                @Html.AntiForgeryToken()
                <es-input name="dias_trial_padrao" type="number" min="1" max="365" value="@diasTrial"
                          label="Dias de trial padrão"
                          helper="Dias concedidos ao criar nova assinatura trial." />
                <es-input name="email_suporte" type="email" value="@emailSuporte"
                          label="E-mail de suporte" />
                <div style="display:flex; justify-content:flex-end;">
                    <es-button type="submit" variant="primary" icon="check">Salvar onboarding</es-button>
                </div>
            </form>
        </es-card>
    </es-tab>

    <es-tab key="pwa" label="PWA Mobile" icon="smartphone">
        <es-card title="PWA Mobile" description="Versão mínima exigida do PWA">
            <form method="post" asp-page-handler="Pwa" style="display:flex; flex-direction:column; gap:14px;">
                @Html.AntiForgeryToken()
                <es-input name="versao_minima_pwa" value="@versaoPwa" label="Versão mínima"
                          placeholder="1.0.0"
                          helper="PWA com versão inferior será forçado a atualizar."
                          field-class="" />
                <div style="display:flex; justify-content:flex-end;">
                    <es-button type="submit" variant="primary" icon="check">Salvar PWA</es-button>
                </div>
            </form>
        </es-card>
    </es-tab>

    <es-tab key="links" label="Links rápidos" icon="external-link">
        <es-card title="Outras configurações">
            <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:12px;">
                <es-button variant="secondary" href="/Configuracoes/SlaMatriz" icon="shield" block="true">Matriz SLA</es-button>
                <es-button variant="secondary" href="/Notificacoes/Canais" icon="bell" block="true">Canais de notificação</es-button>
                <es-button variant="secondary" href="/Diagnostico" icon="stethoscope" block="true">Diagnóstico do sistema</es-button>
                <es-button variant="secondary" href="/AuditLogs" icon="search" block="true">Audit logs</es-button>
            </div>
        </es-card>
    </es-tab>

</es-tabs>
