@page
@model EasyStock.Admin.Pages.Configuracoes.IndexModel
@{
    ViewData["Title"] = "Configurações do Sistema";
    var sucesso = TempData["Sucesso"] as string;
    var erro = TempData["Erro"] as string;
    var manutencaoAtiva = Model.Get("manutencao_ativa") == "true";
    var avisoGlobal = Model.Get("aviso_global");
    var avisoCor = Model.Get("aviso_cor", "gold");
    var diasTrial = Model.Get("dias_trial_padrao", "30");
    var emailSuporte = Model.Get("email_suporte", "suporte@easystock.com.br");
    var versaoPwa = Model.Get("versao_minima_pwa", "1.0.0");
}

@if (!string.IsNullOrEmpty(sucesso))
{
    <div class="bg-green-500/10 border border-green-500/30 text-green-400 rounded-lg px-4 py-3 text-sm mb-4">@sucesso</div>
}
@if (!string.IsNullOrEmpty(erro))
{
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-4 py-3 text-sm mb-4">@erro</div>
}
@if (Model.Erro != null)
{
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-4 py-3 text-sm mb-4">@Model.Erro</div>
}

<div class="grid grid-cols-1 gap-6 max-w-3xl">

    <!-- Disponibilidade -->
    <div class="card p-6">
        <h2 class="text-base font-semibold text-es-ink mb-4 flex items-center gap-2">
            <span>🚦</span> Disponibilidade
        </h2>
        <form method="post" asp-page-handler="Disponibilidade" class="space-y-5">
            @Html.AntiForgeryToken()

            <div class="flex items-center justify-between">
                <div>
                    <div class="text-sm font-medium text-es-ink">Modo Manutenção</div>
                    <div class="text-xs text-es-ink-mute">Bloqueia login de todos os tenants</div>
                </div>
                @* Pattern checkbox+hidden: o hidden value="false" só é enviado quando o checkbox NÃO está marcado.
                   O JS desabilita o hidden quando o checkbox vira true, garantindo apenas UM valor de manutencao_ativa
                   no POST (caso contrário ASP.NET Core recebe array e o handler que espera string falha). *@
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" name="manutencao_ativa" value="true" @(manutencaoAtiva ? "checked" : "")
                           class="sr-only peer"
                           onchange="var h=this.form.querySelector('input[type=hidden][name=manutencao_ativa]'); if(h){ h.disabled = this.checked; }" />
                    <input type="hidden" name="manutencao_ativa" value="false" @(manutencaoAtiva ? "disabled" : "") />
                    <div class="w-11 h-6 bg-es-surface-2 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-red-500 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
                </label>
            </div>

            <div>
                <label class="block text-sm text-es-ink-dim mb-1">Aviso Global <span class="text-es-ink-mute">(vazio = oculto)</span></label>
                <textarea name="aviso_global" rows="2" class="form-input w-full resize-none" placeholder="Texto do banner exibido no app...">@avisoGlobal</textarea>
            </div>

            <div>
                <label class="block text-sm text-es-ink-dim mb-1">Cor do Aviso</label>
                <div class="flex gap-3">
                    @foreach (var (cor, label, hex) in new[] { ("gold", "Dourado", "#f0b84a"), ("red", "Vermelho", "#ef4444"), ("basil", "Verde", "#4fbf9f") })
                    {
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="aviso_cor" value="@cor" @(avisoCor == cor ? "checked" : "") class="hidden peer" />
                            <span class="w-5 h-5 rounded-full border-2 border-es-surface-2 peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-offset-es-card transition-all"
                                  style="background:@hex; ring-color:@hex"></span>
                            <span class="text-sm text-es-ink-dim">@label</span>
                        </label>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(avisoGlobal))
            {
                <div class="rounded-lg px-4 py-2 text-sm font-medium"
                     style="background:@(avisoCor == "red" ? "rgba(239,68,68,0.15)" : avisoCor == "basil" ? "rgba(79,191,159,0.15)" : "rgba(240,184,74,0.15)");
                            color:@(avisoCor == "red" ? "#ef4444" : avisoCor == "basil" ? "#4fbf9f" : "#f0b84a");
                            border:1px solid @(avisoCor == "red" ? "rgba(239,68,68,0.3)" : avisoCor == "basil" ? "rgba(79,191,159,0.3)" : "rgba(240,184,74,0.3)")">
                    Preview: @avisoGlobal
                </div>
            }

            <button type="submit" class="btn-primary">Salvar Disponibilidade</button>
        </form>
    </div>

    <!-- Onboarding -->
    <div class="card p-6">
        <h2 class="text-base font-semibold text-es-ink mb-4 flex items-center gap-2">
            <span>🚀</span> Onboarding
        </h2>
        <form method="post" asp-page-handler="Onboarding" class="space-y-4">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm text-es-ink-dim mb-1">Dias de Trial Padrão</label>
                <input type="number" name="dias_trial_padrao" min="1" max="365" value="@diasTrial" class="form-input w-40" />
                <div class="text-xs text-es-ink-mute mt-1">Dias concedidos ao criar nova assinatura trial</div>
            </div>
            <div>
                <label class="block text-sm text-es-ink-dim mb-1">E-mail de Suporte</label>
                <input type="email" name="email_suporte" value="@emailSuporte" class="form-input w-full max-w-sm" />
            </div>
            <button type="submit" class="btn-primary">Salvar Onboarding</button>
        </form>
    </div>

    <!-- PWA -->
    <div class="card p-6">
        <h2 class="text-base font-semibold text-es-ink mb-4 flex items-center gap-2">
            <span>📱</span> PWA Mobile
        </h2>
        <form method="post" asp-page-handler="Pwa" class="space-y-4">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm text-es-ink-dim mb-1">Versão Mínima do PWA</label>
                <input type="text" name="versao_minima_pwa" value="@versaoPwa" class="form-input w-40" placeholder="1.0.0" />
                <div class="text-xs text-es-ink-mute mt-1">PWA com versão inferior será forçado a atualizar</div>
            </div>
            <button type="submit" class="btn-primary">Salvar PWA</button>
        </form>
    </div>

</div>
