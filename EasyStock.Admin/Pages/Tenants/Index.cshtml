@page
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@model EasyStock.Admin.Pages.Tenants.IndexModel
@{
    ViewData["Title"] = "Clientes";
    var orderBy = Request.Query["orderBy"].FirstOrDefault();
    var dir = Request.Query["dir"].FirstOrDefault();
}

@if (!string.IsNullOrEmpty(Model.NovaSenhaTemporaria))
{
    <div style="background:rgba(245,158,11,.10); border:1px solid rgba(245,158,11,.30); color:var(--warn-700); border-radius:var(--r-md); padding:12px 16px; font-size:13px; margin-bottom:16px;">
        <div style="font-weight:600; margin-bottom:4px;">
            Senha temporária do admin de <strong>@Model.NovoTenantNome</strong> — anote agora, não será reexibida:
        </div>
        <code style="font-family:var(--font-mono); font-size:14px; user-select:all;">@Model.NovaSenhaTemporaria</code>
        <div style="font-size:12px; color:var(--text-muted); margin-top:6px;">
            Enviada também por e-mail para <span style="font-family:var(--font-mono);">@Model.NovoTenantAdminEmail</span> (se o serviço de e-mail estiver disponível).
        </div>
    </div>
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item>Clientes</es-breadcrumb-item>
        </es-breadcrumb>
        <div style="margin-top:4px; color:var(--text-muted); font-size:13px;">
            <strong style="color:var(--text-primary);">@Model.Total</strong> resultado(s)
        </div>
    </div>
</div>

<es-card padding="md" card-class="mb-4" >
    <form method="get" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:12px; align-items:end;">
        <es-input name="search" label="Buscar" value="@Model.Search"
                  placeholder="Nome ou CNPJ..." prefix-icon="search"
                  field-class="md:col-span-2" />
        <es-select name="status" label="Status">
            <option value="">Todos os status</option>
            <option value="Ativa" selected="@(Model.Status == "Ativa")">Ativa</option>
            <option value="Suspensa" selected="@(Model.Status == "Suspensa")">Suspensa</option>
            <option value="Cancelada" selected="@(Model.Status == "Cancelada")">Cancelada</option>
        </es-select>
        <div style="display:flex; gap:8px;">
            <es-button type="submit" variant="primary" icon="filter">Filtrar</es-button>
            @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Status))
            {
                <es-button variant="ghost" href="/Tenants">Limpar</es-button>
            }
        </div>
    </form>
</es-card>

<es-filter-bar>
    @if (!string.IsNullOrEmpty(Model.Status))
    {
        <es-filter-chip label="Status" remove-param="status">@Model.Status</es-filter-chip>
    }
    @if (!string.IsNullOrEmpty(Model.Search))
    {
        <es-filter-chip label="Busca" remove-param="search">@Model.Search</es-filter-chip>
    }
</es-filter-bar>

<div x-data="{ confirmId: null, confirmAcao: null, confirmNome: '' }">
    <es-data-table sort-key="@orderBy" sort-dir="@dir" is-empty="@(!Model.Tenants.Any())">
        <es-data-table-column key="nome" label="Nome" sortable="true" />
        <es-data-table-column key="documento" label="Documento" />
        <es-data-table-column key="planoNome" label="Plano" />
        <es-data-table-column label="Status" />
        <es-data-table-column label="Usuários" align="right" />
        <es-data-table-column label="Lojas" align="right" />
        <es-data-table-column key="criadoEm" label="Criado em" align="right" sortable="true" />
        <es-data-table-column label="" actions="true" width="240px" />

        @foreach (var t in Model.Tenants)
        {
            var id = t.TryGetProperty("id", out var idP) ? idP.GetString() : "";
            var nome = t.TryGetProperty("nome", out var nP) ? nP.GetString() : "";
            var doc = t.TryGetProperty("documento", out var dP) ? dP.GetString() : "—";
            var plano = t.TryGetProperty("planoNome", out var plP) ? plP.GetString() : "—";
            var status = t.TryGetProperty("statusAssinatura", out var sP) ? sP.GetString() : "—";
            var usuarios = t.TryGetProperty("totalUsuarios", out var uP) ? uP.GetInt32() : 0;
            var lojas = t.TryGetProperty("totalLojas", out var lP) ? lP.GetInt32() : 0;
            var criado = t.TryGetProperty("criadoEm", out var cP) ? cP.GetString() : "";
            DateTime.TryParse(criado, out var criadoDt);
            var statusVariant = status?.ToLower() switch {
                "ativa" => "ok",
                "suspensa" => "warn",
                "cancelada" => "crit",
                _ => "neutral"
            };
            var initial = !string.IsNullOrEmpty(nome) ? nome.Substring(0, 1).ToUpper() : "?";

            <tr>
                <td data-label="Nome">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <span class="es-avatar es-avatar-sm" aria-hidden="true">@initial</span>
                        <a href="/Tenants/Detail/@id" style="color:var(--text-primary); font-weight:500; text-decoration:none;">@nome</a>
                    </div>
                </td>
                <td data-label="Documento" style="color:var(--text-muted); font-family:var(--font-mono); font-size:12px;">@(doc ?? "—")</td>
                <td data-label="Plano" style="color:var(--text-secondary); font-size:13px;">@(plano ?? "—")</td>
                <td data-label="Status">
                    <es-badge variant="@statusVariant" with-dot="true">@(status ?? "—")</es-badge>
                </td>
                <td data-label="Usuários" class="es-data-table-td-numeric" style="font-weight:500;">@usuarios</td>
                <td data-label="Lojas" class="es-data-table-td-numeric" style="font-weight:500;">@lojas</td>
                <td data-label="Criado em" class="es-data-table-td-numeric" style="color:var(--text-muted); font-size:12px;">@criadoDt.ToLocalTime().ToString("dd/MM/yy")</td>
                <td class="es-data-table-td-actions">
                    <div class="es-row-actions">
                        <es-button variant="ghost" size="xs" href="/Tenants/Detail/@id" icon="eye">Ver</es-button>
                        @if (status == "Ativa")
                        {
                            <es-button variant="ghost" size="xs" icon="alert-triangle"
                                       x-on:click="confirmId = '@id'; confirmAcao = 'suspender'; confirmNome = '@System.Text.Json.JsonEncodedText.Encode(nome ?? "")'; $dispatch('open-modal-tenant-confirm')">
                                Suspender
                            </es-button>
                        }
                        else if (status == "Suspensa")
                        {
                            <es-button variant="ghost" size="xs" icon="check"
                                       x-on:click="confirmId = '@id'; confirmAcao = 'reativar'; confirmNome = '@System.Text.Json.JsonEncodedText.Encode(nome ?? "")'; $dispatch('open-modal-tenant-confirm')">
                                Reativar
                            </es-button>
                        }
                        <form method="post" asp-page-handler="Impersonar" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@id" />
                            <es-button type="submit" variant="ghost" size="xs" icon="external-link" icon-only="true" aria-label="Impersonar @nome" />
                        </form>
                    </div>
                </td>
            </tr>
        }

        <es-data-table-empty>
            @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Status))
            {
                <es-empty-state icon="search"
                                title="Nenhum cliente encontrado"
                                description="Tente outros termos de busca ou ajuste os filtros.">
                    <es-button variant="ghost" href="/Tenants">Limpar filtros</es-button>
                </es-empty-state>
            }
            else
            {
                <es-empty-state icon="building-2"
                                title="Nenhum cliente cadastrado"
                                description="Use o Diagnóstico para criar dados de demonstração.">
                    <es-button variant="primary" href="/Diagnostico" icon="stethoscope">Ir ao Diagnóstico</es-button>
                </es-empty-state>
            }
        </es-data-table-empty>
    </es-data-table>

    @if (Model.TotalPages > 1)
    {
        <es-pagination page="@Model.Page" page-size="@(Model.Total / Math.Max(1, Model.TotalPages))" total="@Model.Total" />
    }

    <!-- Modal de confirmação suspender/reativar -->
    <es-modal id="tenant-confirm" size="sm">
        <div x-show="confirmAcao === 'suspender'">
            <h2 style="margin:0 0 6px; font-size:16px; font-weight:600; color:var(--text-primary);">Suspender cliente?</h2>
            <p style="margin:0 0 14px; color:var(--text-muted); font-size:13px;">
                <strong x-text="confirmNome"></strong> não conseguirá usar o sistema até a reativação. Esta ação é auditada.
            </p>
        </div>
        <div x-show="confirmAcao === 'reativar'">
            <h2 style="margin:0 0 6px; font-size:16px; font-weight:600; color:var(--text-primary);">Reativar cliente?</h2>
            <p style="margin:0 0 14px; color:var(--text-muted); font-size:13px;">
                <strong x-text="confirmNome"></strong> voltará a ter acesso normal ao sistema.
            </p>
        </div>
        <form method="post" x-bind:action="confirmAcao === 'suspender' ? '?handler=Suspender' : '?handler=Reativar'">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" x-bind:value="confirmId" />
            <div x-show="confirmAcao === 'suspender'" style="margin-bottom:14px;">
                <es-input name="motivo" label="Motivo da suspensão" placeholder="Ex.: inadimplência, fraude, solicitação..." required="true" />
            </div>
            <es-modal-footer>
                <es-button variant="ghost" x-on:click="close()">Cancelar</es-button>
                <button type="submit"
                        class="btn"
                        :class="confirmAcao === 'suspender' ? 'btn-danger btn-md' : 'btn-primary btn-md'">
                    <span x-text="confirmAcao === 'suspender' ? 'Suspender' : 'Reativar'"></span>
                </button>
            </es-modal-footer>
        </form>
    </es-modal>
</div>
