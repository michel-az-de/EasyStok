                    </div>
                }
            </div>
        }

        <!-- Modal Nova Loja -->
        <div x-show="novaOpen" x-cloak class="modal-overlay" @@click.self="novaOpen = false" @@keydown.escape.window="novaOpen = false">
            <div class="modal-box max-w-md" @@click.stop>
                <h3 class="text-es-ink font-semibold mb-4">Nova loja</h3>
                <form method="post" action="/Tenants/Detail/@Model.Id?handler=CriarLoja">
                    <input type="hidden" name="__RequestVerificationToken" value="@afLojas" />
                    <div class="mb-3"><label class="form-label">Nome *</label>
                        <input type="text" name="nome" required maxlength="150" class="form-input w-full text-sm" /></div>
                    <div class="mb-3"><label class="form-label">Descrição</label>
                        <input type="text" name="descricao" maxlength="500" class="form-input w-full text-sm" /></div>
                    <div class="grid grid-cols-2 gap-3 mb-3">
