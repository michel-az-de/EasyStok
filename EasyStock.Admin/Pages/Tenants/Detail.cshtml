    <!-- Atividade unificada (P1) — timeline com filtros -->
    <div x-show="tab === 'atividade'" x-cloak x-data="atividadeTimeline('@Model.Id')" x-init="$watch('tab', t => { if (t === 'atividade' && !carregouUmaVez) { carregouUmaVez = true; recarregar(); } }); if (tab === 'atividade' && !carregouUmaVez) { carregouUmaVez = true; recarregar(); }">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_240px] gap-4">
            <!-- Timeline -->
            <div class="card p-0 overflow-hidden">
                <div class="px-4 py-3 flex items-center justify-between" style="border-bottom:1px solid rgba(247,242,232,0.08)">
                    <h3 class="text-es-ink font-semibold text-sm">Atividade do cliente</h3>
                    <div class="flex items-center gap-2 text-xs text-es-ink-mute">
                        <span x-show="loading" x-cloak>Carregando…</span>
                        <span x-show="!loading && total !== null" x-cloak><b class="text-es-ink" x-text="total"></b> <span x-text="total === 1 ? 'evento' : 'eventos'"></span></span>
                        <button type="button" @@click="recarregar()" class="text-es-ink hover:text-es-accent ml-2">↻</button>
                    </div>
                </div>
                <div x-show="erro" x-cloak class="bg-red-500/10 border-b border-red-500/30 text-red-400 text-xs px-4 py-2" x-text="erro"></div>

                <div class="divide-y" style="--tw-divide-opacity:0.05">
                    <template x-if="!loading && itens.length === 0">
                        <div class="text-es-ink-mute text-sm text-center py-10">
                            Sem atividade no período. Tente ampliar os filtros.
                        </div>
                    </template>
                    <template x-for="ev in itens" :key="ev.id">
                        <div class="px-4 py-3 flex items-start gap-3 hover:bg-es-surface-2/30 transition-colors" style="border-top:1px solid rgba(247,242,232,0.05)">
                            <div class="text-xl leading-none mt-0.5" x-text="iconePorAcao(ev.acao, ev.tipo)"></div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 flex-wrap mb-0.5">
                                    <span class="font-mono text-xs px-1.5 py-0.5 rounded" :style="ev.tipo === 'admin' ? 'background:rgba(244,121,32,.15);color:#f47920' : 'background:rgba(120,160,200,.12);color:#a8c5e2'" x-text="ev.acao"></span>
                                    <span x-show="ev.sucesso === false" x-cloak class="status-badge badge-cancelada">falhou</span>
                                </div>
                                <div class="text-es-ink-dim text-xs mt-0.5">
                                    <span x-text="ev.atorNome || 'Sistema'"></span>
                                    <span x-show="ev.atorEmail" x-cloak class="font-mono text-es-ink-mute">· <span x-text="ev.atorEmail"></span></span>
                                </div>
                                <div x-show="ev.detalhes" x-cloak class="text-es-ink-mute text-xs mt-1 break-all" x-text="formatarDetalhes(ev.acao, ev.detalhes)"></div>
                                <div x-show="ev.motivo" x-cloak class="text-amber-300/80 text-xs mt-1 italic">
                                    Justificativa: <span x-text="ev.motivo"></span>
                                </div>
                                <div class="text-es-ink-mute text-xs mt-1 flex items-center gap-3">
                                    <span :title="new Date(ev.dataHora).toLocaleString('pt-BR')" x-text="formatRelativo(ev.dataHora)"></span>
                                    <span x-show="ev.ip" x-cloak class="font-mono">IP <span x-text="ev.ip"></span></span>
                                </div>
                            </div>
                        </div>
                    </template>
                </div>

                <div x-show="!loading && temMais" x-cloak class="text-center py-3" style="border-top:1px solid rgba(247,242,232,0.08)">
                    <button type="button" @@click="carregarMais()" class="btn-secondary text-xs">Carregar mais</button>
                </div>
            </div>

            <!-- Filtros sticky -->
            <div class="card p-4 self-start lg:sticky lg:top-20 space-y-3">
                <h4 class="text-es-ink font-semibold text-xs uppercase tracking-wide">Filtros</h4>
                <div>
                    <label class="form-label">Tipo</label>
                    <select x-model="filtros.tipo" @@change="recarregar()" class="form-input w-full text-sm">
                        <option value="">Todos</option>
                        <option value="tenant">Atividade do cliente</option>
                        <option value="admin">Ações do operador</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Período</label>
                    <select x-model="filtros.periodo" @@change="aplicarPeriodo(); recarregar()" class="form-input w-full text-sm">
                        <option value="7">Últimos 7 dias</option>
                        <option value="30">Últimos 30 dias</option>
                        <option value="90">Últimos 90 dias</option>
                        <option value="">Tudo</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Busca livre</label>
                    <input type="text" x-model="filtros.search" @@keyup.enter="recarregar()"
                           placeholder="Ex: login, suspendido…"
                           class="form-input w-full text-sm" />
                </div>
                <button type="button" @@click="recarregar()" class="btn-primary text-xs w-full">Aplicar</button>
                <button type="button" @@click="limparFiltros()" class="text-xs text-es-ink-mute hover:text-es-ink w-full">Limpar filtros</button>
            </div>
        </div>

        <script>
        function atividadeTimeline(tenantId) {
            return {
                tenantId,
                carregouUmaVez: false,
                loading: false,
                erro: '',
                itens: [],
                total: null,
                pagina: 1,
                temMais: false,
                filtros: { tipo: '', periodo: '30', search: '', from: null, to: null },

                aplicarPeriodo() {
                    if (!this.filtros.periodo) { this.filtros.from = null; return; }
                    const d = new Date();
                    d.setDate(d.getDate() - parseInt(this.filtros.periodo, 10));
                    this.filtros.from = d.toISOString();
                },
                async recarregar() {
                    this.aplicarPeriodo();
                    this.pagina = 1;
                    this.itens = [];
                    await this._fetch();
                },
                async carregarMais() {
                    this.pagina += 1;
                    await this._fetch(true);
                },
                limparFiltros() {
                    this.filtros = { tipo: '', periodo: '30', search: '', from: null, to: null };
                    this.recarregar();
                },
                async _fetch(append = false) {
                    this.loading = true; this.erro = '';
                    try {
                        const qs = new URLSearchParams({ page: this.pagina });
                        if (this.filtros.tipo) qs.set('tipo', this.filtros.tipo);
                        if (this.filtros.from) qs.set('from', this.filtros.from);
                        if (this.filtros.search) qs.set('search', this.filtros.search);
                        const url = '/Tenants/Detail/' + this.tenantId + '?handler=Atividade&' + qs.toString();
                        const r = await fetch(url, { credentials: 'same-origin', cache: 'no-store' });
                        if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                        const d = await r.json();
                        const items = (d.data || []);
                        this.itens = append ? this.itens.concat(items) : items;
                        const meta = d.meta || {};
                        this.total = meta.total ?? this.itens.length;
                        this.temMais = meta.pages != null && this.pagina < meta.pages;
                    } catch (e) {
                        this.erro = 'Falha ao carregar atividade: ' + (e.message || e);
                    } finally {
                        this.loading = false;
                    }
                },
                iconePorAcao(acao, tipo) {
                    const a = (acao || '').toLowerCase();
                    if (tipo === 'admin') return '🛡️';
                    if (a.includes('login')) return '🔑';
                    if (a.includes('logout')) return '🚪';
                    if (a.includes('venda')) return '💰';
                    if (a.includes('estoque') || a.includes('produto')) return '📦';
                    if (a.includes('senha') || a.includes('reset')) return '🔒';
                    if (a.includes('cadastr') || a.includes('criar')) return '➕';
                    if (a.includes('alter') || a.includes('atualiz') || a.includes('edit')) return '✏️';
                    return '•';
                },
                formatarDetalhes(acao, detalhes) {
                    if (!detalhes) return '';
                    const kv = {};
                    detalhes.split(',').forEach(p => {
                        const [k, ...v] = p.trim().split('=');
                        if (k) kv[k.trim()] = v.join('=').trim();
                    });
                    const a = (acao || '').toLowerCase();
                    if (a.includes('lojacriada'))     return 'Loja ' + (kv['Nome'] || kv['LojaId'] || '') + ' criada';
                    if (a.includes('lojaatualizada')) return 'Loja ' + (kv['Nome'] || '') + ' atualizada';
                    if (a.includes('lojadesativada')) return 'Loja ' + (kv['Nome'] || '') + ' desativada';
                    if (a.includes('lojareativada'))  return 'Loja ' + (kv['Nome'] || '') + ' reativada';
                    if (a.includes('notainternacriada')) {
                        const tipo = kv['Tipo'] || '';
                        const tam  = kv['Tamanho'] || '';
                        return 'Nota interna (' + tipo + (tam ? ', ' + tam + ' chars' : '') + ') adicionada';
                    }
                    if (a.includes('impersonad')) return 'Acesso impersonado — empresa ' + (kv['TenantId'] || '').substring(0, 8) + '…';
                    return Object.entries(kv).map(([k, v]) => k + ': ' + v).join(' · ');
                },
                formatRelativo(iso) {
                    if (!iso) return '';
                    const d = new Date(iso);
                    const diff = (Date.now() - d.getTime()) / 1000;
                    if (diff < 60) return 'agora há pouco';
                    if (diff < 3600) return Math.floor(diff/60) + ' min atrás';
                    if (diff < 86400) return Math.floor(diff/3600) + ' h atrás';
                    if (diff < 86400*7) return plural(Math.floor(diff/86400), 'dia atrás', 'dias atrás');
                    return d.toLocaleDateString('pt-BR');
                }
            };
        }
        </script>
    </div>

    <!-- Tab Notas internas (P3) — handoff entre operadores -->
    <div x-show="tab === 'notas'" x-cloak x-data="notasPanel('@Model.Id')"
         x-init="$watch('tab', t => { if (t === 'notas' && !carregouUmaVez) { carregouUmaVez = true; carregar(); } })">
        <div class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-4">
            <!-- Lista -->
            <div>
                <div class="flex items-center justify-between mb-3">
                    <div>
                        <h3 class="text-es-ink font-semibold text-sm">Notas internas</h3>
                        <p class="text-es-ink-mute text-xs">Visíveis só para o time de back-office. Use pra handoff entre operadores.</p>
                    </div>
                    <div class="text-xs text-es-ink-mute">
                        <span x-show="loading" x-cloak>Carregando…</span>
                        <span x-show="!loading"><b class="text-es-ink" x-text="notas.length"></b> <span x-text="notas.length === 1 ? 'nota' : 'notas'"></span></span>
                    </div>
                </div>
                <div x-show="erro" x-cloak class="text-xs text-red-400 mb-2" x-text="erro"></div>

                <template x-if="!loading && notas.length === 0">
                    <div class="card text-center text-es-ink-mute text-sm py-8">
                        Sem notas ainda. Use o formulário ao lado pra deixar contexto pra próximo operador.
                    </div>
                </template>

                <div class="space-y-3">
                    <template x-for="n in notas" :key="n.id">
                        <div class="card p-3"
                             :style="n.tipoInt === 1 ? 'background:rgba(248,113,113,0.06);border-color:rgba(248,113,113,0.3)' : (n.tipoInt === 2 ? 'background:rgba(247,144,9,0.06);border-color:rgba(247,144,9,0.3)' : '')">
                            <div class="flex items-start gap-3">
                                <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 text-xs font-bold"
                                     :style="'background:rgba(244,121,32,0.2);color:#f47920'"
                                     x-text="(n.autorEmail || '?').substring(0, 1).toUpperCase()"></div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                                        <span class="text-es-ink text-xs font-semibold" x-text="n.autorEmail"></span>
                                        <span class="status-badge"
                                              :class="n.tipoInt === 1 ? 'badge-cancelada' : (n.tipoInt === 2 ? 'badge-suspensa' : 'badge-ativa')"
                                              x-text="n.tipoInt === 1 ? '⚠ Alerta' : (n.tipoInt === 2 ? '↑ Escalonamento' : 'Info')"></span>
                                        <span class="text-es-ink-mute text-[10px]" x-text="formatRelativo(n.criadoEm)" :title="new Date(n.criadoEm).toLocaleString('pt-BR')"></span>
                                        <span x-show="n.editado" x-cloak class="text-es-ink-mute text-[10px] italic">(editada)</span>
                                    </div>
                                    <template x-if="editandoId !== n.id">
                                        <div class="text-es-ink-dim text-sm whitespace-pre-wrap break-words" x-text="n.texto"></div>
                                    </template>
                                    <template x-if="editandoId === n.id">
                                        <div class="space-y-2 mt-1">
                                            <textarea x-model="editandoTexto" rows="3" minlength="3" maxlength="2000"
                                                      class="form-input w-full text-sm font-mono"></textarea>
                                            <select x-model="editandoTipo" class="form-input text-sm">
                                                <option value="Info">Info</option>
                                                <option value="Alerta">⚠ Alerta</option>
                                                <option value="Escalonamento">↑ Escalonamento</option>
                                            </select>
                                            <div class="flex gap-2">
                                                <button type="button" @@click="salvarEdicao(n.id)" :disabled="editandoTexto.trim().length < 3" class="btn-primary text-xs">Salvar</button>
                                                <button type="button" @@click="editandoId = null" class="btn-secondary text-xs">Cancelar</button>
                                            </div>
                                        </div>
                                    </template>
                                </div>
                                <div class="flex items-center gap-2 flex-shrink-0">
                                    <button type="button" @@click="iniciarEdicao(n)" class="text-es-ink-mute hover:text-es-ink text-xs" title="Editar (só autor)">✏️</button>
                                    <button type="button" @@click="excluir(n.id)" class="text-es-ink-mute hover:text-red-400 text-xs" title="Excluir">🗑</button>
                                </div>
                            </div>
                        </div>
                    </template>
                </div>
            </div>

            <!-- Editor -->
            @{ var afNotas = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken; }
            <div class="card p-4 self-start lg:sticky lg:top-20 space-y-3">
                <h4 class="text-es-ink font-semibold text-xs uppercase tracking-wide">Adicionar nota</h4>
                <div>
                    <label class="form-label">Tipo</label>
                    <select x-model="novoTipo" class="form-input w-full text-sm">
                        <option value="Info">Info — observação geral</option>
                        <option value="Alerta">⚠ Alerta — aparece em banner no header</option>
                        <option value="Escalonamento">↑ Escalonamento — passa pra outro operador</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Texto <span class="text-es-ink-mute">(3..2000 chars)</span></label>
                    <textarea x-model="novoTexto" rows="5" minlength="3" maxlength="2000"
                              placeholder="Ex.: cliente prefere ser atendido por email; confirmar com Maria antes de qualquer cobrança."
                              class="form-input w-full text-sm font-mono"></textarea>
                    <p class="text-xs text-es-ink-mute mt-1">
                        <span x-text="novoTexto.length"></span> / 2000
                    </p>
                </div>
                <button type="button" @@click="criar()" :disabled="novoTexto.trim().length < 3 || enviando"
                        class="btn-primary text-sm w-full">
                    <span x-show="!enviando">Adicionar nota</span>
                    <span x-show="enviando" x-cloak>Enviando…</span>
                </button>
            </div>
        </div>

        <script>
        function notasPanel(tenantId) {
            return {
                tenantId,
                carregouUmaVez: false,
                loading: false,
                enviando: false,
                erro: '',
                notas: [],
                novoTexto: '',
                novoTipo: 'Info',
                editandoId: null,
                editandoTexto: '',
                editandoTipo: 'Info',
                async carregar() {
                    this.loading = true; this.erro = '';
                    try {
                        const r = await fetch('/Tenants/Detail/' + this.tenantId + '?handler=Notas', { credentials: 'same-origin', cache: 'no-store' });
                        if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                        const d = await r.json();
                        const data = d.data || d;
                        const itens = data.itens || [];
                        // Notas de alerta (tipoInt===1) ficam no topo da lista.
                        this.notas = [...itens].sort((a, b) => (b.tipoInt === 1 ? 1 : 0) - (a.tipoInt === 1 ? 1 : 0));
                    } catch (e) { this.erro = 'Falha: ' + (e.message || e); }
                    finally { this.loading = false; }
                },
                async criar() {
                    if (this.novoTexto.trim().length < 3) return;
                    this.enviando = true;
                    try {
                        const fd = new FormData();
                        fd.append('texto', this.novoTexto.trim());
                        fd.append('tipo', this.novoTipo);
                        fd.append('__RequestVerificationToken', '@afNotas');
                        const r = await fetch('/Tenants/Detail/' + this.tenantId + '?handler=CriarNota', {
                            method: 'POST', credentials: 'same-origin', body: fd
                        });
                        if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                        if (!r.ok) {
                            const d = await r.json();
                            this.erro = (d && d.error) || ('Falha HTTP ' + r.status);
                            return;
                        }
                        this.novoTexto = '';
                        this.novoTipo = 'Info';
                        await this.carregar();
                    } catch (e) { this.erro = 'Falha: ' + (e.message || e); }
                    finally { this.enviando = false; }
                },
                iniciarEdicao(n) {
                    this.editandoId = n.id;
                    this.editandoTexto = n.texto;
                    this.editandoTipo = n.tipo;
                },
                async salvarEdicao(notaId) {
                    if (this.editandoTexto.trim().length < 3) return;
                    try {
                        const fd = new FormData();
                        fd.append('notaId', notaId);
                        fd.append('texto', this.editandoTexto.trim());
                        fd.append('tipo', this.editandoTipo);
                        fd.append('__RequestVerificationToken', '@afNotas');
                        const r = await fetch('/Tenants/Detail/' + this.tenantId + '?handler=AtualizarNota', {
                            method: 'POST', credentials: 'same-origin', body: fd
                        });
                        if (!r.ok) {
                            const d = await r.json();
                            this.erro = (d && d.error) || ('Falha HTTP ' + r.status);
                            return;
                        }
                        this.editandoId = null;
                        await this.carregar();
                    } catch (e) { this.erro = 'Falha: ' + (e.message || e); }
                },
                async excluir(notaId) {
                    if (!confirm('Excluir esta nota? Esta ação fica auditada.')) return;
                    try {
                        const fd = new FormData();
                        fd.append('notaId', notaId);
                        fd.append('__RequestVerificationToken', '@afNotas');
                        const r = await fetch('/Tenants/Detail/' + this.tenantId + '?handler=ExcluirNota', {
                            method: 'POST', credentials: 'same-origin', body: fd
                        });
                        if (!r.ok) {
                            const d = await r.json();
                            this.erro = (d && d.error) || ('Falha HTTP ' + r.status);
                            return;
                        }
                        await this.carregar();
                    } catch (e) { this.erro = 'Falha: ' + (e.message || e); }
                },
                formatRelativo(iso) {
                    if (!iso) return '';
                    const d = new Date(iso); const diff = (Date.now() - d.getTime()) / 1000;
                    if (diff < 60) return 'agora há pouco';
                    if (diff < 3600) return Math.floor(diff/60) + ' min atrás';
                    if (diff < 86400) return Math.floor(diff/3600) + ' h atrás';
                    if (diff < 86400*7) return plural(Math.floor(diff/86400), 'dia atrás', 'dias atrás');
                    return d.toLocaleDateString('pt-BR');
                }
            };
        }
        </script>
    </div>

    <!-- Tab LGPD (P1 slice 2) — Exportar / Anonimizar / Histórico -->
    <div x-show="tab === 'lgpd'" x-cloak x-data="lgpdPanel('@Model.Id')" x-init="$watch('tab', t => { if (t === 'lgpd' && !carregouHistorico) { carregouHistorico = true; carregarHistorico(); } })">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">

            <!-- Card Exportar -->
            <div class="card">
                <div class="flex items-start gap-2 mb-2">
                    <div class="text-2xl">📤</div>
                    <div>
                        <h4 class="text-es-ink font-semibold text-sm">Exportar dados</h4>
                        <p class="text-es-ink-mute text-xs mt-0.5">LGPD Art. 18 — direito de portabilidade</p>
                    </div>
                </div>
                <p class="text-es-ink-dim text-xs mb-3">
                    Gera snapshot JSON com empresa, lojas, usuários (mascarados), contagens.
                    Operação é auditada. PII desmascarada via endpoint individual.
                </p>
                <div class="space-y-2">
                    <input type="text" x-model="exportarMotivo" placeholder="Justificativa (≥10 chars)"
                           class="form-input w-full text-xs font-mono" />
                    <p x-show="exportarMotivo.length > 0 && exportarMotivo.trim().length < 10" x-cloak
                       class="text-amber-400 text-xs">Mínimo de 10 caracteres para liberar a exportação (fica no audit log).</p>
                    <a :href="exportarUrl"
                       :class="exportarMotivo.trim().length >= 10 ? 'btn-primary' : 'btn-secondary opacity-50 pointer-events-none'"
                       class="text-xs w-full block text-center">
                        Baixar JSON
                    </a>
                </div>
            </div>

            <!-- Card Anonimizar -->
            <div class="card">
                <div class="flex items-start gap-2 mb-2">
                    <div class="text-2xl">⚠️</div>
                    <div>
                        <h4 class="text-es-ink font-semibold text-sm">Anonimizar usuário</h4>
                        <p class="text-es-ink-mute text-xs mt-0.5">LGPD Art. 18 — direito ao esquecimento</p>
                    </div>
                </div>
                <p class="text-es-ink-dim text-xs mb-3">
                    Para anonimizar um usuário deste cliente, abra a aba <button type="button" @@click="$root.tab='usuarios'; window.history.replaceState({}, '', new URL(window.location).toString().replace(/tab=\w+/, 'tab=usuarios'))" class="text-es-accent hover:underline">Usuários</button>,
                    clique em <strong class="text-es-ink">Ações ▾ → Anonimizar (LGPD)</strong>.
                    Operação irreversível com double-confirm por email.
                </p>
                <div class="text-xs text-es-ink-mute" x-show="estatisticas.totalAcoesLgpd != null" x-cloak>
                    <span x-text="plural(estatisticas.totalAcoesLgpd ?? 0, 'ação LGPD registrada', 'ações LGPD registradas') + ' neste cliente'"></span>
                    · <span x-text="plural(estatisticas.totalUnmasks ?? 0, 'unmask de PII', 'unmasks de PII')"></span>
                </div>
            </div>

            <!-- Card Histórico -->
            <div class="card">
                <div class="flex items-start gap-2 mb-2">
                    <div class="text-2xl">📋</div>
                    <div>
                        <h4 class="text-es-ink font-semibold text-sm">Histórico LGPD</h4>
                        <p class="text-es-ink-mute text-xs mt-0.5">Comprovação ANPD em segundos</p>
                    </div>
                </div>
                <p class="text-es-ink-dim text-xs mb-3">
                    Anonimizações, exports e desmascaramentos de PII realizados neste cliente,
                    com operador e justificativa. Veja a tabela abaixo.
                </p>
                <button type="button" @@click="carregarHistorico()"
                        class="btn-secondary text-xs w-full">↻ Atualizar histórico</button>
            </div>
        </div>

        <!-- Tabela histórico -->
        <div class="card p-0 overflow-hidden">
            <div class="px-4 py-3 flex items-center justify-between" style="border-bottom:1px solid rgba(247,242,232,0.08)">
                <h3 class="text-es-ink font-semibold text-sm">Ações LGPD registradas</h3>
                <span class="text-es-ink-mute text-xs"><b class="text-es-ink" x-text="totalHist"></b> <span x-text="totalHist === 1 ? 'registro' : 'registros'"></span></span>
            </div>
            <div x-show="loadingHist" x-cloak class="text-es-ink-mute text-sm py-6 text-center">Carregando…</div>
            <div x-show="erroHist" x-cloak class="bg-red-500/10 text-red-400 text-xs px-4 py-2 border-b border-red-500/30" x-text="erroHist"></div>
            <table class="table-admin">
                <thead><tr><th>Ação</th><th>Operador</th><th>Detalhes</th><th>Justificativa</th><th>Quando</th></tr></thead>
                <tbody>
                    <template x-if="!loadingHist && historico.length === 0">
                        <tr><td colspan="5" class="text-es-ink-mute text-center py-6">Sem registros LGPD para este cliente.</td></tr>
                    </template>
                    <template x-for="r in historico" :key="r.id">
                        <tr>
                            <td class="font-mono text-xs">
                                <span class="status-badge"
                                      :class="r.acao === 'UsuarioTenantAnonimizado' ? 'badge-cancelada' : (r.acao === 'TenantDadosExportados' ? 'badge-ativa' : 'badge-suspensa')"
                                      x-text="iconePorAcao(r.acao) + ' ' + labelAcao(r.acao)"></span>
                            </td>
                            <td class="text-es-ink-dim text-xs font-mono" x-text="r.adminEmail"></td>
                            <td class="text-es-ink-dim text-xs max-w-xs truncate" :title="r.detalhes" x-text="r.detalhes ?? '—'"></td>
                            <td class="text-amber-300/80 text-xs max-w-xs truncate italic" :title="r.motivo" x-text="r.motivo ?? '—'"></td>
                            <td class="text-es-ink-dim text-xs" x-text="new Date(r.criadoEm).toLocaleString('pt-BR')"></td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>

        <script>
        function lgpdPanel(tenantId) {
            return {
                tenantId,
                carregouHistorico: false,
                loadingHist: false,
                erroHist: '',
                historico: [],
                totalHist: 0,
                estatisticas: { totalAcoesLgpd: null, totalUnmasks: null },
                exportarMotivo: '',
                get exportarUrl() {
                    if (this.exportarMotivo.trim().length < 10) return '#';
                    return '/Tenants/Detail/' + this.tenantId + '?handler=ExportarDados&motivo=' + encodeURIComponent(this.exportarMotivo.trim());
                },
                async carregarHistorico() {
                    this.loadingHist = true; this.erroHist = '';
                    try {
                        const r = await fetch('/Tenants/Detail/' + this.tenantId + '?handler=HistoricoLgpd', {
                            credentials: 'same-origin', cache: 'no-store'
                        });
                        if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                        const d = await r.json();
                        const items = (d.data || []);
                        this.historico = items;
                        this.totalHist = (d.meta && d.meta.total) ?? items.length;
                        // Estatísticas vêm fora do envelope `data`/`meta` (DataPaged padrão).
                        if (d.estatisticas) {
                            this.estatisticas = d.estatisticas;
                        }
                    } catch (e) {
                        this.erroHist = 'Falha ao carregar: ' + (e.message || e);
                    } finally {
                        this.loadingHist = false;
                    }
                },
                iconePorAcao(acao) {
                    if (acao === 'UsuarioTenantAnonimizado') return '🗑';
                    if (acao === 'TenantDadosExportados') return '📤';
                    if (acao === 'PiiVisualizado') return '👁';
                    return '🛡';
                },
                labelAcao(acao) {
                    if (acao === 'UsuarioTenantAnonimizado') return 'Anonimizado';
                    if (acao === 'TenantDadosExportados') return 'Export gerado';
                    if (acao === 'PiiVisualizado') return 'PII desmascarada';
                    return acao;
                }
            };
        }
        </script>
    </div>
</div>

<partial name="_ModalJustificativa" />
