@page "{id:guid}"
@model EasyStock.Admin.Pages.Tenants.DetailModel
@{
    var nome = Model.Empresa.ValueKind != System.Text.Json.JsonValueKind.Undefined && Model.Empresa.TryGetProperty("nome", out var np) ? np.GetString() : "Tenant";
    ViewData["Title"] = nome;

    var assinaturaStatus = Model.Assinatura.ValueKind != System.Text.Json.JsonValueKind.Undefined
        && Model.Assinatura.TryGetProperty("status", out var sp) ? sp.GetString() : null;
    var statusClass = assinaturaStatus?.ToLower() switch {
        "ativa" => "badge-ativa",
        "suspensa" => "badge-suspensa",
        "cancelada" => "badge-cancelada",
        _ => "badge-expirada"
    };
}

<a href="/Tenants" class="text-es-ink-mute hover:text-es-ink text-sm mb-4 inline-flex items-center gap-1">← Voltar</a>

@if (Model.Erro != null)
{
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-4 py-3 text-sm mb-4">@Model.Erro</div>
}

<!-- Header -->
<div class="card mb-6" x-data="{ modal: null }">
    <div class="flex items-start justify-between flex-wrap gap-4">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <h2 class="text-es-ink text-xl font-bold">@nome</h2>
                <span class="status-badge @statusClass">@(assinaturaStatus ?? "Sem assinatura")</span>
            </div>
            @{
                var doc = Model.Empresa.TryGetProperty("documento", out var dp) ? dp.GetString() : null;
                var criado = Model.Empresa.TryGetProperty("criadoEm", out var cp) ? cp.GetString() : null;
                DateTime.TryParse(criado, out var criadoDt);
                var planoNome = Model.Assinatura.ValueKind != System.Text.Json.JsonValueKind.Undefined
                    && Model.Assinatura.TryGetProperty("plano", out var pp) && pp.ValueKind != System.Text.Json.JsonValueKind.Null
                    && pp.TryGetProperty("nome", out var pnp) ? pnp.GetString() : "—";
            }
            <div class="text-es-ink-dim text-sm">@(doc ?? "Sem documento") · Criado em @criadoDt.ToLocalTime().ToString("dd/MM/yyyy")</div>
            <div class="text-es-ink-dim text-sm mt-1">Plano: <span class="text-es-ink font-medium">@planoNome</span></div>
        </div>

        <div class="flex gap-2 flex-wrap">
            <form method="post" asp-page-handler="Impersonar" class="inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-secondary text-sm">🎭 Impersonar</button>
            </form>

            @if (assinaturaStatus == "Ativa")
            {
                <button type="button" @@click="modal = 'suspender'" class="btn-danger text-sm">Suspender</button>
            }
            else if (assinaturaStatus == "Suspensa")
            {
                <form method="post" asp-page-handler="Reativar">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-primary text-sm">Reativar</button>
                </form>
            }

            <!-- Trocar plano -->
            <button type="button" @@click="modal = 'plano'" class="btn-secondary text-sm">Trocar Plano</button>
        </div>
    </div>

    <!-- Modal Suspender -->
    <div x-show="modal === 'suspender'" x-cloak class="modal-overlay" @@click.self="modal = null">
        <div class="modal-box" @@click.stop>
            <h3 class="text-es-ink font-semibold mb-4">Suspender Tenant</h3>
            <form method="post" asp-page-handler="Suspender">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label class="form-label">Motivo</label>
                    <input type="text" name="motivo" class="form-input" placeholder="Motivo da suspensão..." required />
                </div>
                <div class="flex gap-3 justify-end">
                    <button type="button" @@click="modal = null" class="btn-secondary">Cancelar</button>
                    <button type="submit" class="btn-danger">Suspender</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Trocar Plano -->
    <div x-show="modal === 'plano'" x-cloak class="modal-overlay" @@click.self="modal = null">
        <div class="modal-box" @@click.stop>
            <h3 class="text-es-ink font-semibold mb-4">Trocar Plano</h3>
            <form method="post" asp-page-handler="TrocarPlano">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label class="form-label">Plano</label>
                    <select name="planoId" class="form-input" required>
                        @foreach (var p in Model.PlanosList)
                        {
                            var pid = p.TryGetProperty("id", out var pidp) ? pidp.GetString() : "";
                            var pnome = p.TryGetProperty("nome", out var pnp2) ? pnp2.GetString() : "";
                            var preco = p.TryGetProperty("precoMensal", out var precoP) ? precoP.GetDecimal() : 0;
                            <option value="@pid">@pnome — R$ @preco.ToString("N2")</option>
                        }
                    </select>
                </div>
                <div class="flex gap-3 justify-end">
                    <button type="button" @@click="modal = null" class="btn-secondary">Cancelar</button>
                    <button type="submit" class="btn-primary">Salvar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Tabs -->
<div x-data="{
        tab: (new URLSearchParams(window.location.search).get('tab')) || 'visao',
        switchTab(t) {
            this.tab = t;
            // Atualiza URL sem recarregar — permite voltar pra mesma tab no F5/Back.
            const u = new URL(window.location);
            u.searchParams.set('tab', t);
            window.history.replaceState({}, '', u);
        }
     }" class="space-y-4">
    <div class="flex gap-1 rounded-lg p-1 w-fit" style="background:#151f31; border:1px solid rgba(247,242,232,0.12)">
        @foreach (var (t, l) in new[] { ("visao","Visão Geral"), ("usuarios","Usuários"), ("lojas","Lojas"), ("audit","Audit Log"), ("features","Features") })
        {
            <button type="button"
                    @@click="switchTab('@t')"
                    x-bind:style="tab === '@t' ? 'background:#f47920;color:#f7f2e8' : 'color:#8793a7'"
                    class="px-4 py-1.5 rounded-md text-sm font-medium transition-all">@l</button>
        }
    </div>

    <!-- Visão geral -->
    <div x-show="tab === 'visao'" class="space-y-4">
        @{
            var usuarios = Model.Usuarios.Count();
            var lojas = Model.Lojas.Count();
            var planoJson = Model.Assinatura.ValueKind != System.Text.Json.JsonValueKind.Undefined
                && Model.Assinatura.TryGetProperty("plano", out var planoProp) && planoProp.ValueKind != System.Text.Json.JsonValueKind.Null
                ? planoProp : default;
        }
        <!-- Métricas rápidas -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="card"><div class="text-es-ink-mute text-xs uppercase tracking-wide mb-1">Usuários</div><div class="text-2xl font-bold text-es-ink">@usuarios</div></div>
            <div class="card"><div class="text-es-ink-mute text-xs uppercase tracking-wide mb-1">Lojas</div><div class="text-2xl font-bold text-es-ink">@lojas</div></div>
            @if (planoJson.ValueKind != System.Text.Json.JsonValueKind.Undefined)
            {
                var limLojas = planoJson.TryGetProperty("limiteLojas", out var ll) ? ll.GetInt32() : 0;
                var limUsuarios = planoJson.TryGetProperty("limiteUsuarios", out var lu) ? lu.GetInt32() : 0;
                var limProdutos = planoJson.TryGetProperty("limiteProdutos", out var lp) ? lp.GetInt32() : 0;
                var preco = planoJson.TryGetProperty("precoMensal", out var pr) ? pr.GetDecimal() : 0m;
                <div class="card">
                    <div class="text-es-ink-mute text-xs uppercase tracking-wide mb-1">Limites do Plano</div>
                    <div class="text-xs text-es-ink-dim space-y-0.5 mt-1">
                        <div>Lojas: @(limLojas == -1 ? "Ilimitado" : limLojas.ToString())</div>
                        <div>Usuários: @(limUsuarios == -1 ? "Ilimitado" : limUsuarios.ToString())</div>
                        <div>Produtos: @(limProdutos == -1 ? "Ilimitado" : limProdutos.ToString())</div>
                    </div>
                </div>
                <div class="card"><div class="text-es-ink-mute text-xs uppercase tracking-wide mb-1">Mensalidade</div><div class="text-2xl font-bold text-es-accent">R$ @preco.ToString("N2")</div></div>
            }
        </div>

        <!-- Trial & Coupon panel -->
        @{
            var trialAtivo = Model.Assinatura.TryGetProperty("trialAtivo", out var tap) && tap.GetBoolean();
            var trialFim = Model.Assinatura.TryGetProperty("trialFim", out var tfp) && tfp.ValueKind != System.Text.Json.JsonValueKind.Null ? tfp.GetString() : null;
            var cupomCodigo = Model.Assinatura.TryGetProperty("cupomCodigo", out var ccp) && ccp.ValueKind != System.Text.Json.JsonValueKind.Null ? ccp.GetString() : null;
            var desconto = Model.Assinatura.TryGetProperty("descontoAplicado", out var dap) && dap.ValueKind != System.Text.Json.JsonValueKind.Null ? (decimal?)dap.GetDecimal() : null;
            DateTime.TryParse(trialFim, out var trialFimDt);
        }
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4" x-data="{ showTrial: false, showCupom: false }">

            <!-- Trial card -->
            <div class="card">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-es-ink font-semibold text-sm">Trial</h3>
                    @if (trialAtivo)
                    {
                        <span class="status-badge badge-ativa">Ativo até @trialFimDt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                    }
                    else if (trialFim != null)
                    {
                        <span class="status-badge badge-expirada">Expirado</span>
                    }
                    else
                    {
                        <span class="text-es-ink-mute text-xs">Sem trial</span>
                    }
                </div>
                <button type="button" @@click="showTrial = !showTrial" class="btn-secondary text-xs w-full">
                    Conceder Trial
                </button>
                <div x-show="showTrial" x-cloak class="mt-3">
                    <form method="post" asp-page-handler="ConcederTrial" class="flex gap-2 items-end">
                        @Html.AntiForgeryToken()
                        <div class="flex-1">
                            <label class="form-label">Dias</label>
                            <input type="number" name="diasTrial" value="30" min="1" max="90" class="form-input" required />
                        </div>
                        <button type="submit" class="btn-primary text-sm">Conceder</button>
                    </form>
                </div>
            </div>

            <!-- Cupom card -->
            <div class="card">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-es-ink font-semibold text-sm">Cupom</h3>
                    @if (cupomCodigo != null)
                    {
                        <span class="font-mono text-xs text-es-accent font-bold">@cupomCodigo</span>
                    }
                    else
                    {
                        <span class="text-es-ink-mute text-xs">Nenhum aplicado</span>
                    }
                </div>
                @if (desconto.HasValue)
                {
                    <div class="text-xs text-es-ink-dim mb-3">Desconto aplicado: <b class="text-es-accent">@desconto.Value.ToString("N2")</b></div>
                }
                <button type="button" @@click="showCupom = !showCupom" class="btn-secondary text-xs w-full">
                    Aplicar Cupom
                </button>
                <div x-show="showCupom" x-cloak class="mt-3">
                    <form method="post" asp-page-handler="AplicarCupom" class="flex gap-2 items-end">
                        @Html.AntiForgeryToken()
                        <div class="flex-1">
                            <label class="form-label">Código</label>
                            <input type="text" name="codigo" class="form-input" placeholder="Ex: PROMO10"
                                   style="text-transform:uppercase" required />
                        </div>
                        <button type="submit" class="btn-primary text-sm">Aplicar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Usuários -->
    <div x-show="tab === 'usuarios'" x-cloak x-data="{ sessoesUserId: null, sessoesData: null, sessoesLoading: false, sessoesErro: '' }">
        <div class="card p-0 overflow-hidden">
            <table class="table-admin">
                <thead><tr><th>Nome</th><th>E-mail</th><th>Nível</th><th>Último acesso</th><th>Status</th><th class="text-right">Ações</th></tr></thead>
                <tbody>
                    @if (!Model.Usuarios.Any())
                    {
                        <tr><td colspan="6" class="text-es-ink-mute text-center py-8 text-sm">Cliente sem usuários cadastrados.</td></tr>
                    }
                    @foreach (var u in Model.Usuarios)
                    {
                        var uid = u.TryGetProperty("id", out var uidp) ? uidp.GetString() : "";
                        var unome = u.TryGetProperty("nome", out var unp) ? unp.GetString() : "";
                        var uemail = u.TryGetProperty("email", out var uep) ? uep.GetString() : "";
                        var nivel = u.TryGetProperty("nivelAcesso", out var univelP) && univelP.ValueKind != System.Text.Json.JsonValueKind.Null ? univelP.GetString() : "—";
                        var ativo = u.TryGetProperty("ativo", out var uap) && uap.GetBoolean();
                        var ultimo = u.TryGetProperty("ultimoAcessoEm", out var uup) && uup.ValueKind != System.Text.Json.JsonValueKind.Null ? uup.GetString() : null;
                        DateTime.TryParse(ultimo, out var ultimoDt);
                        // Escapa pra atributo JS — evita quebra se o nome tiver aspas/apóstrofo.
                        var unomeJs = System.Text.Json.JsonSerializer.Serialize(unome);
                        var uemailJs = System.Text.Json.JsonSerializer.Serialize(uemail);
                        <tr x-data="{ open: false }">
                            <td class="text-es-ink font-medium">@unome</td>
                            <td class="text-es-ink-dim font-mono text-xs">@uemail</td>
                            <td class="text-es-ink-dim">@nivel</td>
                            <td class="text-es-ink-dim">@(ultimoDt != default ? ultimoDt.ToLocalTime().ToString("dd/MM/yy HH:mm") : "—")</td>
                            <td><span class="status-badge @(ativo ? "badge-ativa" : "badge-suspensa")">@(ativo ? "Ativo" : "Inativo")</span></td>
                            <td class="text-right relative">
                                <button type="button" @@click="open = !open" @@click.outside="open = false"
                                        class="btn-secondary text-xs px-3 py-1">Ações ▾</button>
                                <div x-show="open" x-cloak
                                     class="absolute right-0 mt-1 w-56 z-30 rounded-lg shadow-2xl py-1"
                                     style="background:#1a2540;border:1px solid rgba(247,242,232,0.12)">
                                    <button type="button" class="w-full text-left px-3 py-2 text-xs text-es-ink-dim hover:bg-es-surface-2 hover:text-es-ink"
                                            @@click="open=false; $dispatch('open-justificar', {
                                                endpoint: '/Tenants/Detail/@Model.Id?handler=ResetSenhaUsuario&userId=@uid',
                                                acao: 'Resetar senha de @unome',
                                                resumo: 'Uma nova senha temporária será gerada e enviada por email para @uemail. Todas as sessões ativas serão revogadas.',
                                                variant: 'danger',
                                                confirmLabel: 'Resetar senha (auditado)'
                                            })">
                                        🔑 Resetar senha
                                    </button>
                                    <button type="button" class="w-full text-left px-3 py-2 text-xs text-es-ink-dim hover:bg-es-surface-2 hover:text-es-ink"
                                            @@click="open=false; $dispatch('open-justificar', {
                                                endpoint: '/Tenants/Detail/@Model.Id?handler=ForcarLogoutUsuario&userId=@uid',
                                                acao: 'Forçar logout de @unome',
                                                resumo: 'Todas as sessões ativas (refresh tokens) deste usuário serão revogadas. Ele precisará logar novamente em todos os dispositivos.',
                                                variant: 'danger',
                                                confirmLabel: 'Forçar logout (auditado)'
                                            })">
                                        🚪 Forçar logout
                                    </button>
                                    <button type="button" class="w-full text-left px-3 py-2 text-xs text-es-ink-dim hover:bg-es-surface-2 hover:text-es-ink"
                                            @@click="open=false; sessoesUserId='@uid'; sessoesData=null; sessoesErro=''; sessoesLoading=true; fetch('/Tenants/Detail/@Model.Id?handler=SessoesUsuario&userId=@uid', { credentials: 'same-origin' }).then(r => r.json()).then(d => { sessoesData = d.data || d; sessoesLoading = false; }).catch(e => { sessoesErro = e.message; sessoesLoading = false; })">
                                        👁 Ver sessões
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Modal Sessões -->
        <div x-show="sessoesUserId" x-cloak class="modal-overlay" @@click.self="sessoesUserId = null" @@keydown.escape.window="sessoesUserId = null">
            <div class="modal-box max-w-2xl" @@click.stop>
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-es-ink font-semibold">Sessões ativas</h3>
                    <button type="button" @@click="sessoesUserId = null" class="text-es-ink-mute hover:text-es-ink">✕</button>
                </div>
                <div x-show="sessoesLoading" x-cloak class="text-es-ink-mute text-sm py-6 text-center">Carregando sessões…</div>
                <div x-show="sessoesErro" x-cloak class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-3 py-2 text-sm" x-text="sessoesErro"></div>
                <template x-if="sessoesData && !sessoesLoading">
                    <div>
                        <div class="text-es-ink-dim text-xs mb-3">
                            <span x-text="sessoesData.usuarioNome"></span> ·
                            <span x-text="sessoesData.usuarioEmail" class="font-mono"></span> ·
                            <span class="font-bold text-es-ink" x-text="sessoesData.ativas + ' ativa(s) de ' + sessoesData.total"></span>
                        </div>
                        <div class="max-h-96 overflow-y-auto space-y-2">
                            <template x-for="s in (sessoesData.sessoes || [])" :key="s.id">
                                <div class="rounded-lg p-3 text-xs" :style="s.ativa ? 'background:rgba(79,191,159,.08);border:1px solid rgba(79,191,159,.2)' : 'background:rgba(120,120,120,.06);border:1px solid rgba(120,120,120,.15)'">
                                    <div class="flex items-center justify-between mb-1">
                                        <span class="font-mono text-es-ink" x-text="s.ip || '(sem ip)'"></span>
                                        <span class="status-badge" :class="s.ativa ? 'badge-ativa' : 'badge-expirada'" x-text="s.ativa ? 'Ativa' : (s.revogado ? 'Revogada' : 'Expirada')"></span>
                                    </div>
                                    <div class="text-es-ink-mute truncate" x-text="s.userAgent || '(sem user-agent)'"></div>
                                    <div class="text-es-ink-mute mt-1">
                                        Criada: <span x-text="new Date(s.criadoEm).toLocaleString('pt-BR')"></span>
                                        · Expira: <span x-text="new Date(s.expiraEm).toLocaleString('pt-BR')"></span>
                                    </div>
                                </div>
                            </template>
                            <template x-if="(sessoesData.sessoes || []).length === 0">
                                <div class="text-es-ink-mute text-sm text-center py-6">Sem sessões registradas para este usuário.</div>
                            </template>
                        </div>
                    </div>
                </template>
            </div>
        </div>
    </div>

    <!-- Lojas -->
    <div x-show="tab === 'lojas'" x-cloak>
        <div class="card p-0 overflow-hidden">
            <table class="table-admin">
                <thead><tr><th>Nome</th></tr></thead>
                <tbody>
                    @foreach (var l in Model.Lojas)
                    {
                        var lnome = l.TryGetProperty("nome", out var lnp) ? lnp.GetString() : "";
                        <tr><td class="text-es-ink">@lnome</td></tr>
                    }
                    @if (!Model.Lojas.Any())
                    {
                        <tr><td class="text-center text-es-ink-mute py-6">Nenhuma loja cadastrada.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Feature Flags -->
    <div x-show="tab === 'features'" x-cloak>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var f in Model.Features)
            {
                var fkey     = f.TryGetProperty("feature", out var fkp) ? fkp.GetString() : "";
                var fdesc    = f.TryGetProperty("descricao", out var fdp) ? fdp.GetString() : fkey;
                var fativo   = f.TryGetProperty("ativo", out var fap) && fap.GetBoolean();
                <div class="card flex items-start justify-between gap-4">
                    <div>
                        <div class="text-sm font-semibold text-es-ink font-mono">@fkey</div>
                        <div class="text-xs text-es-ink-mute mt-0.5">@fdesc</div>
                    </div>
                    <form method="post" asp-page-handler="ToggleFeature">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="feature" value="@fkey" />
                        <input type="hidden" name="ativo" value="@(!fativo ? "true" : "false")" />
                        <button type="submit"
                                style="@(fativo ? "background:rgba(79,191,159,0.15);color:#4fbf9f;border:1px solid rgba(79,191,159,0.3)" : "background:rgba(135,147,167,0.1);color:#8793a7;border:1px solid rgba(135,147,167,0.2)")"
                                class="text-xs px-3 py-1 rounded-full font-medium transition-all whitespace-nowrap">
                            @(fativo ? "✓ Ativo" : "Inativo")
                        </button>
                    </form>
                </div>
            }
            @if (!Model.Features.Any())
            {
                <div class="col-span-3 text-center text-es-ink-mute py-6">Nenhuma feature disponível.</div>
            }
        </div>
    </div>

    <!-- Audit Log -->
    <div x-show="tab === 'audit'" x-cloak>
        <div class="card p-0 overflow-hidden">
            <table class="table-admin">
                <thead><tr><th>Ação</th><th>Sucesso</th><th>Detalhes</th><th>IP</th><th>Data/Hora</th></tr></thead>
                <tbody>
                    @foreach (var a in Model.AuditLogs)
                    {
                        var acao = a.TryGetProperty("acao", out var aap) ? aap.GetString() : "";
                        var sucesso = a.TryGetProperty("sucesso", out var asp2) && asp2.GetBoolean();
                        var detalhes = a.TryGetProperty("detalhes", out var adp) && adp.ValueKind != System.Text.Json.JsonValueKind.Null ? adp.GetString() : "—";
                        var ip = a.TryGetProperty("ip", out var aip) ? aip.GetString() : "—";
                        var dh = a.TryGetProperty("dataHora", out var adhp) ? adhp.GetString() : null;
                        DateTime.TryParse(dh, out var dhDt);
                        <tr>
                            <td class="font-mono text-xs text-es-ink-dim">@acao</td>
                            <td><span class="status-badge @(sucesso ? "badge-ativa" : "badge-cancelada")">@(sucesso ? "Sim" : "Não")</span></td>
                            <td class="text-es-ink-dim text-xs max-w-xs truncate">@detalhes</td>
                            <td class="text-es-ink-dim text-xs">@ip</td>
                            <td class="text-es-ink-dim text-xs">@dhDt.ToLocalTime().ToString("dd/MM/yy HH:mm")</td>
                        </tr>
                    }
                    @if (!Model.AuditLogs.Any())
                    {
                        <tr><td colspan="5" class="text-center text-es-ink-mute py-6">Nenhuma ação auditada.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<partial name="_ModalJustificativa" />
