        </div>

        <!-- Modal Editar Loja -->
        <div x-show="editandoLoja" x-cloak class="modal-overlay" @@click.self="editandoLoja = null" @@keydown.escape.window="editandoLoja = null">
            <div class="modal-box max-w-md" @@click.stop x-show="editandoLoja">
                <template x-if="editandoLoja">
                    <div>
                        <h3 class="text-es-ink font-semibold mb-4">Editar loja: <span x-text="editandoLoja.nome"></span></h3>
                        <form method="post" :action="'/Tenants/Detail/@Model.Id?handler=AtualizarLoja&lojaId=' + editandoLoja.id">
                            <input type="hidden" name="__RequestVerificationToken" value="@afLojas" />
                            <div class="mb-3"><label class="form-label">Nome *</label>
                                <input type="text" name="nome" required maxlength="150" :value="editandoLoja.nome" class="form-input w-full text-sm" /></div>
                            <div class="mb-3"><label class="form-label">Descrição</label>
                                <input type="text" name="descricao" maxlength="500" :value="editandoLoja.descricao" class="form-input w-full text-sm" /></div>
                            <div class="grid grid-cols-2 gap-3 mb-3">
                                <div><label class="form-label">Documento</label>
                                    <input type="text" name="documento" maxlength="18" x-mask:doc inputmode="numeric" placeholder="CPF ou CNPJ" :value="editandoLoja.documento" class="form-input w-full text-sm" /></div>
                                <div><label class="form-label">Telefone</label>
                                    <input type="tel" name="telefone" maxlength="15" x-mask:phone inputmode="numeric" placeholder="(11) 99999-0000" :value="editandoLoja.telefone" class="form-input w-full text-sm" /></div>
                            </div>
                            <div class="mb-3"><label class="form-label">Endereço</label>
                                <input type="text" name="endereco" maxlength="300" :value="editandoLoja.endereco" class="form-input w-full text-sm" /></div>
                            <div class="mb-4"><label class="form-label">Justificativa <span class="text-es-ink-mute">(audit log)</span></label>
                                <textarea name="motivo" rows="2" minlength="10" maxlength="1000" required
                                          placeholder="Ex.: cliente solicitou alteração de telefone"
                                          class="form-input w-full text-sm font-mono"></textarea></div>
                            <div class="flex gap-3 justify-end">
                                <button type="button" @@click="editandoLoja = null" class="btn-secondary text-sm">Cancelar</button>
                                <button type="submit" class="btn-primary text-sm">Salvar (auditado)</button>
