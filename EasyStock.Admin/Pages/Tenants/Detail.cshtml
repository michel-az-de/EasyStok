@page "{id:guid}"
@model EasyStock.Admin.Pages.Tenants.DetailModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var nome = Model.Empresa.ValueKind != System.Text.Json.JsonValueKind.Undefined && Model.Empresa.TryGetProperty("nome", out var np) ? np.GetString() : "Tenant";
    ViewData["Title"] = nome;

    var assinaturaStatus = Model.Assinatura.ValueKind != System.Text.Json.JsonValueKind.Undefined
        && Model.Assinatura.TryGetProperty("status", out var sp) ? sp.GetString() : null;
    var statusClass = assinaturaStatus?.ToLower() switch {
        "ativa" => "badge-ativa",
        "suspensa" => "badge-suspensa",
        "cancelada" => "badge-cancelada",
        _ => "badge-expirada"
    };
}

@{
    var nomeBreadcrumb = nome != null && nome.Length > 40 ? nome.Substring(0, 40) + "…" : nome;
}
<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:16px; flex-wrap:wrap;">
    <es-breadcrumb>
        <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
        <es-breadcrumb-item href="/Tenants">Clientes</es-breadcrumb-item>
        <es-breadcrumb-item>@nomeBreadcrumb</es-breadcrumb-item>
    </es-breadcrumb>
    <es-button variant="ghost" size="sm" href="/Tenants" icon="arrow-left">Voltar</es-button>
</div>

@* Banner dourado — senha temporária do tenant ou usuário recém-criado. Some no próximo navigate. *@
@if (!string.IsNullOrEmpty(Model.NovaSenhaTemporaria))
{
    <div class="bg-es-gold/10 border border-es-gold/30 text-es-gold rounded-lg px-4 py-3 text-sm mb-4">
        <div class="font-semibold mb-1">
            Senha temporária de <strong>@Model.NovoUsuarioNome</strong> — anote agora, não será reexibida:
        </div>
        <code class="font-mono text-base select-all">@Model.NovaSenhaTemporaria</code>
        <div class="text-xs text-es-ink-mute mt-2">
            E-mail de destino: <span class="font-mono">@Model.NovoUsuarioEmail</span>
        </div>
    </div>
}

<!-- Banner de alerta — populado por fetch ao carregar notas. -->
<div x-data="alertaBanner('@Model.Id')" x-init="carregar()"
     x-show="alertasAtivos > 0" x-cloak
     class="mb-3 px-4 py-2.5 rounded-lg flex items-start gap-3"
     style="background:rgba(248,113,113,0.10);border:1px solid rgba(248,113,113,0.35)">
    <div class="text-xl leading-none">⚠️</div>
    <div class="flex-1 text-sm">
        <span class="text-red-300 font-semibold">
            <span x-text="plural(alertasAtivos, 'alerta ativo', 'alertas ativos') + ' neste cliente.'"></span>
        </span>
        <span class="text-es-ink-dim">Veja na aba <strong>Notas</strong> antes de agir.</span>
        <span x-show="primeiroAlertaTexto" x-cloak class="block text-xs text-red-300/80 mt-0.5 italic">
            "<span x-text="primeiroAlertaTexto"></span><span x-show="primeiroAlertaTexto.length >= 80" x-cloak>…</span>"
        </span>
    </div>
    <a href="?tab=notas" class="text-xs text-red-300 hover:text-red-200 underline whitespace-nowrap">Ver notas</a>
</div>

<script>
function alertaBanner(tenantId) {
    return {
        alertasAtivos: 0,
        primeiroAlertaTexto: '',
        async carregar() {
            try {
                const r = await fetch('/Tenants/Detail/' + tenantId + '?handler=Notas', { credentials: 'same-origin', cache: 'no-store' });
                if (!r.ok) return;
                const d = await r.json();
                const data = d.data || d;
                this.alertasAtivos = data.alertasAtivos ?? 0;
                const alerta = (data.itens || []).find(n => n.tipoInt === 1);
                this.primeiroAlertaTexto = alerta ? (alerta.texto || '').substring(0, 80) : '';
            } catch {}
        }
    };
}

// F4: card "Sincronização Mobile" no Detail. Fetch o counts via Razor handler.
function mobileSyncHealth(tenantId) {
    return {
        loaded: false, erro: false, healthy: true, totalPending: 0,
        devices: 0, lastSyncAt: null, lastSyncFormatado: '',
        entregueSemVenda: 0,
        metricas: [],
        async carregar() {
            this.erro = false;
            const ctrl = new AbortController();
            const timer = setTimeout(() => ctrl.abort(), 8000);
            try {
                const r = await fetch('/Tenants/Detail/' + tenantId + '?handler=MobileSyncHealth',
                    { credentials: 'same-origin', cache: 'no-store', signal: ctrl.signal });
                if (!r.ok) { this.erro = true; this.loaded = true; return; }
                const json = await r.json();
                const d = json.data || json;
                if (d.error) { this.erro = true; this.loaded = true; return; }
                this.healthy = !!d.healthy;
                this.totalPending = d.totalPending ?? 0;
                this.devices = d.devices ?? 0;
                this.lastSyncAt = d.lastSyncAt;
                this.entregueSemVenda = d.orders?.entregueSemVenda ?? 0;
                this.metricas = [
                    { label: 'Pedidos',  total: d.orders?.total   ?? 0, pending: d.orders?.pending   ?? 0 },
                    { label: 'Clientes', total: d.clients?.total  ?? 0, pending: d.clients?.pending  ?? 0 },
                    { label: 'Produtos', total: d.products?.total ?? 0, pending: d.products?.pending ?? 0 },
                    { label: 'Lotes',    total: d.batches?.total  ?? 0, pending: d.batches?.pending  ?? 0 },
                    { label: 'Caixa',    total: d.cash?.total     ?? 0, pending: d.cash?.pending     ?? 0 },
                ];
                if (d.lastSyncAt) {
                    const dt = new Date(d.lastSyncAt);
                    const diff = Math.floor((Date.now() - dt.getTime()) / 60000);
                    if (diff < 1) this.lastSyncFormatado = 'agora';
                    else if (diff < 60) this.lastSyncFormatado = diff + ' min atrás';
                    else if (diff < 1440) this.lastSyncFormatado = Math.floor(diff/60) + 'h atrás';
                    else this.lastSyncFormatado = dt.toLocaleDateString('pt-BR') + ' ' + dt.toLocaleTimeString('pt-BR', {hour:'2-digit', minute:'2-digit'});
                }
                this.loaded = true;
            } catch (e) { this.erro = true; this.loaded = true; }
            finally { clearTimeout(timer); }
        }
    };
}
</script>

<!-- Header -->
<div class="card mb-6" x-data="{ modal: null, motivoSuspender: '' }">
    <div class="flex items-start justify-between flex-wrap gap-4">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <h2 class="text-es-ink text-xl font-bold">@nome</h2>
                <span class="status-badge @statusClass">@(assinaturaStatus ?? "Sem assinatura")</span>
            </div>
            @{
                var doc = Model.Empresa.TryGetProperty("documento", out var dp) ? dp.GetString() : null;
                var criado = Model.Empresa.TryGetProperty("criadoEm", out var cp) ? cp.GetString() : null;
                DateTime.TryParse(criado, out var criadoDt);
                var planoNome = Model.Assinatura.ValueKind != System.Text.Json.JsonValueKind.Undefined
                    && Model.Assinatura.TryGetProperty("plano", out var pp) && pp.ValueKind != System.Text.Json.JsonValueKind.Null
                    && pp.TryGetProperty("nome", out var pnp) ? pnp.GetString() : "—";
            }
            <div class="text-es-ink-dim text-sm" style="display:flex; align-items:center; gap:6px; flex-wrap:wrap;">
                <span>@(doc ?? "—")</span>
                @if (!string.IsNullOrEmpty(doc))
                {
                    <es-copy value="@doc" label="CNPJ" icon-only="true" />
                }
                <span>· Criado em @criadoDt.ParaBrasilia().ToString("dd/MM/yy")</span>
            </div>
            <div class="text-es-ink-dim text-sm mt-1">Plano: <span class="text-es-ink font-medium">@planoNome</span></div>
        </div>

        <div style="display:flex; gap:6px; flex-wrap:wrap;">
            <form method="post" asp-page-handler="Impersonar" style="display:inline;">
                @Html.AntiForgeryToken()
                <es-button type="submit" variant="ghost" size="sm" icon="external-link">Impersonar</es-button>
            </form>

            @if (assinaturaStatus == "Ativa")
            {
                <es-button variant="danger" size="sm" icon="alert-triangle" x-on:click="modal = 'suspender'">Suspender</es-button>
            }
            else if (assinaturaStatus == "Suspensa")
            {
                <form method="post" asp-page-handler="Reativar" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <es-button type="submit" variant="primary" size="sm" icon="check">Reativar</es-button>
                </form>
            }

            <es-button variant="secondary" size="sm" icon="list-checks" x-on:click="modal = 'plano'">Trocar plano</es-button>
        </div>
    </div>

    <!-- Modal Suspender -->
    <div x-show="modal === 'suspender'" x-cloak class="modal-overlay" @@click.self="modal = null">
        <div class="modal-box" @@click.stop>
            <h3 class="text-es-ink font-semibold mb-4">Suspender Tenant</h3>
            <form method="post" asp-page-handler="Suspender">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label class="form-label">Motivo</label>
                    <textarea name="motivo" x-model="motivoSuspender" rows="2" minlength="10" maxlength="1000"
                              placeholder="Motivo da suspensão..." required
                              class="form-input w-full"></textarea>
                    <p class="text-xs mt-1" :class="motivoSuspender.trim().length >= 10 ? 'text-es-basil' : 'text-es-ink-mute'">
                        <span x-text="motivoSuspender.trim().length"></span> / 10 mínimo
                    </p>
                </div>
                <div class="flex gap-3 justify-end">
                    <button type="button" @@click="modal = null; motivoSuspender = ''" class="btn-secondary">Cancelar</button>
                    <button type="submit" :disabled="motivoSuspender.trim().length < 10" class="btn-danger">Suspender</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Trocar Plano -->
    <div x-show="modal === 'plano'" x-cloak class="modal-overlay" @@click.self="modal = null">
        <div class="modal-box" @@click.stop>
            <h3 class="text-es-ink font-semibold mb-4">Trocar Plano</h3>
            <form method="post" asp-page-handler="TrocarPlano">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label class="form-label">Plano</label>
                    @{
                        var assinPlano = Model.Assinatura.ValueKind != System.Text.Json.JsonValueKind.Undefined
                            && Model.Assinatura.TryGetProperty("plano", out var apObj) && apObj.ValueKind != System.Text.Json.JsonValueKind.Null ? apObj : default;
                        var planoAtualId = assinPlano.ValueKind != System.Text.Json.JsonValueKind.Undefined
                            && assinPlano.TryGetProperty("id", out var apIdP) && apIdP.ValueKind != System.Text.Json.JsonValueKind.Null ? apIdP.GetString() : null;
                        var planoAtualNome = assinPlano.ValueKind != System.Text.Json.JsonValueKind.Undefined
                            && assinPlano.TryGetProperty("nome", out var apNmP) ? apNmP.GetString() : null;
                    }
                    <select name="planoId" class="form-input" required>
                        @foreach (var p in Model.PlanosList)
                        {
                            var pid = p.TryGetProperty("id", out var pidp) ? pidp.GetString() : "";
                            var pnome = p.TryGetProperty("nome", out var pnp2) ? pnp2.GetString() : "";
                            var preco = p.TryGetProperty("precoMensal", out var precoP) ? precoP.GetDecimal() : 0;
                            // Pré-seleciona o plano atual do tenant (id, com fallback por nome) para não
                            // default no primeiro da lista, evitando troca acidental (BUG-002).
                            var ehAtual = (planoAtualId != null && pid == planoAtualId)
                                || (planoAtualId == null && planoAtualNome != null && pnome == planoAtualNome);
                            <option value="@pid" selected="@ehAtual">@pnome — R$ @preco.ToString("N2")</option>
                        }
                    </select>
                </div>
                <div class="flex gap-3 justify-end">
                    <button type="button" @@click="modal = null" class="btn-secondary">Cancelar</button>
                    <button type="submit" class="btn-primary">Salvar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Tabs -->
<div x-data="{
        tab: (new URLSearchParams(window.location.search).get('tab')) || 'visao',
        switchTab(t) {
            this.tab = t;
            // Atualiza URL sem recarregar — permite voltar pra mesma tab no F5/Back.
            const u = new URL(window.location);
            u.searchParams.set('tab', t);
            window.history.replaceState({}, '', u);
        }
     }" class="space-y-4">
    <div class="flex gap-1 rounded-lg p-1 w-fit" style="background:#151f31; border:1px solid rgba(247,242,232,0.12)">
        @foreach (var (t, l) in new[] { ("visao","Visão Geral"), ("usuarios","Usuários"), ("lojas","Lojas"), ("atividade","Atividade"), ("notas","Notas"), ("features","Features"), ("lgpd","LGPD") })
        {
            <button type="button"
                    @@click="switchTab('@t')"
                    x-bind:style="tab === '@t' ? 'background:#f47920;color:#f7f2e8' : 'color:#8793a7'"
                    class="px-4 py-1.5 rounded-md text-sm font-medium transition-all">@l</button>
        }
    </div>

    <!-- Visão geral -->
    <div x-show="tab === 'visao'" class="space-y-4">
        @{
            var usuarios = Model.Usuarios.Count();
            var lojas = Model.Lojas.Count();
            var planoJson = Model.Assinatura.ValueKind != System.Text.Json.JsonValueKind.Undefined
                && Model.Assinatura.TryGetProperty("plano", out var planoProp) && planoProp.ValueKind != System.Text.Json.JsonValueKind.Null
                ? planoProp : default;
        }
        <!-- Métricas rápidas -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="card"><div class="text-es-ink-mute text-xs uppercase tracking-wide mb-1">Usuários</div><div class="text-2xl font-bold text-es-ink">@usuarios</div></div>
            <div class="card"><div class="text-es-ink-mute text-xs uppercase tracking-wide mb-1">Lojas</div><div class="text-2xl font-bold text-es-ink">@lojas</div></div>
            @if (planoJson.ValueKind != System.Text.Json.JsonValueKind.Undefined)
            {
                var limLojas = planoJson.TryGetProperty("limiteLojas", out var ll) ? ll.GetInt32() : 0;
                var limUsuarios = planoJson.TryGetProperty("limiteUsuarios", out var lu) ? lu.GetInt32() : 0;
                var limProdutos = planoJson.TryGetProperty("limiteProdutos", out var lp) ? lp.GetInt32() : 0;
                var preco = planoJson.TryGetProperty("precoMensal", out var pr) ? pr.GetDecimal() : 0m;
                <div class="card">
                    <div class="text-es-ink-mute text-xs uppercase tracking-wide mb-1">Limites do Plano</div>
                    <div class="text-xs text-es-ink-dim space-y-0.5 mt-1">
                        <div>Lojas: @(limLojas == -1 ? "Ilimitado" : limLojas.ToString())</div>
                        <div>Usuários: @(limUsuarios == -1 ? "Ilimitado" : limUsuarios.ToString())</div>
                        <div>Produtos: @(limProdutos == -1 ? "Ilimitado" : limProdutos.ToString())</div>
                    </div>
                </div>
                <div class="card"><div class="text-es-ink-mute text-xs uppercase tracking-wide mb-1">Mensalidade</div><div class="text-2xl font-bold text-es-accent">R$ @preco.ToString("N2")</div></div>
            }
        </div>

        <!-- Trial & Coupon panel -->
        @{
            var trialAtivo = Model.Assinatura.TryGetProperty("trialAtivo", out var tap) && tap.GetBoolean();
            var trialFim = Model.Assinatura.TryGetProperty("trialFim", out var tfp) && tfp.ValueKind != System.Text.Json.JsonValueKind.Null ? tfp.GetString() : null;
            var cupomCodigo = Model.Assinatura.TryGetProperty("cupomCodigo", out var ccp) && ccp.ValueKind != System.Text.Json.JsonValueKind.Null ? ccp.GetString() : null;
            var desconto = Model.Assinatura.TryGetProperty("descontoAplicado", out var dap) && dap.ValueKind != System.Text.Json.JsonValueKind.Null ? (decimal?)dap.GetDecimal() : null;
            DateTime.TryParse(trialFim, out var trialFimDt);
        }
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4" x-data="{ showTrial: false, showCupom: false }">

            <!-- Trial card -->
            <div class="card">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-es-ink font-semibold text-sm">Trial</h3>
                    @if (trialAtivo)
                    {
                        <span class="status-badge badge-ativa">Ativo até @trialFimDt.ParaBrasilia().ToString("dd/MM/yy")</span>
                    }
                    else if (trialFim != null)
                    {
                        <span class="status-badge badge-expirada">Expirado</span>
                    }
                    else
                    {
                        <span class="text-es-ink-mute text-xs">Sem trial</span>
                    }
                </div>
                <button type="button" @@click="showTrial = !showTrial" class="btn-secondary text-xs w-full">
                    Conceder Trial
                </button>
                <div x-show="showTrial" x-cloak class="mt-3" x-data="{ dias: 30 }">
                    <form method="post" asp-page-handler="ConcederTrial" class="flex gap-2 items-end">
                        @Html.AntiForgeryToken()
                        <div class="flex-1">
                            <label class="form-label">Dias</label>
                            <input type="number" name="diasTrial" x-model.number="dias" min="1" max="90" class="form-input" required />
                            <p x-show="dias < 1 || dias > 90" x-cloak class="text-xs mt-1" style="color:var(--crit-600);">
                                Informe de 1 a 90 dias.
                            </p>
                        </div>
                        <button type="submit" :disabled="!(dias >= 1 && dias <= 90)" class="btn-primary text-sm">Conceder</button>
                    </form>
                </div>
            </div>

            <!-- Cupom card -->
            <div class="card">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-es-ink font-semibold text-sm">Cupom</h3>
                    @if (cupomCodigo != null)
                    {
                        <span class="font-mono text-xs text-es-accent font-bold">@cupomCodigo</span>
                    }
                    else
                    {
                        <span class="text-es-ink-mute text-xs">Nenhum aplicado</span>
                    }
                </div>
                @if (desconto.HasValue)
                {
                    <div class="text-xs text-es-ink-dim mb-3">Desconto aplicado: <b class="text-es-accent">@desconto.Value.ToString("N2")</b></div>
                }
                <button type="button" @@click="showCupom = !showCupom" class="btn-secondary text-xs w-full">
                    Aplicar Cupom
                </button>
                <div x-show="showCupom" x-cloak class="mt-3">
                    <form method="post" asp-page-handler="AplicarCupom" class="flex gap-2 items-end" x-data="{ codigo: '' }">
                        @Html.AntiForgeryToken()
                        <div class="flex-1">
                            <label class="form-label">Código</label>
                            <input type="text" name="codigo" x-model="codigo" class="form-input" placeholder="Ex: PROMO10"
                                   style="text-transform:uppercase" required />
                        </div>
                        <button type="submit" :disabled="codigo.trim().length < 3" class="btn-primary text-sm">Aplicar</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- F4: Card Sincronização Mobile (Casa da Babá APK / PWA) -->
        <div class="card" x-data="mobileSyncHealth('@Model.Id')" x-init="carregar()">
            <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2">
                    <h3 class="text-es-ink font-semibold">Sincronização Mobile</h3>
                    <span x-show="loaded && healthy" x-cloak
                          class="text-xs px-2 py-0.5 rounded-full"
                          style="background:rgba(34,197,94,0.15);color:#4ade80;border:1px solid rgba(34,197,94,0.35)">
                        ✓ sincronizado
                    </span>
                    <span x-show="loaded && !healthy" x-cloak
                          class="text-xs px-2 py-0.5 rounded-full"
                          style="background:rgba(248,113,113,0.15);color:#fca5a5;border:1px solid rgba(248,113,113,0.35)">
                        ⚠ <span x-text="totalPending"></span> pendente(s)
                    </span>
                </div>
                <button type="button" @@click="carregar()" class="text-xs text-es-ink-dim hover:text-es-ink">↻ atualizar</button>
            </div>
            <div x-show="!loaded" class="text-xs text-es-ink-dim">carregando…</div>
            <div x-show="loaded && erro" x-cloak class="text-xs" style="color:var(--crit-600);">Não foi possível carregar (timeout/erro). Tente ↻ atualizar.</div>
            <div x-show="loaded && !erro" x-cloak class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                <template x-for="m in metricas" :key="m.label">
                    <div class="rounded-lg p-3" style="background:#0f172a;border:1px solid rgba(247,242,232,0.08)">
                        <div class="text-[11px] uppercase tracking-wider text-es-ink-mute" x-text="m.label"></div>
                        <div class="flex items-baseline gap-2 mt-1">
                            <span class="text-lg font-semibold text-es-ink" x-text="m.total"></span>
                            <span class="text-xs"
                                  :style="m.pending > 0 ? 'color:#fca5a5' : 'color:#4ade80'"
                                  x-text="m.pending > 0 ? (m.pending + ' sem link') : 'tudo linkado'"></span>
                        </div>
                    </div>
                </template>
            </div>
            <div x-show="loaded && entregueSemVenda > 0" x-cloak
                 class="mt-3 text-xs rounded-lg px-3 py-2"
                 style="background:rgba(248,113,113,0.10);border:1px solid rgba(248,113,113,0.30);color:#fca5a5">
                <strong x-text="entregueSemVenda"></strong> pedido(s) entregue(s) sem Venda — rode backfill.
            </div>
            <div x-show="loaded && lastSyncAt" x-cloak class="mt-3 text-xs text-es-ink-mute">
                <span x-text="devices"></span> device(s) pareados · último sync <span x-text="lastSyncFormatado"></span>
            </div>
        </div>
    </div>

    <!-- Usuários -->
    <div x-show="tab === 'usuarios'" x-cloak x-data="{
            sessoesUserId: null, sessoesData: null, sessoesLoading: false, sessoesErro: '',
            modalNovoUsuario: false,
            async carregarSessoes(uid) {
                this.sessoesUserId = uid;
                this.sessoesData = null;
                this.sessoesErro = '';
                this.sessoesLoading = true;
                try {
                    const r = await fetch('/Tenants/Detail/@Model.Id?handler=SessoesUsuario&userId=' + uid,
                        { credentials: 'same-origin', cache: 'no-store' });
                    if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                    const d = await r.json();
                    if (!r.ok) {
                        this.sessoesErro = (d && d.error) || ('Falha HTTP ' + r.status);
                        return;
                    }
                    this.sessoesData = d.data || d;
                } catch (e) {
                    this.sessoesErro = 'Falha de rede: ' + (e.message || e);
                } finally {
                    this.sessoesLoading = false;
                }
            }
         }">
        <div class="flex items-center justify-between mb-3">
            <div class="text-es-ink-dim text-sm">@Model.Usuarios.Count() @(Model.Usuarios.Count() == 1 ? "usuário cadastrado" : "usuários cadastrados") neste cliente</div>
            <button type="button" @@click="modalNovoUsuario = true" class="btn-primary text-sm">
                + Adicionar usuário
            </button>
        </div>
        <div class="card p-0 overflow-x-auto">
            <table class="table-admin">
                <thead><tr><th class="whitespace-nowrap min-w-[180px]">Nome</th><th>E-mail</th><th>Nível</th><th>Último acesso</th><th>Status</th><th class="text-right">Ações</th></tr></thead>
                <tbody>
                    @if (!Model.Usuarios.Any())
                    {
                        <tr><td colspan="6" class="text-es-ink-mute text-center py-8 text-sm">
                            Cliente sem usuários cadastrados.
                            <button type="button" @@click="modalNovoUsuario = true" class="text-es-accent hover:underline ml-1">Adicionar o primeiro →</button>
                        </td></tr>
                    }
                    @foreach (var u in Model.Usuarios)
                    {
                        var uid = u.TryGetProperty("id", out var uidp) ? uidp.GetString() : "";
                        var unome = u.TryGetProperty("nome", out var unp) ? unp.GetString() : "";
                        var uemail = u.TryGetProperty("email", out var uep) ? uep.GetString() : "";
                        var nivel = u.TryGetProperty("nivelAcesso", out var univelP) && univelP.ValueKind != System.Text.Json.JsonValueKind.Null ? univelP.GetString() : "—";
                        var ativo = u.TryGetProperty("ativo", out var uap) && uap.GetBoolean();
                        var ultimo = u.TryGetProperty("ultimoAcessoEm", out var uup) && uup.ValueKind != System.Text.Json.JsonValueKind.Null ? uup.GetString() : null;
                        DateTime.TryParse(ultimo, out var ultimoDt);
                        @* Nome/email do tenant são dados não-confiáveis: emitidos via data-* (o Razor
                           HTML-encoda o atributo) e lidos como string pelo Alpine. Nunca interpolar
                           direto em literal JS/atributo (era stored-XSS). *@
                        <tr data-uid="@uid" data-unome="@unome" data-uemail="@uemail"
                            x-data="Object.assign({ open: false, _uid: $el.dataset.uid, _unome: $el.dataset.unome, _uemail: $el.dataset.uemail }, piiReveal($el.dataset.uid, 'email', $el.dataset.uemail))">
                            <td class="text-es-ink font-medium whitespace-nowrap max-w-[220px] overflow-hidden text-ellipsis" title="@unome">@unome</td>
                            <td class="text-es-ink-dim font-mono text-xs">
                                <span x-text="piiValor"></span>
                                <button type="button" :title="piiVisivel ? 'Re-mascarar' : 'Ver completo (auditado)'"
                                        @@click="piiVisivel ? remascarar() : abrirRevealModal()"
                                        class="ml-1 text-es-ink-mute hover:text-es-accent text-xs">
                                    <span x-text="piiVisivel ? '🙈' : '👁'"></span>
                                </button>
                                <span x-show="piiVisivel && piiTtl > 0" x-cloak class="text-[10px] text-es-ink-mute ml-1">
                                    (<span x-text="Math.ceil(piiTtl/60)"></span> min)
                                </span>
                            </td>
                            <td class="text-es-ink-dim">@nivel</td>
                            <td class="text-es-ink-dim">@(ultimoDt != default ? ultimoDt.ParaBrasilia().ToString("dd/MM/yy HH:mm") : "—")</td>
                            <td><span class="status-badge @(ativo ? "badge-ativa" : "badge-suspensa")">@(ativo ? "Ativo" : "Inativo")</span></td>
                            <td class="text-right">
                                <div class="relative" @@click.outside="open = false">
                                <button type="button" @@click="open = !open"
                                        class="btn-secondary text-xs px-3 py-1">Ações ▾</button>
                                <div x-show="open" x-cloak
                                     class="absolute right-0 mt-1 w-56 z-30 rounded-lg shadow-2xl py-1"
                                     style="background:#1a2540;border:1px solid rgba(247,242,232,0.12)">
                                    <button type="button" class="w-full text-left px-3 py-2 text-xs text-es-ink-dim hover:bg-es-surface-2 hover:text-es-ink"
                                            @@click="open=false; $dispatch('open-justificar', {
                                                endpoint: '/Tenants/Detail/@Model.Id?handler=ResetSenhaUsuario&userId=@uid',
                                                acao: 'Resetar senha de ' + _unome,
                                                resumo: 'Uma senha temporária será gerada para ' + _uemail + '. As sessões ativas serão encerradas — o usuário vai precisar logar de novo.',
                                                variant: 'danger',
                                                confirmLabel: 'Resetar senha (auditado)'
                                            })">
                                        🔑 Resetar senha
                                    </button>
                                    <button type="button" class="w-full text-left px-3 py-2 text-xs text-es-ink-dim hover:bg-es-surface-2 hover:text-es-ink"
                                            @@click="open=false; $dispatch('open-justificar', {
                                                endpoint: '/Tenants/Detail/@Model.Id?handler=ForcarLogoutUsuario&userId=@uid',
                                                acao: 'Forçar logout de ' + _unome,
                                                resumo: 'Todas as sessões ativas serão encerradas. O usuário vai precisar logar de novo em todos os dispositivos.',
                                                variant: 'danger',
                                                confirmLabel: 'Forçar logout (auditado)'
                                            })">
                                        🚪 Forçar logout
                                    </button>
                                    <button type="button" class="w-full text-left px-3 py-2 text-xs text-es-ink-dim hover:bg-es-surface-2 hover:text-es-ink"
                                            @@click="open=false; carregarSessoes('@uid')">
                                        👁 Ver sessões
                                    </button>
                                    <div class="border-t my-1" style="border-color:rgba(247,242,232,0.08)"></div>
                                    <button type="button" class="w-full text-left px-3 py-2 text-xs text-es-ink-dim hover:bg-es-surface-2 hover:text-es-ink"
                                            @@click="open=false; $dispatch('open-editar-usuario', { userId: _uid, nome: _unome, email: _uemail })">
                                        ✏️ Editar nome/email
                                    </button>
                                    @if (ativo)
                                    {
                                        <button type="button" class="w-full text-left px-3 py-2 text-xs text-amber-300 hover:bg-es-surface-2"
                                                @@click="open=false; $dispatch('open-justificar', {
                                                    endpoint: '/Tenants/Detail/@Model.Id?handler=DesativarUsuario&userId=@uid',
                                                    acao: 'Desativar ' + _unome,
                                                    resumo: 'O usuário não conseguirá mais fazer login. Sessões ativas serão encerradas. Pode ser reativado depois.',
                                                    variant: 'danger',
                                                    confirmLabel: 'Desativar (auditado)'
                                                })">
                                            🚫 Desativar conta
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="w-full text-left px-3 py-2 text-xs text-es-basil hover:bg-es-surface-2"
                                                @@click="open=false; $dispatch('open-justificar', {
                                                    endpoint: '/Tenants/Detail/@Model.Id?handler=ReativarUsuario&userId=@uid',
                                                    acao: 'Reativar ' + _unome,
                                                    resumo: 'O usuário voltará a conseguir fazer login. Tentativas de bloqueio serão zeradas.',
                                                    variant: 'primary',
                                                    confirmLabel: 'Reativar (auditado)'
                                                })">
                                            ✓ Reativar conta
                                        </button>
                                    }
                                    <div class="border-t my-1" style="border-color:rgba(247,242,232,0.08)"></div>
                                    <button type="button" class="w-full text-left px-3 py-2 text-xs text-red-400 hover:bg-red-500/10"
                                            @@click="open=false; $dispatch('open-anonimizar', { userId: _uid, nome: _unome, email: _uemail })">
                                        ⚠️ Anonimizar (LGPD)
                                    </button>
                                </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Modal Sessões -->
        <div x-show="sessoesUserId" x-cloak class="modal-overlay" @@click.self="sessoesUserId = null" @@keydown.escape.window="sessoesUserId = null">
            <div class="modal-box max-w-2xl" @@click.stop>
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-es-ink font-semibold">Sessões ativas</h3>
                    <button type="button" @@click="sessoesUserId = null" class="text-es-ink-mute hover:text-es-ink">✕</button>
                </div>
                <div x-show="sessoesLoading" x-cloak class="text-es-ink-mute text-sm py-6 text-center">Carregando sessões…</div>
                <div x-show="sessoesErro" x-cloak class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-3 py-2 text-sm" x-text="sessoesErro"></div>
                <template x-if="sessoesData && !sessoesLoading">
                    <div>
                        <div class="text-es-ink-dim text-xs mb-3">
                            <span x-text="sessoesData.usuarioNome"></span> ·
                            <span x-text="sessoesData.usuarioEmail" class="font-mono"></span> ·
                            <span class="font-bold text-es-ink" x-text="plural(sessoesData.ativas, 'ativa', 'ativas') + ' de ' + sessoesData.total"></span>
                        </div>
                        <div class="max-h-96 overflow-y-auto space-y-2">
                            <template x-for="s in (sessoesData.sessoes || [])" :key="s.id">
                                <div class="rounded-lg p-3 text-xs" :style="s.ativa ? 'background:rgba(79,191,159,.08);border:1px solid rgba(79,191,159,.2)' : 'background:rgba(120,120,120,.06);border:1px solid rgba(120,120,120,.15)'">
                                    <div class="flex items-center justify-between mb-1">
                                        <span class="font-mono text-es-ink" x-text="s.ip || '(sem ip)'"></span>
                                        <span class="status-badge" :class="s.ativa ? 'badge-ativa' : 'badge-expirada'" x-text="s.ativa ? 'Ativa' : (s.revogado ? 'Revogada' : 'Expirada')"></span>
                                    </div>
                                    <div class="text-es-ink-mute truncate" x-text="s.userAgent || '(sem user-agent)'"></div>
                                    <div class="text-es-ink-mute mt-1">
                                        Criada: <span x-text="new Date(s.criadoEm).toLocaleString('pt-BR')"></span>
                                        · Expira: <span x-text="new Date(s.expiraEm).toLocaleString('pt-BR')"></span>
                                    </div>
                                </div>
                            </template>
                            <template x-if="(sessoesData.sessoes || []).length === 0">
                                <div class="text-es-ink-mute text-sm text-center py-6">Sem sessões registradas para este usuário.</div>
                            </template>
                        </div>
                    </div>
                </template>
            </div>
        </div>

        @{ var afEditar = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken; }

        <!-- Modal Adicionar usuário ao tenant -->
        <div x-show="modalNovoUsuario" x-cloak class="modal-overlay"
             @@click.self="modalNovoUsuario = false" @@keydown.escape.window="modalNovoUsuario = false"
             role="dialog" aria-modal="true" aria-labelledby="modal-novo-usuario-title">
            <div class="modal-box max-w-md" x-data="{ motivoNovo: '', submitting: false }" @@click.stop>
                <div class="flex items-start justify-between gap-3 mb-1">
                    <div>
                        <h3 id="modal-novo-usuario-title" class="text-es-ink font-semibold">Adicionar usuário ao cliente</h3>
                        <p class="text-es-ink-dim text-xs mt-1">
                            Cria o login no tenant. Senha temporária é gerada e enviada por e-mail.
                        </p>
                    </div>
                    <button type="button" @@click="modalNovoUsuario = false" aria-label="Fechar"
                            class="text-es-ink-mute hover:text-es-ink text-xl leading-none">×</button>
                </div>

                <form method="post" asp-page-handler="CriarUsuario" @@submit="submitting = true" class="mt-4 space-y-3">
                    <input type="hidden" name="__RequestVerificationToken" value="@afEditar" />

                    <div>
                        <label class="form-label">Nome</label>
                        <input type="text" name="nome" required minlength="2" maxlength="120"
                               placeholder="João Pereira" class="form-input w-full" />
                    </div>

                    <div>
                        <label class="form-label">E-mail</label>
                        <input type="email" name="email" required maxlength="160"
                               placeholder="joao@empresa.com.br" class="form-input w-full font-mono" />
                        <p class="text-xs text-es-ink-mute mt-1">Tem que ser único no sistema todo.</p>
                    </div>

                    <div>
                        <label class="form-label">Nível de acesso</label>
                        <select name="nivel" class="form-input w-full">
                            <option value="Operador" selected>Operador (default)</option>
                            <option value="Gerente">Gerente</option>
                            <option value="Admin">Admin</option>
                            <option value="Visualizador">Visualizador (somente leitura)</option>
                        </select>
                        <p class="text-xs text-es-ink-mute mt-1">
                            Admin pode tudo. Gerente vê relatórios. Operador opera caixa. Visualizador só lê.
                        </p>
                    </div>

                    <div>
                        <label class="form-label">Justificativa <span class="text-es-ink-mute">(audit log)</span></label>
                        <textarea name="motivo" x-model="motivoNovo" rows="2" minlength="10" maxlength="1000" required
                                  placeholder="Ex.: cliente abriu chamado #1234, admin original saiu da empresa"
                                  class="form-input w-full font-mono text-sm"></textarea>
                        <p class="text-xs mt-1" :class="motivoNovo.trim().length >= 10 ? 'text-es-basil' : 'text-es-ink-mute'">
                            <span x-text="motivoNovo.trim().length"></span> / 10 mínimo
                        </p>
                    </div>

                    <label class="flex items-center gap-2 text-xs text-es-ink-dim">
                        <input type="checkbox" name="enviarEmail" value="true" checked class="form-checkbox" />
                        Enviar a senha temporária por e-mail também
                    </label>

                    <div class="flex gap-3 justify-end pt-2">
                        <button type="button" @@click="modalNovoUsuario = false" :disabled="submitting"
                                class="btn-secondary text-sm">Cancelar</button>
                        <button type="submit" :disabled="motivoNovo.trim().length < 10 || submitting"
                                class="btn-primary text-sm">
                            <span x-show="!submitting">Adicionar usuário (auditado)</span>
                            <span x-show="submitting" x-cloak>Adicionando…</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Modal Editar usuário (com diff before/after) -->
        <div x-data="editarUsuarioModal()" x-init="init()"
             x-show="open" x-cloak class="modal-overlay"
             @@click.self="close()" @@keydown.escape.window="close()">
            <div class="modal-box max-w-md" @@click.stop>
                <div class="flex items-start gap-3 mb-4">
                    <div class="text-2xl">✏️</div>
                    <div class="flex-1">
                        <h3 class="text-es-ink font-semibold">Editar dados do usuário</h3>
                        <p class="text-es-ink-dim text-xs mt-1">As alterações são auditadas com seu nome.</p>
                    </div>
                </div>

                <form method="post" :action="'/Tenants/Detail/@Model.Id?handler=AtualizarUsuario&userId=' + ctx.userId" @@submit="submitting = true">
                    <input type="hidden" name="__RequestVerificationToken" value="@afEditar" />

                    <div class="mb-3">
                        <label class="form-label">Nome</label>
                        <input type="text" name="nome" x-model="nome" required minlength="2" maxlength="120"
                               class="form-input w-full text-sm" />
                        <p x-show="nome !== ctx.nome" x-cloak class="text-xs text-es-accent mt-1">
                            <span class="line-through text-red-400" x-text="ctx.nome"></span>
                            → <span class="text-es-basil font-semibold" x-text="nome"></span>
                        </p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">E-mail</label>
                        <input type="email" name="email" x-model="email" maxlength="160"
                               class="form-input w-full text-sm font-mono" />
                        <p x-show="email !== ctx.email && email.length > 0" x-cloak class="text-xs mt-1">
                            <span class="text-amber-400">⚠ Trocar email obriga o usuário a confirmar de novo.</span><br/>
                            <span class="line-through text-red-400 font-mono" x-text="ctx.email"></span>
                            → <span class="text-es-basil font-mono font-semibold" x-text="email"></span>
                        </p>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Justificativa <span class="text-es-ink-mute">(audit log)</span></label>
                        <textarea name="motivo" x-model="motivo" rows="2" minlength="10" maxlength="1000" required
                                  placeholder="Ex.: cliente acionou suporte chamado #1234"
                                  class="form-input w-full text-sm font-mono"></textarea>
                        <p class="text-xs mt-1" :class="motivo.trim().length >= 10 ? 'text-es-basil' : 'text-es-ink-mute'">
                            <span x-text="motivo.trim().length"></span> / 10 mínimo
                        </p>
                    </div>

                    <div class="flex gap-3 justify-end">
                        <button type="button" @@click="close()" :disabled="submitting" class="btn-secondary text-sm">Cancelar</button>
                        <button type="submit" :disabled="!podeEnviar || submitting" class="btn-primary text-sm">
                            <span x-show="!submitting">Salvar (auditado)</span>
                            <span x-show="submitting" x-cloak>Enviando…</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

        <script>
        function editarUsuarioModal() {
            return {
                open: false,
                submitting: false,
                ctx: { userId: '', nome: '', email: '' },
                nome: '',
                email: '',
                motivo: '',
                init() {
                    window.addEventListener('open-editar-usuario', (e) => {
                        this.ctx = Object.assign({ userId: '', nome: '', email: '' }, e.detail || {});
                        this.nome = this.ctx.nome || '';
                        this.email = this.ctx.email || '';
                        this.motivo = '';
                        this.submitting = false;
                        this.open = true;
                    });
                },
                get podeEnviar() {
                    if (this.motivo.trim().length < 10) return false;
                    if (!this.ctx.userId) return false;
                    const trocouNome = this.nome.trim() && this.nome.trim() !== this.ctx.nome;
                    const trocouEmail = this.email.trim() && this.email.trim() !== this.ctx.email;
                    return trocouNome || trocouEmail;
                },
                close() { if (!this.submitting) this.open = false; }
            };
        }

        // PII reveal — mostra valor por janela curta após auditoria.
        // tenantId é capturado de window.__tenantId definido logo abaixo.
        function piiReveal(userId, campo, valorMascarado) {
            return {
                piiVisivel: false,
                piiValor: valorMascarado,
                piiTtl: 0,
                _tickHandle: null,
                abrirRevealModal() {
                    window.dispatchEvent(new CustomEvent('open-pii-reveal', {
                        detail: { userId, campo, callback: (valor, expiraEm) => {
                            this.piiValor = valor;
                            this.piiVisivel = true;
                            const expiresAt = new Date(expiraEm).getTime();
                            const tick = () => {
                                this.piiTtl = Math.max(0, Math.floor((expiresAt - Date.now()) / 1000));
                                if (this.piiTtl <= 0) { this.remascarar(); }
                            };
                            tick();
                            clearInterval(this._tickHandle);
                            this._tickHandle = setInterval(tick, 1000);
                        }}
                    }));
                },
                remascarar() {
                    this.piiVisivel = false;
                    this.piiValor = valorMascarado;
                    this.piiTtl = 0;
                    clearInterval(this._tickHandle);
                }
            };
        }
        window.__tenantId = '@Model.Id';
        function plural(n, sg, pl) { return n + ' ' + (n === 1 ? sg : pl); }
        </script>

        <!-- Modal global PII reveal — escuta `open-pii-reveal` -->
        <div x-data="piiRevealModal()" x-init="init()" x-show="open" x-cloak
             class="modal-overlay" @@click.self="close()" @@keydown.escape.window="close()">
            <div class="modal-box max-w-md" @@click.stop>
                <div class="flex items-start gap-3 mb-4">
                    <div class="text-2xl">👁</div>
                    <div class="flex-1">
                        <h3 class="text-es-ink font-semibold">Visualizar dado pessoal</h3>
                        <p class="text-es-ink-dim text-xs mt-1">
                            Você está prestes a visualizar <b x-text="cfg.campo"></b> em texto-claro.
                            Esta visualização será registrada no log LGPD com seu nome.
                            O valor ficará visível por 5 minutos e depois será re-mascarado automaticamente.
                        </p>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Justificativa <span class="text-es-ink-mute">(audit log)</span></label>
                    <textarea x-model="motivo" rows="2" minlength="10" maxlength="1000"
                              placeholder="Ex.: cliente confirmou identidade no chamado #1234"
                              class="form-input w-full text-sm font-mono"></textarea>
                    <p class="text-xs mt-1" :class="motivo.trim().length >= 10 ? 'text-es-basil' : 'text-es-ink-mute'">
                        <span x-text="motivo.trim().length"></span> / 10 mínimo
                    </p>
                </div>
                <div x-show="erro" x-cloak class="text-xs text-red-400 mb-3" x-text="erro"></div>

                <div class="flex gap-3 justify-end">
                    <button type="button" @@click="close()" :disabled="submitting" class="btn-secondary text-sm">Cancelar</button>
                    <button type="button" @@click="confirmar()" :disabled="motivo.trim().length < 10 || submitting" class="btn-primary text-sm">
                        <span x-show="!submitting">Mostrar (auditado)</span>
                        <span x-show="submitting" x-cloak>Buscando…</span>
                    </button>
                </div>
            </div>
        </div>

        <script>
        function piiRevealModal() {
            return {
                open: false,
                submitting: false,
                erro: '',
                motivo: '',
                cfg: { userId: '', campo: '', callback: null },
                init() {
                    window.addEventListener('open-pii-reveal', (e) => {
                        this.cfg = Object.assign({ userId: '', campo: '', callback: null }, e.detail || {});
                        this.motivo = '';
                        this.erro = '';
                        this.submitting = false;
                        this.open = true;
                    });
                },
                async confirmar() {
                    if (this.motivo.trim().length < 10) return;
                    this.submitting = true; this.erro = '';
                    try {
                        const url = '/Tenants/Detail/' + window.__tenantId
                            + '?handler=PiiUsuario'
                            + '&userId=' + encodeURIComponent(this.cfg.userId)
                            + '&campo=' + encodeURIComponent(this.cfg.campo)
                            + '&motivo=' + encodeURIComponent(this.motivo.trim());
                        const r = await fetch(url, { credentials: 'same-origin', cache: 'no-store' });
                        const d = await r.json();
                        if (!r.ok) {
                            this.erro = (d && d.error) || ('Falha HTTP ' + r.status);
                            this.submitting = false;
                            return;
                        }
                        const data = d.data || d;
                        if (this.cfg.callback) this.cfg.callback(data.valor, data.expiraEm);
                        this.open = false;
                    } catch (e) {
                        this.erro = 'Falha de rede: ' + (e.message || e);
                    } finally {
                        this.submitting = false;
                    }
                },
                close() { if (!this.submitting) this.open = false; }
            };
        }
        </script>

        <!-- Modal Anonimizar (LGPD double-confirm) -->
        @{ var afLgpd = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken; }
        <div x-data="anonimizarModal()" x-init="init()" x-show="open" x-cloak
             class="modal-overlay" @@click.self="close()" @@keydown.escape.window="close()">
            <div class="modal-box max-w-lg" @@click.stop>
                <div class="flex items-start gap-3 mb-4">
                    <div class="text-2xl">⚠️</div>
                    <div class="flex-1">
                        <h3 class="text-red-400 font-bold">Anonimizar usuário</h3>
                        <p class="text-es-ink-dim text-xs mt-1">
                            <strong class="text-red-400">Operação irreversível.</strong> Os dados pessoais
                            (nome, email, avatar) serão pseudonimizados; senha será apagada; sessões e
                            tokens de credencial removidos. AuditLog/movimentações ficam preservados
                            (UsuarioId mantido) — orientação ANPD.
                        </p>
                    </div>
                </div>

                <form method="post" :action="'/Tenants/Detail/@Model.Id?handler=AnonimizarUsuario&userId=' + ctx.userId" @@submit="submitting = true">
                    <input type="hidden" name="__RequestVerificationToken" value="@afLgpd" />

                    <div class="mb-4 p-3 rounded-lg" style="background:rgba(248,113,113,0.08);border:1px solid rgba(248,113,113,0.2)">
                        <p class="text-xs text-red-300 mb-2">
                            Para confirmar, digite o <strong>email exato</strong> do usuário-alvo:
                        </p>
                        <div class="text-es-ink-mute text-xs mb-2">Email do usuário: <span class="font-mono text-es-ink" x-text="ctx.email"></span></div>
                        <input type="email" name="confirmacaoEmail" x-model="confirmacaoEmail"
                               placeholder="email@dominio.com"
                               class="form-input w-full text-sm font-mono"
                               :class="emailMatch ? 'border-es-basil/50' : (confirmacaoEmail.length > 0 ? 'border-red-500/50' : '')" />
                        <p x-show="confirmacaoEmail.length > 0 && !emailMatch" x-cloak class="text-xs text-red-400 mt-1">
                            Email digitado não bate com o do usuário-alvo.
                        </p>
                        <p x-show="emailMatch" x-cloak class="text-xs text-es-basil mt-1">✓ Email confere.</p>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Justificativa <span class="text-es-ink-mute">(≥20 chars, audit log LGPD)</span></label>
                        <textarea name="motivo" x-model="motivo" rows="3" minlength="20" maxlength="1000" required
                                  placeholder="Ex.: cliente solicitou exclusão de conta via canal de suporte conforme chamado #1234"
                                  class="form-input w-full text-sm font-mono"></textarea>
                        <p class="text-xs mt-1" :class="motivo.trim().length >= 20 ? 'text-es-basil' : 'text-es-ink-mute'">
                            <span x-text="motivo.trim().length"></span> / 20 mínimo
                        </p>
                    </div>

                    <div class="flex gap-3 justify-end">
                        <button type="button" @@click="close()" :disabled="submitting" class="btn-secondary text-sm">Cancelar</button>
                        <button type="submit" :disabled="!podeEnviar || submitting" class="btn-danger text-sm">
                            <span x-show="!submitting">Anonimizar definitivamente</span>
                            <span x-show="submitting" x-cloak>Anonimizando…</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <script>
        function anonimizarModal() {
            return {
                open: false,
                submitting: false,
                ctx: { userId: '', nome: '', email: '' },
                confirmacaoEmail: '',
                motivo: '',
                init() {
                    window.addEventListener('open-anonimizar', (e) => {
                        this.ctx = Object.assign({ userId: '', nome: '', email: '' }, e.detail || {});
                        this.confirmacaoEmail = '';
                        this.motivo = '';
                        this.submitting = false;
                        this.open = true;
                    });
                },
                get emailMatch() {
                    return this.confirmacaoEmail.trim().toLowerCase() === (this.ctx.email || '').trim().toLowerCase();
                },
                get podeEnviar() {
                    return this.emailMatch && this.motivo.trim().length >= 20;
                },
                close() { if (!this.submitting) this.open = false; }
            };
        }
        </script>

    <!-- Lojas -->
    @{ var afLojas = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken; }
    <div x-show="tab === 'lojas'" x-cloak x-data="{ novaOpen: false, editandoLoja: null }">
        <div class="flex justify-end mb-4">
            <button type="button" @@click="novaOpen = true" class="btn-primary text-sm">+ Nova Loja</button>
        </div>

        @if (!Model.Lojas.Any())
        {
            <div class="card text-center text-es-ink-mute text-sm py-10">
                Cliente ainda não criou lojas. Use <strong class="text-es-ink">+ Nova Loja</strong> acima.
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                @foreach (var l in Model.Lojas)
                {
                    var lid = l.TryGetProperty("id", out var lidp) ? lidp.GetString() : "";
                    var lnome = l.TryGetProperty("nome", out var lnp) ? lnp.GetString() : "";
                    var ldesc = l.TryGetProperty("descricao", out var ldp) && ldp.ValueKind != System.Text.Json.JsonValueKind.Null ? ldp.GetString() : "";
                    var ldoc = l.TryGetProperty("documento", out var ldocp) && ldocp.ValueKind != System.Text.Json.JsonValueKind.Null ? ldocp.GetString() : "";
                    var lend = l.TryGetProperty("endereco", out var lendp) && lendp.ValueKind != System.Text.Json.JsonValueKind.Null ? lendp.GetString() : "";
                    var ltel = l.TryGetProperty("telefone", out var ltelp) && ltelp.ValueKind != System.Text.Json.JsonValueKind.Null ? ltelp.GetString() : "";
                    var lativa = l.TryGetProperty("ativa", out var lap) && lap.GetBoolean();
                    // Contexto JSON pro modal de edição — emitido via data-loja (o Razor HTML-encoda
                    // o atributo); o Alpine faz JSON.parse. Nome da loja é dado não-confiável → data-lnome.
                    var lojaJson = System.Text.Json.JsonSerializer.Serialize(new { id = lid, nome = lnome, descricao = ldesc, documento = ldoc, endereco = lend, telefone = ltel });
                    <div class="card flex flex-col">
                        <div class="flex items-start justify-between mb-2">
                            <h4 class="text-es-ink font-semibold flex-1 truncate" title="@lnome">@lnome</h4>
                            <span class="status-badge ml-2 @(lativa ? "badge-ativa" : "badge-suspensa")">@(lativa ? "Ativa" : "Inativa")</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(ldesc))
                        {
                            <p class="text-es-ink-dim text-xs mb-2 line-clamp-2">@ldesc</p>
                        }
                        <dl class="text-xs space-y-1 text-es-ink-mute mt-1 mb-3">
                            @if (!string.IsNullOrWhiteSpace(ldoc)) { <div><span class="text-es-ink-dim">Doc:</span> <span class="text-es-ink-dim font-mono">@ldoc</span></div> }
                            @if (!string.IsNullOrWhiteSpace(lend)) { <div><span class="text-es-ink-dim">End:</span> <span class="text-es-ink-dim">@lend</span></div> }
                            @if (!string.IsNullOrWhiteSpace(ltel)) { <div><span class="text-es-ink-dim">Tel:</span> <span class="text-es-ink-dim font-mono">@ltel</span></div> }
                        </dl>
                        <div class="flex gap-2 mt-auto pt-2" style="border-top:1px solid rgba(247,242,232,0.06)">
                            <button type="button" data-loja="@lojaJson" @@click="editandoLoja = JSON.parse($el.dataset.loja)" class="btn-secondary text-xs flex-1">✏️ Editar</button>
                            @if (lativa)
                            {
                                <button type="button" data-lnome="@lnome"
                                        @@click="$dispatch('open-justificar', {
                                            endpoint: '/Tenants/Detail/@Model.Id?handler=ToggleLoja&lojaId=@lid',
                                            acao: 'Desativar loja ' + $el.dataset.lnome,
                                            resumo: 'A loja não aparecerá mais para o cliente. Histórico (vendas, estoque) é preservado. Pode ser reativada.',
                                            variant: 'danger',
                                            confirmLabel: 'Desativar (auditado)',
                                            extraFields: '<input type=&quot;hidden&quot; name=&quot;ativa&quot; value=&quot;false&quot; />'
                                        })"
                                        class="btn-danger text-xs">🚫 Desativar</button>
                            }
                            else
                            {
                                <button type="button" data-lnome="@lnome"
                                        @@click="$dispatch('open-justificar', {
                                            endpoint: '/Tenants/Detail/@Model.Id?handler=ToggleLoja&lojaId=@lid',
                                            acao: 'Reativar loja ' + $el.dataset.lnome,
                                            resumo: 'A loja voltará a aparecer para o cliente.',
                                            variant: 'primary',
                                            confirmLabel: 'Reativar (auditado)',
                                            extraFields: '<input type=&quot;hidden&quot; name=&quot;ativa&quot; value=&quot;true&quot; />'
                                        })"
