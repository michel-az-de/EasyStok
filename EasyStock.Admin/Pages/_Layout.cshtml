<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "EasyStock Admin")</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'admin-bg': '#0f172a',
                        'admin-sidebar': '#1e293b',
                        'admin-accent': '#7c3aed',
                    }
                }
            }
        }
    </script>
    <style>
        [x-cloak] { display: none !important; }
        .sidebar-link { display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 1rem; border-radius: 0.5rem; color: #94a3b8; transition: all 0.15s; }
        .sidebar-link:hover { color: white; background: #334155; }
        .sidebar-link.active { background: #7c3aed; color: white; }
    </style>
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="h-full bg-slate-950 text-white" x-data="adminApp()" x-init="init()">

<div class="flex h-full min-h-screen">

    <!-- Sidebar -->
    <aside class="w-64 bg-slate-800 flex flex-col fixed inset-y-0 left-0 z-50">
        <!-- Logo -->
        <div class="flex items-center gap-3 px-6 py-5 border-b border-slate-700">
            <div class="w-8 h-8 bg-violet-600 rounded-lg flex items-center justify-center">
                <span class="text-white font-bold text-sm">ES</span>
            </div>
            <div>
                <div class="text-white font-semibold text-sm">EasyStock</div>
                <div class="text-violet-400 text-xs font-medium">Admin Panel</div>
            </div>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
            <a href="/" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")">
                <span class="text-base">📊</span>
                <span class="text-sm font-medium">Dashboard</span>
            </a>
            <a href="/Tenants" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Tenants") == true ? "active" : "")">
                <span class="text-base">🏢</span>
                <span class="text-sm font-medium">Tenants</span>
                <span x-show="dash.totalTenants > 0" x-text="dash.totalTenants"
                      class="ml-auto bg-slate-600 text-slate-300 text-xs rounded-full px-2 py-0.5" x-cloak></span>
            </a>
            <a href="/Tickets" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Tickets") == true ? "active" : "")">
                <span class="text-base">🎫</span>
                <span class="text-sm font-medium">Tickets</span>
                <span x-show="dash.ticketsBadge > 0"
                      x-text="dash.ticketsBadge"
                      class="ml-auto bg-red-600 text-white text-xs rounded-full px-2 py-0.5 font-bold" x-cloak></span>
            </a>
            <a href="/Planos" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Planos") == true ? "active" : "")">
                <span class="text-base">📋</span>
                <span class="text-sm font-medium">Planos</span>
            </a>

            <div class="pt-4 border-t border-slate-700 mt-4 space-y-1">
                <a href="http://localhost:5000" target="_blank" class="sidebar-link">
                    <span class="text-base">🔗</span>
                    <span class="text-sm font-medium">Abrir EasyStock</span>
                </a>
                <form method="post" action="/Auth/Logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-link w-full text-left">
                        <span class="text-base">🚪</span>
                        <span class="text-sm font-medium">Sair</span>
                    </button>
                </form>
            </div>
        </nav>

        <!-- User info -->
        <div class="px-4 py-3 border-t border-slate-700">
            <div class="flex items-center gap-2">
                <div class="w-7 h-7 bg-violet-700 rounded-full flex items-center justify-center text-xs font-bold">
                    @(Context.Session.GetString("admin_nome")?.Substring(0, 1).ToUpper() ?? "A")
                </div>
                <div class="flex-1 min-w-0">
                    <div class="text-xs font-medium text-white truncate">@Context.Session.GetString("admin_nome")</div>
                    <div class="text-xs text-slate-400 truncate">@Context.Session.GetString("admin_email")</div>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main content -->
    <div class="flex-1 ml-64 flex flex-col min-h-screen">

        <!-- Topbar -->
        <header class="bg-slate-900 border-b border-slate-700 px-6 py-4 flex items-center justify-between sticky top-0 z-40">
            <div class="flex items-center gap-3">
                <h1 class="text-white font-semibold text-lg">@(ViewData["Title"] ?? "Dashboard")</h1>
            </div>
            <div class="flex items-center gap-3">
                <span class="bg-violet-700 text-violet-100 text-xs font-semibold px-2.5 py-1 rounded-full">ADMIN</span>
                <span class="text-slate-400 text-sm">@Context.Session.GetString("admin_nome")</span>
            </div>
        </header>

        <!-- Page content -->
        <main class="flex-1 p-6">
            @RenderBody()
        </main>
    </div>
</div>

@await RenderSectionAsync("Scripts", required: false)

<script>
    function adminApp() {
        return {
            dash: { totalTenants: 0, ticketsBadge: 0 },
            async init() {
                await this.fetchDashBadges();
                setInterval(() => this.fetchDashBadges(), 60000);
            },
            async fetchDashBadges() {
                try {
                    const r = await fetch('/api-proxy/dashboard-badges');
                    if (r.ok) {
                        const d = await r.json();
                        this.dash.totalTenants = d.totalTenants ?? 0;
                        this.dash.ticketsBadge = (d.ticketsCriticos ?? 0) + (d.ticketsAbertos ?? 0);
                    }
                } catch {}
            }
        }
    }
</script>

</body>
</html>
