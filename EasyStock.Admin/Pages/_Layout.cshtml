@inject Microsoft.Extensions.Configuration.IConfiguration _cfg
<!DOCTYPE html>
<html lang="pt-BR" class="h-full" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "EasyStock Admin")</title>
    <script>
        // Theme bootstrap (Admin é dark-first; usuário pode ter toggleado para light).
        (function () {
            try {
                var saved = localStorage.getItem('easystok-admin-theme');
                if (saved === 'light') document.documentElement.removeAttribute('data-theme');
            } catch (e) { /* localStorage indisponível */ }
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.dist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <style>
        [x-cloak] { display: none !important; }
        .sidebar-link { display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 1rem; border-radius: 0.5rem; color: var(--es-ink-mute); transition: all 0.15s; }
        .sidebar-link:hover { color: var(--es-ink); background: var(--es-surface-2); }
        .sidebar-link.active { background: var(--es-accent); color: var(--es-ink); }
    </style>
</head>
<body class="h-full bg-es-bg text-es-ink font-sans" x-data="adminApp()" x-init="init()">

<div class="flex h-full min-h-screen">

    <!-- Sidebar -->
    <aside class="w-64 bg-es-surface flex flex-col fixed inset-y-0 left-0 z-50" style="border-right:1px solid rgba(247,242,232,0.08)">
        <!-- Logo -->
        <div class="flex items-center gap-3 px-5 py-4" style="border-bottom:1px solid rgba(247,242,232,0.08)">
            <!-- Box icon SVG -->
            <svg width="32" height="32" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="EasyStock" style="flex-shrink:0">
                <path d="M32 6 L56 18 L32 30 L8 18 Z" fill="#E85814"/>
                <path d="M8 18 L32 30 L32 58 L8 46 Z" fill="#0E2A6E"/>
                <path d="M56 18 L32 30 L32 58 L56 46 Z" fill="#06143A"/>
            </svg>
            <div>
                <div class="text-sm font-bold" style="line-height:1.2;font-family:'Fraunces',serif;letter-spacing:-0.02em;">
                    <span style="color:var(--es-ink)">Easy</span><span style="color:var(--es-accent)">Stok</span>
                </div>
                <div class="text-xs font-medium" style="color:var(--es-ink-mute)">Admin Panel</div>
            </div>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">

            <!-- Cmd+K trigger -->
            <button type="button" @@click="$dispatch('open-cmdk')"
                    class="sidebar-link w-full text-left mb-2"
                    style="background:rgba(247,242,232,0.04);border:1px dashed rgba(247,242,232,0.12)">
                <span class="text-base">🔍</span>
                <span class="text-sm font-medium flex-1 text-es-ink-mute">Buscar…</span>
                <kbd class="text-[10px] px-1.5 py-0.5 rounded bg-es-surface-2 text-es-ink-mute font-mono">Ctrl K</kbd>
            </button>

            <!-- Recently viewed clientes (localStorage) -->
            <template x-if="recentTenants.length > 0">
                <div class="mb-2 pb-2" style="border-bottom:1px solid rgba(247,242,232,0.05)">
                    <div class="px-3 pt-1 pb-1 text-[10px] font-semibold tracking-widest text-es-ink-mute">RECENTES</div>
                    <template x-for="t in recentTenants" :key="t.id">
                        <a :href="'/Tenants/Detail/' + t.id" class="sidebar-link" style="padding-top:.4rem;padding-bottom:.4rem">
                            <span class="text-xs">🏢</span>
                            <span class="text-xs truncate flex-1" x-text="t.nome"></span>
                        </a>
                    </template>
                </div>
            </template>

            <a href="/" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")">
                <span class="text-base">📊</span>
                <span class="text-sm font-medium">Dashboard</span>
            </a>
            <a href="/Tenants" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Tenants") == true ? "active" : "")">
                <span class="text-base">🏢</span>
                <span class="text-sm font-medium">Clientes</span>
                <span x-show="dash.totalTenants > 0" x-text="dash.totalTenants"
                      class="ml-auto bg-es-surface-2 text-es-ink-dim text-xs rounded-full px-2 py-0.5" x-cloak></span>
            </a>
            <a href="/Tickets" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Tickets") == true ? "active" : "")">
                <span class="text-base">🎫</span>
                <span class="text-sm font-medium">Tickets</span>
                <span x-show="dash.ticketsBadge > 0"
                      x-text="dash.ticketsBadge"
                      class="ml-auto bg-red-600 text-white text-xs rounded-full px-2 py-0.5 font-bold" x-cloak></span>
            </a>
            <a href="/Planos" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Planos") == true ? "active" : "")">
                <span class="text-base">📋</span>
                <span class="text-sm font-medium">Planos</span>
            </a>
            <a href="/Cupons" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Cupons") == true ? "active" : "")">
                <span class="text-base">🏷️</span>
                <span class="text-sm font-medium">Cupons</span>
            </a>
            <a href="/AuditLogs" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/AuditLogs") == true ? "active" : "")">
                <span class="text-base">🔍</span>
                <span class="text-sm font-medium">Audit Logs</span>
            </a>
            <a href="/Diagnostico" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Diagnostico") == true ? "active" : "")">
                <span class="text-base">🩺</span>
                <span class="text-sm font-medium">Diagnóstico</span>
            </a>
            <a href="/Notificacoes/Templates" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Notificacoes") == true ? "active" : "")">
                <span class="text-base">🔔</span>
                <span class="text-sm font-medium">Notificações</span>
            </a>

            <div class="pt-4 mt-2 space-y-1" style="border-top:1px solid rgba(247,242,232,0.08)">
                <div class="px-3 pt-2 pb-1 text-xs font-semibold tracking-widest" style="color:#4b5563">GOVERNANÇA</div>
            </div>
            <a href="/Admins" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admins") == true ? "active" : "")">
                <span class="text-base">👤</span>
                <span class="text-sm font-medium">Admins</span>
            </a>
            <a href="/Configuracoes" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Configuracoes") == true ? "active" : "")">
                <span class="text-base">⚙️</span>
                <span class="text-sm font-medium">Configurações</span>
            </a>

            <div class="pt-4 mt-4 space-y-1" style="border-top:1px solid rgba(247,242,232,0.08)">
                <a href="@(_cfg["EasyStockWebUrl"]?.TrimEnd('/') ?? "http://localhost:5000")" target="_blank" class="sidebar-link">
                    <span class="text-base">🔗</span>
                    <span class="text-sm font-medium">Abrir EasyStock</span>
                </a>
                <form method="post" action="/Auth/Logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-link w-full text-left">
                        <span class="text-base">🚪</span>
                        <span class="text-sm font-medium">Sair</span>
                    </button>
                </form>
            </div>
        </nav>

        <!-- User info -->
        <div class="px-4 py-3" style="border-top:1px solid rgba(247,242,232,0.08)">
            <div class="flex items-center gap-2">
                <div class="w-7 h-7 bg-es-accent rounded-full flex items-center justify-center text-xs font-bold text-es-ink">
                    @(Context.Session.GetString("admin_nome")?.Substring(0, 1).ToUpper() ?? "A")
                </div>
                <div class="flex-1 min-w-0">
                    <div class="text-xs font-semibold text-es-ink truncate">@Context.Session.GetString("admin_nome")</div>
                    <div class="text-xs text-es-ink-mute truncate">@Context.Session.GetString("admin_email")</div>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main content -->
    <div class="flex-1 ml-64 flex flex-col min-h-screen">

        <!-- Topbar -->
        <header class="bg-es-surface px-6 py-4 flex items-center justify-between sticky top-0 z-40" style="border-bottom:1px solid rgba(247,242,232,0.08)">
            <div class="flex items-center gap-3">
                <h1 class="text-es-ink font-semibold text-lg">@(ViewData["Title"] ?? "Dashboard")</h1>
            </div>
            <div class="flex items-center gap-3">
                <span class="bg-es-accent text-es-ink text-xs font-bold px-2.5 py-1 rounded-full tracking-wide">ADMIN</span>
                <span class="text-es-ink-dim text-sm">@Context.Session.GetString("admin_nome")</span>
            </div>
        </header>

        <!-- Page content -->
        <main class="flex-1 p-6">
            @RenderBody()
        </main>
    </div>
</div>

@await RenderSectionAsync("Scripts", required: false)

@{
    var _toastSucesso = TempData["Sucesso"] as string;
    var _toastErro    = TempData["Erro"] as string;
}
@if (_toastSucesso != null || _toastErro != null)
{
    var _isOk = _toastSucesso != null;
    var _msg  = _toastSucesso ?? _toastErro;
    <div x-data="{ show: true }"
         x-show="show"
         x-cloak
         x-init="setTimeout(() => show = false, 4000)"
         style="transition:opacity .4s; background:#1a2540; border:1px solid @(_isOk ? "rgba(79,191,159,.35)" : "rgba(248,113,113,.35)");"
         class="fixed bottom-6 right-6 z-[200] flex items-center gap-3 px-5 py-3 rounded-xl shadow-2xl text-sm font-medium"
         :style="show ? 'opacity:1' : 'opacity:0'">
        <span class="text-base @(_isOk ? "text-es-basil" : "text-red-400")">@(_isOk ? "✓" : "✗")</span>
        <span class="text-es-ink">@_msg</span>
        <button @@click="show=false" class="text-es-ink-mute hover:text-es-ink ml-2 leading-none">✕</button>
    </div>
}

<script>
    const RECENT_TENANTS_KEY = 'easystok-admin-recent-tenants';

    function adminApp() {
        return {
            dash: {
                totalTenants: 0, tenantsAtivos: 0, tenantsSuspensos: 0, tenantsNovos: 0,
                ticketsAbertos: 0, ticketsCriticos: 0, ticketsEmAtendimento: 0,
                ticketsComNovaMensagem: 0, totalUsuariosAtivos: 0, logins24h: 0,
                receitaMensalEstimada: 0, ticketsBadge: 0
            },
            dashSecsAgo: 0,
            _lastFetch: 0,
            recentTenants: [],
            cheatOpen: false,
            _gPressed: false,
            _gTimer: null,
            async init() {
                this.loadRecent();
                this.bindShortcuts();
                this.trackTenantViewed();
                // Seed do dashboard via window.__initialDash (definido inline em /Index.cshtml).
                // Acontece ANTES da fetch pra UI mostrar valores server-side imediatamente,
                // sem o "flash de zeros" enquanto a fetch não retorna. fetchDashBadges()
                // depois sobrescreve com valores frescos da API.
                if (typeof window.__initialDash === 'object' && window.__initialDash !== null) {
                    Object.assign(this.dash, window.__initialDash);
                    this.dash.ticketsBadge = (this.dash.ticketsComNovaMensagem ?? 0) + (this.dash.ticketsCriticos ?? 0);
                }
                await this.fetchDashBadges();
                setInterval(() => this.fetchDashBadges(), 60000);
                setInterval(() => { if (this._lastFetch) this.dashSecsAgo = Math.floor((Date.now() - this._lastFetch) / 1000); }, 5000);
            },
            async fetchDashBadges() {
                try {
                    const r = await fetch('/api-proxy/dashboard-badges', { credentials: 'same-origin' });
                    if (!r.ok) {
                        console.warn('[admin] dashboard-badges retornou', r.status);
                        return;
                    }
                    const d = await r.json();
                    Object.assign(this.dash, d);
                    this.dash.ticketsBadge = (d.ticketsComNovaMensagem ?? 0) + (d.ticketsCriticos ?? 0);
                    this._lastFetch = Date.now();
                    this.dashSecsAgo = 0;
                } catch (e) {
                    console.error('[admin] fetchDashBadges falhou:', e);
                }
            },

            // ── Recently viewed (localStorage) ──
            loadRecent() {
                try {
                    const raw = localStorage.getItem(RECENT_TENANTS_KEY);
                    this.recentTenants = raw ? JSON.parse(raw).slice(0, 5) : [];
                } catch { this.recentTenants = []; }
            },
            pushRecent(id, nome) {
                if (!id) return;
                let list = this.recentTenants.filter(t => t.id !== id);
                list.unshift({ id, nome: (nome || '').slice(0, 60) || 'Cliente', at: Date.now() });
                list = list.slice(0, 5);
                this.recentTenants = list;
                try { localStorage.setItem(RECENT_TENANTS_KEY, JSON.stringify(list)); } catch {}
            },
            trackTenantViewed() {
                // Detecta /Tenants/Detail/{guid} — adiciona à lista de recentes.
                const m = window.location.pathname.match(/^\/Tenants\/Detail\/([0-9a-f-]{36})/i);
                if (!m) return;
                const id = m[1];
                // Pega o nome do <h2> do header se existir.
                const titulo = document.querySelector('h2.text-es-ink')?.textContent?.trim() || document.title;
                this.pushRecent(id, titulo);
            },

            // ── Atalhos teclado ──
            bindShortcuts() {
                window.addEventListener('keydown', (e) => {
                    // Cmd+K / Ctrl+K — sempre abre busca, ignora foco.
                    if ((e.ctrlKey || e.metaKey) && (e.key === 'k' || e.key === 'K')) {
                        e.preventDefault();
                        window.dispatchEvent(new CustomEvent('open-cmdk'));
                        return;
                    }
                    // Atalhos de letra só fora de input/textarea/select.
                    const tag = (e.target.tagName || '').toLowerCase();
                    if (tag === 'input' || tag === 'textarea' || tag === 'select' || e.target.isContentEditable) return;

                    // ? — abre cheatsheet (precisa Shift+/ no teclado padrão BR/US).
                    if (e.key === '?' && !e.ctrlKey && !e.metaKey && !e.altKey) {
                        e.preventDefault();
                        this.cheatOpen = true;
                        return;
                    }

                    // g + letra — atalhos "vai para".
                    if (e.key === 'g' && !this._gPressed) {
                        this._gPressed = true;
                        clearTimeout(this._gTimer);
                        this._gTimer = setTimeout(() => { this._gPressed = false; }, 1200);
                        return;
                    }
                    if (this._gPressed) {
                        this._gPressed = false; clearTimeout(this._gTimer);
                        const dest = {
                            'd': '/',
                            'c': '/Tenants',
                            't': '/Tickets',
                            'p': '/Planos',
                            'a': '/Admins',
                            's': '/Diagnostico'
                        }[e.key.toLowerCase()];
                        if (dest) {
                            e.preventDefault();
                            window.location.href = dest;
                        }
                    }
                }, true);
            }
        }
    }

    // ── Cmd+K modal Alpine factory ──
    function cmdkModal() {
        return {
            open: false,
            q: '',
            loading: false,
            erro: '',
            sel: 0,
            results: { clientes: [], lojas: [], usuarios: [] },
            _debounceHandle: null,
            recentes: [],
            init() {
                window.addEventListener('open-cmdk', () => this.show());
                try {
                    this.recentes = JSON.parse(localStorage.getItem(RECENT_TENANTS_KEY) || '[]').slice(0, 5);
                } catch {}
            },
            show() {
                this.open = true;
                this.q = '';
                this.results = { clientes: [], lojas: [], usuarios: [] };
                this.sel = 0;
                this.erro = '';
                this.$nextTick && this.$nextTick(() => {
                    document.getElementById('cmdk-input')?.focus();
                });
                setTimeout(() => document.getElementById('cmdk-input')?.focus(), 50);
            },
            close() { this.open = false; },
            onInput() {
                clearTimeout(this._debounceHandle);
                this._debounceHandle = setTimeout(() => this.search(), 200);
            },
            async search() {
                const termo = this.q.trim();
                if (termo.length < 2) {
                    this.results = { clientes: [], lojas: [], usuarios: [] };
                    return;
                }
                this.loading = true; this.erro = ''; this.sel = 0;
                try {
                    const r = await fetch('/api-proxy/buscar-global?q=' + encodeURIComponent(termo) + '&limit=8', {
                        credentials: 'same-origin', cache: 'no-store'
                    });
                    if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                    const d = await r.json();
                    const data = d.data || d;
                    this.results = {
                        clientes: data.clientes || [],
                        lojas: data.lojas || [],
                        usuarios: data.usuarios || []
                    };
                } catch (e) {
                    this.erro = 'Falha de rede: ' + (e.message || e);
                } finally {
                    this.loading = false;
                }
            },
            get flatList() {
                return [
                    ...this.results.clientes.map(x => ({ ...x, _section: 'Cliente' })),
                    ...this.results.lojas.map(x => ({ ...x, _section: 'Loja' })),
                    ...this.results.usuarios.map(x => ({ ...x, _section: 'Usuário' }))
                ];
            },
            move(delta) {
                const n = this.flatList.length;
                if (n === 0) return;
                this.sel = (this.sel + delta + n) % n;
            },
            choose() {
                const item = this.flatList[this.sel];
                if (item && item.url && item.url !== '#') {
                    window.location.href = item.url;
                }
            }
        };
    }
</script>

<!-- Modal Cmd+K global -->
<div x-data="cmdkModal()" x-init="init()" x-show="open" x-cloak
     class="fixed inset-0 z-[300] flex items-start justify-center bg-black/60 backdrop-blur-sm"
     style="padding-top:10vh"
     @@click.self="close()"
     @@keydown.escape.window="if (open) close()"
     @@keydown.arrow-down.window="if (open) { move(1); $event.preventDefault(); }"
     @@keydown.arrow-up.window="if (open) { move(-1); $event.preventDefault(); }"
     @@keydown.enter.window="if (open) { choose(); $event.preventDefault(); }">
    <div class="w-full max-w-2xl rounded-xl shadow-2xl overflow-hidden"
         style="background:#0b1530;border:1px solid rgba(247,242,232,.12)">
        <div class="flex items-center gap-3 px-5 py-4" style="border-bottom:1px solid rgba(247,242,232,.08)">
            <span class="text-2xl">🔍</span>
            <input id="cmdk-input" type="text" x-model="q" @@input="onInput()"
                   placeholder="Buscar cliente, usuário, loja, email ou CNPJ…"
                   class="flex-1 bg-transparent text-es-ink text-lg outline-none placeholder:text-es-ink-mute" />
            <kbd class="text-[10px] px-1.5 py-0.5 rounded bg-es-surface-2 text-es-ink-mute font-mono">Esc</kbd>
        </div>

        <div class="max-h-[60vh] overflow-y-auto py-2">
            <div x-show="loading" x-cloak class="text-es-ink-mute text-sm text-center py-6">Buscando…</div>
            <div x-show="erro" x-cloak class="text-red-400 text-sm text-center py-3" x-text="erro"></div>

            <!-- Estado vazio com recentes -->
            <template x-if="!loading && q.trim().length < 2">
                <div>
                    <template x-if="recentes.length > 0">
                        <div>
                            <div class="px-5 py-1.5 text-[10px] font-bold uppercase tracking-widest text-es-ink-mute">Vistos recentemente</div>
                            <template x-for="t in recentes" :key="t.id">
                                <a :href="'/Tenants/Detail/' + t.id" class="flex items-center gap-3 px-5 py-2 hover:bg-es-surface-2/50 transition-colors">
                                    <span class="text-base">🏢</span>
                                    <span class="text-es-ink text-sm flex-1" x-text="t.nome"></span>
                                    <span class="text-[10px] text-es-ink-mute">↵</span>
                                </a>
                            </template>
                        </div>
                    </template>
                    <template x-if="recentes.length === 0">
                        <div class="text-es-ink-mute text-sm text-center py-8">
                            Digite ao menos 2 caracteres pra buscar.<br/>
                            <span class="text-xs">Pressione <kbd class="px-1 py-0.5 bg-es-surface-2 rounded">?</kbd> pra ver atalhos.</span>
                        </div>
                    </template>
                </div>
            </template>

            <!-- Resultados -->
            <template x-for="(grupo, gi) in [
                { titulo: 'Clientes', items: results.clientes },
                { titulo: 'Lojas', items: results.lojas },
                { titulo: 'Usuários', items: results.usuarios }
            ]" :key="gi">
                <div x-show="grupo.items.length > 0">
                    <div class="px-5 py-1.5 text-[10px] font-bold uppercase tracking-widest text-es-ink-mute" x-text="grupo.titulo"></div>
                    <template x-for="(item, idx) in grupo.items" :key="(grupo.titulo + ':' + item.id)">
                        <a :href="item.url"
                           @@mouseenter="sel = flatList.findIndex(x => x.id === item.id && x._section.startsWith(grupo.titulo.slice(0, -1)))"
                           class="flex items-center gap-3 px-5 py-2.5 transition-colors"
                           :class="flatList[sel] && flatList[sel].id === item.id ? 'bg-es-accent/15 border-l-2 border-es-accent' : 'hover:bg-es-surface-2/50 border-l-2 border-transparent'">
                            <span class="text-base" x-text="grupo.titulo === 'Clientes' ? '🏢' : (grupo.titulo === 'Lojas' ? '🛒' : '👤')"></span>
                            <div class="flex-1 min-w-0">
                                <div class="text-es-ink text-sm truncate" x-text="item.nome"></div>
                                <div class="text-es-ink-mute text-[11px] truncate font-mono">
                                    <template x-if="grupo.titulo === 'Clientes'">
                                        <span x-text="item.documento || item.id.slice(0, 8)"></span>
                                    </template>
                                    <template x-if="grupo.titulo === 'Lojas'">
                                        <span x-text="item.empresaNome + (item.ativa ? '' : ' · inativa')"></span>
                                    </template>
                                    <template x-if="grupo.titulo === 'Usuários'">
                                        <span x-text="item.emailMascarado + ' · ' + item.empresaNome + (item.ativo ? '' : ' · inativo')"></span>
                                    </template>
                                </div>
                            </div>
                        </a>
                    </template>
                </div>
            </template>

            <template x-if="!loading && q.trim().length >= 2 && flatList.length === 0">
                <div class="text-es-ink-mute text-sm text-center py-8">
                    Sem resultados para "<span class="text-es-ink" x-text="q"></span>".<br/>
                    <span class="text-xs">Tente CNPJ sem pontuação ou parte do email/nome.</span>
                </div>
            </template>
        </div>

        <div class="px-5 py-2 text-[10px] text-es-ink-mute flex items-center justify-between" style="background:rgba(0,0,0,.2);border-top:1px solid rgba(247,242,232,.05)">
            <span>↑↓ navegar · ↵ abrir · Esc fechar</span>
            <span x-show="flatList.length > 0" x-cloak><b class="text-es-ink" x-text="flatList.length"></b> resultado(s)</span>
        </div>
    </div>
</div>

<!-- Cheatsheet de atalhos -->
<div x-show="cheatOpen" x-cloak
     class="fixed inset-0 z-[300] flex items-center justify-center bg-black/60 backdrop-blur-sm"
     @@click.self="cheatOpen = false" @@keydown.escape.window="cheatOpen = false">
    <div class="w-full max-w-md rounded-xl shadow-2xl p-5"
         style="background:#0b1530;border:1px solid rgba(247,242,232,.12)">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-es-ink font-semibold">Atalhos do teclado</h3>
            <button @@click="cheatOpen = false" class="text-es-ink-mute hover:text-es-ink">✕</button>
        </div>
        <dl class="space-y-2 text-sm">
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Buscar (Cmd+K)</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">Ctrl K</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Ir pro Dashboard</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g d</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Ir pra Clientes</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g c</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Ir pra Tickets</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g t</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Ir pra Planos</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g p</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Ir pra Admins</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g a</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Ir pra Diagnóstico</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g s</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Esta tela</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">?</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Fechar modais</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">Esc</kbd></dd></div>
        </dl>
        <p class="text-es-ink-mute text-xs mt-4">
            Atalhos só funcionam fora de campos de texto. Dentro de inputs, atalhos do navegador prevalecem.
        </p>
    </div>
</div>

</body>
</html>
