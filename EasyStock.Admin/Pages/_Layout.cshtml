@inject Microsoft.Extensions.Configuration.IConfiguration _cfg
<!DOCTYPE html>
<html lang="pt-BR" class="h-full" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="view-transition" content="same-origin" />
    <title>@(ViewData["Title"] ?? "EasyStock Admin")</title>
    <script>
        // Theme bootstrap (Admin é dark-first; usuário pode ter toggleado para light).
        (function () {
            try {
                var saved = localStorage.getItem('easystok-admin-theme');
                if (saved === 'light') document.documentElement.removeAttribute('data-theme');
            } catch (e) { /* localStorage indisponível */ }
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    @* Alpine self-hosted (mesma origem) — sem CDN/SRI. O jsDelivr era bloqueado pelo
       firewall corporativo E os hashes SRI antigos estavam errados; ambos matavam o
       Alpine -> tabs/dashboards/Ctrl+K/sync inertes. Vendored de alpinejs@@3.14.9
       (core+persist+focus).

       ORDEM CRITICA (#469): o core Alpine (defer) auto-inicia ao executar com
       document.readyState=interactive e avalia os x-data NA HORA. Logo, tudo que
       define factory/global usada em x-data tem de carregar ANTES do core:
         - persist/focus: plugins (registram via alpine:init);
         - masks.js: registra via alpine:init;
         - admin-components.js: define window.esTabs/esDataTable/esCountUp.
       Com o core por ULTIMO, esTabs/isActive ja existem quando o <es-tabs> de
       /Configuracoes e avaliado (antes quebrava com "esTabs is not defined"). *@
    <script defer src="~/js/vendor/alpine/persist.js" asp-append-version="true"></script>
    <script defer src="~/js/vendor/alpine/focus.js" asp-append-version="true"></script>
    <script defer src="~/js/masks.js" asp-append-version="true"></script>
    <script defer src="~/js/admin-components.js" asp-append-version="true"></script>
    <script defer src="~/js/vendor/alpine/alpine.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.dist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <style>
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="h-full bg-es-bg text-es-ink font-sans" x-data="adminApp()">

<a href="#main" class="skip-link">Pular para o conteúdo</a>

<div class="app-shell">

    <!-- Backdrop mobile -->
    <div class="sidebar-backdrop"
         :class="mobileOpen ? 'is-visible' : ''"
         @@click="closeMobile()"
         aria-hidden="true"></div>

    <!-- Sidebar -->
    <aside id="sidebar"
           class="sidebar"
           :class="[sidebarCollapsed ? 'is-rail' : '', mobileOpen ? 'is-mobile-open' : '']"
           aria-label="Navegação principal">

        <!-- Logo -->
        <div class="sidebar-brand">
            <svg width="32" height="32" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="EasyStock" style="flex-shrink:0">
                <path d="M32 6 L56 18 L32 30 L8 18 Z" fill="#E85814"/>
                <path d="M8 18 L32 30 L32 58 L8 46 Z" fill="#0E2A6E"/>
                <path d="M56 18 L32 30 L32 58 L56 46 Z" fill="#06143A"/>
            </svg>
            <div class="sidebar-brand-text">
                <div class="text-sm font-bold" style="line-height:1.2;font-family:'Fraunces',serif;letter-spacing:-0.02em;">
                    <span style="color:var(--es-ink)">Easy</span><span style="color:var(--es-accent)">Stok</span>
                </div>
                <div class="text-xs font-medium" style="color:var(--es-ink-mute)">Admin Panel</div>
            </div>
            <span class="sidebar-brand-pill sidebar-label">ops</span>
        </div>

        <!-- Navegação -->
        <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto" aria-label="Menus do admin">

            <!-- Cmd+K trigger -->
            <button type="button"
                    class="sidebar-link sidebar-search mb-2"
                    @@click="$dispatch('open-cmdk')"
                    aria-label="Abrir busca global">
                <es-icon name="search" size="18" />
                <span class="sidebar-label sidebar-search-text">Buscar…</span>
                <kbd class="sidebar-search-kbd sidebar-label">Ctrl K</kbd>
            </button>

            <!-- Recentemente visitados (clientes) -->
            <template x-if="recentTenants.length > 0 && !sidebarCollapsed">
                <div class="sidebar-recent mb-2 pb-2" style="border-bottom:1px solid rgba(247,242,232,0.05)">
                    <div class="sidebar-section-title" style="padding-top: 4px;">Recentes</div>
                    <template x-for="t in recentTenants" :key="t.id">
                        <a :href="'/Tenants/Detail/' + t.id"
                           class="sidebar-link"
                           style="padding-top:.4rem;padding-bottom:.4rem">
                            <span style="color: var(--text-muted);">
                                <svg class="es-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><use href="/icons/sprite.svg#icon-building-2"/></svg>
                            </span>
                            <span class="text-xs truncate flex-1 sidebar-label" x-text="t.nome"></span>
                        </a>
                    </template>
                </div>
            </template>

            <div class="sidebar-group">
                <div class="sidebar-section-title">Operação</div>
                <a href="/" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "is-active" : "")">
                    <es-icon name="layout-dashboard" size="18" />
                    <span class="text-sm font-medium sidebar-label">Dashboard</span>
                </a>
                <a href="/Tenants" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Tenants") == true ? "is-active" : "")">
                    <es-icon name="building-2" size="18" />
                    <span class="text-sm font-medium sidebar-label">Clientes</span>
                    <span x-show="dash.totalTenants > 0 && !sidebarCollapsed"
                          x-text="dash.totalTenants"
                          class="sidebar-count sidebar-label"
                          x-cloak></span>
                </a>
                <a href="/Tickets" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Tickets") == true ? "is-active" : "")">
                    <es-icon name="ticket" size="18" />
                    <span class="text-sm font-medium sidebar-label">Tickets</span>
                    <span x-show="dash.ticketsBadge > 0 && !sidebarCollapsed"
                          x-text="dash.ticketsBadge"
                          class="sidebar-count sidebar-count-danger sidebar-label"
                          x-cloak></span>
                </a>
                <a href="/Operacao" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Operacao") == true ? "is-active" : "")">
                    <es-icon name="trending-up" size="18" />
                    <span class="text-sm font-medium sidebar-label">Operação</span>
                </a>
            </div>

            <div class="sidebar-group">
                <div class="sidebar-section-title">Comercial</div>
                <a href="/Storefronts" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Storefronts") == true ? "is-active" : "")">
                    <es-icon name="shopping-bag" size="18" />
                    <span class="text-sm font-medium sidebar-label">Storefronts</span>
                </a>
                <a href="/Planos" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Planos") == true ? "is-active" : "")">
                    <es-icon name="list-checks" size="18" />
                    <span class="text-sm font-medium sidebar-label">Planos</span>
                </a>
                <a href="/Cupons" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Cupons") == true ? "is-active" : "")">
                    <es-icon name="tag" size="18" />
                    <span class="text-sm font-medium sidebar-label">Cupons</span>
                </a>
                <a href="/Faturas" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Faturas") == true ? "is-active" : "")">
                    <es-icon name="receipt" size="18" />
                    <span class="text-sm font-medium sidebar-label">Faturas</span>
                </a>
            </div>

            <div class="sidebar-group">
                <div class="sidebar-section-title">Plataforma</div>
                <a href="/Dispositivos" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Dispositivos") == true ? "is-active" : "")">
                    <es-icon name="smartphone" size="18" />
                    <span class="text-sm font-medium sidebar-label">Dispositivos</span>
                </a>
                <a href="/Notificacoes/Templates" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Notificacoes") == true ? "is-active" : "")">
                    <es-icon name="bell" size="18" />
                    <span class="text-sm font-medium sidebar-label">Notificações</span>
                </a>
                <a href="/Diagnostico" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Diagnostico") == true ? "is-active" : "")">
                    <es-icon name="stethoscope" size="18" />
                    <span class="text-sm font-medium sidebar-label">Diagnóstico</span>
                </a>
                <a href="/AuditLogs" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/AuditLogs") == true ? "is-active" : "")">
                    <es-icon name="search" size="18" />
                    <span class="text-sm font-medium sidebar-label">Audit Logs</span>
                </a>
            </div>

            <div class="sidebar-group">
                <div class="sidebar-section-title">Governança</div>
                <a href="/Admins" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admins") == true ? "is-active" : "")">
                    <es-icon name="users" size="18" />
                    <span class="text-sm font-medium sidebar-label">Admins</span>
                </a>
                <a href="/Configuracoes" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Configuracoes") == true ? "is-active" : "")">
                    <es-icon name="settings" size="18" />
                    <span class="text-sm font-medium sidebar-label">Configurações</span>
                </a>
                <a href="/Configuracoes/ConfiguracaoFiscal" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("ConfiguracaoFiscal") == true ? "is-active" : "")">
                    <es-icon name="file-text" size="18" />
                    <span class="text-sm font-medium sidebar-label">Config. Fiscal</span>
                </a>
            </div>

            <div class="sidebar-external">
                <a href="@(_cfg["EasyStockWebUrl"]?.TrimEnd('/') ?? "http://localhost:5000")" target="_blank" rel="noopener noreferrer" class="sidebar-link">
                    <es-icon name="external-link" size="18" />
                    <span class="text-sm font-medium sidebar-label">Abrir EasyStock</span>
                </a>
                <form method="post" action="/Auth/Logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-link w-full text-left">
                        <es-icon name="log-out" size="18" />
                        <span class="text-sm font-medium sidebar-label">Sair</span>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Footer: usuário logado -->
        <div class="px-4 py-3" style="border-top:1px solid rgba(247,242,232,0.08); flex: none;">
            <div class="flex items-center gap-2">
                <div class="es-avatar es-avatar-sm" aria-hidden="true">
                    @(Context.Session.GetString("admin_nome")?.Substring(0, 1).ToUpper() ?? "A")
                </div>
                <div class="flex-1 min-w-0 sidebar-user-meta">
                    <div class="text-xs font-semibold text-es-ink truncate">@Context.Session.GetString("admin_nome")</div>
                    <div class="text-xs text-es-ink-mute truncate">@Context.Session.GetString("admin_email")</div>
                </div>
            </div>
        </div>
    </aside>

    <!-- Conteúdo principal -->
    <div class="app-main" :class="sidebarCollapsed ? 'is-rail' : ''">

        <!-- Topbar -->
        <header class="app-topbar" role="banner">
            <div class="flex items-center gap-2 min-w-0">
                <!-- Hamburger (mobile) -->
                <button type="button"
                        class="topbar-icon-btn mobile-only"
                        @@click="openMobile()"
                        aria-label="Abrir menu de navegação"
                        aria-controls="sidebar"
                        :aria-expanded="mobileOpen ? 'true' : 'false'">
                    <es-icon name="menu" size="20" aria-label="Menu" />
                </button>

                <!-- Sidebar collapse (desktop) -->
                <button type="button"
                        class="topbar-icon-btn desktop-only"
                        @@click="toggleSidebar()"
                        :aria-label="sidebarCollapsed ? 'Expandir menu lateral' : 'Recolher menu lateral'"
                        aria-controls="sidebar"
                        :aria-expanded="sidebarCollapsed ? 'false' : 'true'">
                    <template x-if="!sidebarCollapsed">
                        <svg class="es-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><use href="/icons/sprite.svg#icon-panel-left-close"/></svg>
                    </template>
                    <template x-if="sidebarCollapsed">
                        <svg class="es-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><use href="/icons/sprite.svg#icon-panel-left-open"/></svg>
                    </template>
                </button>

                <h1 class="text-es-ink font-semibold text-lg truncate">@(ViewData["Title"] ?? "Dashboard")</h1>
            </div>

            <div class="flex items-center gap-2">
                <!-- Theme toggle -->
                <button type="button"
                        class="topbar-icon-btn"
                        @@click="toggleTheme()"
                        :aria-label="theme === 'dark' ? 'Mudar para tema claro' : 'Mudar para tema escuro'">
                    <template x-if="theme === 'dark'">
                        <svg class="es-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><use href="/icons/sprite.svg#icon-sun"/></svg>
                    </template>
                    <template x-if="theme === 'light'">
                        <svg class="es-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><use href="/icons/sprite.svg#icon-moon"/></svg>
                    </template>
                </button>

                <!-- Cheatsheet (?) -->
                <button type="button"
                        class="topbar-icon-btn hidden md:inline-flex"
                        @@click="cheatOpen = true"
                        aria-label="Ver atalhos do teclado">
                    <span style="font-weight:700; font-size:14px; line-height:1;">?</span>
                </button>

                <!-- Onda 2 (#438): indicador global de saude da stack -->
                <a href="/Diagnostico?tab=stack" x-show="stackStatus" x-cloak
                   class="topbar-icon-btn flex items-center justify-center"
                   :title="'Saúde da stack: ' + (stackStatus === 'Healthy' ? 'saudável' : stackStatus === 'Degraded' ? 'degradada' : 'com falha') + ' — abrir board'"
                   :aria-label="'Saúde da stack: ' + (stackStatus === 'Healthy' ? 'saudável' : stackStatus === 'Degraded' ? 'degradada' : 'com falha')">
                    <span class="inline-block w-2.5 h-2.5 rounded-full"
                          :class="stackStatus === 'Healthy' ? 'bg-es-basil' : stackStatus === 'Degraded' ? 'bg-amber-400 animate-pulse' : 'bg-red-500 animate-pulse'"></span>
                </a>
                <span class="bg-es-accent text-es-ink text-xs font-bold px-2.5 py-1 rounded-full tracking-wide hidden sm:inline-flex">ADMIN</span>
                <span class="text-es-ink-dim text-sm hidden lg:inline truncate" style="max-width: 200px;">@Context.Session.GetString("admin_nome")</span>
            </div>
        </header>

        <main id="main" class="admin-content" tabindex="-1" aria-label="@(ViewData["Title"] ?? "Conteúdo principal")">
            <div class="admin-content-inner">
                @RenderBody()
            </div>
        </main>
    </div>
</div>

@await RenderSectionAsync("Scripts", required: false)

<!-- Toast region (Alpine store global, substituí TempData inline) -->
<partial name="Components/_Toast" />

<!-- Command Palette (⌘K v2) -->
<partial name="Components/_CommandPalette" />

<!-- Cheatsheet de atalhos -->
<div x-show="cheatOpen" x-cloak
     class="fixed inset-0 flex items-center justify-center"
     style="z-index: var(--z-command); background: rgba(0,0,0,.6); backdrop-filter: blur(4px);"
     @@click.self="cheatOpen = false"
     @@keydown.escape.window="cheatOpen = false"
     role="dialog"
     aria-modal="true"
     aria-labelledby="cheat-title">
    <div class="w-full max-w-md rounded-xl shadow-2xl p-5"
         style="background:#0b1530;border:1px solid rgba(247,242,232,.12)">
        <div class="flex items-center justify-between mb-4">
            <h3 id="cheat-title" class="text-es-ink font-semibold">Atalhos do teclado</h3>
            <button @@click="cheatOpen = false"
                    class="topbar-icon-btn"
                    aria-label="Fechar atalhos">
                <es-icon name="x" size="18" />
            </button>
        </div>
        <dl class="space-y-2 text-sm">
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Buscar (Cmd+K)</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">Ctrl K</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Ir pro Dashboard</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g d</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Ir pra Clientes</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g c</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Ir pra Tickets</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g t</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Ir pra Planos</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g p</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Ir pra Admins</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g a</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Ir pra Diagnóstico</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g s</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Recolher menu lateral</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">[</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Alternar tema claro/escuro</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">g h</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Esta tela</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">?</kbd></dd></div>
            <div class="flex items-center justify-between"><dt class="text-es-ink-dim">Fechar modais</dt><dd><kbd class="px-1.5 py-0.5 bg-es-surface-2 rounded font-mono text-xs">Esc</kbd></dd></div>
        </dl>
        <p class="text-es-ink-mute text-xs mt-4">
            Atalhos só funcionam fora de campos de texto. Dentro de inputs, atalhos do navegador prevalecem.
        </p>
    </div>
</div>

<script>
    // ── Captura global de erros JS (preservado de versão anterior). ──
    (function () {
        function sendFrontendError(source, category, message, details, url) {
            try {
                fetch('/api-proxy/diag/frontend-error', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ source, category, message: String(message).slice(0, 1500), details: String(details || '').slice(0, 7000), url: url || window.location.pathname })
                }).catch(function () {});
            } catch (e) {}
        }
        window.sendFrontendError = sendFrontendError;
        window.addEventListener('unhandledrejection', function (ev) {
            var msg = (ev.reason && ev.reason.message) ? ev.reason.message : String(ev.reason || 'UnhandledRejection');
            sendFrontendError('admin_frontend', 'js_error', msg, ev.reason && ev.reason.stack, window.location.pathname);
        });
        window.addEventListener('error', function (ev) {
            if (!ev.message || ev.message === 'Script error.') return;
            sendFrontendError('admin_frontend', 'js_error', ev.message, ev.error && ev.error.stack, window.location.pathname);
        });
    })();

    // ── Helper global para alternar tema (consumido por ⌘K e por adminApp). ──
    window.toggleTheme = function () {
        var root = document.documentElement;
        var isDark = root.getAttribute('data-theme') === 'dark';
        if (isDark) {
            root.removeAttribute('data-theme');
            try { localStorage.setItem('easystok-admin-theme', 'light'); } catch (e) {}
        } else {
            root.setAttribute('data-theme', 'dark');
            try { localStorage.setItem('easystok-admin-theme', 'dark'); } catch (e) {}
        }
        window.dispatchEvent(new CustomEvent('theme-changed', { detail: { theme: isDark ? 'light' : 'dark' } }));
    };

    const RECENT_TENANTS_KEY = 'easystok-admin-recent-tenants';
    const SIDEBAR_RAIL_KEY  = 'easystok-admin-sidebar-rail';

    function adminApp() {
        return {
            // ── Layout state ──
            sidebarCollapsed: false,
            mobileOpen: false,
            theme: 'dark',

            // ── Dashboard polling (preservado) ──
            dash: {
                totalTenants: 0, tenantsAtivos: 0, tenantsSuspensos: 0, tenantsNovos: 0,
                ticketsAbertos: 0, ticketsCriticos: 0, ticketsEmAtendimento: 0,
                ticketsComNovaMensagem: 0, totalUsuariosAtivos: 0, logins24h: 0,
                receitaMensalEstimada: 0, ticketsBadge: 0
            },
            dashSecsAgo: 0,
            _lastFetch: 0,
            recentTenants: [],
            cheatOpen: false,
            _gPressed: false,
            _gTimer: null,
            stackStatus: null,

            async init() {
                this._loadSidebarState();
                this._loadTheme();
                this.loadRecent();
                this.bindShortcuts();
                this.trackTenantViewed();

                window.addEventListener('theme-changed', (e) => {
                    this.theme = (e.detail && e.detail.theme) || (document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light');
                });
                window.addEventListener('resize', () => {
                    if (window.innerWidth >= 768 && this.mobileOpen) this.closeMobile();
                });

                // Seed do dashboard via window.__initialDash (definido inline em /Index.cshtml).
                if (typeof window.__initialDash === 'object' && window.__initialDash !== null) {
                    Object.assign(this.dash, window.__initialDash);
                    this.dash.ticketsBadge = (this.dash.ticketsComNovaMensagem ?? 0) + (this.dash.ticketsCriticos ?? 0);
                }
                await this.fetchDashBadges();
                // BUG-014: so faz o poll quando a aba esta visivel. Evita requisicoes
                // desnecessarias em abas ocultas/em segundo plano e deixa a pagina atingir
                // "idle". Ao voltar a ficar visivel, atualiza na hora.
                setInterval(() => { if (!document.hidden) this.fetchDashBadges(); }, 60000);
                setInterval(() => { if (this._lastFetch) this.dashSecsAgo = Math.floor((Date.now() - this._lastFetch) / 1000); }, 5000);
                document.addEventListener('visibilitychange', () => { if (!document.hidden) this.fetchDashBadges(); });

                // Onda 2 (#438): indicador global de saude da stack no topbar.
                // Mesma cadencia/pausa do BUG-014 (so com aba visivel).
                this.fetchStackHealth();
                setInterval(() => { if (!document.hidden) this.fetchStackHealth(); }, 60000);
                document.addEventListener('visibilitychange', () => { if (!document.hidden) this.fetchStackHealth(); });
            },

            // ── Sidebar collapse ──
            _loadSidebarState() {
                try {
                    this.sidebarCollapsed = localStorage.getItem(SIDEBAR_RAIL_KEY) === '1';
                } catch { this.sidebarCollapsed = false; }
            },
            toggleSidebar() {
                this.sidebarCollapsed = !this.sidebarCollapsed;
                try { localStorage.setItem(SIDEBAR_RAIL_KEY, this.sidebarCollapsed ? '1' : '0'); } catch {}
            },
            openMobile() {
                this.mobileOpen = true;
                document.body.style.overflow = 'hidden';
            },
            closeMobile() {
                this.mobileOpen = false;
                document.body.style.overflow = '';
            },

            // ── Theme ──
            _loadTheme() {
                try {
                    var saved = localStorage.getItem('easystok-admin-theme');
                    this.theme = (saved === 'light') ? 'light' : 'dark';
                } catch { this.theme = 'dark'; }
            },
            toggleTheme() {
                window.toggleTheme();
                this.theme = (this.theme === 'dark') ? 'light' : 'dark';
            },

            // ── Dashboard polling (idêntico ao comportamento anterior) ──
            async fetchDashBadges() {
                try {
                    const r = await fetch('/api-proxy/dashboard-badges', { credentials: 'same-origin' });
                    if (!r.ok) {
                        console.warn('[admin] dashboard-badges retornou', r.status);
                        return;
                    }
                    const d = await r.json();
                    Object.assign(this.dash, d);
                    this.dash.ticketsBadge = (d.ticketsComNovaMensagem ?? 0) + (d.ticketsCriticos ?? 0);
                    this._lastFetch = Date.now();
                    this.dashSecsAgo = 0;
                } catch (e) {
                    console.error('[admin] fetchDashBadges falhou:', e);
                }
            },

            async fetchStackHealth() {
                try {
                    const r = await fetch('/api-proxy/diag/health', { credentials: 'same-origin', cache: 'no-store' });
                    if (!r.ok) { this.stackStatus = null; return; }
                    const d = await r.json();
                    this.stackStatus = d?.status || null;
                } catch (e) {
                    this.stackStatus = null;
                }
            },

            // ── Recently viewed (localStorage) ──
            loadRecent() {
                try {
                    const raw = localStorage.getItem(RECENT_TENANTS_KEY);
                    this.recentTenants = raw ? JSON.parse(raw).slice(0, 5) : [];
                } catch { this.recentTenants = []; }
            },
            pushRecent(id, nome) {
                if (!id) return;
                let list = this.recentTenants.filter(t => t.id !== id);
                list.unshift({ id, nome: (nome || '').slice(0, 60) || 'Cliente', at: Date.now() });
                list = list.slice(0, 5);
                this.recentTenants = list;
                try { localStorage.setItem(RECENT_TENANTS_KEY, JSON.stringify(list)); } catch {}
            },
            trackTenantViewed() {
                const m = window.location.pathname.match(/^\/Tenants\/Detail\/([0-9a-f-]{36})/i);
                if (!m) return;
                const id = m[1];
                const titulo = document.querySelector('h2.text-es-ink')?.textContent?.trim() || document.title;
                this.pushRecent(id, titulo);
            },

            // ── Atalhos teclado ──
            bindShortcuts() {
                window.addEventListener('keydown', (e) => {
                    // Cmd+K / Ctrl+K — abre busca, ignora foco.
                    if ((e.ctrlKey || e.metaKey) && (e.key === 'k' || e.key === 'K')) {
                        e.preventDefault();
                        window.dispatchEvent(new CustomEvent('open-cmdk'));
                        return;
                    }
                    // Atalhos de letra só fora de input/textarea/select.
                    const tag = (e.target.tagName || '').toLowerCase();
                    if (tag === 'input' || tag === 'textarea' || tag === 'select' || e.target.isContentEditable) return;

                    // ? — abre cheatsheet.
                    if (e.key === '?' && !e.ctrlKey && !e.metaKey && !e.altKey) {
                        e.preventDefault();
                        this.cheatOpen = true;
                        return;
                    }

                    // [ — toggle sidebar collapse.
                    if (e.key === '[' && !e.ctrlKey && !e.metaKey && !e.altKey) {
                        e.preventDefault();
                        this.toggleSidebar();
                        return;
                    }

                    // g + letra — atalhos "vai para".
                    if (e.key === 'g' && !this._gPressed) {
                        this._gPressed = true;
                        clearTimeout(this._gTimer);
                        this._gTimer = setTimeout(() => { this._gPressed = false; }, 1200);
                        return;
                    }
                    if (this._gPressed) {
                        this._gPressed = false; clearTimeout(this._gTimer);
                        if (e.key.toLowerCase() === 'h') {
                            e.preventDefault();
                            this.toggleTheme();
                            return;
                        }
                        const dest = {
                            'd': '/',
                            'c': '/Tenants',
                            't': '/Tickets',
                            'p': '/Planos',
                            'a': '/Admins',
                            's': '/Diagnostico'
                        }[e.key.toLowerCase()];
                        if (dest) {
                            e.preventDefault();
                            window.location.href = dest;
                        }
                    }
                }, true);
            }
        }
    }
</script>


</body>
</html>
