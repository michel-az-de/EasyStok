@page
@model EasyStock.Admin.Pages.Auth.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Login — EasyStock Admin";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-slate-950 flex items-center justify-center">
<div class="w-full max-w-sm mx-auto px-4">

    <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-14 h-14 bg-violet-700 rounded-2xl mb-4">
            <span class="text-white font-bold text-xl">ES</span>
        </div>
        <h1 class="text-white text-2xl font-bold">EasyStock Admin</h1>
        <p class="text-slate-400 text-sm mt-1">Painel restrito a Super Administradores</p>
    </div>

    <div class="bg-slate-800 border border-slate-700 rounded-xl p-6">
        @if (Model.Erro != null)
        {
            <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-4 py-3 text-sm mb-4">
                @Model.Erro
            </div>
        }

        <form method="post" class="space-y-4">
            @Html.AntiForgeryToken()

            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1.5">E-mail</label>
                <input asp-for="Email" type="email" required
                       class="w-full bg-slate-900 border border-slate-600 rounded-lg text-white px-3 py-2.5 text-sm focus:outline-none focus:border-violet-500 transition-colors placeholder-slate-500"
                       placeholder="admin@easystock.com.br" />
            </div>

            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1.5">Senha</label>
                <input asp-for="Senha" type="password" required
                       class="w-full bg-slate-900 border border-slate-600 rounded-lg text-white px-3 py-2.5 text-sm focus:outline-none focus:border-violet-500 transition-colors placeholder-slate-500"
                       placeholder="••••••••" />
            </div>

            <button type="submit"
                    class="w-full bg-violet-700 hover:bg-violet-600 text-white font-semibold py-2.5 rounded-lg text-sm transition-colors mt-2">
                Entrar
            </button>
        </form>
    </div>

    <p class="text-center text-slate-600 text-xs mt-6">EasyStock Admin Panel • Acesso restrito</p>
</div>
</body>
</html>
