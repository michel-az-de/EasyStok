@page
@model EasyStock.Admin.Pages.Auth.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Login — EasyStock Admin";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.dist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="min-h-screen font-sans flex items-center justify-center" data-theme="dark" style="background:var(--bg-app);color:var(--text-primary);">
<div class="w-full max-w-sm mx-auto px-4">

    <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center mb-4">
            <svg width="56" height="56" viewBox="0 0 64 64" fill="none" aria-label="EasyStock">
                <path d="M32 6 L56 18 L32 30 L8 18 Z" fill="#E85814"/>
                <path d="M8 18 L32 30 L32 58 L8 46 Z" fill="#0E2A6E"/>
                <path d="M56 18 L32 30 L32 58 L56 46 Z" fill="#06143A"/>
            </svg>
        </div>
        <h1 class="text-es-ink text-2xl font-bold" style="font-family:'Fraunces',serif;letter-spacing:-0.02em;">
            <span>Easy</span><span style="color:#F26B25">Stok</span> Admin
        </h1>
        <p class="text-es-ink-dim text-sm mt-1">Painel restrito a Super Administradores</p>
    </div>

    <div class="bg-es-card rounded-xl p-6" style="border:1px solid rgba(247,242,232,0.18)">
        @if (Model.Erro != null)
        {
            <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-4 py-3 text-sm mb-4">
                @Model.Erro
            </div>
        }

        <form method="post" class="space-y-4">
            @Html.AntiForgeryToken()

            <div>
                <label class="block text-xs font-bold text-es-ink-mute uppercase tracking-widest mb-1.5">E-mail</label>
                <input asp-for="Email" type="email" required
                       class="w-full bg-es-bg rounded-lg text-es-ink px-3 py-2.5 text-sm outline-none transition-all placeholder-es-ink-mute"
                       style="border:1px solid rgba(247,242,232,0.18)"
                       onfocus="this.style.borderColor='#f47920';this.style.boxShadow='0 0 0 3px rgba(244,121,32,.16)'"
                       onblur="this.style.borderColor='rgba(247,242,232,0.18)';this.style.boxShadow='none'"
                       placeholder="admin@easystock.com.br" />
            </div>

            <div>
                <label class="block text-xs font-bold text-es-ink-mute uppercase tracking-widest mb-1.5">Senha</label>
                <input asp-for="Senha" type="password" required
                       class="w-full bg-es-bg rounded-lg text-es-ink px-3 py-2.5 text-sm outline-none transition-all placeholder-es-ink-mute"
                       style="border:1px solid rgba(247,242,232,0.18)"
                       onfocus="this.style.borderColor='#f47920';this.style.boxShadow='0 0 0 3px rgba(244,121,32,.16)'"
                       onblur="this.style.borderColor='rgba(247,242,232,0.18)';this.style.boxShadow='none'"
                       placeholder="••••••••" />
            </div>

            <button type="submit"
                    class="w-full bg-es-accent text-es-ink font-bold py-2.5 rounded-lg text-sm transition-all mt-2"
                    onmouseover="this.style.background='#d96610'"
                    onmouseout="this.style.background='#f47920'"
                    onmousedown="this.style.transform='scale(0.98)'"
                    onmouseup="this.style.transform='scale(1)'">
                Entrar
            </button>
        </form>
    </div>

    <p class="text-center text-es-ink-mute text-xs mt-6">EasyStock Admin Panel • Acesso restrito</p>
</div>
</body>
</html>
