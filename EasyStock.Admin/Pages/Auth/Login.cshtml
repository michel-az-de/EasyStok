@page
@model EasyStock.Admin.Pages.Auth.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Login — EasyStok Admin";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#06143A" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.dist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <style>
        /* ─── Background: admin dark clean ──────────────────────────────────── */
        :root {
            --neon-orange: #F47920;
            --neon-orange-soft: #FFA45C;
            --neon-cyan: #4FBF9F;
            --navy-deep: #06143A;
            --navy-mid: #0A1F52;
        }
        body {
            background:
                linear-gradient(180deg, rgba(232,88,20,.10) 0%, transparent 34%),
                linear-gradient(135deg, rgba(14,42,110,.35) 0%, transparent 46%),
                linear-gradient(180deg, #06143A 0%, #02081f 100%);
            position: relative;
            overflow-x: hidden;
        }
        /* Grid técnico bem sutil, sem competir com o formulário. */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(247,242,232,.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(247,242,232,.04) 1px, transparent 1px);
            background-size: 48px 48px;
            mask-image: radial-gradient(ellipse 100% 60% at 50% 30%, black 0%, transparent 75%);
            pointer-events: none;
            z-index: 0;
        }
        body::after {
            content: none;
        }

        /* ─── Status bar topo (toque sci-fi) ──────────────────────────────────── */
        .status-bar {
            position: fixed;
            top: 0; left: 0; right: 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 20px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            color: rgba(247,242,232,.5);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            z-index: 10;
            pointer-events: none;
        }
        .status-bar .dot {
            display: inline-block;
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--neon-cyan);
            box-shadow: 0 0 8px var(--neon-cyan);
            animation: pulse-dot 1.6s ease-in-out infinite;
            margin-right: 6px;
            vertical-align: middle;
        }
        @@keyframes pulse-dot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: .5; transform: scale(.85); }
        }

        /* ─── Logo ───────────────────────────────────────────────────────────── */
        .logo-orbit {
            position: relative;
            width: 76px; height: 76px;
            margin: 0 auto 24px;
            border-radius: 18px;
            background: rgba(247,242,232,.045);
            border: 1px solid rgba(247,242,232,.10);
            display: grid;
            place-items: center;
        }
        .logo-orbit svg {
            width: 50px; height: 50px;
            filter: drop-shadow(0 8px 20px rgba(244,121,32,.28));
            z-index: 2;
        }
        .logo-orbit::before {
            content: none;
        }

        /* ─── Card ───────────────────────────────────────────────────────────── */
        .auth-card {
            position: relative;
            background: linear-gradient(180deg, rgba(255,255,255,.04), transparent 110px), rgba(6,20,58,.92);
            border: 1px solid rgba(247,242,232,.11);
            border-radius: 16px;
            padding: 36px 32px;
            box-shadow: 0 24px 70px rgba(0,0,0,.42);
            z-index: 1;
        }
        .auth-card::before {
            content: '';
            position: absolute;
            top: 0; left: 16px; right: 16px;
            height: 1px;
            background: rgba(244,121,32,.55);
        }

        /* ─── Inputs ─────────────────────────────────────────────────────────── */
        .field-group {
            position: relative;
            margin-bottom: 18px;
        }
        .field-group label {
            display: block;
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: rgba(247,242,232,.55);
            margin-bottom: 6px;
            transition: color .25s;
        }
        .field-group:focus-within label {
            color: var(--neon-orange);
        }
        .field-input {
            width: 100%;
            background: rgba(2,8,31,.6);
            border: 1px solid rgba(247,242,232,.12);
            border-radius: 8px;
            padding: 12px 14px;
            font-size: 14px;
            color: #F7F2E8;
            font-family: 'Inter', sans-serif;
            transition: all .25s;
            outline: none;
        }
        .field-input::placeholder {
            color: rgba(247,242,232,.25);
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
        }
        .field-input:focus {
            border-color: var(--neon-orange);
            background: rgba(2,8,31,.85);
            box-shadow:
                0 0 0 3px rgba(244,121,32,.15),
                inset 0 0 20px rgba(244,121,32,.04);
        }
        /* Indicador discreto à esquerda do input quando focado */
        .field-group::before {
            content: '';
            position: absolute;
            left: -12px;
            top: 24px;
            bottom: 0;
            width: 2px;
            background: var(--neon-orange);
            opacity: 0;
            transition: opacity .25s;
            box-shadow: 0 0 8px var(--neon-orange);
        }
        .field-group:focus-within::before {
            opacity: 1;
        }

        /* ─── Botão com shimmer ───────────────────────────────────────────────── */
        .btn-launch {
            position: relative;
            width: 100%;
            background: linear-gradient(135deg, #F47920 0%, #E85814 100%);
            color: #0a1530;
            font-weight: 800;
            font-size: 13px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 14px 16px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            overflow: hidden;
            transition: all .2s;
            box-shadow:
                0 8px 24px rgba(232,88,20,.25),
                inset 0 1px 0 rgba(255,255,255,.2);
            font-family: 'Inter', sans-serif;
        }
        .btn-launch::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,.25) 50%, transparent 100%);
            transition: left .6s ease;
        }
        .btn-launch:hover::before { left: 100%; }
        .btn-launch:hover {
            transform: translateY(-1px);
            box-shadow:
                0 12px 32px rgba(232,88,20,.35),
                inset 0 1px 0 rgba(255,255,255,.25);
        }
        .btn-launch:active { transform: translateY(0) scale(.99); }
        .btn-launch:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }
        .btn-launch::after {
            content: '→';
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 16px;
            transition: transform .2s;
        }
        .btn-launch:hover::after { transform: translateY(-50%) translateX(3px); }

        /* ─── Loading overlay ─────────────────────────────────────────────────── */
        .loading-overlay {
            position: fixed;
            inset: 0;
            background: linear-gradient(180deg, #06143A 0%, #02081f 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 100;
            opacity: 0;
            visibility: hidden;
            transition: opacity .4s, visibility .4s;
        }
        .loading-overlay.active {
            opacity: 1;
            visibility: visible;
        }
        .loading-overlay::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(247,242,232,.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(247,242,232,.04) 1px, transparent 1px);
            background-size: 32px 32px;
            mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 70%);
            pointer-events: none;
        }
        .loading-cube {
            position: relative;
            width: 80px;
            height: 80px;
            margin: 0 auto 32px;
            animation: cube-spin 2s ease-in-out infinite;
        }
        @@keyframes cube-spin {
            0% { transform: rotateY(0) rotateX(0); }
            50% { transform: rotateY(180deg) rotateX(15deg); }
            100% { transform: rotateY(360deg) rotateX(0); }
        }
        .loading-cube svg {
            filter: drop-shadow(0 0 20px rgba(244,121,32,.6));
        }
        .loading-steps {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            color: rgba(247,242,232,.7);
            min-height: 24px;
            text-align: center;
            letter-spacing: 0.05em;
        }
        .loading-steps .step-line {
            display: block;
            opacity: 0;
            transform: translateY(4px);
            transition: opacity .4s, transform .4s;
            line-height: 1.8;
        }
        .loading-steps .step-line.show {
            opacity: 1;
            transform: translateY(0);
        }
        .loading-steps .step-line.done::before {
            content: '✓ ';
            color: var(--neon-cyan);
            font-weight: bold;
        }
        .loading-steps .step-line.active::before {
            content: '▸ ';
            color: var(--neon-orange);
            animation: blink 1s steps(2) infinite;
        }
        @@keyframes blink {
            50% { opacity: .3; }
        }

        /* Progress bar embaixo da loading screen */
        .loading-progress {
            position: absolute;
            bottom: 80px;
            left: 50%;
            transform: translateX(-50%);
            width: 240px;
            height: 2px;
            background: rgba(247,242,232,.08);
            border-radius: 2px;
            overflow: hidden;
        }
        .loading-progress::before {
            content: '';
            display: block;
            width: 30%;
            height: 100%;
            background: linear-gradient(90deg, transparent, var(--neon-orange), transparent);
            animation: progress-slide 1.4s ease-in-out infinite;
        }
        @@keyframes progress-slide {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(400%); }
        }

        /* ─── Erros / banners ─────────────────────────────────────────────────── */
        .alert {
            border-radius: 8px;
            padding: 12px 14px;
            font-size: 13px;
            margin-bottom: 16px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-family: 'Inter', sans-serif;
        }
        .alert-error {
            background: rgba(248,113,113,.1);
            border: 1px solid rgba(248,113,113,.3);
            color: #fca5a5;
        }
        .alert-warn {
            background: rgba(247,144,9,.08);
            border: 1px solid rgba(247,144,9,.28);
            color: #fbbf24;
        }
        .alert::before {
            font-family: 'JetBrains Mono', monospace;
            font-weight: bold;
        }
        .alert-error::before { content: '✕'; }
        .alert-warn::before  { content: '!'; }

        /* ─── Footer ──────────────────────────────────────────────────────────── */
        .footer-tag {
            text-align: center;
            margin-top: 24px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: rgba(247,242,232,.35);
        }
        .footer-tag .sep {
            color: var(--neon-orange);
            margin: 0 8px;
        }

        /* Reduced motion: corta animações pra quem pediu */
        @@media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>
<body class="min-h-screen font-sans flex items-center justify-center" data-theme="dark">

<!-- Barra superior -->
<div class="status-bar">
    <span><span class="dot"></span>SISTEMA ONLINE</span>
    <span>EASYSTOK ADMIN</span>
</div>

<div class="w-full max-w-sm mx-auto px-4" style="position:relative; z-index:1;">

    <!-- Logo orbital -->
    <div class="logo-orbit">
        <svg viewBox="0 0 64 64" fill="none" aria-label="EasyStok">
            <path d="M32 6 L56 18 L32 30 L8 18 Z" fill="#E85814"/>
            <path d="M8 18 L32 30 L32 58 L8 46 Z" fill="#0E2A6E"/>
            <path d="M56 18 L32 30 L32 58 L56 46 Z" fill="#06143A"/>
        </svg>
    </div>

    <!-- Branding -->
    <div class="text-center mb-7">
        <h1 class="text-2xl font-bold" style="font-family:'Fraunces',serif;letter-spacing:-0.02em;color:#F7F2E8;">
            <span>Easy</span><span style="color:#F26B25">Stok</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.18em;font-weight:600;color:rgba(247,242,232,.4);margin-left:6px;vertical-align:6px;">[ ADMIN ]</span>
        </h1>
        <p style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;color:rgba(247,242,232,.48);margin-top:8px;text-transform:uppercase;">
            Painel de controle seguro
        </p>
    </div>

    <!-- Card glass com form -->
    <div class="auth-card">
        @if (Model.SessaoExpirada)
        {
            <div class="alert alert-warn" role="status" aria-live="polite">
                <div>Sua sessão expirou por inatividade. Entre novamente para continuar.</div>
            </div>
        }
        @if (Model.Erro != null)
        {
            <div class="alert alert-error" role="alert" aria-live="assertive">
                <div>@Model.Erro</div>
            </div>
        }

        <form method="post" id="loginForm" autocomplete="on" aria-busy="false">
            @Html.AntiForgeryToken()

            <!-- EmpresaId preenchido pelo JS step-2 antes do submit final -->
            <input type="hidden" asp-for="EmpresaId" id="hiddenEmpresaId" />

            <!-- Step 1: credenciais (sempre visível no início) -->
            <div id="stepCredenciais">
                <div class="field-group">
                    <label for="Email">E-mail</label>
                    <input asp-for="Email" id="Email" type="email" required autocomplete="username"
                           class="field-input"
                           placeholder="admin@easystock.com.br" />
                </div>

                <div class="field-group">
                    <label for="Senha">Senha</label>
                    <div class="relative">
                        <input asp-for="Senha" id="Senha" type="password" required autocomplete="current-password"
                               class="field-input pr-10"
                               placeholder="••••••••••••" />
                        <button type="button" id="toggleSenha"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-es-ink-mute hover:text-es-ink text-base leading-none"
                                aria-label="Mostrar/ocultar senha"
                                onclick="const s=document.getElementById('Senha');s.type=s.type==='password'?'text':'password';this.textContent=s.type==='password'?'👁':'🙈';">👁</button>
                    </div>
                </div>

                <button type="button" class="btn-launch" id="btnVerificar">
                    Continuar
                </button>
            </div>

            <!-- Step 2: seleção de empresa (visível só após verificação) -->
            <div id="stepEmpresa" style="display:none;">
                <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:rgba(247,242,232,.55);letter-spacing:.16em;text-transform:uppercase;margin-bottom:12px;">
                    Selecione a empresa
                </div>
                <div id="listaEmpresas" style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px;">
                    <!-- Empresas injetadas pelo JS -->
                </div>
                <button type="button" id="btnVoltarEmpresa"
                        style="font-size:12px;color:rgba(247,242,232,.5);background:none;border:none;cursor:pointer;text-decoration:underline;padding:0;">
                    ← Voltar
                </button>
            </div>
        </form>
    </div>

    <p class="footer-tag">
        ACESSO RESTRITO <span class="sep">◇</span> ADMIN
    </p>
</div>

<!-- ─── Loading overlay ─────────────────────────────────────────────────── -->
<div class="loading-overlay" id="loadingOverlay" role="status" aria-live="polite" aria-label="Verificando credenciais">
    <div style="text-align:center;">
        <div class="loading-cube" aria-hidden="true">
            <svg width="80" height="80" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                <path d="M32 6 L56 18 L32 30 L8 18 Z" fill="#E85814"/>
                <path d="M8 18 L32 30 L32 58 L8 46 Z" fill="#0E2A6E"/>
                <path d="M56 18 L32 30 L32 58 L56 46 Z" fill="#06143A"/>
            </svg>
        </div>
        <div class="loading-steps">
            <span class="step-line" data-step="0">VERIFICANDO CREDENCIAIS</span>
            <span class="step-line" data-step="1">CARREGANDO PERMISSÕES</span>
            <span class="step-line" data-step="2">SINCRONIZANDO PAINEL</span>
            <span class="step-line" data-step="3">PRONTO</span>
        </div>
    </div>
    <div class="loading-progress" aria-hidden="true"></div>
</div>

<script>
    // ── Typed effect no subtítulo ────────────────────────────────────────
    (function () {
        const txt = 'PAINEL DE CONTROLE • ACESSO PROTEGIDO';
        const target = document.getElementById('typedSubtitle');
        if (!target) return;
        let i = 0;
        function type() {
            if (i <= txt.length) {
                target.textContent = txt.slice(0, i);
                i++;
                setTimeout(type, 35);
            }
        }
        // Pequena pausa antes de começar (deixa o card aparecer)
        setTimeout(type, 250);
    })();

    // ── Login 2-etapas (ADR-0031) ────────────────────────────────────────
    (function () {
        const form = document.getElementById('loginForm');
        const overlay = document.getElementById('loadingOverlay');
        const btnVerificar = document.getElementById('btnVerificar');
        const stepCred = document.getElementById('stepCredenciais');
        const stepEmp = document.getElementById('stepEmpresa');
        const listaEmpresas = document.getElementById('listaEmpresas');
        const hiddenEmpresaId = document.getElementById('hiddenEmpresaId');
        const btnVoltar = document.getElementById('btnVoltarEmpresa');
        if (!form || !overlay) return;

        // Foco inteligente
        const hasServerError = !!document.querySelector('.alert-error');
        (hasServerError ? document.getElementById('Senha') : document.getElementById('Email'))?.focus();

        function showOverlay() {
            overlay.classList.add('active');
            const lines = overlay.querySelectorAll('.step-line');
            const stepDelays = [0, 600, 1100, 1700];
            lines.forEach((line, idx) => {
                setTimeout(() => {
                    lines.forEach((l, i) => {
                        l.classList.remove('active');
                        l.removeAttribute('aria-current');
                        if (i < idx) l.classList.add('done');
                        else if (i === idx) {
                            l.classList.add('show', 'active');
                            l.setAttribute('aria-current', 'step');
                        }
                    });
                }, stepDelays[idx]);
            });
        }

        // Botão "Continuar": step 1 — verifica credenciais e lista empresas
        btnVerificar?.addEventListener('click', async function () {
            const email = document.getElementById('Email')?.value?.trim();
            const senha = document.getElementById('Senha')?.value;
            if (!email || !senha) { alert('Preencha e-mail e senha.'); return; }

            btnVerificar.disabled = true;
            btnVerificar.textContent = 'Verificando...';

            try {
                const resp = await fetch('/api-proxy/auth/lista-empresas', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, senha })
                });
                const json = await resp.json();

                if (!resp.ok) {
                    const msg = json?.error?.message ?? 'E-mail ou senha incorretos.';
                    alert(msg);
                    btnVerificar.disabled = false;
                    btnVerificar.textContent = 'Continuar';
                    return;
                }

                const data = json.data ?? json;
                if (data.isSuperAdmin) {
                    // SuperAdmin: submit direto (sem empresa)
                    showOverlay();
                    form.submit();
                    return;
                }

                // Tenant: mostrar picker de empresa
                listaEmpresas.innerHTML = '';
                (data.empresas ?? []).forEach(function (emp) {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.textContent = emp.nome;
                    btn.style.cssText = 'width:100%;padding:12px 14px;border-radius:8px;' +
                        'background:rgba(2,8,31,.6);border:1px solid rgba(247,242,232,.18);' +
                        'color:#F7F2E8;font-size:14px;cursor:pointer;text-align:left;' +
                        'font-family:Inter,sans-serif;transition:border-color .2s;';
                    btn.addEventListener('mouseenter', () => btn.style.borderColor = '#F47920');
                    btn.addEventListener('mouseleave', () => btn.style.borderColor = 'rgba(247,242,232,.18)');
                    btn.addEventListener('click', function () {
                        hiddenEmpresaId.value = emp.id;
                        showOverlay();
                        form.submit();
                    });
                    listaEmpresas.appendChild(btn);
                });

                stepCred.style.display = 'none';
                stepEmp.style.display = 'block';

            } catch (e) {
                alert('Erro de conexão. Tente novamente.');
                btnVerificar.disabled = false;
                btnVerificar.textContent = 'Continuar';
            }
        });

        // Botão voltar: volta para step 1
        btnVoltar?.addEventListener('click', function () {
            stepEmp.style.display = 'none';
            stepCred.style.display = 'block';
            btnVerificar.disabled = false;
            btnVerificar.textContent = 'Continuar';
            hiddenEmpresaId.value = '';
        });

        // Se há erro server-side (POST voltou pra esta página), mostrar step 1
        // (o servidor rejeitou o login, seja por credencial ou empresa).
        window.addEventListener('pageshow', () => {
            overlay.classList.remove('active');
            form.setAttribute('aria-busy', 'false');
        });
    })();
</script>
</body>
</html>
