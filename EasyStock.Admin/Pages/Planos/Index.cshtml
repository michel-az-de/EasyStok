@page
@model EasyStock.Admin.Pages.Planos.IndexModel
@{
    ViewData["Title"] = "Planos";
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:24px;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item>Planos</es-breadcrumb-item>
        </es-breadcrumb>
        <div style="margin-top:4px; color: var(--text-muted); font-size: 13px;">
            <strong style="color: var(--text-primary);">@Model.Planos.Count()</strong> plano(s) configurados
        </div>
    </div>
    <es-button variant="primary" icon="plus" x-on:click="$dispatch('open-modal-novo-plano')">Novo plano</es-button>
</div>

@if (!Model.Planos.Any())
{
    <es-card>
        <es-empty-state icon="list-checks"
                        title="Nenhum plano configurado"
                        description="Defina os planos de assinatura disponíveis com seus limites e preços.">
            <es-button variant="primary" icon="plus" x-on:click="$dispatch('open-modal-novo-plano')">Criar primeiro plano</es-button>
        </es-empty-state>
    </es-card>
}
else
{
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:16px;" x-data="{ editingId: '' }">
        @foreach (var p in Model.Planos)
        {
            var pid = p.TryGetProperty("id", out var pidP) ? pidP.GetString() : "";
            var nome = p.TryGetProperty("nome", out var nP) ? nP.GetString() : "";
            var descricao = p.TryGetProperty("descricao", out var dP) && dP.ValueKind != System.Text.Json.JsonValueKind.Null ? dP.GetString() : "";
            var limLojas = p.TryGetProperty("limiteLojas", out var llP) ? llP.GetInt32() : 0;
            var limUsuarios = p.TryGetProperty("limiteUsuarios", out var luP) ? luP.GetInt32() : 0;
            var limProdutos = p.TryGetProperty("limiteProdutos", out var lpP) ? lpP.GetInt32() : 0;
            var limIa = p.TryGetProperty("limiteGeracoesIaMensais", out var liaP) ? liaP.GetInt32() : 0;
            var preco = p.TryGetProperty("precoMensal", out var prP) ? prP.GetDecimal() : 0m;
            var ativo = p.TryGetProperty("ativo", out var atP) && atP.GetBoolean();
            var totalTenants = p.TryGetProperty("totalTenants", out var ttP) ? ttP.GetInt32() : 0;

            <es-card padding="none" card-class="@(ativo ? "" : "")">
                <div style="padding:20px 20px 16px; border-bottom:1px solid var(--border-soft);">
                    <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:8px;">
                        <h3 style="margin:0; font-size:16px; font-weight:600; color:var(--text-primary);">@nome</h3>
                        <es-badge variant="@(ativo ? "ok" : "neutral")" with-dot="true">@(ativo ? "ATIVO" : "INATIVO")</es-badge>
                    </div>
                    <div style="font-size:13px; color:var(--text-muted); min-height:18px;">@descricao</div>
                    <div style="display:flex; align-items:baseline; gap:6px; margin-top:14px;">
                        <span style="font-family:var(--font-display); font-size:32px; font-weight:700; color:var(--text-primary); letter-spacing:-0.02em; line-height:1;">R$ @preco.ToString("N2")</span>
                        <span style="font-size:13px; color:var(--text-muted);">/ mês</span>
                    </div>
                </div>

                <ul style="list-style:none; padding:16px 20px; margin:0; display:flex; flex-direction:column; gap:8px; font-size:13px; color:var(--text-secondary);">
                    <li style="display:flex; align-items:center; gap:8px;">
                        <es-icon name="check-circle" size="14" />
                        <span><strong style="color:var(--text-primary);">@(limLojas == -1 ? "∞" : limLojas.ToString())</strong> @(limLojas == 1 ? "loja" : "lojas")</span>
                    </li>
                    <li style="display:flex; align-items:center; gap:8px;">
                        <es-icon name="check-circle" size="14" />
                        <span><strong style="color:var(--text-primary);">@(limUsuarios == -1 ? "∞" : limUsuarios.ToString())</strong> @(limUsuarios == 1 ? "usuário" : "usuários")</span>
                    </li>
                    <li style="display:flex; align-items:center; gap:8px;">
                        <es-icon name="check-circle" size="14" />
                        <span><strong style="color:var(--text-primary);">@(limProdutos == -1 ? "∞" : limProdutos.ToString())</strong> @(limProdutos == 1 ? "produto" : "produtos")</span>
                    </li>
                    <li style="display:flex; align-items:center; gap:8px;">
                        <es-icon name="check-circle" size="14" />
                        <span><strong style="color:var(--text-primary);">@(limIa == -1 ? "∞" : limIa.ToString())</strong> @(limIa == 1 ? "geração de IA/mês" : "gerações de IA/mês")</span>
                    </li>
                </ul>

                <div style="padding:12px 20px; border-top:1px solid var(--border-soft); background:var(--surface-sunken); display:flex; align-items:center; justify-content:space-between; gap:8px;">
                    <span style="font-size:12px; color:var(--text-muted);"><strong style="color:var(--text-primary);">@totalTenants</strong> tenant(s)</span>
                    <div style="display:flex; gap:6px;">
                        <es-button variant="ghost" size="xs" icon="edit-2" x-on:click="editingId = (editingId === '@pid' ? '' : '@pid')">
                            <span x-text="editingId === '@pid' ? 'Cancelar' : 'Editar'"></span>
                        </es-button>
                        <form method="post" asp-page-handler="Toggle" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@pid" />
                            <es-button type="submit" variant="@(ativo ? "ghost" : "primary")" size="xs">@(ativo ? "Desativar" : "Ativar")</es-button>
                        </form>
                    </div>
                </div>

                <!-- Inline edit -->
                <div x-show="editingId === '@pid'" x-cloak style="padding:16px 20px; border-top:1px solid var(--border-soft);">
                    <form method="post" asp-page-handler="Editar" style="display:flex; flex-direction:column; gap:10px;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@pid" />
                        <es-input name="nome" label="Nome" value="@nome" required="true" />
                        <es-input name="descricao" label="Descrição" value="@descricao" label-optional="true" />
                        <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:10px;">
                            <es-input name="limiteLojas" type="number" min="-1" label="Limite Lojas" value="@limLojas" required="true" helper="-1 = ∞" />
                            <es-input name="limiteUsuarios" type="number" min="-1" label="Limite Usuários" value="@limUsuarios" required="true" />
                            <es-input name="limiteProdutos" type="number" min="-1" label="Limite Produtos" value="@limProdutos" required="true" />
                            <es-input name="limiteGeracoesIaMensais" type="number" min="-1" label="Limite IA/mês" value="@limIa" required="true" />
                        </div>
                        <es-input name="precoMensal" type="number" min="0" label="Preço mensal" value="@preco.ToString(System.Globalization.CultureInfo.InvariantCulture)" step="0.01" prefix="R$" required="true" />
                        <es-button type="submit" variant="primary" icon="check" block="true">Salvar alterações</es-button>
                    </form>
                </div>
            </es-card>
        }
    </div>
}

<!-- Modal Novo Plano -->
<es-modal id="novo-plano" title="Novo plano" description="Defina nome, limites e preço mensal." size="md">
    <form method="post" asp-page-handler="Criar" style="display:flex; flex-direction:column; gap:14px;">
        @Html.AntiForgeryToken()
        <es-input name="nome" label="Nome" required="true" placeholder="Ex.: Profissional" />
        <es-input name="descricao" label="Descrição" label-optional="true" placeholder="Para empresas em crescimento" />

        <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:12px;">
            <es-input name="limiteLojas" type="number" min="-1" label="Limite Lojas" value="1" required="true" helper="-1 = ∞" />
            <es-input name="limiteUsuarios" type="number" min="-1" label="Limite Usuários" value="5" required="true" />
            <es-input name="limiteProdutos" type="number" min="-1" label="Limite Produtos" value="500" required="true" />
            <es-input name="limiteGeracoesIaMensais" type="number" min="-1" label="Limite IA/mês" value="10" required="true" />
        </div>

        <es-input name="precoMensal" type="number" min="0" label="Preço mensal" value="0" step="0.01" prefix="R$" required="true" />

        <es-modal-footer>
            <es-button variant="ghost" x-on:click="close()">Cancelar</es-button>
            <es-button type="submit" variant="primary" icon="check">Criar plano</es-button>
        </es-modal-footer>
    </form>
</es-modal>
