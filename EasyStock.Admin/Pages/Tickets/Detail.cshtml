@page "{id:guid}"
@model EasyStock.Admin.Pages.Tickets.DetailModel
@using System.Text.Json
@{
    ViewData["Title"] = Model.Titulo;
    var priClass = Model.Prioridade.ToLower() switch { "critica" => "badge-critica", "alta" => "badge-alta", _ => "badge-normal" };
    var stClass = Model.Status.ToLower().Replace(" ", "") switch
    {
        "aberto" => "badge-aberto",
        "ematendimento" => "badge-ematendimento",
        "aguardandocliente" => "badge-alta",
        "resolvido" => "badge-resolvido",
        _ => "badge-fechado"
    };
}

<a href="/Tickets" class="text-es-ink-mute hover:text-es-ink text-sm mb-4 inline-flex items-center gap-1">← Voltar</a>

@if (Model.Erro != null)
{
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-4 py-3 text-sm mb-4">@Model.Erro</div>
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6"
     x-data="{
        modalEncaminhar: false, modalBug: false, modalRevelar: false,
        clienteRevelado: null,
        async revelar(motivo) {
            const r = await fetch('/api-proxy/admin-empresas-revelar?empresaId=@Model.EmpresaId&ticketId=@Model.Id', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ motivo })
            });
            if (!r.ok) { alert('Falha ao revelar dados.'); return; }
            const d = await r.json();
            clienteRevelado = d.data || d;
            modalRevelar = false;
        }
     }">

    <!-- Conversa principal -->
    <div class="lg:col-span-2 space-y-4">
        <!-- Header do ticket -->
        <div class="card">
            <div class="flex items-start justify-between gap-4 flex-wrap">
                <div class="min-w-0 flex-1">
                    <h2 class="text-es-ink text-lg font-bold mb-1">@Model.Titulo</h2>
                    <div class="flex items-center gap-2 flex-wrap">
                        <span class="status-badge @stClass">@Model.Status</span>
                        <span class="status-badge @priClass">@Model.Prioridade</span>
                        <span class="text-es-ink-mute text-xs px-2 py-0.5 bg-es-surface-2 rounded">@Model.Categoria</span>
                        <span class="text-es-ink-mute text-xs px-2 py-0.5 bg-es-accent/10 border border-es-accent/30 text-es-accent rounded font-bold">@Model.Nivel</span>
                        @if (!string.IsNullOrEmpty(Model.OrigemTicketId))
                        {
                            <a href="/Tickets/Detail/@Model.OrigemTicketId" class="text-es-accent hover:text-es-cream text-xs">↳ Origem: @Model.OrigemTicketTitulo</a>
                        }
                    </div>
                </div>
                <div class="flex gap-2 flex-wrap">
                    @if (Model.Status != "Resolvido" && Model.Status != "Fechado")
                    {
                        <form method="post" asp-page-handler="Resolver">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-primary text-sm">✓ Resolver</button>
                        </form>
                    }
                    <form method="post" asp-page-handler="AlterarStatus" class="flex items-center gap-2"
                          x-data="{ submitting: false }"
                          @@submit="submitting = true">
                        @Html.AntiForgeryToken()
                        <select name="status" class="form-input text-sm py-1.5" style="width:160px"
                                aria-label="Alterar status do ticket"
                                :disabled="submitting"
                                onchange="if (!this.dataset.submitted) { this.dataset.submitted = '1'; this.form.submit(); }">
                            <option value="Aberto" selected="@(Model.Status == "Aberto")">Aberto</option>
                            <option value="EmAtendimento" selected="@(Model.Status == "EmAtendimento")">Em Atend.</option>
                            <option value="AguardandoCliente" selected="@(Model.Status == "AguardandoCliente")">Aguard. Cliente</option>
                            <option value="Resolvido" selected="@(Model.Status == "Resolvido")">Resolvido</option>
                            <option value="Fechado" selected="@(Model.Status == "Fechado")">Fechado</option>
                        </select>
                    </form>
                </div>
            </div>
            <p class="text-es-ink-dim text-sm mt-3 whitespace-pre-wrap">@Model.Descricao</p>
        </div>

        <!-- Timeline (mensagens + historico) -->
        <div class="space-y-3">
            @{
                var items = new List<(DateTime Quando, string Tipo, JsonElement Dado)>();
                foreach (var m in Model.Mensagens)
                {
                    if (m.TryGetProperty("criadoEm", out var cep) && DateTime.TryParse(cep.GetString(), out var dt))
                        items.Add((dt, "msg", m));
                }
                foreach (var h in Model.Historico)
                {
                    if (h.TryGetProperty("criadoEm", out var cep) && DateTime.TryParse(cep.GetString(), out var dt))
                        items.Add((dt, "hist", h));
                }
                items.Sort((a, b) => a.Quando.CompareTo(b.Quando));
            }

            @foreach (var (quando, tipo, el) in items)
            {
                if (tipo == "msg")
                {
                    var isAdmin = el.TryGetProperty("isAdmin", out var iap) && iap.GetBoolean();
                    var interno = el.TryGetProperty("interno", out var inp) && inp.GetBoolean();
                    var autor = el.TryGetProperty("autorNome", out var anp) && anp.ValueKind != JsonValueKind.Null ? anp.GetString() : "?";
                    var conteudo = el.TryGetProperty("conteudo", out var cp2) ? cp2.GetString() : "";

                    if (interno)
                    {
                        <div class="flex justify-center">
                            <div class="max-w-2xl w-full">
                                <div class="text-center text-xs text-yellow-400 mb-1">🔒 INTERNO · @autor · @quando.ToLocalTime().ToString("dd/MM HH:mm")</div>
                                <div class="rounded-xl px-4 py-3 text-sm text-es-ink-dim" style="background:rgba(234,179,8,.08); border:1px dashed rgba(234,179,8,.40)">@conteudo</div>
                            </div>
                        </div>
                    }
                    else if (isAdmin)
                    {
                        <div class="flex justify-end">
                            <div class="max-w-lg">
                                <div class="text-right text-xs text-es-ink-mute mb-1">@autor · @quando.ToLocalTime().ToString("dd/MM HH:mm")</div>
                                <div class="rounded-xl rounded-tr-sm px-4 py-3 text-sm text-es-ink" style="background:rgba(244,121,32,.16); border:1px solid rgba(244,121,32,.28)">@conteudo</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="flex justify-start">
                            <div class="max-w-lg">
                                <div class="text-left text-xs text-es-ink-mute mb-1">@autor · @quando.ToLocalTime().ToString("dd/MM HH:mm")</div>
                                <div class="rounded-xl rounded-tl-sm px-4 py-3 text-sm text-es-ink-dim" style="background:#202b42; border:1px solid rgba(247,242,232,.12)">@conteudo</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    var acao = el.TryGetProperty("acao", out var ap) ? ap.GetString() : "?";
                    var antes = el.TryGetProperty("valorAntes", out var vap) && vap.ValueKind != JsonValueKind.Null ? vap.GetString() : null;
                    var depois = el.TryGetProperty("valorDepois", out var vdp) && vdp.ValueKind != JsonValueKind.Null ? vdp.GetString() : null;
                    var label = acao switch
                    {
                        "StatusAlterado" => $"status mudou de {antes} para {depois}",
                        "PrioridadeAlterada" => $"prioridade alterada de {antes} para {depois}",
                        "AtendenteAtribuido" => $"atendente atribuído",
                        "NivelEncaminhado" => $"encaminhado de {antes} para {depois}",
                        "SlaProximoVencer" => $"⚠ SLA próximo: {depois}",
                        "SlaViolado" => $"🚨 SLA violado: {depois}",
                        "AnexoAdicionado" => $"📎 anexou {depois}",
                        "BugFixGerado" => $"🐛 bug-fix gerado ({depois})",
                        "ClienteRevelado" => $"🔓 dados do cliente revelados (LGPD)",
                        "Criado" => "ticket criado",
                        _ => acao ?? ""
                    };
                    <div class="flex justify-center">
                        <div class="text-xs text-es-ink-mute">— @label · @quando.ToLocalTime().ToString("dd/MM HH:mm") —</div>
                    </div>
                }
            }

            @if (!items.Any())
            {
                <div class="text-center text-es-ink-mute text-sm py-6">Sem atividade ainda.</div>
            }
        </div>

        <!-- Anexos -->
        @if (Model.Anexos.Any())
        {
            <div class="card">
                <h3 class="text-es-ink font-semibold text-sm mb-3">📎 Anexos</h3>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
                    @foreach (var a in Model.Anexos)
                    {
                        var nome = a.TryGetProperty("nomeArquivo", out var np) ? np.GetString() : "anexo";
                        var url = a.TryGetProperty("url", out var up) ? up.GetString() : "#";
                        var tam = a.TryGetProperty("tamanhoBytes", out var tp) ? tp.GetInt64() : 0L;
                        <a href="@url" target="_blank" class="bg-es-surface-2 hover:bg-es-surface-3 border border-es-ink-mute/20 rounded-lg p-2 text-sm">
                            <div class="text-es-ink truncate">@nome</div>
                            <div class="text-es-ink-mute text-xs">@(tam / 1024) KB</div>
                        </a>
                    }
                </div>
            </div>
        }

        <!-- Composer -->
        @if (Model.Status != "Fechado")
        {
            <div class="card" x-data="{ interno: false }">
                <form method="post" asp-page-handler="Responder" class="space-y-3">
                    @Html.AntiForgeryToken()
                    <div class="flex items-center justify-between">
                        <label class="form-label mb-0">Resposta</label>
                        <label class="flex items-center gap-2 text-sm text-es-ink-dim cursor-pointer">
                            <input type="checkbox" name="interno" value="true" x-model="interno" />
                            Comentário interno (não visível ao cliente)
                        </label>
                    </div>
                    <textarea name="conteudo" class="form-input" rows="4"
                              :placeholder="interno ? 'Comentário interno entre atendentes...' : 'Resposta visível ao cliente...'"
                              required></textarea>
                    <div class="flex justify-end">
                        <button type="submit" class="btn-primary"
                                :class="interno ? '!bg-yellow-600 hover:!bg-yellow-700' : ''"
                                x-text="interno ? 'Salvar comentário interno' : 'Enviar resposta'">Enviar resposta</button>
                    </div>
                </form>
                <p class="text-es-ink-mute text-xs mt-3">📎 Anexos: use a API <code>POST /api/admin/tickets/@Model.Id/anexos</code> (drag &amp; drop em breve).</p>
            </div>
        }
    </div>

    <!-- Sidebar -->
    <div class="space-y-4">
        <!-- Empresa + LGPD -->
        <div class="card">
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-es-ink font-semibold text-sm">Empresa (Cliente)</h3>
                <button type="button" @@click="modalRevelar = true" class="text-es-accent hover:text-es-cream text-xs">🔓 Revelar (LGPD)</button>
            </div>
            <div class="text-es-ink-dim font-medium">@Model.EmpresaNome</div>
            <template x-if="!clienteRevelado">
                <div class="text-es-ink-mute text-xs mt-1">Documento: ••••••</div>
            </template>
            <template x-if="clienteRevelado">
                <div class="mt-1 text-xs space-y-1">
                    <div class="text-yellow-400">✓ Dados revelados (audit gravado)</div>
                    <div class="text-es-ink-dim">Doc: <span x-text="clienteRevelado.documentoExibicao || '—'"></span></div>
                    <div class="text-es-ink-mute">Plano: <span x-text="clienteRevelado.planoNome || '—'"></span></div>
                </div>
            </template>
            <a href="/Tenants/Detail/@Model.EmpresaId" class="text-es-accent hover:text-es-cream text-xs mt-2 inline-block">Ver tenant →</a>
        </div>

        <!-- SLA -->
        <div class="card">
            <h3 class="text-es-ink font-semibold text-sm mb-3">⏱ SLA</h3>
            <div class="space-y-3 text-sm">
                @{
                    string SlaBadge(DateTime? prazo, bool violado, DateTime? cumprido)
                    {
                        if (cumprido.HasValue) return "<span class='text-green-400'>✓ Cumprido</span>";
                        if (violado) return "<span class='text-red-400 font-bold'>VIOLADO</span>";
                        if (!prazo.HasValue) return "<span class='text-es-ink-mute'>—</span>";
                        var rest = prazo.Value.ToUniversalTime() - DateTime.UtcNow;
                        if (rest.TotalMinutes < 0) return "<span class='text-orange-400'>Atraso</span>";
                        if (rest.TotalMinutes < 30) return $"<span class='text-orange-400 font-bold'>{(int)rest.TotalMinutes}m</span>";
                        if (rest.TotalHours < 4) return $"<span class='text-yellow-400 font-bold'>{(int)rest.TotalHours}h {rest.Minutes}m</span>";
                        return $"<span class='text-green-400'>{(int)rest.TotalHours}h</span>";
                    }
                }
                <div class="flex justify-between">
                    <span class="text-es-ink-mute">Resposta</span>
                    @Html.Raw(SlaBadge(Model.PrazoResposta, Model.SlaRespostaViolado, Model.PrimeiraRespostaEm))
                </div>
                @if (Model.PrazoResposta.HasValue)
                {
                    <div class="text-xs text-es-ink-mute">Prazo: @Model.PrazoResposta.Value.ToLocalTime().ToString("dd/MM HH:mm")</div>
                }
                <div class="flex justify-between mt-2">
                    <span class="text-es-ink-mute">Resolução</span>
                    @Html.Raw(SlaBadge(Model.PrazoResolucao, Model.SlaResolucaoViolado, Model.ResolvidoEm))
                </div>
                @if (Model.PrazoResolucao.HasValue)
                {
                    <div class="text-xs text-es-ink-mute">Prazo: @Model.PrazoResolucao.Value.ToLocalTime().ToString("dd/MM HH:mm")</div>
                }
            </div>
        </div>

        <!-- Atendimento -->
        <div class="card">
            <h3 class="text-es-ink font-semibold text-sm mb-3">👤 Atendimento</h3>
            <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                    <span class="text-es-ink-mute">Nível</span>
                    <span class="text-es-accent font-bold">@Model.Nivel</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-es-ink-mute">Atendente</span>
                    <span class="text-es-ink-dim">@(string.IsNullOrEmpty(Model.AtendenteNome) ? "— (na fila)" : Model.AtendenteNome)</span>
                </div>
            </div>
            <div class="space-y-2 mt-3">
                @if (string.IsNullOrEmpty(Model.AtendenteNome))
                {
                    <form method="post" asp-page-handler="Assumir">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-primary w-full text-sm">Assumir ticket</button>
                    </form>
                }
                <button type="button" @@click="modalEncaminhar = true" class="btn-secondary w-full text-sm">↗ Encaminhar para outro nível</button>
            </div>
        </div>

        <!-- Ações -->
        <div class="card">
            <h3 class="text-es-ink font-semibold text-sm mb-3">⚡ Ações</h3>
            <div class="space-y-2">
                <button type="button" @@click="modalBug = true" class="btn-secondary w-full text-sm">🐛 Gerar bug-fix para dev</button>
            </div>
            @if (Model.MetaTecnico is JsonElement meta)
            {
                <div class="mt-3 pt-3 border-t border-es-ink-mute/20 text-xs space-y-1">
                    <div class="text-es-ink-mute">Severidade: <span class="text-es-ink-dim">@(meta.TryGetProperty("severidadeTecnica", out var sev) ? sev.GetString() : "—")</span></div>
                    <div class="text-es-ink-mute">Componente: <span class="text-es-ink-dim">@(meta.TryGetProperty("componenteAfetado", out var co) && co.ValueKind != JsonValueKind.Null ? co.GetString() : "—")</span></div>
                </div>
            }
        </div>
    </div>

    <!-- Modal Encaminhar -->
    <div x-show="modalEncaminhar" x-cloak class="modal-overlay" @@click.self="modalEncaminhar = false">
        <div class="modal-box" @@click.stop>
            <h3 class="text-es-ink font-semibold mb-4">Encaminhar para outro nível</h3>
            <form method="post" asp-page-handler="Encaminhar" class="space-y-4">
                @Html.AntiForgeryToken()
                <div>
                    <label class="form-label" for="encaminhar-novoNivel">Nível destino</label>
                    <select id="encaminhar-novoNivel" name="novoNivel" class="form-input" required aria-label="Nível de destino">
                        <option value="N1">N1 - Triagem</option>
                        <option value="N2">N2 - Suporte</option>
                        <option value="N3">N3 - Técnico</option>
                        <option value="N4">N4 - Engenharia</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Motivo (opcional)</label>
                    <textarea name="motivo" class="form-input" rows="2" maxlength="500"></textarea>
                </div>
                <div class="flex gap-3 justify-end">
                    <button type="button" @@click="modalEncaminhar = false" class="btn-secondary">Cancelar</button>
                    <button type="submit" class="btn-primary">Encaminhar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Bug-fix -->
    <div x-show="modalBug" x-cloak class="modal-overlay" @@click.self="modalBug = false">
        <div class="modal-box" @@click.stop>
            <h3 class="text-es-ink font-semibold mb-4">🐛 Gerar bug-fix para o time de desenvolvimento</h3>
            <form method="post" asp-page-handler="BugFix" class="space-y-4">
                @Html.AntiForgeryToken()
                <div>
                    <label class="form-label">Título do bug</label>
                    <input type="text" name="titulo" class="form-input" required minlength="3" maxlength="200" />
                </div>
                <div>
                    <label class="form-label">Descrição técnica</label>
                    <textarea name="descricao" class="form-input" rows="4" required minlength="5" maxlength="4000" placeholder="Steps to reproduce, comportamento esperado vs atual..."></textarea>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="form-label" for="bugfix-severidade">Severidade</label>
                        <select id="bugfix-severidade" name="severidade" class="form-input" aria-label="Severidade do bug">
                            <option value="Baixa">Baixa</option>
                            <option value="Media" selected>Média</option>
                            <option value="Alta">Alta</option>
                            <option value="Critica">Crítica</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Componente</label>
                        <input type="text" name="componente" class="form-input" placeholder="Ex: estoque, vendas, mobile" />
                    </div>
                </div>
                <div>
                    <label class="form-label">Stack trace (opcional)</label>
                    <textarea name="stackTrace" class="form-input font-mono text-xs" rows="3"></textarea>
                </div>
                <div class="flex gap-3 justify-end">
                    <button type="button" @@click="modalBug = false" class="btn-secondary">Cancelar</button>
                    <button type="submit" class="btn-primary">Encaminhar para dev</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Revelar Cliente (LGPD) -->
    <div x-show="modalRevelar" x-cloak class="modal-overlay" @@click.self="modalRevelar = false">
        <div class="modal-box" @@click.stop x-data="{ motivo: '' }">
            <h3 class="text-es-ink font-semibold mb-2">🔓 Revelar dados completos do cliente</h3>
            <p class="text-es-ink-mute text-xs mb-4">Esta ação será registrada no log de auditoria (LGPD). Informe o motivo.</p>
            <div class="space-y-3">
                <textarea x-model="motivo" rows="3" class="form-input" minlength="10" placeholder="Ex: investigando reclamação relativa a cobrança duplicada..."></textarea>
                <div class="flex gap-3 justify-end">
                    <button type="button" @@click="modalRevelar = false" class="btn-secondary">Cancelar</button>
                    <button type="button" @@click="if (motivo.length >= 10) revelar(motivo); else alert('Motivo precisa de no mínimo 10 caracteres.')" class="btn-primary">Revelar</button>
                </div>
            </div>
        </div>
    </div>
</div>
