@page
@model EasyStock.Admin.Pages.Tickets.DashboardModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard Helpdesk";
    var maxNivel = Model.PorNivel.Values.DefaultIfEmpty(1).Max();
}

@* Fase 3: painel helpdesk no padrao deck (issue #626). Server-rendered. *@
<header class="deck-head deck-rise" style="--deck-i:0; margin-bottom:20px;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item href="/Tickets">Tickets</es-breadcrumb-item>
            <es-breadcrumb-item>Painel</es-breadcrumb-item>
        </es-breadcrumb>
        <div class="deck-eyebrow deck-accent-underline" style="margin-top:8px;">Helpdesk</div>
        <h1>Painel Helpdesk</h1>
        <p>SLA, fila de criticidade e distribuição por nível</p>
    </div>
    <div class="deck-head-actions">
        <es-button variant="ghost" href="/Tickets" icon="arrow-left">Lista de tickets</es-button>
    </div>
</header>

<!-- KPIs (6) -->
<section class="deck-rise" style="--deck-i:1; display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:14px; margin-bottom:20px;">
    <div class="deck-panel deck-tile">
        <div class="deck-eyebrow">Abertos</div>
        <div class="deck-kpi">@Model.Abertos</div>
    </div>
    <div class="deck-panel deck-tile">
        <div class="deck-eyebrow">Em atendimento</div>
        <div class="deck-kpi" style="color:var(--orange-500);">@Model.EmAtendimento</div>
    </div>
    <div class="deck-panel deck-tile">
        <div class="deck-eyebrow">Aguard. cliente</div>
        <div class="deck-kpi" style="color:var(--warn-600);">@Model.AguardandoCliente</div>
    </div>
    <div class="deck-panel deck-tile">
        <div class="deck-eyebrow">Resolvidos hoje</div>
        <div class="deck-kpi" style="color:var(--ok-600);">@Model.ResolvidosHoje</div>
    </div>
    <div class="deck-panel deck-tile">
        <div class="deck-eyebrow">SLA em risco</div>
        <div class="deck-kpi" style="color:var(--warn-600);">@Model.SlaRisco</div>
    </div>
    <div class="deck-panel deck-tile">
        <div class="deck-eyebrow">SLA violado</div>
        <div class="deck-kpi" style="color:var(--crit-600);">@Model.SlaViolado</div>
    </div>
</section>

<section class="deck-rise" style="--deck-i:2; display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:16px;">

    <article class="deck-panel">
        <div class="deck-panel-head">
            <h3>Fila de criticidade</h3>
            <span class="deck-sub">Top 10 críticos por SLA</span>
        </div>
        @if (!Model.FilaCriticidade.Any())
        {
            <div style="padding:8px var(--s-5) 28px;">
                <es-empty-state icon="check-circle" title="Sem tickets críticos" description="A fila está em dia." />
            </div>
        }
        else
        {
            <table class="deck-table">
                <thead>
                    <tr>
                        <th scope="col">Ticket</th>
                        <th scope="col">Empresa</th>
                        <th scope="col">Prio</th>
                        <th scope="col">Nível</th>
                        <th scope="col">SLA</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.FilaCriticidade)
                    {
                        var tid = t.TryGetProperty("id", out var tidP) ? tidP.GetString() : "";
                        var titulo = t.TryGetProperty("titulo", out var titP) ? titP.GetString() : "";
                        var empresa = t.TryGetProperty("empresaNome", out var empP) ? empP.GetString() : "—";
                        var pri = t.TryGetProperty("prioridade", out var priP) ? priP.GetString() : "";
                        var nivel = t.TryGetProperty("nivel", out var nvP) ? nvP.GetString() : "";
                        var slaRespV = t.TryGetProperty("slaRespostaViolado", out var sv) && sv.GetBoolean();
                        var slaResolV = t.TryGetProperty("slaResolucaoViolado", out var srv) && srv.GetBoolean();
                        var prazoResp = t.TryGetProperty("prazoResposta", out var pp) && pp.ValueKind != JsonValueKind.Null ? pp.GetString() : null;
                        DateTime.TryParse(prazoResp, out var prazoDt);
                        // BUG-07 (issue #631): guarda de negativo + le slaResolucaoViolado.
                        // Antes imprimia minuto cru negativo (ex.: "-11252m") quando o ticket entrava
                        // na fila por violacao de RESOLUCAO (slaRespV=false) com prazoResposta vencido.
                        // Espelha o formatador por-ticket de Tickets/Index.cshtml.
                        string slaText; string slaVariant;
                        if (slaRespV || slaResolV) { slaVariant = "crit"; slaText = "VIOLADO"; }
                        else if (prazoDt != default)
                        {
                            var restante = prazoDt.ToUniversalTime() - DateTime.UtcNow;
                            if (restante.TotalMinutes < 0) { slaVariant = "crit"; slaText = "ATRASO"; }
                            else if (restante.TotalMinutes < 60) { slaVariant = "warn"; slaText = $"{(int)restante.TotalMinutes}m"; }
                            else { slaVariant = "warn"; slaText = $"{(int)restante.TotalHours}h"; }
                        }
                        else { slaVariant = "neutral"; slaText = "—"; }
                        var priVariant = pri?.ToLower() switch { "critica" => "crit", "alta" => "warn", _ => "neutral" };
                        <tr style="cursor:pointer;" onclick="window.location.href='/Tickets/Detail/@tid'">
                            <td><a href="/Tickets/Detail/@tid">@titulo</a></td>
                            <td style="color:var(--text-muted); font-size:13px;">@empresa</td>
                            <td><es-badge variant="@priVariant">@pri</es-badge></td>
                            <td style="font-family:var(--font-mono); font-weight:700; color:var(--orange-500);">@nivel</td>
                            <td><es-badge variant="@slaVariant">@slaText</es-badge></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </article>

    <article class="deck-panel">
        <div class="deck-panel-head">
            <h3>Tickets ativos por nível</h3>
            <span class="deck-sub">Distribuição da carga</span>
        </div>
        @if (!Model.PorNivel.Any())
        {
            <div style="padding:8px var(--s-5) 28px;">
                <es-empty-state icon="trending-up" title="Sem dados" description="Não há tickets ativos no momento." />
            </div>
        }
        else
        {
            <div style="display:flex; flex-direction:column; gap:14px; padding:var(--s-2) var(--s-5) var(--s-5);">
                @foreach (var (nivel, count) in Model.PorNivel)
                {
                    var pct = maxNivel == 0 ? 0 : (count * 100 / maxNivel);
                    <div>
                        <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:6px;">
                            <span style="font-family:var(--font-mono); font-weight:700; color:var(--orange-500); font-size:13px;">@nivel</span>
                            <span style="color:var(--text-secondary); font-weight:600;">@count</span>
                        </div>
                        <div style="height:6px; background:var(--surface-sunken); border-radius:999px; overflow:hidden;">
                            <div style="height:100%; width:@(pct)%; background:linear-gradient(90deg, var(--orange-500), var(--orange-600)); transition:width var(--duration-slow) var(--ease-out);"></div>
                        </div>
                    </div>
                }
            </div>
        }
    </article>
</section>
