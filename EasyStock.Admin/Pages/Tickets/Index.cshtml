@page
@model EasyStock.Admin.Pages.Tickets.IndexModel
@using System.Text.Json
@using EasyStock.Admin.Pages.Tickets
@{
    ViewData["Title"] = "Tickets";
    var orderBy = Request.Query["orderBy"].FirstOrDefault();
    var dir = Request.Query["dir"].FirstOrDefault();

    var qsExport = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.Status)) qsExport.Add($"status={Uri.EscapeDataString(Model.Status)}");
    if (!string.IsNullOrWhiteSpace(Model.Prioridade)) qsExport.Add($"prioridade={Uri.EscapeDataString(Model.Prioridade)}");
    if (!string.IsNullOrWhiteSpace(Model.Nivel)) qsExport.Add($"nivel={Uri.EscapeDataString(Model.Nivel)}");
    if (!string.IsNullOrWhiteSpace(Model.SlaStatus)) qsExport.Add($"slaStatus={Uri.EscapeDataString(Model.SlaStatus)}");
    if (!string.IsNullOrWhiteSpace(Model.Categoria)) qsExport.Add($"categoria={Uri.EscapeDataString(Model.Categoria)}");
    if (!string.IsNullOrWhiteSpace(Model.Search)) qsExport.Add($"search={Uri.EscapeDataString(Model.Search)}");
    var exportHref = "/Tickets?handler=ExportCsv" + (qsExport.Count > 0 ? "&" + string.Join("&", qsExport) : "");
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item>Helpdesk</es-breadcrumb-item>
        </es-breadcrumb>
        <div style="margin-top:4px; color:var(--text-muted); font-size:13px;">
            <strong style="color:var(--text-primary);">@Model.Total</strong> ticket(s)
        </div>
    </div>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
        <es-button variant="ghost" href="/Tickets/Dashboard" icon="trending-up">Dashboard</es-button>
        <es-button variant="ghost" href="/Configuracoes/SlaMatriz" icon="settings">Matriz SLA</es-button>
        <es-button variant="ghost" href="@exportHref" icon="download">Exportar CSV</es-button>
        <es-button variant="primary" icon="plus" x-on:click="$dispatch('open-modal-novo-ticket')">Novo ticket</es-button>
    </div>
</div>

<es-card padding="md" card-class="mb-4">
    <form method="get" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:12px; align-items:end;">
        <es-input name="search" label="Buscar" value="@Model.Search" placeholder="Título…" prefix-icon="search" />
        <es-select name="status" label="Status">
            <option value="">Todos</option>
            <option value="Aberto" selected="@(Model.Status == "Aberto")">Aberto</option>
            <option value="EmAtendimento" selected="@(Model.Status == "EmAtendimento")">Em Atendimento</option>
            <option value="AguardandoCliente" selected="@(Model.Status == "AguardandoCliente")">Aguard. Cliente</option>
            <option value="Resolvido" selected="@(Model.Status == "Resolvido")">Resolvido</option>
            <option value="Fechado" selected="@(Model.Status == "Fechado")">Fechado</option>
        </es-select>
        <es-select name="prioridade" label="Prioridade">
            <option value="">Todas</option>
            <option value="Critica" selected="@(Model.Prioridade == "Critica")">Crítica</option>
            <option value="Alta" selected="@(Model.Prioridade == "Alta")">Alta</option>
            <option value="Normal" selected="@(Model.Prioridade == "Normal")">Normal</option>
            <option value="Baixa" selected="@(Model.Prioridade == "Baixa")">Baixa</option>
        </es-select>
        <es-select name="nivel" label="Nível">
            <option value="">Todos</option>
            <option value="N1" selected="@(Model.Nivel == "N1")">N1</option>
            <option value="N2" selected="@(Model.Nivel == "N2")">N2</option>
            <option value="N3" selected="@(Model.Nivel == "N3")">N3</option>
            <option value="N4" selected="@(Model.Nivel == "N4")">N4</option>
        </es-select>
        <es-select name="slaStatus" label="SLA">
            <option value="">Todos</option>
            <option value="ok" selected="@(Model.SlaStatus == "ok")">OK</option>
            <option value="violado" selected="@(Model.SlaStatus == "violado")">Violado</option>
        </es-select>
        <es-select name="categoria" label="Categoria">
            <option value="">Todas</option>
            <option value="Bug" selected="@(Model.Categoria == "Bug")">Bug</option>
            <option value="Duvida" selected="@(Model.Categoria == "Duvida")">Dúvida</option>
            <option value="Financeiro" selected="@(Model.Categoria == "Financeiro")">Financeiro</option>
            <option value="Solicitacao" selected="@(Model.Categoria == "Solicitacao")">Solicitação</option>
            <option value="Incidente" selected="@(Model.Categoria == "Incidente")">Incidente</option>
            <option value="BugFixDev" selected="@(Model.Categoria == "BugFixDev")">Bug-fix Dev</option>
            <option value="Outro" selected="@(Model.Categoria == "Outro")">Outro</option>
        </es-select>
        <div style="display:flex; gap:8px;">
            <es-button type="submit" variant="primary" icon="filter">Filtrar</es-button>
            @if (!string.IsNullOrEmpty(Model.Status) || !string.IsNullOrEmpty(Model.Prioridade) || !string.IsNullOrEmpty(Model.Nivel) || !string.IsNullOrEmpty(Model.SlaStatus) || !string.IsNullOrEmpty(Model.Categoria) || !string.IsNullOrEmpty(Model.Search))
            {
                <es-button variant="ghost" href="/Tickets">Limpar</es-button>
            }
        </div>
    </form>
</es-card>

<es-filter-bar>
    @if (!string.IsNullOrEmpty(Model.Status))    { <es-filter-chip label="Status"     remove-param="status">@Model.Status</es-filter-chip> }
    @if (!string.IsNullOrEmpty(Model.Prioridade)){ <es-filter-chip label="Prioridade" remove-param="prioridade">@Model.Prioridade</es-filter-chip> }
    @if (!string.IsNullOrEmpty(Model.Nivel))     { <es-filter-chip label="Nível"      remove-param="nivel">@Model.Nivel</es-filter-chip> }
    @if (!string.IsNullOrEmpty(Model.SlaStatus)) { <es-filter-chip label="SLA"        remove-param="slaStatus">@Model.SlaStatus</es-filter-chip> }
    @if (!string.IsNullOrEmpty(Model.Categoria)) { <es-filter-chip label="Categoria"  remove-param="categoria">@Model.Categoria</es-filter-chip> }
    @if (!string.IsNullOrEmpty(Model.Search))    { <es-filter-chip label="Busca"      remove-param="search">@Model.Search</es-filter-chip> }
</es-filter-bar>

<es-data-table sort-key="@orderBy" sort-dir="@dir" bulk-name="ids" is-empty="@(!Model.Tickets.Any())">
    <es-data-table-column label="SLA" />
    <es-data-table-column key="titulo" label="Título" sortable="true" />
    <es-data-table-column label="Empresa" />
    <es-data-table-column label="Cat" />
    <es-data-table-column label="Prio" />
    <es-data-table-column label="Nível" />
    <es-data-table-column label="Status" />
    <es-data-table-column label="Atendente" />
    <es-data-table-column key="criadoEm" label="Criado" align="right" sortable="true" />

    @foreach (var t in Model.Tickets)
    {
        var tid = t.TryGetProperty("id", out var tidP) ? tidP.GetString() : "";
        var titulo = t.TryGetProperty("titulo", out var titP) ? titP.GetString() : "";
        var empresa = t.TryGetProperty("empresaNome", out var empP) ? empP.GetString() : "—";
        var naoLidos = t.TryGetProperty("mensagensNaoLidas", out var nlP) ? nlP.GetInt32() : 0;
        var cat = t.TryGetProperty("categoria", out var catP) ? catP.GetString() : "";
        var pri = t.TryGetProperty("prioridade", out var priP) ? priP.GetString() : "";
        var nivel = t.TryGetProperty("nivel", out var nvP) ? nvP.GetString() : "";
        var status = t.TryGetProperty("status", out var stP) ? stP.GetString() : "";
        var atendente = t.TryGetProperty("atendenteNome", out var atP) && atP.ValueKind != JsonValueKind.Null ? atP.GetString() : "—";
        var criado = t.TryGetProperty("criadoEm", out var cP) ? cP.GetString() : null;
        DateTime.TryParse(criado, out var criadoDt);

        var slaRespViolado = t.TryGetProperty("slaRespostaViolado", out var srvP) && srvP.GetBoolean();
        var slaResolViolado = t.TryGetProperty("slaResolucaoViolado", out var srlP) && srlP.GetBoolean();
        var prazoResp = t.TryGetProperty("prazoResposta", out var prP) && prP.ValueKind != JsonValueKind.Null ? prP.GetString() : null;
        DateTime.TryParse(prazoResp, out var prazoRespDt);

        string slaVariant; string slaText;
        var statusFinalizado = string.Equals(status, "Resolvido", StringComparison.OrdinalIgnoreCase)
                            || string.Equals(status, "Fechado", StringComparison.OrdinalIgnoreCase);
        if (statusFinalizado)
        {
            // BUG-04: ticket finalizado mostra o DESFECHO do SLA, nao tempo restante "corrente".
            if (slaRespViolado || slaResolViolado) { slaVariant = "crit"; slaText = "Violado"; }
            else { slaVariant = "ok"; slaText = "Cumprido"; }
        }
        else if (slaRespViolado || slaResolViolado) { slaVariant = "crit"; slaText = "VIOLADO"; }
        else if (prazoRespDt != default)
        {
            var restante = prazoRespDt.ToUniversalTime() - DateTime.UtcNow;
            if (restante.TotalMinutes < 30) { slaVariant = "warn"; slaText = restante.TotalMinutes < 0 ? "ATRASO" : $"{(int)restante.TotalMinutes}m"; }
            else if (restante.TotalHours < 4) { slaVariant = "warn"; slaText = $"{(int)restante.TotalHours}h"; }
            else { slaVariant = "ok"; slaText = $"{(int)restante.TotalHours}h"; }
        }
        else { slaVariant = "neutral"; slaText = "—"; }

        var priVariant = pri?.ToLower() switch { "critica" => "crit", "alta" => "warn", _ => "neutral" };
        var stVariant = status?.ToLower().Replace(" ", "") switch
        {
            "aberto" => "info",
            "ematendimento" => "accent",
            "aguardandocliente" => "warn",
            "resolvido" => "ok",
            _ => "neutral"
        };

        <tr style="cursor:pointer;" tabindex="0"
            onclick="window.location.href='/Tickets/Detail/@tid'"
            onkeydown="if(event.key==='Enter') window.location.href='/Tickets/Detail/@tid'">
            <td onclick="event.stopPropagation()" onkeydown="event.stopPropagation()"><input type="checkbox" name="ids" value="@tid" data-bulk-row aria-label="Selecionar ticket" /></td>
            <td data-label="SLA"><es-badge variant="@slaVariant">@slaText</es-badge></td>
            <td data-label="Título" style="font-weight:500; color:var(--text-primary);">
                @titulo
                @if (naoLidos > 0)
                {
                    <span style="margin-left:6px; background:var(--orange-500); color:white; font-size:10px; font-weight:700; border-radius:999px; padding:2px 7px;">@naoLidos</span>
                }
            </td>
            <td data-label="Empresa" style="color:var(--text-secondary); font-size:13px;">@empresa</td>
            <td data-label="Cat" style="color:var(--text-muted); font-size:12px;">@TicketLabels.Categoria(cat)</td>
            <td data-label="Prio"><es-badge variant="@priVariant">@TicketLabels.Prioridade(pri)</es-badge></td>
            <td data-label="Nível" style="font-weight:700; font-family:var(--font-mono); color:var(--text-secondary);">@nivel</td>
            <td data-label="Status"><es-badge variant="@stVariant">@TicketLabels.Status(status)</es-badge></td>
            <td data-label="Atendente" style="color:var(--text-muted); font-size:13px;">@atendente</td>
            <td data-label="Criado" class="es-data-table-td-numeric" style="color:var(--text-muted); font-size:12px;">@criadoDt.ParaBrasilia().ToString("dd/MM/yy")</td>
        </tr>
    }

    <es-data-table-bulk-actions>
        <es-button variant="ghost" size="sm" icon="check-circle"
                   x-on:click="esStampIds('bulkFecharForm', ids()); $dispatch('open-modal-bulk-fechar')">Fechar</es-button>
        <es-button variant="ghost" size="sm" icon="user-check"
                   x-on:click="esStampIds('bulkAssumirForm', ids()); $dispatch('open-modal-bulk-assumir')">Assumir</es-button>
    </es-data-table-bulk-actions>

    <es-data-table-empty>
        <es-empty-state icon="ticket"
                        title="Nenhum ticket encontrado"
                        description="Ajuste os filtros ou aguarde novos chamados.">
            <es-button variant="ghost" href="/Tickets">Limpar filtros</es-button>
        </es-empty-state>
    </es-data-table-empty>
</es-data-table>

@if (Model.TotalPages > 1)
{
    <es-pagination page="@Model.Page" page-size="@(Math.Max(1, Model.Total / Model.TotalPages))" total="@Model.Total" />
}

<!-- Modal Novo Ticket -->
<es-modal id="novo-ticket" title="Novo ticket" description="Abrir um novo chamado em nome de uma empresa." size="md">
    <form method="post"
          x-data="{ empresaSelecionada: null, buscaEmpresa: '', resultadosEmpresa: [], debounce: null }"
          style="display:flex; flex-direction:column; gap:14px;">
        @Html.AntiForgeryToken()

        <div>
            <label class="es-form-label es-form-label-required">Empresa</label>
            <input type="hidden" name="empresaId" :value="empresaSelecionada ? empresaSelecionada.id : ''" />
            <template x-if="!empresaSelecionada">
                <div style="position:relative;">
                    <input type="text" x-model="buscaEmpresa" placeholder="Digite o nome ou CNPJ..." class="es-form-input"
                           @@input="clearTimeout(debounce); debounce = setTimeout(async () => { if (buscaEmpresa.length < 2) { resultadosEmpresa = []; return; } const r = await fetch('/api-proxy/buscar-global?q=' + encodeURIComponent(buscaEmpresa) + '&limit=8'); const d = await r.json(); resultadosEmpresa = (d.data && d.data.clientes) || d.clientes || []; }, 200)" />
                    <div x-show="resultadosEmpresa.length > 0"
                         style="position:absolute; z-index:50; margin-top:4px; width:100%; background:var(--bg-surface); border:1px solid var(--border-soft); border-radius:var(--r-md); box-shadow:var(--elev-3); max-height:240px; overflow-y:auto;">
                        <template x-for="emp in resultadosEmpresa" :key="emp.id">
                            <button type="button" @@click="empresaSelecionada = emp; resultadosEmpresa = []"
                                    style="display:block; width:100%; text-align:left; padding:8px 12px; background:transparent; border:0; cursor:pointer; color:var(--text-primary); font-size:13px;">
                                <span x-text="emp.nome"></span>
                                <span style="color:var(--text-muted); font-size:11px; margin-left:8px;" x-text="emp.documento || ''"></span>
                            </button>
                        </template>
                    </div>
                </div>
            </template>
            <template x-if="empresaSelecionada">
                <div style="display:flex; align-items:center; justify-content:space-between; padding:8px 12px; background:rgba(232,88,20,.10); border:1px solid rgba(232,88,20,.30); border-radius:var(--r-md);">
                    <div>
                        <div style="font-size:13px; font-weight:500; color:var(--text-primary);" x-text="empresaSelecionada.nome"></div>
                        <div style="font-size:11px; color:var(--text-muted); font-family:var(--font-mono);" x-text="empresaSelecionada.documento || ''"></div>
                    </div>
                    <es-button variant="ghost" size="xs" x-on:click="empresaSelecionada = null; buscaEmpresa = ''">Trocar</es-button>
                </div>
            </template>
        </div>

        <es-input name="titulo" label="Título" required="true" minlength="3" maxlength="200" />
        <es-textarea name="descricao" label="Descrição" required="true" minlength="5" maxlength="4000" rows="3" />

        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:10px;">
            <es-select name="categoria" label="Categoria">
                <option value="Bug">Bug</option>
                <option value="Duvida">Dúvida</option>
                <option value="Financeiro">Financeiro</option>
                <option value="Solicitacao">Solicitação</option>
                <option value="Incidente">Incidente</option>
                <option value="Outro">Outro</option>
            </es-select>
            <es-select name="prioridade" label="Prioridade">
                <option value="Normal">Normal</option>
                <option value="Baixa">Baixa</option>
                <option value="Alta">Alta</option>
                <option value="Critica">Crítica</option>
            </es-select>
            <es-select name="nivel" label="Nível inicial">
                <option value="N1">N1 - Triagem</option>
                <option value="N2">N2 - Suporte</option>
                <option value="N3">N3 - Técnico</option>
                <option value="N4">N4 - Engenharia</option>
            </es-select>
        </div>

        <es-modal-footer>
            <es-button variant="ghost" x-on:click="close()">Cancelar</es-button>
            <button type="submit" class="btn btn-primary btn-md" :disabled="!empresaSelecionada">
                <span>Criar ticket</span>
            </button>
        </es-modal-footer>
    </form>
</es-modal>

<!-- Modal: fechar tickets em lote -->
<es-modal id="bulk-fechar" size="sm">
    <h2 style="margin:0 0 6px; font-size:16px; font-weight:600; color:var(--text-primary);">Fechar tickets selecionados?</h2>
    <p style="margin:0 0 14px; color:var(--text-muted); font-size:13px;">
        Os tickets marcados serão marcados como Fechado. Registrado no histórico de cada ticket.
    </p>
    <form id="bulkFecharForm" method="post" asp-page-handler="FecharEmLote"
          x-data="{ loading: false }" x-on:submit="loading = true">
        @Html.AntiForgeryToken()
        <div data-ids-slot></div>
        <es-modal-footer>
            <es-button variant="ghost" x-on:click="close()" :disabled="loading">Cancelar</es-button>
            <button type="submit" class="btn btn-primary btn-md" :disabled="loading">
                <span x-show="!loading">Fechar selecionados</span>
                <span x-show="loading" x-cloak>Fechando…</span>
            </button>
        </es-modal-footer>
    </form>
</es-modal>

<!-- Modal: assumir tickets em lote -->
<es-modal id="bulk-assumir" size="sm">
    <h2 style="margin:0 0 6px; font-size:16px; font-weight:600; color:var(--text-primary);">Assumir tickets selecionados?</h2>
    <p style="margin:0 0 14px; color:var(--text-muted); font-size:13px;">
        Os tickets marcados serão atribuídos a você como atendente.
    </p>
    <form id="bulkAssumirForm" method="post" asp-page-handler="AssumirEmLote"
          x-data="{ loading: false }" x-on:submit="loading = true">
        @Html.AntiForgeryToken()
        <div data-ids-slot></div>
        <es-modal-footer>
            <es-button variant="ghost" x-on:click="close()" :disabled="loading">Cancelar</es-button>
            <button type="submit" class="btn btn-primary btn-md" :disabled="loading">
                <span x-show="!loading">Assumir selecionados</span>
                <span x-show="loading" x-cloak>Atribuindo…</span>
            </button>
        </es-modal-footer>
    </form>
</es-modal>
