@page
@model EasyStock.Admin.Pages.Tickets.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Tickets";
    var hasFilters = !string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Status)
        || !string.IsNullOrEmpty(Model.Prioridade) || !string.IsNullOrEmpty(Model.Nivel)
        || !string.IsNullOrEmpty(Model.SlaStatus) || !string.IsNullOrEmpty(Model.Categoria);
}

<div class="flex items-center justify-between mb-4 flex-wrap gap-4">
    <h1 class="text-es-ink text-xl font-semibold">Helpdesk</h1>
    <div class="flex gap-2">
        <a href="/Tickets/Dashboard" class="btn-secondary text-sm">📊 Dashboard</a>
        <a href="/Configuracoes/SlaMatriz" class="btn-secondary text-sm">⚙ Matriz SLA</a>
        <button type="button" onclick="window.dispatchEvent(new Event('openNovoTicket'))" class="btn-primary text-sm">+ Novo Ticket</button>
    </div>
</div>

<div class="flex items-center mb-6 flex-wrap gap-4" x-data="{ modalNovo: false, empresaSelecionada: null, buscaEmpresa: '', resultadosEmpresa: [], debounce: null }"
     @@openNovoTicket.window="modalNovo = true; empresaSelecionada = null; buscaEmpresa = ''; resultadosEmpresa = []">
    <form method="get" class="flex items-center gap-2 flex-wrap">
        <input type="text" name="search" value="@Model.Search" placeholder="Buscar por título..."
               class="form-input max-w-xs" />
        <select name="status" class="form-input max-w-[160px]">
            <option value="">Todos status</option>
            <option value="Aberto" selected="@(Model.Status == "Aberto")">Aberto</option>
            <option value="EmAtendimento" selected="@(Model.Status == "EmAtendimento")">Em Atendimento</option>
            <option value="AguardandoCliente" selected="@(Model.Status == "AguardandoCliente")">Aguard. Cliente</option>
            <option value="Resolvido" selected="@(Model.Status == "Resolvido")">Resolvido</option>
            <option value="Fechado" selected="@(Model.Status == "Fechado")">Fechado</option>
        </select>
        <select name="prioridade" class="form-input max-w-[140px]">
            <option value="">Prioridade</option>
            <option value="Critica" selected="@(Model.Prioridade == "Critica")">Crítica</option>
            <option value="Alta" selected="@(Model.Prioridade == "Alta")">Alta</option>
            <option value="Normal" selected="@(Model.Prioridade == "Normal")">Normal</option>
            <option value="Baixa" selected="@(Model.Prioridade == "Baixa")">Baixa</option>
        </select>
        <select name="nivel" class="form-input max-w-[100px]">
            <option value="">Nível</option>
            <option value="N1" selected="@(Model.Nivel == "N1")">N1</option>
            <option value="N2" selected="@(Model.Nivel == "N2")">N2</option>
            <option value="N3" selected="@(Model.Nivel == "N3")">N3</option>
            <option value="N4" selected="@(Model.Nivel == "N4")">N4</option>
        </select>
        <select name="slaStatus" class="form-input max-w-[120px]">
            <option value="">SLA</option>
            <option value="ok" selected="@(Model.SlaStatus == "ok")">OK</option>
            <option value="violado" selected="@(Model.SlaStatus == "violado")">Violado</option>
        </select>
        <select name="categoria" class="form-input max-w-[140px]">
            <option value="">Categoria</option>
            <option value="Bug" selected="@(Model.Categoria == "Bug")">Bug</option>
            <option value="Duvida" selected="@(Model.Categoria == "Duvida")">Dúvida</option>
            <option value="Financeiro" selected="@(Model.Categoria == "Financeiro")">Financeiro</option>
            <option value="Solicitacao" selected="@(Model.Categoria == "Solicitacao")">Solicitação</option>
            <option value="Incidente" selected="@(Model.Categoria == "Incidente")">Incidente</option>
            <option value="BugFixDev" selected="@(Model.Categoria == "BugFixDev")">Bug-fix Dev</option>
            <option value="Outro" selected="@(Model.Categoria == "Outro")">Outro</option>
        </select>
        <button type="submit" class="btn-primary">Filtrar</button>
        @if (!string.IsNullOrEmpty(Model.Status) || !string.IsNullOrEmpty(Model.Prioridade) || !string.IsNullOrEmpty(Model.Nivel) || !string.IsNullOrEmpty(Model.SlaStatus) || !string.IsNullOrEmpty(Model.Categoria) || !string.IsNullOrEmpty(Model.Search))
        {
            <a href="/Tickets" class="btn-secondary">Limpar</a>
        }
    </form>

    <!-- Modal novo ticket -->
    <div x-show="modalNovo" x-cloak class="modal-overlay" @@click.self="modalNovo = false">
        <div class="modal-box" @@click.stop>
            <h3 class="text-es-ink font-semibold mb-4">Novo Ticket</h3>
            <form method="post" class="space-y-4">
                @Html.AntiForgeryToken()

                <div>
                    <label class="form-label">Empresa</label>
                    <input type="hidden" name="empresaId" :value="empresaSelecionada ? empresaSelecionada.id : ''" />
                    <template x-if="!empresaSelecionada">
                        <div class="relative">
                            <input type="text" x-model="buscaEmpresa" placeholder="Digite o nome ou CNPJ..." class="form-input"
                                   @@input="clearTimeout(debounce); debounce = setTimeout(async () => { if (buscaEmpresa.length < 2) { resultadosEmpresa = []; return; } const r = await fetch('/api-proxy/buscar-global?q=' + encodeURIComponent(buscaEmpresa) + '&limit=8'); const d = await r.json(); resultadosEmpresa = d.clientes || []; }, 200)" />
                            <div x-show="resultadosEmpresa.length > 0" class="absolute z-50 mt-1 w-full bg-es-surface border border-es-ink-mute/20 rounded-lg shadow-lg max-h-60 overflow-y-auto">
                                <template x-for="emp in resultadosEmpresa" :key="emp.id">
                                    <button type="button" @@click="empresaSelecionada = emp; resultadosEmpresa = []"
                                            class="w-full text-left px-3 py-2 hover:bg-es-accent/10 text-es-ink text-sm">
                                        <span x-text="emp.nome"></span>
                                        <span class="text-es-ink-mute text-xs ml-2" x-text="emp.documento || ''"></span>
                                    </button>
                                </template>
                            </div>
                        </div>
                    </template>
                    <template x-if="empresaSelecionada">
                        <div class="flex items-center justify-between bg-es-accent/10 border border-es-accent/30 rounded-lg px-3 py-2">
                            <div>
                                <div class="text-es-ink text-sm font-medium" x-text="empresaSelecionada.nome"></div>
                                <div class="text-es-ink-mute text-xs" x-text="empresaSelecionada.documento || ''"></div>
                            </div>
                            <button type="button" @@click="empresaSelecionada = null; buscaEmpresa = ''" class="text-es-ink-mute hover:text-es-ink text-sm">Trocar</button>
                        </div>
                    </template>
                </div>

                <div>
                    <label class="form-label">Título</label>
                    <input type="text" name="titulo" class="form-input" required minlength="3" maxlength="200" />
                </div>
                <div>
                    <label class="form-label">Descrição</label>
                    <textarea name="descricao" class="form-input" rows="3" required minlength="5" maxlength="4000"></textarea>
                </div>
                <div class="grid grid-cols-3 gap-3">
                    <div>
                        <label class="form-label">Categoria</label>
                        <select name="categoria" class="form-input">
                            <option value="Bug">Bug</option>
                            <option value="Duvida">Dúvida</option>
                            <option value="Financeiro">Financeiro</option>
                            <option value="Solicitacao">Solicitação</option>
                            <option value="Incidente">Incidente</option>
                            <option value="Outro">Outro</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Prioridade</label>
                        <select name="prioridade" class="form-input">
                            <option value="Normal">Normal</option>
                            <option value="Baixa">Baixa</option>
                            <option value="Alta">Alta</option>
                            <option value="Critica">Crítica</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Nível inicial</label>
                        <select name="nivel" class="form-input">
                            <option value="N1">N1 - Triagem</option>
                            <option value="N2">N2 - Suporte</option>
                            <option value="N3">N3 - Técnico</option>
                            <option value="N4">N4 - Engenharia</option>
                        </select>
                    </div>
                </div>
                <div class="flex gap-3 justify-end pt-2">
                    <button type="button" @@click="modalNovo = false" class="btn-secondary">Cancelar</button>
                    <button type="submit" class="btn-primary" :disabled="!empresaSelecionada">Criar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (Model.Erro != null)
{
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-4 py-3 text-sm mb-4">@Model.Erro</div>
}

<div class="card p-0 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="table-admin">
            <thead>
                <tr>
                    <th>SLA</th>
                    <th>Título</th>
                    <th>Empresa</th>
                    <th>Categoria</th>
                    <th>Prioridade</th>
                    <th>Nível</th>
                    <th>Status</th>
                    <th>Atendente</th>
                    <th>Criado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Tickets)
                {
                    var tid = t.TryGetProperty("id", out var tidP) ? tidP.GetString() : "";
                    var titulo = t.TryGetProperty("titulo", out var titP) ? titP.GetString() : "";
                    var empresa = t.TryGetProperty("empresaNome", out var empP) ? empP.GetString() : "—";
                    var naoLidos = t.TryGetProperty("mensagensNaoLidas", out var nlP) ? nlP.GetInt32() : 0;
                    var cat = t.TryGetProperty("categoria", out var catP) ? catP.GetString() : "";
                    var pri = t.TryGetProperty("prioridade", out var priP) ? priP.GetString() : "";
                    var nivel = t.TryGetProperty("nivel", out var nvP) ? nvP.GetString() : "";
                    var status = t.TryGetProperty("status", out var stP) ? stP.GetString() : "";
                    var atendente = t.TryGetProperty("atendenteNome", out var atP) && atP.ValueKind != JsonValueKind.Null ? atP.GetString() : "—";
                    var criado = t.TryGetProperty("criadoEm", out var cP) ? cP.GetString() : null;
                    DateTime.TryParse(criado, out var criadoDt);

                    var slaRespViolado = t.TryGetProperty("slaRespostaViolado", out var srvP) && srvP.GetBoolean();
                    var slaResolViolado = t.TryGetProperty("slaResolucaoViolado", out var srlP) && srlP.GetBoolean();
                    var prazoResp = t.TryGetProperty("prazoResposta", out var prP) && prP.ValueKind != JsonValueKind.Null ? prP.GetString() : null;
                    DateTime.TryParse(prazoResp, out var prazoRespDt);

                    string slaBadge;
                    string slaText;
                    if (slaRespViolado || slaResolViolado)
                    {
                        slaBadge = "bg-red-500/20 text-red-400 border-red-500/30";
                        slaText = "VIOLADO";
                    }
                    else if (prazoRespDt != default)
                    {
                        var restante = prazoRespDt.ToUniversalTime() - DateTime.UtcNow;
                        if (restante.TotalMinutes < 30) { slaBadge = "bg-orange-500/20 text-orange-400 border-orange-500/30"; slaText = restante.TotalMinutes < 0 ? "ATRASO" : $"{(int)restante.TotalMinutes}m"; }
                        else if (restante.TotalHours < 4) { slaBadge = "bg-yellow-500/20 text-yellow-400 border-yellow-500/30"; slaText = $"{(int)restante.TotalHours}h"; }
                        else { slaBadge = "bg-green-500/20 text-green-400 border-green-500/30"; slaText = $"{(int)restante.TotalHours}h"; }
                    }
                    else { slaBadge = "bg-es-ink-mute/20 text-es-ink-mute border-es-ink-mute/20"; slaText = "—"; }

                    var priClass = pri?.ToLower() switch { "critica" => "badge-critica", "alta" => "badge-alta", "baixa" => "badge-normal", _ => "badge-normal" };
                    var stClass = status?.ToLower().Replace(" ", "") switch
                    {
                        "aberto" => "badge-aberto",
                        "ematendimento" => "badge-ematendimento",
                        "aguardandocliente" => "badge-alta",
                        "resolvido" => "badge-resolvido",
                        _ => "badge-fechado"
                    };
                    <tr class="ticket-row cursor-pointer" tabindex="0"
                        @@click="window.location.href='/Tickets/Detail/@tid'"
                        @@keydown.enter="window.location.href='/Tickets/Detail/@tid'"
                        x-data>
                        <td>
                            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-bold border @slaBadge">@slaText</span>
                        </td>
                        <td class="text-es-ink font-medium">
                            @titulo
                            @if (naoLidos > 0)
                            {
                                <span class="ml-2 bg-es-accent text-white text-xs font-bold rounded-full px-1.5 py-0.5">@naoLidos</span>
                            }
                        </td>
                        <td class="text-es-ink-dim text-sm">@empresa</td>
                        <td class="text-es-ink-dim text-sm">@cat</td>
                        <td><span class="status-badge @priClass">@pri</span></td>
                        <td class="text-es-ink-dim text-sm font-bold">@nivel</td>
                        <td><span class="status-badge @stClass">@status</span></td>
                        <td class="text-es-ink-dim text-sm">@atendente</td>
                        <td class="text-es-ink-dim text-sm">@criadoDt.ToLocalTime().ToString("dd/MM/yy")</td>
                    </tr>
                }
                @if (!Model.Tickets.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-es-ink-mute py-10">
                            @if (hasFilters)
                            {
                                <div>Nenhum ticket com estes filtros. <a href="/Tickets" class="text-es-accent hover:underline">Limpar filtros</a></div>
                            }
                            else
                            {
                                <div class="space-y-2">
                                    <div class="text-3xl">🎫</div>
                                    <div class="font-semibold text-es-ink">Nenhum ticket cadastrado ainda.</div>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <div class="flex items-center justify-center gap-2 mt-6">
        @if (Model.Page > 1)
        {
            <a href="?page=@(Model.Page-1)&status=@Model.Status&prioridade=@Model.Prioridade&nivel=@Model.Nivel&slaStatus=@Model.SlaStatus&categoria=@Model.Categoria&search=@Model.Search" class="btn-secondary text-sm">← Anterior</a>
        }
        <span class="text-es-ink-mute text-sm">@Model.Page / @Model.TotalPages</span>
        @if (Model.Page < Model.TotalPages)
        {
            <a href="?page=@(Model.Page+1)&status=@Model.Status&prioridade=@Model.Prioridade&nivel=@Model.Nivel&slaStatus=@Model.SlaStatus&categoria=@Model.Categoria&search=@Model.Search" class="btn-secondary text-sm">Próximo →</a>
        }
    </div>
}
