@page
@model EasyStock.Admin.Pages.Faturas.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Faturas";
    var orderBy = Request.Query["orderBy"].FirstOrDefault();
    var dir = Request.Query["dir"].FirstOrDefault();

    string FmtCurrency(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
    string StatusVariant(string s) => (s ?? "").ToLowerInvariant().Replace(" ", "") switch
    {
        "rascunho" => "neutral",
        "emitida" => "info",
        "parcialmentepaga" => "warn",
        "paga" => "ok",
        "vencida" => "crit",
        "cancelada" => "neutral",
        _ => "neutral"
    };
    string StatusLabel(string s) => (s ?? "") switch
    {
        "ParcialmentePaga" => "PARCIAL",
        _ => (s ?? "").ToUpper()
    };

    var qsExport = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.Status)) qsExport.Add($"status={Uri.EscapeDataString(Model.Status)}");
    if (!string.IsNullOrWhiteSpace(Model.Origem)) qsExport.Add($"origem={Uri.EscapeDataString(Model.Origem)}");
    if (Model.EmpresaId.HasValue) qsExport.Add($"empresaId={Model.EmpresaId.Value}");
    if (Model.VencimentoDe.HasValue) qsExport.Add($"vencimentoDe={Model.VencimentoDe.Value:yyyy-MM-dd}");
    if (Model.VencimentoAte.HasValue) qsExport.Add($"vencimentoAte={Model.VencimentoAte.Value:yyyy-MM-dd}");
    if (Model.ValorMin.HasValue) qsExport.Add($"valorMin={Model.ValorMin.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
    if (Model.ValorMax.HasValue) qsExport.Add($"valorMax={Model.ValorMax.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
    if (!string.IsNullOrWhiteSpace(Model.Busca)) qsExport.Add($"busca={Uri.EscapeDataString(Model.Busca.Trim())}");
    var exportQs = qsExport.Count > 0 ? "?" + string.Join("&", qsExport) : "";
    var exportHref = "/Faturas?handler=ExportCsv" + (exportQs.StartsWith("?") ? "&" + exportQs.Substring(1) : exportQs);
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item>Faturas</es-breadcrumb-item>
        </es-breadcrumb>
        <div style="margin-top:4px; color:var(--text-muted); font-size:13px;">
            <strong style="color:var(--text-primary);">@Model.Total</strong> fatura(s)
        </div>
    </div>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
        <es-button variant="ghost" href="/Faturas/Dashboard" icon="trending-up">Dashboard</es-button>
        <es-button variant="ghost" href="@exportHref" icon="download">Exportar CSV</es-button>
        <es-button variant="primary" href="/Faturas/Emitir" icon="plus">Emitir avulsa</es-button>
    </div>
</div>

<es-card padding="md" card-class="mb-4">
    <form method="get" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:12px; align-items:end;">
        <es-input name="busca" label="Busca" value="@Model.Busca" placeholder="Número, observação..." prefix-icon="search" field-class="md:col-span-2" />
        <es-select name="status" label="Status">
            <option value="">Todos</option>
            <option value="Rascunho" selected="@(Model.Status == "Rascunho")">Rascunho</option>
            <option value="Emitida" selected="@(Model.Status == "Emitida")">Emitida</option>
            <option value="ParcialmentePaga" selected="@(Model.Status == "ParcialmentePaga")">Parcial</option>
            <option value="Paga" selected="@(Model.Status == "Paga")">Paga</option>
            <option value="Vencida" selected="@(Model.Status == "Vencida")">Vencida</option>
            <option value="Cancelada" selected="@(Model.Status == "Cancelada")">Cancelada</option>
        </es-select>
        <es-select name="origem" label="Origem">
            <option value="">Todas</option>
            <option value="Assinatura" selected="@(Model.Origem == "Assinatura")">Assinatura</option>
            <option value="Pedido" selected="@(Model.Origem == "Pedido")">Pedido</option>
            <option value="Avulsa" selected="@(Model.Origem == "Avulsa")">Avulsa</option>
        </es-select>
        <es-input name="vencimentoDe" type="date" label="Vencimento de" value="@(Model.VencimentoDe?.ToString("yyyy-MM-dd"))" />
        <es-input name="vencimentoAte" type="date" label="Vencimento até" value="@(Model.VencimentoAte?.ToString("yyyy-MM-dd"))" />
        <es-input name="valorMin" type="number" step="0.01" label="Valor mín" value="@(Model.ValorMin?.ToString(System.Globalization.CultureInfo.InvariantCulture))" prefix="R$" />
        <es-input name="valorMax" type="number" step="0.01" label="Valor máx" value="@(Model.ValorMax?.ToString(System.Globalization.CultureInfo.InvariantCulture))" prefix="R$" />
        <div style="display:flex; gap:8px;">
            <es-button type="submit" variant="primary" icon="filter">Filtrar</es-button>
            <es-button variant="ghost" href="/Faturas">Limpar</es-button>
        </div>
    </form>
</es-card>

<es-filter-bar>
    @if (!string.IsNullOrEmpty(Model.Status)) { <es-filter-chip label="Status" remove-param="status">@Model.Status</es-filter-chip> }
    @if (!string.IsNullOrEmpty(Model.Origem)) { <es-filter-chip label="Origem" remove-param="origem">@Model.Origem</es-filter-chip> }
    @if (!string.IsNullOrEmpty(Model.Busca)) { <es-filter-chip label="Busca" remove-param="busca">@Model.Busca</es-filter-chip> }
    @if (Model.VencimentoDe.HasValue) { <es-filter-chip label="Venc. de" remove-param="vencimentoDe">@Model.VencimentoDe.Value.ToString("dd/MM/yyyy")</es-filter-chip> }
    @if (Model.VencimentoAte.HasValue) { <es-filter-chip label="Venc. até" remove-param="vencimentoAte">@Model.VencimentoAte.Value.ToString("dd/MM/yyyy")</es-filter-chip> }
    @if (Model.ValorMin.HasValue) { <es-filter-chip label="Min" remove-param="valorMin">R$ @Model.ValorMin.Value.ToString("N2")</es-filter-chip> }
    @if (Model.ValorMax.HasValue) { <es-filter-chip label="Máx" remove-param="valorMax">R$ @Model.ValorMax.Value.ToString("N2")</es-filter-chip> }
</es-filter-bar>

<es-data-table sort-key="@orderBy" sort-dir="@dir" is-empty="@(!Model.Faturas.Any())">
    <es-data-table-column key="numero" label="Número" sortable="true" />
    <es-data-table-column label="Empresa" />
    <es-data-table-column label="Faturado" />
    <es-data-table-column label="Origem" />
    <es-data-table-column label="Status" />
    <es-data-table-column key="total" label="Total" align="right" sortable="true" />
    <es-data-table-column label="Pago" align="right" />
    <es-data-table-column label="Pendente" align="right" />
    <es-data-table-column key="dataEmissao" label="Emissão" align="right" sortable="true" />
    <es-data-table-column key="dataVencimento" label="Vencimento" align="right" sortable="true" />

    @foreach (var f in Model.Faturas)
    {
        var id = f.TryGetProperty("id", out var idp) ? idp.GetString() : "";
        var numero = f.TryGetProperty("numero", out var n) ? n.GetString() : "";
        var empresaNome = f.TryGetProperty("empresaNome", out var en) && en.ValueKind != JsonValueKind.Null ? en.GetString() : "—";
        var faturadoNome = f.TryGetProperty("faturadoNome", out var fn) && fn.ValueKind != JsonValueKind.Null ? fn.GetString() : "—";
        var origem = f.TryGetProperty("origem", out var o) ? o.GetString() ?? "" : "";
        var status = f.TryGetProperty("status", out var s) ? s.GetString() ?? "" : "";
        var total = f.TryGetProperty("total", out var t) ? t.GetDecimal() : 0m;
        var totalPago = f.TryGetProperty("totalPago", out var tp) ? tp.GetDecimal() : 0m;
        var pendente = f.TryGetProperty("pendente", out var pp) ? pp.GetDecimal() : 0m;
        var emissao = f.TryGetProperty("dataEmissao", out var de) ? de.GetString() : null;
        var venc = f.TryGetProperty("dataVencimento", out var dv) ? dv.GetString() : null;
        DateTime.TryParse(emissao, out var emissaoDt);
        DateTime.TryParse(venc, out var vencDt);

        <tr style="cursor:pointer;" tabindex="0"
            onclick="window.location.href='/Faturas/Detail/@id'"
            onkeydown="if(event.key==='Enter') window.location.href='/Faturas/Detail/@id'">
            <td data-label="Número" style="font-family:var(--font-mono); font-size:13px; font-weight:500; color:var(--text-primary);">@numero</td>
            <td data-label="Empresa" style="color:var(--text-secondary); font-size:13px;">@empresaNome</td>
            <td data-label="Faturado" style="color:var(--text-muted); font-size:13px;">@faturadoNome</td>
            <td data-label="Origem"><es-badge variant="neutral">@origem</es-badge></td>
            <td data-label="Status"><es-badge variant="@StatusVariant(status)">@StatusLabel(status)</es-badge></td>
            <td data-label="Total" class="es-data-table-td-numeric" style="font-weight:600; color:var(--text-primary);">@FmtCurrency(total)</td>
            <td data-label="Pago" class="es-data-table-td-numeric" style="color:var(--text-muted);">@FmtCurrency(totalPago)</td>
            <td data-label="Pendente" class="es-data-table-td-numeric" style="color:@(pendente > 0 ? "var(--crit-600)" : "var(--text-muted)"); font-weight:@(pendente > 0 ? "600" : "400");">@FmtCurrency(pendente)</td>
            <td data-label="Emissão" class="es-data-table-td-numeric" style="color:var(--text-muted); font-size:12px;">@emissaoDt.ParaBrasilia().ToString("dd/MM/yyyy")</td>
            <td data-label="Vencimento" class="es-data-table-td-numeric" style="color:var(--text-muted); font-size:12px;">@vencDt.ToString("dd/MM/yyyy")</td>
        </tr>
    }

    <es-data-table-empty>
        <es-empty-state icon="receipt"
                        title="Nenhuma fatura encontrada"
                        description="Ajuste os filtros ou emita uma fatura avulsa.">
            <es-button variant="primary" icon="plus" href="/Faturas/Emitir">Emitir avulsa</es-button>
        </es-empty-state>
    </es-data-table-empty>
</es-data-table>

@if (Model.TotalPages > 1)
{
    <es-pagination page="@Model.Page" page-size="@(Math.Max(1, Model.Total / Model.TotalPages))" total="@Model.Total" />
}
