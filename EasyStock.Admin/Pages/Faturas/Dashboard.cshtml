@page
@model EasyStock.Admin.Pages.Faturas.DashboardModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard Financeiro";
    string FmtCurrency(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
    string FmtNumber(int v) => v.ToString("N0", new System.Globalization.CultureInfo("pt-BR"));
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item href="/Faturas">Faturas</es-breadcrumb-item>
            <es-breadcrumb-item>Painel financeiro</es-breadcrumb-item>
        </es-breadcrumb>
        <h2 class="admin-page-title">Painel financeiro</h2>
        <p style="margin:4px 0 0; color:var(--text-muted); font-size:13px;">Receita, churn e inadimplência por período</p>
    </div>
    <form method="get" style="display:flex; align-items:center; gap:8px;">
        <span style="font-size:12px; color:var(--text-muted); font-weight:600; text-transform:uppercase; letter-spacing:0.06em;">Janela</span>
        <select name="dias" onchange="this.form.submit()" class="es-form-select" style="width:auto;">
            <option value="7" selected="@(Model.Dias == 7)">7 dias</option>
            <option value="30" selected="@(Model.Dias == 30)">30 dias</option>
            <option value="90" selected="@(Model.Dias == 90)">90 dias</option>
            <option value="180" selected="@(Model.Dias == 180)">180 dias</option>
            <option value="365" selected="@(Model.Dias == 365)">12 meses</option>
        </select>
    </form>
</div>

@if (Model.Carregada)
{
    var ativas = Model.Int("assinaturasAtivas");
    var canceladas = Model.Int("assinaturasCanceladas");
    var totalCohort = ativas + canceladas;
    var churnPct = totalCohort > 0 ? Math.Round((decimal)canceladas / totalCohort * 100m, 1) : 0m;

    <!-- Linha 1: receita -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px; margin-bottom:14px;">
        <div class="es-stat-card">
            <div class="es-stat-label">MRR</div>
            <div class="es-stat-value">@FmtCurrency(Model.Dec("mrr"))</div>
            <div class="es-stat-meta"><span>Receita recorrente mensal</span></div>
        </div>
        <div class="es-stat-card">
            <div class="es-stat-label">ARR</div>
            <div class="es-stat-value">@FmtCurrency(Model.Dec("arr"))</div>
            <div class="es-stat-meta"><span>MRR × 12</span></div>
        </div>
        <div class="es-stat-card">
            <div class="es-stat-label">Receita no período</div>
            <div class="es-stat-value" style="color:var(--ok-600);">@FmtCurrency(Model.Dec("receitaPeriodo"))</div>
            <div class="es-stat-meta"><span>@Model.Int("faturasPagasPeriodo") fatura(s) paga(s)</span></div>
        </div>
        <div class="es-stat-card">
            <div class="es-stat-label">Em atraso</div>
            <div class="es-stat-value" style="color:var(--crit-600);">@FmtCurrency(Model.Dec("valorVencido"))</div>
            <div class="es-stat-meta"><span>@Model.Int("faturasVencidas") fatura(s) vencida(s)</span></div>
        </div>
    </div>

    <!-- Linha 2: assinaturas -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px; margin-bottom:14px;">
        <div class="es-stat-card">
            <div class="es-stat-label">Assinaturas ativas</div>
            <div class="es-stat-value es-stat-value-sm">@FmtNumber(Model.Int("assinaturasAtivas"))</div>
        </div>
        <div class="es-stat-card">
            <div class="es-stat-label">Suspensas</div>
            <div class="es-stat-value es-stat-value-sm" style="color:var(--warn-600);">@FmtNumber(Model.Int("assinaturasSuspensas"))</div>
            <div class="es-stat-meta"><span>Inadimplência provável</span></div>
        </div>
        <div class="es-stat-card">
            <div class="es-stat-label">Canceladas</div>
            <div class="es-stat-value es-stat-value-sm" style="color:var(--text-muted);">@FmtNumber(Model.Int("assinaturasCanceladas"))</div>
            <div class="es-stat-meta"><span>Acumulado histórico</span></div>
        </div>
        <div class="es-stat-card">
            <div class="es-stat-label">Churn aprox.</div>
            <div class="es-stat-value es-stat-value-sm" style="color:@(churnPct > 10m ? "var(--crit-600)" : "var(--text-primary)");">@churnPct.ToString("0.0")%</div>
            <div class="es-stat-meta"><span>Cancel / (Ativa + Cancel)</span></div>
        </div>
    </div>

    <!-- Linha 3: KPIs operacionais -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px; margin-bottom:24px;">
        <div class="es-stat-card">
            <div class="es-stat-label">Conversão</div>
            <div class="es-stat-value es-stat-value-sm">@Model.Dec("taxaConversao").ToString("0.0")%</div>
            <div class="es-stat-meta"><span>Pagas / Emitidas</span></div>
        </div>
        <div class="es-stat-card">
            <div class="es-stat-label">Ticket médio</div>
            <div class="es-stat-value es-stat-value-sm">@FmtCurrency(Model.Dec("ticketMedio"))</div>
            <div class="es-stat-meta"><span>Receita / Pagas</span></div>
        </div>
        <div class="es-stat-card">
            <div class="es-stat-label">Atraso médio</div>
            <div class="es-stat-value es-stat-value-sm" style="color:@(Model.Dbl("atrasoMedioDias") > 30d ? "var(--crit-600)" : "var(--text-primary)");">@Model.Dbl("atrasoMedioDias").ToString("0.0") d</div>
            <div class="es-stat-meta"><span>Vencidas em aberto</span></div>
        </div>
        <div class="es-stat-card">
            <div class="es-stat-label">Faturas no período</div>
            <div class="es-stat-value es-stat-value-sm">@FmtNumber(Model.Int("faturasEmitidasPeriodo"))</div>
            <div class="es-stat-meta"><span>Paga + Emitida + Vencida</span></div>
        </div>
    </div>

    @if (Model.TopInadimplentes.Any())
    {
        <es-card title="Top inadimplentes" description="Empresas com maior valor vencido em aberto">
            <div style="margin:-20px;">
                <table class="es-data-table">
                    <thead>
                        <tr>
                            <th scope="col">Empresa</th>
                            <th scope="col" class="es-data-table-td-numeric">Vencidas</th>
                            <th scope="col" class="es-data-table-td-numeric">Valor total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.TopInadimplentes)
                        {
                            var empId = t.TryGetProperty("empresaId", out var eid) ? eid.GetString() : "";
                            var empNome = t.TryGetProperty("empresaNome", out var en) && en.ValueKind != JsonValueKind.Null ? en.GetString() : "(sem nome)";
                            var qtd = t.TryGetProperty("quantidadeVencidas", out var q) ? q.GetInt32() : 0;
                            var valor = t.TryGetProperty("valorTotalVencido", out var v) ? v.GetDecimal() : 0m;
                            <tr>
                                <td><a href="/Tenants/Detail/@empId" style="color:var(--orange-500); text-decoration:none; font-weight:500;">@empNome</a></td>
                                <td class="es-data-table-td-numeric" style="color:var(--crit-600); font-weight:600;">@qtd</td>
                                <td class="es-data-table-td-numeric" style="color:var(--crit-600); font-weight:600;">@FmtCurrency(valor)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </es-card>
    }
}
else
{
    <es-card>
        <es-empty-state icon="trending-up" title="Carregando dados financeiros..." description="O dashboard será exibido em instantes." />
    </es-card>
}
