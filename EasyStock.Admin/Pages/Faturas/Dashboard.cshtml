@page
@model EasyStock.Admin.Pages.Faturas.DashboardModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard Financeiro";
    string FmtCurrency(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
    string FmtNumber(int v) => v.ToString("N0", new System.Globalization.CultureInfo("pt-BR"));
}

@* Fase 3: painel financeiro no padrao deck (issue #625). Server-rendered. *@
<header class="deck-head deck-rise" style="--deck-i:0; margin-bottom:20px;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item href="/Faturas">Faturas</es-breadcrumb-item>
            <es-breadcrumb-item>Painel financeiro</es-breadcrumb-item>
        </es-breadcrumb>
        <div class="deck-eyebrow deck-accent-underline" style="margin-top:8px;">Financeiro</div>
        <h1>Painel financeiro</h1>
        <p>Receita, churn e inadimplência por período</p>
    </div>
    <form method="get" class="deck-head-actions">
        <span class="deck-eyebrow">Janela</span>
        <select name="dias" onchange="this.form.submit()" class="es-form-select" style="width:auto;">
            <option value="7" selected="@(Model.Dias == 7)">7 dias</option>
            <option value="30" selected="@(Model.Dias == 30)">30 dias</option>
            <option value="90" selected="@(Model.Dias == 90)">90 dias</option>
            <option value="180" selected="@(Model.Dias == 180)">180 dias</option>
            <option value="365" selected="@(Model.Dias == 365)">12 meses</option>
        </select>
    </form>
</header>

@if (Model.Carregada)
{
    var ativas = Model.Int("assinaturasAtivas");
    var canceladas = Model.Int("assinaturasCanceladas");
    var totalCohort = ativas + canceladas;
    var churnPct = totalCohort > 0 ? Math.Round((decimal)canceladas / totalCohort * 100m, 1) : 0m;

    <!-- Linha 1: receita (hero numerals) -->
    <section class="deck-rise" style="--deck-i:1; display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px; margin-bottom:14px;">
        <div class="deck-panel deck-tile">
            <div class="deck-eyebrow">MRR</div>
            <div class="deck-kpi">@FmtCurrency(Model.Dec("mrr"))</div>
            <div class="deck-meta">Receita recorrente mensal</div>
        </div>
        <div class="deck-panel deck-tile">
            <div class="deck-eyebrow">ARR</div>
            <div class="deck-kpi">@FmtCurrency(Model.Dec("arr"))</div>
            <div class="deck-meta">MRR × 12</div>
        </div>
        <div class="deck-panel deck-tile">
            <div class="deck-eyebrow">Receita no período</div>
            <div class="deck-kpi" style="color:var(--ok-600);">@FmtCurrency(Model.Dec("receitaPeriodo"))</div>
            <div class="deck-meta">@Model.Int("faturasPagasPeriodo") fatura(s) paga(s)</div>
        </div>
        <div class="deck-panel deck-tile">
            <div class="deck-eyebrow">Em atraso</div>
            <div class="deck-kpi" style="color:var(--crit-600);">@FmtCurrency(Model.Dec("valorVencido"))</div>
            <div class="deck-meta">@Model.Int("faturasVencidas") fatura(s) vencida(s)</div>
        </div>
    </section>

    <!-- Linha 2: assinaturas -->
    <section class="deck-rise" style="--deck-i:2; display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px; margin-bottom:14px;">
        <div class="deck-panel deck-tile">
            <div class="deck-eyebrow">Assinaturas ativas</div>
            <div class="deck-kpi" style="font-size:26px;">@FmtNumber(Model.Int("assinaturasAtivas"))</div>
        </div>
        <div class="deck-panel deck-tile">
            <div class="deck-eyebrow">Suspensas</div>
            <div class="deck-kpi" style="font-size:26px; color:var(--warn-600);">@FmtNumber(Model.Int("assinaturasSuspensas"))</div>
            <div class="deck-meta">Inadimplência provável</div>
        </div>
        <div class="deck-panel deck-tile">
            <div class="deck-eyebrow">Canceladas</div>
            <div class="deck-kpi" style="font-size:26px; color:var(--text-muted);">@FmtNumber(Model.Int("assinaturasCanceladas"))</div>
            <div class="deck-meta">Acumulado histórico</div>
        </div>
        <div class="deck-panel deck-tile">
            <div class="deck-eyebrow">Churn aprox.</div>
            <div class="deck-kpi" style="font-size:26px; color:@(churnPct > 10m ? "var(--crit-600)" : "var(--text-primary)");">@churnPct.ToString("0.0")%</div>
            <div class="deck-meta">Cancel / (Ativa + Cancel)</div>
        </div>
    </section>

    <!-- Linha 3: KPIs operacionais -->
    <section class="deck-rise" style="--deck-i:3; display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px; margin-bottom:24px;">
        <div class="deck-panel deck-tile">
            <div class="deck-eyebrow">Conversão</div>
            <div class="deck-kpi" style="font-size:26px;">@Model.Dec("taxaConversao").ToString("0.0")%</div>
            <div class="deck-meta">Pagas / Emitidas</div>
        </div>
        <div class="deck-panel deck-tile">
            <div class="deck-eyebrow">Ticket médio</div>
            <div class="deck-kpi" style="font-size:26px;">@FmtCurrency(Model.Dec("ticketMedio"))</div>
            <div class="deck-meta">Receita / Pagas</div>
        </div>
        <div class="deck-panel deck-tile">
            <div class="deck-eyebrow">Atraso médio</div>
            <div class="deck-kpi" style="font-size:26px; color:@(Model.Dbl("atrasoMedioDias") > 30d ? "var(--crit-600)" : "var(--text-primary)");">@Model.Dbl("atrasoMedioDias").ToString("0.0") d</div>
            <div class="deck-meta">Vencidas em aberto</div>
        </div>
        <div class="deck-panel deck-tile">
            <div class="deck-eyebrow">Faturas no período</div>
            <div class="deck-kpi" style="font-size:26px;">@FmtNumber(Model.Int("faturasEmitidasPeriodo"))</div>
            <div class="deck-meta">Paga + Emitida + Vencida</div>
        </div>
    </section>

    @if (Model.TopInadimplentes.Any())
    {
        <article class="deck-panel deck-rise" style="--deck-i:4;">
            <div class="deck-panel-head">
                <h3>Top inadimplentes</h3>
                <span class="deck-sub">maior valor vencido em aberto</span>
            </div>
            <table class="deck-table">
                <thead>
                    <tr>
                        <th scope="col">Empresa</th>
                        <th scope="col" style="text-align:right">Vencidas</th>
                        <th scope="col" style="text-align:right">Valor total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.TopInadimplentes)
                    {
                        var empId = t.TryGetProperty("empresaId", out var eid) ? eid.GetString() : "";
                        var empNome = t.TryGetProperty("empresaNome", out var en) && en.ValueKind != JsonValueKind.Null ? en.GetString() : "(sem nome)";
                        var qtd = t.TryGetProperty("quantidadeVencidas", out var q) ? q.GetInt32() : 0;
                        var valor = t.TryGetProperty("valorTotalVencido", out var v) ? v.GetDecimal() : 0m;
                        <tr>
                            <td><a href="/Tenants/Detail/@empId">@empNome</a></td>
                            <td style="text-align:right; color:var(--crit-600); font-weight:600;">@qtd</td>
                            <td style="text-align:right; color:var(--crit-600); font-weight:600;">@FmtCurrency(valor)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </article>
    }
}
else
{
    <div class="deck-panel" style="padding:8px var(--s-5) 28px;">
        <es-empty-state icon="trending-up" title="Carregando dados financeiros..." description="O dashboard será exibido em instantes." />
    </div>
}
