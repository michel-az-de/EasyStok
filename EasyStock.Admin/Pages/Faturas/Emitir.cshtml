@page
@model EasyStock.Admin.Pages.Faturas.EmitirModel
@{
    ViewData["Title"] = "Emitir fatura avulsa";
    var amanha = DateTime.UtcNow.AddDays(7).ToString("yyyy-MM-dd");
    var hojeDateMin = DateTime.UtcNow.ToString("yyyy-MM-dd");

    // IMP-001: picker de tenant por nome/CNPJ no lugar de colar GUID. Em re-render
    // (erro de validacao) so temos o GUID cru — o picker mostra o id ate trocar.
    var empresaPickerVd = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        ["Mode"] = "field",
        ["Name"] = "empresaId",
        ["InitialId"] = Model.EmpresaIdRaw,
        ["Required"] = true,
        ["Label"] = "Empresa cliente"
    };
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item href="/Faturas">Faturas</es-breadcrumb-item>
            <es-breadcrumb-item>Emitir avulsa</es-breadcrumb-item>
        </es-breadcrumb>
        <h2 class="admin-page-title">Emitir fatura avulsa</h2>
        <p style="margin:4px 0 0; color:var(--text-muted); font-size:13px;">Configure cliente, itens e vencimento. Número gerado automaticamente.</p>
    </div>
    <es-button variant="ghost" href="/Faturas" icon="arrow-left">Voltar</es-button>
</div>

<form method="post" x-data="emitirFatura()" x-init="if (itens.length === 0) addItem()" x-on:submit="onSubmit($event)" style="display:flex; flex-direction:column; gap:16px;">
    @Html.AntiForgeryToken()

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:16px;">
        <es-card title="Empresa (tenant)" description="Busque por nome ou CNPJ">
            <partial name="Components/_EmpresaPicker" view-data="empresaPickerVd" />
        </es-card>

        <es-card title="Dados do faturado" description="Quem aparece na fatura como destinatário">
            <div style="display:flex; flex-direction:column; gap:12px;">
                <es-input name="faturadoNome" label="Nome" required="true" value="@Model.FaturadoNome" minlength="2" maxlength="200" />
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                    <es-input name="faturadoDocumento" label="CNPJ/CPF" label-optional="true" value="@Model.FaturadoDocumento" maxlength="20" />
                    <es-input name="faturadoTelefone" label="Telefone" label-optional="true" value="@Model.FaturadoTelefone" maxlength="20" />
                </div>
                <es-input name="faturadoEmail" type="email" label="Email" label-optional="true" value="@Model.FaturadoEmail" maxlength="200" />
            </div>
        </es-card>
    </div>

    <es-card padding="none">
        <es-card-header-actions>
            <es-button variant="ghost" size="sm" icon="plus" x-on:click="addItem()">Adicionar item</es-button>
        </es-card-header-actions>

        <header class="es-card-header">
            <div>
                <h3 class="es-card-title">Itens</h3>
                <div class="es-card-desc">Itens "Desconto" entram como negativo · "Taxa" como acréscimo</div>
            </div>
        </header>

        <div class="es-data-table-scroll">
            <table class="es-data-table">
                <thead>
                    <tr>
                        <th scope="col" style="width:50%;">Descrição</th>
                        <th scope="col" class="es-data-table-td-numeric" style="width:12%;">Qtd</th>
                        <th scope="col" class="es-data-table-td-numeric" style="width:15%;">Preço unit</th>
                        <th scope="col" style="width:15%;">Tipo</th>
                        <th scope="col" class="es-data-table-td-actions" style="width:8%;"></th>
                    </tr>
                </thead>
                <tbody>
                    <template x-for="(item, idx) in itens" :key="idx">
                        <tr>
                            <td><input type="text" name="itemDescricao" x-model="item.descricao" class="es-form-input" required minlength="2" maxlength="300" /></td>
                            <td><input type="number" name="itemQuantidade" x-model.number="item.quantidade" step="0.001" min="0.001" class="es-form-input" style="text-align:right;" x-on:focus="$event.target.select()" required /></td>
                            <td><input type="number" name="itemPrecoUnitario" x-model.number="item.precoUnitario" step="0.01" min="0" class="es-form-input" style="text-align:right;" :style="{ 'border-color': Number(item.precoUnitario) < 0 ? 'var(--crit-600)' : '' }" placeholder="0,00" x-on:focus="$event.target.select()" required /></td>
                            <td>
                                <select name="itemTipo" x-model="item.tipo" class="es-form-select">
                                    <option value="Servico">Serviço</option>
                                    <option value="Produto">Produto</option>
                                    <option value="Recorrencia">Recorrência</option>
                                    <option value="Taxa">Taxa</option>
                                    <option value="Desconto">Desconto</option>
                                </select>
                            </td>
                            <td class="es-data-table-td-actions">
                                <button type="button" class="btn btn-danger btn-xs btn-icon" @@click="removeItem(idx)" :disabled="itens.length <= 1" aria-label="Remover item">
                                    <es-icon name="x" size="12" />
                                </button>
                            </td>
                        </tr>
                    </template>
                </tbody>
                <tfoot>
                    <tr style="background:var(--surface-sunken);">
                        <td colspan="3" style="text-align:right; font-weight:600; color:var(--text-primary); padding:12px 14px;">Subtotal estimado</td>
                        @* UX-003: laranja (cor de alerta) so quando negativo; positivo/zero usa cor neutra. *@
                        <td colspan="2" style="font-family:var(--font-mono); font-weight:700; padding:12px 14px;" :style="{ color: subtotal < 0 ? 'var(--crit-600)' : 'var(--text-primary)' }" x-text="formatCurrency(subtotal)"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </es-card>

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:16px;">
        <es-card title="Vencimento">
            <es-input name="dataVencimento" type="date" label="Data de vencimento"
                      value="@amanha" required="true" />
        </es-card>
        <es-card title="Observações" description="Notas internas ou instruções ao cliente">
            <es-textarea name="observacoes" label="Observações" label-optional="true"
                         rows="3" maxlength="4000"
                         placeholder="Notas internas, instruções, etc." />
        </es-card>
    </div>

    <div x-show="erro" x-cloak role="alert" style="color:var(--crit-600); font-size:13px; font-weight:500; text-align:right;" x-text="erro"></div>

    <div style="display:flex; justify-content:flex-end; gap:8px;">
        <es-button variant="ghost" href="/Faturas">Cancelar</es-button>
        <es-button type="submit" variant="primary" icon="check">Emitir fatura</es-button>
    </div>
</form>

@* Itens submetidos reidratados no postback (BUG-03). Embed seguro: System.Text.Json
   (encoder default) escapa < > & ' " -> "</script>" e aspas nao quebram o bloco (G2). *@
<script type="application/json" id="faturas-itens">@Html.Raw(Model.ItensJson)</script>
<script>
    function emitirFatura() {
        let iniciais = [];
        try { iniciais = JSON.parse(document.getElementById('faturas-itens').textContent || '[]'); }
        catch (e) { iniciais = []; }
        return {
            itens: iniciais,
            erro: '',
            addItem() {
                // precoUnitario null (campo vazio com placeholder) evita o '0' inicial
                // concatenar ao digitar (BUG-04). Subtotal usa Number(...)||0.
                this.itens.push({ descricao: '', quantidade: 1, precoUnitario: null, tipo: 'Servico' });
            },
            removeItem(idx) {
                if (this.itens.length > 1) this.itens.splice(idx, 1);
            },
            get subtotal() {
                return this.itens.reduce((acc, i) => {
                    const sub = (Number(i.quantidade) || 0) * (Number(i.precoUnitario) || 0);
                    return acc + (i.tipo === 'Desconto' ? -Math.abs(sub) : sub);
                }, 0);
            },
            formatCurrency(v) {
                return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v || 0);
            },
            onSubmit(e) {
                this.erro = '';
                // NEW-001: bloqueia preco unitario negativo e subtotal negativo — fatura de cobranca
                // nao pode ter valor negativo. O backend tambem valida; aqui evita o round-trip e da
                // feedback claro sem perder o preenchimento.
                const idxNeg = this.itens.findIndex(i => Number(i.precoUnitario) < 0);
                if (idxNeg >= 0) {
                    e.preventDefault();
                    this.erro = 'Preço unitário não pode ser negativo.';
                    const campo = e.target.querySelectorAll('input[name="itemPrecoUnitario"]')[idxNeg];
                    if (campo) { campo.scrollIntoView({ block: 'center', behavior: 'smooth' }); campo.focus(); }
                    return;
                }
                if (this.subtotal < 0) {
                    e.preventDefault();
                    this.erro = 'O subtotal não pode ser negativo. Revise os itens de Desconto.';
                    return;
                }
                // IMP-03: rola/foca o 1o campo invalido (em vez de so o balao nativo solto).
                if (!e.target.checkValidity()) {
                    e.preventDefault();
                    const inv = e.target.querySelector(':invalid');
                    if (inv) { inv.scrollIntoView({ block: 'center', behavior: 'smooth' }); inv.focus(); }
                    e.target.reportValidity();
                }
            }
        };
    }
</script>
