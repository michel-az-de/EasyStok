@page
@model EasyStock.Admin.Pages.Faturas.EmitirModel
@{
    ViewData["Title"] = "Emitir fatura avulsa";
    var amanha = DateTime.UtcNow.AddDays(7).ToString("yyyy-MM-dd");
}

<div class="flex items-center justify-between mb-4 flex-wrap gap-4">
    <div class="flex items-center gap-3">
        <a href="/Faturas" class="btn-secondary text-sm">← Voltar</a>
        <h1 class="text-es-ink text-xl font-semibold">Emitir fatura avulsa</h1>
    </div>
</div>

@if (TempData["Erro"] is string erroT)
{
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-4 py-3 text-sm mb-4">@erroT</div>
}

<form method="post" class="space-y-4"
      x-data="emitirFatura()" x-init="if (itens.length === 0) addItem()">
    @Html.AntiForgeryToken()

    <!-- Empresa + Faturado -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="card">
            <h2 class="text-es-ink font-semibold mb-3">Empresa (tenant)</h2>
            <div>
                <label class="form-label">Empresa ID *</label>
                <input type="text" name="empresaId" class="form-input font-mono text-sm" required
                       placeholder="00000000-0000-0000-0000-000000000000"
                       pattern="[0-9a-fA-F\-]{36}" />
                <small class="text-es-ink-mute text-xs">
                    GUID da empresa cliente. Pegue em <a href="/Tenants" class="text-es-accent hover:underline">Clientes</a>.
                </small>
            </div>
        </div>

        <div class="card">
            <h2 class="text-es-ink font-semibold mb-3">Dados do faturado</h2>
            <div class="space-y-3">
                <div>
                    <label class="form-label">Nome *</label>
                    <input type="text" name="faturadoNome" class="form-input" required minlength="2" maxlength="200" />
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="form-label">CNPJ/CPF</label>
                        <input type="text" name="faturadoDocumento" class="form-input" maxlength="20" />
                    </div>
                    <div>
                        <label class="form-label">Telefone</label>
                        <input type="text" name="faturadoTelefone" class="form-input" maxlength="20" />
                    </div>
                </div>
                <div>
                    <label class="form-label">Email</label>
                    <input type="email" name="faturadoEmail" class="form-input" maxlength="200" />
                </div>
            </div>
        </div>
    </div>

    <!-- Itens dinamicos -->
    <div class="card">
        <div class="flex items-center justify-between mb-3">
            <h2 class="text-es-ink font-semibold">Itens</h2>
            <button type="button" @@click="addItem()" class="btn-secondary text-sm">+ Adicionar item</button>
        </div>
        <div class="overflow-x-auto">
            <table class="table-admin">
                <thead>
                    <tr>
                        <th style="width:50%">Descricao</th>
                        <th style="width:12%" class="text-right">Qtd</th>
                        <th style="width:15%" class="text-right">Preco unit</th>
                        <th style="width:15%">Tipo</th>
                        <th style="width:8%"></th>
                    </tr>
                </thead>
                <tbody>
                    <template x-for="(item, idx) in itens" :key="idx">
                        <tr>
                            <td><input type="text" name="itemDescricao" x-model="item.descricao" class="form-input" required minlength="2" maxlength="300" /></td>
                            <td><input type="number" name="itemQuantidade" x-model.number="item.quantidade" step="0.001" min="0.001" class="form-input text-right" required /></td>
                            <td><input type="number" name="itemPrecoUnitario" x-model.number="item.precoUnitario" step="0.01" min="0" class="form-input text-right" required /></td>
                            <td>
                                <select name="itemTipo" x-model="item.tipo" class="form-input">
                                    <option value="Servico">Servico</option>
                                    <option value="Produto">Produto</option>
                                    <option value="Recorrencia">Recorrencia</option>
                                    <option value="Taxa">Taxa</option>
                                    <option value="Desconto">Desconto</option>
                                </select>
                            </td>
                            <td>
                                <button type="button" @@click="removeItem(idx)" class="btn-danger text-xs"
                                        :disabled="itens.length <= 1">✕</button>
                            </td>
                        </tr>
                    </template>
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-right font-semibold text-es-ink">Subtotal estimado</td>
                        <td colspan="2" class="font-mono font-semibold text-es-accent" x-text="formatCurrency(subtotal)"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
        <p class="text-es-ink-mute text-xs mt-3">
            Itens do tipo <strong>Desconto</strong> sao tratados como negativos no calculo de total. Itens
            <strong>Taxa</strong> entram como acrescimo. Numero da fatura sera gerado automaticamente
            (formato YYYY-NNNNNN, sequencial por empresa+ano).
        </p>
    </div>

    <!-- Vencimento + observacoes -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="card">
            <div>
                <label class="form-label">Data de vencimento *</label>
                <input type="date" name="dataVencimento" value="@amanha" class="form-input" required min="@DateTime.UtcNow.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div class="card">
            <div>
                <label class="form-label">Observacoes</label>
                <textarea name="observacoes" rows="3" class="form-input" maxlength="4000"
                          placeholder="Notas internas, instrucoes ao cliente, etc."></textarea>
            </div>
        </div>
    </div>

    <div class="flex justify-end gap-2">
        <a href="/Faturas" class="btn-secondary">Cancelar</a>
        <button type="submit" class="btn-primary">Emitir fatura</button>
    </div>
</form>

<script>
    function emitirFatura() {
        return {
            itens: [],
            addItem() {
                this.itens.push({ descricao: '', quantidade: 1, precoUnitario: 0, tipo: 'Servico' });
            },
            removeItem(idx) {
                if (this.itens.length > 1) this.itens.splice(idx, 1);
            },
            get subtotal() {
                return this.itens.reduce((acc, i) => {
                    const sub = (Number(i.quantidade) || 0) * (Number(i.precoUnitario) || 0);
                    return acc + (i.tipo === 'Desconto' ? -Math.abs(sub) : sub);
                }, 0);
            },
            formatCurrency(v) {
                return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v || 0);
            }
        };
    }
</script>
