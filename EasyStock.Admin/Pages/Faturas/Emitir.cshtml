@page
@model EasyStock.Admin.Pages.Faturas.EmitirModel
@{
    ViewData["Title"] = "Emitir fatura avulsa";
    var amanha = DateTime.UtcNow.AddDays(7).ToString("yyyy-MM-dd");
    var hojeDateMin = DateTime.UtcNow.ToString("yyyy-MM-dd");
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
    <div>
        <es-breadcrumb>
            <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
            <es-breadcrumb-item href="/Faturas">Faturas</es-breadcrumb-item>
            <es-breadcrumb-item>Emitir avulsa</es-breadcrumb-item>
        </es-breadcrumb>
        <h2 class="admin-page-title">Emitir fatura avulsa</h2>
        <p style="margin:4px 0 0; color:var(--text-muted); font-size:13px;">Configure cliente, itens e vencimento. Número gerado automaticamente.</p>
    </div>
    <es-button variant="ghost" href="/Faturas" icon="arrow-left">Voltar</es-button>
</div>

<form method="post" x-data="emitirFatura()" x-init="if (itens.length === 0) addItem()" style="display:flex; flex-direction:column; gap:16px;">
    @Html.AntiForgeryToken()

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:16px;">
        <es-card title="Empresa (tenant)" description="GUID da empresa cliente">
            <es-input name="empresaId"
                      label="Empresa ID"
                      required="true"
                      placeholder="00000000-0000-0000-0000-000000000000"
                      pattern="[0-9a-fA-F\-]{36}"
                      input-class="font-mono"
                      helper="Cole o GUID da página /Tenants." />
        </es-card>

        <es-card title="Dados do faturado" description="Quem aparece na fatura como destinatário">
            <div style="display:flex; flex-direction:column; gap:12px;">
                <es-input name="faturadoNome" label="Nome" required="true" minlength="2" maxlength="200" />
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                    <es-input name="faturadoDocumento" label="CNPJ/CPF" label-optional="true" maxlength="20" />
                    <es-input name="faturadoTelefone" label="Telefone" label-optional="true" maxlength="20" />
                </div>
                <es-input name="faturadoEmail" type="email" label="Email" label-optional="true" maxlength="200" />
            </div>
        </es-card>
    </div>

    <es-card padding="none">
        <es-card-header-actions>
            <es-button variant="ghost" size="sm" icon="plus" x-on:click="addItem()">Adicionar item</es-button>
        </es-card-header-actions>

        <header class="es-card-header">
            <div>
                <h3 class="es-card-title">Itens</h3>
                <div class="es-card-desc">Itens "Desconto" entram como negativo · "Taxa" como acréscimo</div>
            </div>
        </header>

        <div class="es-data-table-scroll">
            <table class="es-data-table">
                <thead>
                    <tr>
                        <th scope="col" style="width:50%;">Descrição</th>
                        <th scope="col" class="es-data-table-td-numeric" style="width:12%;">Qtd</th>
                        <th scope="col" class="es-data-table-td-numeric" style="width:15%;">Preço unit</th>
                        <th scope="col" style="width:15%;">Tipo</th>
                        <th scope="col" class="es-data-table-td-actions" style="width:8%;"></th>
                    </tr>
                </thead>
                <tbody>
                    <template x-for="(item, idx) in itens" :key="idx">
                        <tr>
                            <td><input type="text" name="itemDescricao" x-model="item.descricao" class="es-form-input" required minlength="2" maxlength="300" /></td>
                            <td><input type="number" name="itemQuantidade" x-model.number="item.quantidade" step="0.001" min="0.001" class="es-form-input" style="text-align:right;" required /></td>
                            <td><input type="number" name="itemPrecoUnitario" x-model.number="item.precoUnitario" step="0.01" min="0" class="es-form-input" style="text-align:right;" required /></td>
                            <td>
                                <select name="itemTipo" x-model="item.tipo" class="es-form-select">
                                    <option value="Servico">Serviço</option>
                                    <option value="Produto">Produto</option>
                                    <option value="Recorrencia">Recorrência</option>
                                    <option value="Taxa">Taxa</option>
                                    <option value="Desconto">Desconto</option>
                                </select>
                            </td>
                            <td class="es-data-table-td-actions">
                                <button type="button" class="btn btn-danger btn-xs btn-icon" @@click="removeItem(idx)" :disabled="itens.length <= 1" aria-label="Remover item">
                                    <es-icon name="x" size="12" />
                                </button>
                            </td>
                        </tr>
                    </template>
                </tbody>
                <tfoot>
                    <tr style="background:var(--surface-sunken);">
                        <td colspan="3" style="text-align:right; font-weight:600; color:var(--text-primary); padding:12px 14px;">Subtotal estimado</td>
                        <td colspan="2" style="font-family:var(--font-mono); font-weight:700; color:var(--orange-500); padding:12px 14px;" x-text="formatCurrency(subtotal)"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </es-card>

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:16px;">
        <es-card title="Vencimento">
            <es-input name="dataVencimento" type="date" label="Data de vencimento"
                      value="@amanha" required="true" />
        </es-card>
        <es-card title="Observações" description="Notas internas ou instruções ao cliente">
            <es-textarea name="observacoes" label="Observações" label-optional="true"
                         rows="3" maxlength="4000"
                         placeholder="Notas internas, instruções, etc." />
        </es-card>
    </div>

    <div style="display:flex; justify-content:flex-end; gap:8px;">
        <es-button variant="ghost" href="/Faturas">Cancelar</es-button>
        <es-button type="submit" variant="primary" icon="check">Emitir fatura</es-button>
    </div>
</form>

<script>
    function emitirFatura() {
        return {
            itens: [],
            addItem() {
                this.itens.push({ descricao: '', quantidade: 1, precoUnitario: 0, tipo: 'Servico' });
            },
            removeItem(idx) {
                if (this.itens.length > 1) this.itens.splice(idx, 1);
            },
            get subtotal() {
                return this.itens.reduce((acc, i) => {
                    const sub = (Number(i.quantidade) || 0) * (Number(i.precoUnitario) || 0);
                    return acc + (i.tipo === 'Desconto' ? -Math.abs(sub) : sub);
                }, 0);
            },
            formatCurrency(v) {
                return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v || 0);
            }
        };
    }
</script>
