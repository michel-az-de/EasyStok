@page
@model EasyStock.Admin.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    var inv = System.Globalization.CultureInfo.InvariantCulture;
}

@*
    Seed do dashboard: gera JSON em <script> num escopo global (window.__initialDash).
    O adminApp() do _Layout.cshtml lê isso no init() e popula `dash` no escopo certo.

    POR QUE NÃO USAR <div x-init="Object.assign($root.dash, ...)"> AQUI:
    - <div x-init> SEM x-data ainda cria escopo Alpine; $root passa a apontar pro próprio
      <div>, não pro <body x-data="adminApp()">. Resultado: $root.dash é undefined,
      os <span x-text="dash.X"> renderizam vazio. Bug observado em produção
      (todos os KPIs em branco mesmo com sidebar mostrando contadores corretos).
*@
<script>
    window.__initialDash = {
        tenantsAtivos: @Model.TenantsAtivos.ToString(inv),
        totalTenants: @Model.TotalTenants.ToString(inv),
        tenantsSuspensos: @Model.TenantsSuspensos.ToString(inv),
        tenantsNovos: @Model.TenantsNovos.ToString(inv),
        ticketsAbertos: @Model.TicketsAbertos.ToString(inv),
        ticketsCriticos: @Model.TicketsCriticos.ToString(inv),
        ticketsEmAtendimento: @Model.TicketsEmAtendimento.ToString(inv),
        totalUsuariosAtivos: @Model.TotalUsuariosAtivos.ToString(inv),
        logins24h: @Model.Logins24h.ToString(inv),
        receitaMensalEstimada: @Model.ReceitaMensal.ToString(inv)
    };
</script>

<!-- Header com indicador de polling -->
<section class="admin-hero">
    <div class="admin-hero-main">
        <div class="admin-eyebrow">Central de controle</div>
        <h2 class="admin-page-title">Visão geral</h2>
        <p>Clientes, tickets, receita e saúde operacional em tempo real.</p>
    </div>
    <div class="admin-hero-actions">
        <div class="admin-live-pill">
            <span aria-hidden="true"></span>
            <span x-text="dashSecsAgo > 0 ? 'Atualizado há ' + dashSecsAgo + 's' : 'Atualizando…'"></span>
        </div>
        <es-button variant="ghost" href="/Tenants" icon="building-2">Clientes</es-button>
        <es-button variant="ghost" href="/Tickets" icon="ticket">Tickets</es-button>
    </div>
</section>

<!-- Card de seed quando ambiente está vazio -->
<div x-show="dash.totalTenants === 0" x-cloak
     class="es-card card-interactive"
     style="background:linear-gradient(135deg, rgba(232,88,20,.10), rgba(232,88,20,.02)); border-color:rgba(232,88,20,.30); padding: 22px; margin-bottom:20px; display:flex; flex-wrap:wrap; align-items:center; gap:18px;">
    <span style="display:inline-grid; place-items:center; width:56px; height:56px; border-radius:var(--r-lg); background:rgba(232,88,20,.20);">
        <es-icon name="zap" size="28" />
    </span>
    <div style="flex:1; min-width:240px;">
        <h3 style="margin:0 0 4px; color:var(--text-primary); font-weight:700; font-size:15px;">Banco vazio — nada pra testar</h3>
        <p style="margin:0; color:var(--text-muted); font-size:13px; line-height:1.5;">
            Ainda não há tenants. Popule o ambiente com cenários de teste (4 tenants variados, tickets, notas internas e audit logs).
        </p>
    </div>
    <es-button variant="primary" icon="zap" href="/Diagnostico?tab=operacoes">Popular ambiente</es-button>
</div>

<!-- Métricas principais (4 cards com drill-down) -->
<div class="admin-metric-grid">

    <a href="/Tenants?status=Ativa" class="es-stat-card is-link card-interactive">
        <div class="es-stat-label">Tenants ativos</div>
        <div class="es-stat-value" x-text="dash.tenantsAtivos">@Model.TenantsAtivos</div>
        <div class="es-stat-meta">
            <span>de <strong style="color:var(--text-primary);" x-text="dash.totalTenants">@Model.TotalTenants</strong> total</span>
        </div>
    </a>

    <a href="/Tenants?status=Suspensa" class="es-stat-card is-link card-interactive">
        <div class="es-stat-label">Suspensos</div>
        <div class="es-stat-value" :style="dash.tenantsSuspensos > 0 ? 'color: var(--warn-600);' : ''" x-text="dash.tenantsSuspensos">@Model.TenantsSuspensos</div>
        <div class="es-stat-meta">
            <span>de <strong style="color:var(--text-primary);" x-text="dash.totalTenants">@Model.TotalTenants</strong> total</span>
        </div>
    </a>

    <a href="/Tickets?prioridade=Critica" class="es-stat-card is-link card-interactive">
        <div class="es-stat-label">Tickets abertos</div>
        <div class="es-stat-value" x-text="dash.ticketsAbertos">@Model.TicketsAbertos</div>
        <div class="es-stat-meta">
            <span class="es-stat-delta es-stat-delta-down" x-show="dash.ticketsCriticos > 0" x-cloak>
                <es-icon name="alert-triangle" size="10" />
                <span x-text="dash.ticketsCriticos">@Model.TicketsCriticos</span> críticos
            </span>
            <span x-show="!dash.ticketsCriticos">sem críticos</span>
        </div>
    </a>

    <div class="es-stat-card">
        <div class="es-stat-label">Receita estimada</div>
        <div class="es-stat-value" style="color:var(--orange-500);">
            R$ <span x-text="(dash.receitaMensalEstimada ?? 0).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })">@Model.ReceitaMensal.ToString("N2")</span>
        </div>
        <div class="es-stat-meta">
            <span>mensal · assinaturas ativas</span>
        </div>
    </div>
</div>

<!-- Métricas secundárias -->
<div class="admin-metric-grid admin-metric-grid-secondary">
    <div class="es-stat-card">
        <div class="es-stat-label">Usuários ativos</div>
        <div class="es-stat-value es-stat-value-sm" x-text="dash.totalUsuariosAtivos">@Model.TotalUsuariosAtivos</div>
        <div class="es-stat-meta"><span>plataforma (inclui super-admin)</span></div>
    </div>
    <div class="es-stat-card">
        <div class="es-stat-label">Logins (24h)</div>
        <div class="es-stat-value es-stat-value-sm" x-text="dash.logins24h">@Model.Logins24h</div>
    </div>
    <div class="es-stat-card">
        <div class="es-stat-label">Em atendimento</div>
        <div class="es-stat-value es-stat-value-sm" :style="dash.ticketsEmAtendimento > 0 ? 'color: var(--warn-600);' : ''" x-text="dash.ticketsEmAtendimento">@Model.TicketsEmAtendimento</div>
    </div>
    <div class="es-stat-card">
        <div class="es-stat-label">Tenants novos</div>
        <div class="es-stat-value es-stat-value-sm" x-text="dash.tenantsNovos">@Model.TenantsNovos</div>
        <div class="es-stat-meta"><span>últimos 30 dias</span></div>
    </div>
</div>

<!-- Tabelas lado a lado -->
<div class="admin-dashboard-panels">

    <es-card padding="none" title="Tickets críticos" description="Alta prioridade — ação imediata">
        <es-card-header-actions>
            <es-button variant="ghost" size="xs" href="/Tickets?prioridade=Critica" icon-trailing="arrow-right">Ver todos</es-button>
        </es-card-header-actions>

        @if (!Model.UltimosTicketsCriticos.Any())
        {
            <div style="padding:32px;">
                <es-empty-state icon="check-circle" title="Nenhum ticket crítico" description="A fila está em dia." />
            </div>
        }
        else
        {
            <table class="es-data-table">
                <thead>
                    <tr>
                        <th scope="col">Título</th>
                        <th scope="col">Empresa</th>
                        <th scope="col">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.UltimosTicketsCriticos)
                    {
                        var id = t.TryGetProperty("id", out var idProp) ? idProp.GetString() : "";
                        var titulo = t.TryGetProperty("titulo", out var tp) ? tp.GetString() : "";
                        var empresa = t.TryGetProperty("empresaNome", out var ep) ? ep.GetString() : "";
                        var status = t.TryGetProperty("status", out var sp) ? sp.GetString() : "";
                        var stVar = status?.ToLower().Replace(" ", "") switch
                        {
                            "aberto" => "info",
                            "ematendimento" => "accent",
                            "aguardandocliente" => "warn",
                            "resolvido" => "ok",
                            _ => "neutral"
                        };
                        <tr>
                            <td><a href="/Tickets/Detail/@id" style="color:var(--text-primary); font-weight:500; text-decoration:none;">@titulo</a></td>
                            <td style="color:var(--text-muted); font-size:13px;">@empresa</td>
                            <td><es-badge variant="@stVar">@status</es-badge></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </es-card>

    <es-card padding="none" title="Tenants recentes" description="Últimos 30 dias">
        <es-card-header-actions>
            <es-button variant="ghost" size="xs" href="/Tenants" icon-trailing="arrow-right">Ver todos</es-button>
        </es-card-header-actions>

        @if (!Model.TenantsRecentes.Any())
        {
            <div style="padding:32px;">
                <es-empty-state icon="building-2" title="Nenhum tenant novo" description="Sem cadastros nos últimos 30 dias." />
            </div>
        }
        else
        {
            <table class="es-data-table">
                <thead>
                    <tr>
                        <th scope="col">Nome</th>
                        <th scope="col">Documento</th>
                        <th scope="col" class="es-data-table-td-numeric">Criado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.TenantsRecentes)
                    {
                        var id = t.TryGetProperty("id", out var idProp) ? idProp.GetString() : "";
                        var nome = t.TryGetProperty("nome", out var np) ? np.GetString() : "";
                        var doc = t.TryGetProperty("documento", out var dp) ? dp.GetString() : "—";
                        var criado = t.TryGetProperty("criadoEm", out var cp) ? cp.GetString() : "";
                        DateTime.TryParse(criado, out var criadoDt);
                        <tr>
                            <td><a href="/Tenants/Detail/@id" style="color:var(--text-primary); font-weight:500; text-decoration:none;">@nome</a></td>
                            <td style="color:var(--text-muted); font-family:var(--font-mono); font-size:11px;">@(doc ?? "—")</td>
                            <td class="es-data-table-td-numeric" style="color:var(--text-muted); font-size:12px;">@criadoDt.ParaBrasilia().ToString("dd/MM/yy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </es-card>
</div>

<style>
    @@keyframes dash-pulse { 0%,100%{opacity:1;} 50%{opacity:.4;} }
</style>
