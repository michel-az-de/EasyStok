@page
@model EasyStock.Admin.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    var inv = System.Globalization.CultureInfo.InvariantCulture;
}

@*
    Seed do dashboard: gera JSON em <script> num escopo global (window.__initialDash).
    O adminApp() do _Layout.cshtml le isso no init() e popula `dash` no escopo certo.
    NAO usar <div x-init> aqui (cria escopo Alpine proprio -> $root.dash undefined). Ver
    historico no git: KPIs em branco em producao.
*@
<script>
    window.__initialDash = {
        tenantsAtivos: @Model.TenantsAtivos.ToString(inv),
        totalTenants: @Model.TotalTenants.ToString(inv),
        tenantsSuspensos: @Model.TenantsSuspensos.ToString(inv),
        tenantsNovos: @Model.TenantsNovos.ToString(inv),
        ticketsAbertos: @Model.TicketsAbertos.ToString(inv),
        ticketsCriticos: @Model.TicketsCriticos.ToString(inv),
        ticketsEmAtendimento: @Model.TicketsEmAtendimento.ToString(inv),
        totalUsuariosAtivos: @Model.TotalUsuariosAtivos.ToString(inv),
        logins24h: @Model.Logins24h.ToString(inv),
        receitaMensalEstimada: @Model.ReceitaMensal.ToString(inv)
    };
</script>

@* Tira de telemetria: dado real (stack health, tickets criticos, MRR). Dot CINZA/
   indeterminado quando stackStatus ainda null, NUNCA verde otimista. *@
<div class="deck-telemetry deck-rise" style="--deck-i:0" role="status" aria-live="polite" aria-label="Telemetria operacional">
    <span class="deck-tele-item">
        <span class="deck-dot" :class="stackStatus==='Healthy' ? 'is-ok deck-pulse' : (stackStatus==='Degraded' ? 'is-warn' : (stackStatus ? 'is-crit' : 'is-unknown'))"></span>
        stack <strong x-text="stackStatus ? (stackStatus==='Healthy' ? 'operacional' : stackStatus) : 'verificando…'">verificando…</strong>
    </span>
    <span class="deck-tele-sep"></span>
    <span class="deck-tele-item">
        <span class="deck-dot" :class="dash.ticketsCriticos > 0 ? 'is-crit' : 'is-ok'"></span>
        tickets criticos <strong x-text="dash.ticketsCriticos">@Model.TicketsCriticos</strong>
    </span>
    <span class="deck-tele-ticker deck-tele-item">
        MRR <strong>R$&nbsp;<span x-text="(dash.receitaMensalEstimada ?? 0).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })">@Model.ReceitaMensal.ToString("N2")</span></strong>
        · <span x-text="dashSecsAgo > 0 ? 'ha ' + dashSecsAgo + 's' : 'agora'"></span>
    </span>
</div>

@* Hero header *@
<header class="deck-head deck-rise" style="--deck-i:1">
    <div>
        <div class="deck-eyebrow deck-accent-underline">Central de controle</div>
        <h1>Visao geral</h1>
        <p>Clientes, tickets, receita e saude operacional em tempo real.</p>
    </div>
    <div class="deck-head-actions">
        <es-button variant="ghost" href="/Tenants" icon="building-2">Clientes</es-button>
        <es-button variant="ghost" href="/Tickets" icon="ticket">Tickets</es-button>
    </div>
</header>

@* Card de seed quando o ambiente esta vazio *@
<div x-show="dash.totalTenants === 0" x-cloak class="deck-panel deck-rise"
     style="--deck-i:2; padding:22px; margin-bottom:20px; display:flex; flex-wrap:wrap; align-items:center; gap:18px;">
    <span style="display:inline-grid; place-items:center; width:52px; height:52px; border-radius:var(--r-lg); background:var(--deck-accent-soft); color:var(--deck-accent);">
        <es-icon name="zap" size="26" />
    </span>
    <div style="flex:1; min-width:240px;">
        <h3 style="margin:0 0 4px; color:var(--text-primary); font-weight:700; font-size:15px;">Banco vazio — nada pra testar</h3>
        <p style="margin:0; color:var(--text-muted); font-size:13px; line-height:1.5;">Ainda nao ha tenants. Popule o ambiente com cenarios de teste (tenants, tickets, audit logs).</p>
    </div>
    <es-button variant="primary" icon="zap" href="/Diagnostico?tab=operacoes">Popular ambiente</es-button>
</div>

@* Hero assimetrico: tile-feature de receita (Fraunces) + rail de indicadores secundarios *@
<section class="deck-hero" aria-label="Receita e indicadores secundarios">
    <article class="deck-panel deck-feature deck-rise" style="--deck-i:2">
        <div class="deck-eyebrow">Receita mensal recorrente</div>
        <div>
            <span class="deck-feature-cur">R$</span><span class="deck-kpi" x-text="(dash.receitaMensalEstimada ?? 0).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })">@Model.ReceitaMensal.ToString("N2")</span>
        </div>
        <div class="deck-eyebrow" style="color:var(--text-muted)">estimativa mensal · assinaturas ativas</div>
    </article>
    <aside class="deck-panel deck-rail deck-rise" style="--deck-i:3" aria-label="Indicadores secundarios">
        <div class="deck-rail-item"><span class="deck-rail-label">Usuarios ativos</span><span class="deck-rail-value" x-text="dash.totalUsuariosAtivos">@Model.TotalUsuariosAtivos</span></div>
        <div class="deck-rail-item"><span class="deck-rail-label">Logins (24h)</span><span class="deck-rail-value" x-text="dash.logins24h">@Model.Logins24h</span></div>
        <div class="deck-rail-item"><span class="deck-rail-label">Em atendimento</span><span class="deck-rail-value" :style="dash.ticketsEmAtendimento > 0 ? 'color:var(--warn-500)' : ''" x-text="dash.ticketsEmAtendimento">@Model.TicketsEmAtendimento</span></div>
        <div class="deck-rail-item"><span class="deck-rail-label">Tenants novos (30d)</span><span class="deck-rail-value" x-text="dash.tenantsNovos">@Model.TenantsNovos</span></div>
    </aside>
</section>

@* KPI row (drill-down) *@
<section class="deck-kpis deck-rise" style="--deck-i:4" aria-label="Indicadores principais">
    <a class="deck-panel deck-tile is-interactive" href="/Tenants?status=Ativa">
        <div class="deck-eyebrow">Tenants ativos</div>
        <div class="deck-kpi" x-text="dash.tenantsAtivos">@Model.TenantsAtivos</div>
        <div class="deck-meta">de <strong x-text="dash.totalTenants">@Model.TotalTenants</strong> total</div>
    </a>
    <a class="deck-panel deck-tile is-interactive" href="/Tenants?status=Suspensa">
        <div class="deck-eyebrow">Suspensos</div>
        <div class="deck-kpi" :style="dash.tenantsSuspensos > 0 ? 'color:var(--warn-500)' : ''" x-text="dash.tenantsSuspensos">@Model.TenantsSuspensos</div>
        <div class="deck-meta">de <strong x-text="dash.totalTenants">@Model.TotalTenants</strong> total</div>
    </a>
    <a class="deck-panel deck-tile is-interactive" href="/Tickets?prioridade=Critica">
        <div class="deck-eyebrow">Tickets abertos</div>
        <div class="deck-kpi" x-text="dash.ticketsAbertos">@Model.TicketsAbertos</div>
        <div class="deck-meta">
            <span class="deck-crit" x-show="dash.ticketsCriticos > 0" x-cloak><span class="deck-dot is-crit"></span> <span x-text="dash.ticketsCriticos">@Model.TicketsCriticos</span> criticos</span>
            <span x-show="!dash.ticketsCriticos">sem criticos</span>
        </div>
    </a>
</section>

@* Tabelas lado a lado *@
<section class="deck-panels" aria-label="Tickets criticos e tenants recentes">
    <article class="deck-panel deck-rise" style="--deck-i:5">
        <div class="deck-panel-head">
            <h3>Tickets criticos</h3>
            <es-button variant="ghost" size="xs" href="/Tickets?prioridade=Critica" icon-trailing="arrow-right">Ver todos</es-button>
        </div>
        @if (!Model.UltimosTicketsCriticos.Any())
        {
            <div style="padding:8px var(--s-5) 28px;">
                <es-empty-state icon="check-circle" title="Nenhum ticket critico" description="A fila esta em dia." />
            </div>
        }
        else
        {
            <table class="deck-table">
                <thead><tr><th scope="col">Titulo</th><th scope="col">Empresa</th><th scope="col">Status</th></tr></thead>
                <tbody>
                    @foreach (var t in Model.UltimosTicketsCriticos)
                    {
                        var id = t.TryGetProperty("id", out var idProp) ? idProp.GetString() : "";
                        var titulo = t.TryGetProperty("titulo", out var tp) ? tp.GetString() : "";
                        var empresa = t.TryGetProperty("empresaNome", out var ep) ? ep.GetString() : "";
                        var status = t.TryGetProperty("status", out var sp) ? sp.GetString() : "";
                        var stVar = status?.ToLower().Replace(" ", "") switch
                        {
                            "aberto" => "info",
                            "ematendimento" => "accent",
                            "aguardandocliente" => "warn",
                            "resolvido" => "ok",
                            _ => "neutral"
                        };
                        <tr>
                            <td><a href="/Tickets/Detail/@id">@titulo</a></td>
                            <td style="color:var(--text-muted);">@empresa</td>
                            <td><es-badge variant="@stVar">@status</es-badge></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </article>

    <article class="deck-panel deck-rise" style="--deck-i:6">
        <div class="deck-panel-head">
            <h3>Tenants recentes</h3>
            <es-button variant="ghost" size="xs" href="/Tenants" icon-trailing="arrow-right">Ver todos</es-button>
        </div>
        @if (!Model.TenantsRecentes.Any())
        {
            <div style="padding:8px var(--s-5) 28px;">
                <es-empty-state icon="building-2" title="Nenhum tenant novo" description="Sem cadastros nos ultimos 30 dias." />
            </div>
        }
        else
        {
            <table class="deck-table">
                <thead><tr><th scope="col">Nome</th><th scope="col">Documento</th><th scope="col" style="text-align:right">Criado</th></tr></thead>
                <tbody>
                    @foreach (var t in Model.TenantsRecentes)
                    {
                        var id = t.TryGetProperty("id", out var idProp) ? idProp.GetString() : "";
                        var nome = t.TryGetProperty("nome", out var np) ? np.GetString() : "";
                        var doc = t.TryGetProperty("documento", out var dp) ? dp.GetString() : "—";
                        var criado = t.TryGetProperty("criadoEm", out var cp) ? cp.GetString() : "";
                        DateTime.TryParse(criado, out var criadoDt);
                        <tr>
                            <td><a href="/Tenants/Detail/@id">@nome</a></td>
                            <td class="deck-mono">@(doc ?? "—")</td>
                            <td class="deck-mono" style="text-align:right">@criadoDt.ParaBrasilia().ToString("dd/MM/yy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </article>
</section>
