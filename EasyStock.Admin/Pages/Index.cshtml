@page
@model EasyStock.Admin.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

@if (Model.Erro != null)
{
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-4 py-3 text-sm mb-6">
        Erro ao carregar dados: @Model.Erro
    </div>
}

@{
    // Cultura do thread é pt-BR (Program.cs) → ToString() default usa vírgula decimal,
    // o que quebra JSON inline (vira "1500,50" em vez de "1500.50" → syntax error).
    // Force InvariantCulture nos números pra emitir JSON-safe.
    var inv = System.Globalization.CultureInfo.InvariantCulture;
}

@*
    Seed do dashboard: gera JSON em <script> num escopo global (window.__initialDash).
    O adminApp() do _Layout.cshtml lê isso no init() e popula `dash` no escopo certo.

    POR QUE NÃO USAR <div x-init="Object.assign($root.dash, ...)"> AQUI:
    - <div x-init> SEM x-data ainda cria escopo Alpine; $root passa a apontar pro próprio
      <div>, não pro <body x-data="adminApp()">. Resultado: $root.dash é undefined,
      os <span x-text="dash.X"> renderizam vazio. Bug observado em produção
      (todos os KPIs em branco mesmo com sidebar mostrando contadores corretos).
*@
<script>
    window.__initialDash = {
        tenantsAtivos: @Model.TenantsAtivos.ToString(inv),
        totalTenants: @Model.TotalTenants.ToString(inv),
        tenantsSuspensos: @Model.TenantsSuspensos.ToString(inv),
        tenantsNovos: @Model.TenantsNovos.ToString(inv),
        ticketsAbertos: @Model.TicketsAbertos.ToString(inv),
        ticketsCriticos: @Model.TicketsCriticos.ToString(inv),
        ticketsEmAtendimento: @Model.TicketsEmAtendimento.ToString(inv),
        totalUsuariosAtivos: @Model.TotalUsuariosAtivos.ToString(inv),
        logins24h: @Model.Logins24h.ToString(inv),
        receitaMensalEstimada: @Model.ReceitaMensal.ToString(inv)
    };
</script>

<div>

    @* Card grande de seed — aparece quando o tenant count chega em 0. CTA leva
       direto pra tab Operações do /Diagnostico onde o painel completo de seed
       (com 3 botões + console de debug + diagnóstico de flags) está disponível.
       Sai automaticamente quando dash.totalTenants > 0. *@
    <div x-show="dash.totalTenants === 0" x-cloak
         class="card mb-6 flex flex-wrap items-center gap-4"
         style="background:linear-gradient(135deg,rgba(232,88,20,0.08),rgba(247,242,232,0.04));border:1px solid rgba(232,88,20,0.2)">
        <div class="text-5xl">🌱</div>
        <div class="flex-1 min-w-[260px]">
            <h3 class="text-es-ink font-bold text-base">Banco vazio — nada pra testar</h3>
            <p class="text-es-ink-mute text-sm mt-0.5">
                Ainda não há tenants. Popule o ambiente com um seed de cenários de teste do Admin
                (4 tenants variados, tickets, notas internas, audit logs).
            </p>
        </div>
        <a href="/Diagnostico?tab=operacoes" class="btn-primary text-sm whitespace-nowrap">
            🚀 Popular ambiente
        </a>
    </div>

    <!-- Indicador de atualização -->
    <div class="flex items-center justify-end mb-3 gap-2 text-xs text-es-ink-mute">
        <span class="w-1.5 h-1.5 rounded-full bg-es-basil animate-pulse"></span>
        <span x-text="dashSecsAgo > 0 ? 'Atualizado há ' + dashSecsAgo + 's' : 'Atualizando…'"></span>
    </div>

    <!-- Métricas principais -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="card">
            <div class="text-es-ink-mute text-xs font-semibold uppercase tracking-wide mb-1">Tenants Ativos</div>
            <div class="text-3xl font-bold text-es-ink" x-text="dash.tenantsAtivos">@Model.TenantsAtivos</div>
            <div class="text-es-ink-mute text-xs mt-1">de <span x-text="dash.totalTenants">@Model.TotalTenants</span> total</div>
        </div>
        <div class="card">
            <div class="text-es-ink-mute text-xs font-semibold uppercase tracking-wide mb-1">Suspensos</div>
            <div class="text-3xl font-bold text-es-gold" x-text="dash.tenantsSuspensos">@Model.TenantsSuspensos</div>
            <div class="text-es-ink-mute text-xs mt-1">+<span x-text="dash.tenantsNovos">@Model.TenantsNovos</span> novos (30d)</div>
        </div>
        <div class="card">
            <div class="text-es-ink-mute text-xs font-semibold uppercase tracking-wide mb-1">Tickets Abertos</div>
            <div class="text-3xl font-bold text-es-basil" x-text="dash.ticketsAbertos">@Model.TicketsAbertos</div>
            <div class="text-red-400 text-xs mt-1 font-medium"><span x-text="dash.ticketsCriticos">@Model.TicketsCriticos</span> críticos</div>
        </div>
        <div class="card">
            <div class="text-es-ink-mute text-xs font-semibold uppercase tracking-wide mb-1">Receita Estimada</div>
            <div class="text-3xl font-bold text-es-accent">R$ <span x-text="(dash.receitaMensalEstimada ?? 0).toLocaleString('pt-BR',{minimumFractionDigits:0,maximumFractionDigits:0})">@Model.ReceitaMensal.ToString("N0")</span></div>
            <div class="text-es-ink-mute text-xs mt-1">mensal (assinaturas ativas)</div>
        </div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="card">
            <div class="text-es-ink-mute text-xs font-semibold uppercase tracking-wide mb-1">Usuários Ativos</div>
            <div class="text-2xl font-bold text-es-ink" x-text="dash.totalUsuariosAtivos">@Model.TotalUsuariosAtivos</div>
        </div>
        <div class="card">
            <div class="text-es-ink-mute text-xs font-semibold uppercase tracking-wide mb-1">Logins (24h)</div>
            <div class="text-2xl font-bold text-es-ink" x-text="dash.logins24h">@Model.Logins24h</div>
        </div>
        <div class="card">
            <div class="text-es-ink-mute text-xs font-semibold uppercase tracking-wide mb-1">Em Atendimento</div>
            <div class="text-2xl font-bold text-es-gold" x-text="dash.ticketsEmAtendimento">@Model.TicketsEmAtendimento</div>
        </div>
        <div class="card">
            <div class="text-es-ink-mute text-xs font-semibold uppercase tracking-wide mb-1">Tenants Novos</div>
            <div class="text-2xl font-bold text-es-basil" x-text="dash.tenantsNovos">@Model.TenantsNovos</div>
            <div class="text-es-ink-mute text-xs mt-1">últimos 30 dias</div>
        </div>
    </div>
</div>

<!-- Tabelas -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <!-- Últimos tickets críticos -->
    <div class="card p-0 overflow-hidden">
        <div class="px-4 py-3 flex items-center justify-between" style="border-bottom:1px solid rgba(247,242,232,0.10)">
            <h2 class="text-es-ink font-semibold text-sm">Tickets Críticos</h2>
            <a href="/Tickets?prioridade=Critica" class="text-es-accent hover:text-es-cream text-xs">Ver todos →</a>
        </div>
        @if (!Model.UltimosTicketsCriticos.Any())
        {
            <div class="px-4 py-8 text-center text-es-ink-mute text-sm">Nenhum ticket crítico 🎉</div>
        }
        else
        {
            <table class="table-admin">
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Empresa</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.UltimosTicketsCriticos)
                    {
                        var id = t.TryGetProperty("id", out var idProp) ? idProp.GetString() : "";
                        var titulo = t.TryGetProperty("titulo", out var tp) ? tp.GetString() : "";
                        var empresa = t.TryGetProperty("empresaNome", out var ep) ? ep.GetString() : "";
                        var status = t.TryGetProperty("status", out var sp) ? sp.GetString() : "";
                        <tr>
                            <td><a href="/Tickets/Detail/@id" class="text-es-accent hover:text-es-cream">@titulo</a></td>
                            <td class="text-es-ink-dim">@empresa</td>
                            <td><span class="status-badge badge-@(status?.ToLower().Replace(" ", ""))">@status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Tenants recentes -->
    <div class="card p-0 overflow-hidden">
        <div class="px-4 py-3 flex items-center justify-between" style="border-bottom:1px solid rgba(247,242,232,0.10)">
            <h2 class="text-es-ink font-semibold text-sm">Tenants Recentes</h2>
            <a href="/Tenants" class="text-es-accent hover:text-es-cream text-xs">Ver todos →</a>
        </div>
        @if (!Model.TenantsRecentes.Any())
        {
            <div class="px-4 py-8 text-center text-es-ink-mute text-sm">Nenhum tenant novo nos últimos 30 dias</div>
        }
        else
        {
            <table class="table-admin">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Documento</th>
                        <th>Criado em</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.TenantsRecentes)
                    {
                        var id = t.TryGetProperty("id", out var idProp) ? idProp.GetString() : "";
                        var nome = t.TryGetProperty("nome", out var np) ? np.GetString() : "";
                        var doc = t.TryGetProperty("documento", out var dp) ? dp.GetString() : "—";
                        var criado = t.TryGetProperty("criadoEm", out var cp) ? cp.GetString() : "";
                        DateTime.TryParse(criado, out var criadoDt);
                        <tr>
                            <td><a href="/Tenants/Detail/@id" class="text-es-accent hover:text-es-cream">@nome</a></td>
                            <td class="text-es-ink-dim">@(doc ?? "—")</td>
                            <td class="text-es-ink-dim">@criadoDt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

</div>
