@page
@model EasyStock.Admin.Pages.Status.IndexModel
@using System.Text.Json
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Status do Sistema";
}

@if (Model.Erro != null)
{
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-4 py-3 text-sm mb-4">@Model.Erro</div>
}

<div x-data="statusPage()" x-init="init()">

    <!-- Header com auto-refresh indicator -->
    <div class="flex items-center justify-between mb-6">
        <div class="text-es-ink-mute text-sm">
            Última atualização: <span x-text="lastUpdated" class="text-es-ink"></span>
        </div>
        <button type="button" @@click="refresh()" class="btn-secondary text-sm">↻ Atualizar</button>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

        <!-- Database -->
        <div class="card">
            <div class="flex items-center gap-2 mb-3">
                <span x-bind:class="dbDotClass()" class="w-2.5 h-2.5 rounded-full inline-block"></span>
                <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">Database</span>
            </div>
            <div class="text-2xl font-bold text-es-ink" x-text="data.database?.latencyMs != null ? (data.database.latencyMs + ' ms') : '—'">—</div>
            <div class="text-xs mt-1" x-bind:class="dbTextClass()" x-text="data.database?.status ?? '—'"></div>
        </div>

        <!-- API -->
        <div class="card">
            <div class="flex items-center gap-2 mb-3">
                <span class="w-2.5 h-2.5 rounded-full bg-green-400 inline-block"></span>
                <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">API</span>
            </div>
            <div class="text-2xl font-bold text-es-ink" x-text="formatUptime(data.api?.uptimeSeconds)">—</div>
            <div class="text-xs text-es-basil mt-1" x-text="data.api?.version ? ('v' + data.api.version) : 'v—'"></div>
        </div>

        <!-- Errors -->
        <div class="card">
            <div class="flex items-center gap-2 mb-3">
                <span x-bind:class="errorDotClass()" class="w-2.5 h-2.5 rounded-full inline-block"></span>
                <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">Erros (24h)</span>
            </div>
            <div class="text-2xl font-bold" x-bind:class="data.erros24h?.total > 0 ? 'text-red-400' : 'text-es-ink'" x-text="data.erros24h?.total ?? 0">—</div>
            <div class="text-xs text-es-ink-mute mt-1" x-text="(data.erros24h?.ultimaHora ?? 0) + ' na última hora'"></div>
        </div>

        <!-- Usage -->
        <div class="card">
            <div class="flex items-center gap-2 mb-3">
                <span class="w-2.5 h-2.5 rounded-full bg-es-accent inline-block"></span>
                <span class="text-es-ink-mute text-xs uppercase tracking-wide font-bold">Uso</span>
            </div>
            <div class="text-2xl font-bold text-es-ink" x-text="data.uso?.usuariosAtivos24h ?? 0">—</div>
            <div class="text-xs text-es-ink-mute mt-1">usuários ativos (24h)</div>
            <div class="flex gap-3 mt-2 text-xs text-es-ink-mute">
                <span>IA: <b class="text-es-ink" x-text="data.uso?.iaGeracoesMes ?? 0"></b>/mês</span>
                <span>Tickets: <b class="text-es-ink" x-text="data.uso?.ticketsAbertos ?? 0"></b> abertos</span>
            </div>
        </div>
    </div>

    <!-- Erros recentes -->
    <div class="card">
        <h3 class="text-es-ink font-semibold text-sm mb-4">Erros Recentes</h3>
        <template x-if="(data.errosRecentes ?? []).length === 0">
            <p class="text-es-ink-mute text-sm text-center py-4">Nenhum erro recente.</p>
        </template>
        <table class="table-admin" x-show="(data.errosRecentes ?? []).length > 0">
            <thead>
                <tr>
                    <th>Ação</th>
                    <th>Detalhes</th>
                    <th>Data/Hora</th>
                </tr>
            </thead>
            <tbody>
                <template x-for="e in (data.errosRecentes ?? [])" :key="e.dataHora">
                    <tr>
                        <td class="font-mono text-xs text-es-ink" x-text="e.acao"></td>
                        <td class="text-es-ink-dim text-xs max-w-xs truncate" x-text="e.detalhes ?? '—'"></td>
                        <td class="text-es-ink-dim text-xs" x-text="formatDate(e.dataHora)"></td>
                    </tr>
                </template>
            </tbody>
        </table>
    </div>
</div>

<!-- Painel Seed (dev/staging — desabilitado em produção via Seed:ApiEnabled=false) -->
@{ var afStatus = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken; }
<div class="card mt-6" x-data="seedPanel()" x-init="carregarStatus()">
    <div class="flex items-center justify-between mb-3">
        <div>
            <h3 class="text-es-ink font-semibold text-sm">🌱 Seed de dados</h3>
            <p class="text-es-ink-mute text-xs mt-0.5">
                Popula o banco com tenants/lojas/usuários de demonstração pra testes.
                <span x-show="!enabled && enabled !== null" x-cloak class="text-amber-300 font-semibold">
                    Desabilitado neste ambiente (defina <code>Seed:ApiEnabled=true</code> ou <code>SEED_API_ENABLED=true</code>).
                </span>
            </p>
        </div>
        <button type="button" @@click="carregarStatus()" class="btn-secondary text-xs">↻</button>
    </div>

    <div x-show="loadingStatus" x-cloak class="text-es-ink-mute text-sm py-3">Consultando status…</div>

    <template x-if="!loadingStatus && counts">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
            <div class="rounded-lg p-3 text-center" style="background:rgba(247,242,232,0.04)">
                <div class="text-2xl font-bold text-es-ink" x-text="counts.empresas ?? 0"></div>
                <div class="text-[10px] uppercase tracking-wide text-es-ink-mute">Empresas</div>
            </div>
            <div class="rounded-lg p-3 text-center" style="background:rgba(247,242,232,0.04)">
                <div class="text-2xl font-bold text-es-ink" x-text="counts.usuarios ?? 0"></div>
                <div class="text-[10px] uppercase tracking-wide text-es-ink-mute">Usuários</div>
            </div>
            <div class="rounded-lg p-3 text-center" style="background:rgba(247,242,232,0.04)">
                <div class="text-2xl font-bold text-es-ink" x-text="counts.lojas ?? 0"></div>
                <div class="text-[10px] uppercase tracking-wide text-es-ink-mute">Lojas</div>
            </div>
            <div class="rounded-lg p-3 text-center" style="background:rgba(247,242,232,0.04)">
                <div class="text-2xl font-bold text-es-ink" x-text="counts.planos ?? 0"></div>
                <div class="text-[10px] uppercase tracking-wide text-es-ink-mute">Planos</div>
            </div>
        </div>
    </template>

    <div x-show="erro" x-cloak class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg px-3 py-2 text-sm mb-3" x-text="erro"></div>
    <div x-show="sucesso" x-cloak class="bg-es-basil/10 border border-es-basil/30 text-es-basil rounded-lg px-3 py-2 text-sm mb-3" x-text="sucesso"></div>

    <div class="flex flex-wrap gap-2 items-center">
        <select x-model="volume" :disabled="!enabled || executando" class="form-input text-sm max-w-[200px]">
            <option value="small">Small (2 tenants)</option>
            <option value="medium">Medium (3 tenants)</option>
            <option value="large">Large (4 tenants — default)</option>
        </select>
        <button type="button" @@click="executarDemo()" :disabled="!enabled || executando" class="btn-primary text-sm">
            <span x-show="!executando">🚀 Rodar seed demo</span>
            <span x-show="executando" x-cloak>Executando…</span>
        </button>
        <button type="button" @@click="executarMinimal()" :disabled="!enabled || executando" class="btn-secondary text-sm">
            ⚡ Seed mínimo (1 admin)
        </button>
        <a href="/Tenants" class="text-es-accent hover:text-es-cream text-xs ml-auto">→ Ver clientes</a>
    </div>
    <p class="text-es-ink-mute text-[11px] mt-3">
        Demo cria empresas fictícias (PastaBella, Cantina Mauricio, CasaDaBaba, MassasVeneza) com lojas, usuários
        e movimentações pra testar o módulo de Gestão de Cliente. <strong>Idempotente</strong> — rodar múltiplas
        vezes não duplica dados.
    </p>
</div>

@section Scripts {
<script>
function statusPage() {
    return {
        data: @(Model.StatusData.ValueKind != System.Text.Json.JsonValueKind.Undefined
            ? Model.StatusData.GetRawText()
            : "{}"),
        lastUpdated: new Date().toLocaleTimeString('pt-BR'),

        init() {
            setInterval(() => this.refresh(), 30000);
        },

        async refresh() {
            try {
                const r = await fetch('/api-proxy/status', { credentials: 'same-origin', cache: 'no-store' });
                if (r.status === 401) {
                    // Sessão expirou no servidor — manda pro login pra evitar polling em loop.
                    window.location.href = '/Auth/Login';
                    return;
                }
                if (r.ok) {
                    this.data = await r.json();
                    this.lastUpdated = new Date().toLocaleTimeString('pt-BR');
                }
                // 502/outros: mantém último data e timestamp; usuário vê dados estagnados sem crash.
            } catch {}
        },

        dbDotClass() {
            const s = this.data.database?.status;
            return s === 'ok' ? 'bg-green-400' : s === 'degraded' ? 'bg-yellow-400' : 'bg-red-400';
        },

        dbTextClass() {
            const s = this.data.database?.status;
            return s === 'ok' ? 'text-es-basil' : s === 'degraded' ? 'text-es-gold' : 'text-red-400';
        },

        errorDotClass() {
            const n = this.data.erros24h?.total ?? 0;
            return n === 0 ? 'bg-green-400' : n < 10 ? 'bg-yellow-400' : 'bg-red-400';
        },

        formatUptime(seconds) {
            if (!seconds) return '—';
            const d = Math.floor(seconds / 86400);
            const h = Math.floor((seconds % 86400) / 3600);
            const m = Math.floor((seconds % 3600) / 60);
            return d > 0 ? `${d}d ${h}h ${m}m` : `${h}h ${m}m`;
        },

        formatDate(iso) {
            if (!iso) return '—';
            return new Date(iso).toLocaleString('pt-BR', { dateStyle: 'short', timeStyle: 'short' });
        }
    }
}

function seedPanel() {
    return {
        enabled: null,        // null = ainda não consultou; true/false após carregarStatus
        loadingStatus: false,
        executando: false,
        counts: null,
        volume: 'large',
        erro: '',
        sucesso: '',
        async carregarStatus() {
            this.loadingStatus = true; this.erro = ''; this.sucesso = '';
            try {
                const r = await fetch('/Status?handler=SeedStatus', { credentials: 'same-origin', cache: 'no-store' });
                if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                const d = await r.json();
                if (!r.ok) {
                    this.erro = (d && d.error) || ('Falha HTTP ' + r.status);
                    return;
                }
                const data = d.data || d;
                this.enabled = !!data.enabled;
                this.counts = data.counts || null;
            } catch (e) {
                this.erro = 'Falha de rede ao consultar seed: ' + (e.message || e);
            } finally {
                this.loadingStatus = false;
            }
        },
        async _post(url) {
            if (!this.enabled || this.executando) return;
            this.executando = true; this.erro = ''; this.sucesso = '';
            try {
                const fd = new FormData();
                fd.append('__RequestVerificationToken', '@afStatus');
                if (url.includes('handler=SeedDemo')) fd.append('volume', this.volume);
                const r = await fetch(url, { method: 'POST', credentials: 'same-origin', body: fd });
                if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                const d = await r.json();
                if (!r.ok) {
                    this.erro = (d && (d.error || (d.error?.message))) || ('Falha HTTP ' + r.status);
                    return;
                }
                const data = d.data || d;
                this.sucesso = data.mensagem || 'Seed executado com sucesso.';
                if (data.counts) this.counts = data.counts;
                else await this.carregarStatus();
            } catch (e) {
                this.erro = 'Falha de rede ao executar seed: ' + (e.message || e);
            } finally {
                this.executando = false;
            }
        },
        async executarDemo() {
            await this._post('/Status?handler=SeedDemo&volume=' + encodeURIComponent(this.volume));
        },
        async executarMinimal() {
            if (!confirm('Executar seed mínimo? Cria apenas 1 admin + 1 empresa + 1 loja.')) return;
            await this._post('/Status?handler=SeedMinimal');
        }
    };
}
</script>
}
