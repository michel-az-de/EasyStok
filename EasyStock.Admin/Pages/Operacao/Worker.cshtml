@page
@model EasyStock.Admin.Pages.Operacao.WorkerModel
@{
    ViewData["Title"] = "Worker";
}

@functions {
    private string SerializarDadosIniciais()
    {
        if (Model.Data.ValueKind == System.Text.Json.JsonValueKind.Undefined
            || Model.Data.ValueKind == System.Text.Json.JsonValueKind.Null)
        {
            return "null";
        }
        return Model.Data.GetRawText();
    }
}

<div x-data="workerDashboard()" x-init="init()" class="space-y-6">

    <!-- Header -->
    <div class="flex items-start justify-between gap-4">
        <div>
            <h2 class="text-es-ink text-2xl font-bold tracking-tight">Worker — saúde do pipeline</h2>
            <p class="text-es-ink-mute text-sm mt-1">
                7 hosted services: SLA monitor, dispatcher de notificações, avaliador, coletor, signaler, outbox de integração e anonimização LGPD.
                Refresh automático a cada 30s.
            </p>
        </div>
        <div class="flex items-center gap-3">
            <span class="text-xs text-es-ink-mute" x-show="ultimaAtualizacao" x-cloak>
                atualizado <span x-text="formatarHorario(ultimaAtualizacao)"></span>
            </span>
            <button @@click="refresh()" :disabled="loading"
                    class="rounded-md px-3 py-1.5 text-xs font-semibold"
                    style="background:var(--es-surface-2);border:1px solid rgba(247,242,232,.12);color:var(--es-ink)">
                <span x-show="!loading">↻ Atualizar</span>
                <span x-show="loading">carregando...</span>
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Erro))
    {
        <div class="rounded-xl p-4"
             style="background:var(--es-surface);border:1px solid rgba(220,38,38,.4)">
            <p class="text-red-400 text-sm">@Model.Erro</p>
        </div>
    }

    <!-- Saude global -->
    <template x-if="d?.saude">
        <div class="rounded-xl p-5"
             :style="`background:var(--es-surface);border:1px solid ${corBordaSaude()}`">
            <div class="flex items-center gap-3">
                <span class="inline-block w-3 h-3 rounded-full"
                      :style="`background:${corDotSaude()}`"></span>
                <span class="text-es-ink text-lg font-semibold" x-text="rotuloSaude()"></span>
                <span class="text-es-ink-mute text-xs ml-auto" x-show="d.saude.ultimaAtividadeHa !== null">
                    última atividade há <span x-text="formatarSegundos(d.saude.ultimaAtividadeHa)"></span>
                </span>
            </div>
        </div>
    </template>

    <!-- Hosted services -->
    <template x-if="d?.heartbeats">
        <div class="rounded-xl"
             style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
            <div class="px-5 py-3 border-b" style="border-color:rgba(247,242,232,.08)">
                <h3 class="text-es-ink text-sm font-semibold tracking-wide">Hosted services</h3>
            </div>
            <div class="divide-y" style="border-color:rgba(247,242,232,.06)">
                <template x-for="hb in d.heartbeats" :key="hb.servico">
                    <div class="px-5 py-3 flex items-center gap-3"
                         style="border-color:rgba(247,242,232,.06)">
                        <span class="inline-block w-2 h-2 rounded-full"
                              :style="`background:${corStatusHeartbeat(hb)}`"></span>
                        <span class="text-es-ink text-sm font-medium" x-text="hb.servico"></span>
                        <span class="text-es-ink-mute text-xs"
                              :style="`color:${corTexto(hb)}`"
                              x-text="`há ${formatarSegundos(hb.segundosDesdeUltimoTick)}`"></span>
                        <span class="text-es-ink-mute text-[10px] uppercase tracking-wider ml-2"
                              x-text="hb.status"></span>
                        <span class="text-es-ink-dim text-xs" x-show="hb.itensProcessados !== null && hb.itensProcessados !== undefined">
                            · <span x-text="hb.itensProcessados"></span> itens
                        </span>
                        <span class="text-es-ink-dim text-xs" x-show="hb.duracaoMs !== null && hb.duracaoMs !== undefined">
                            · <span x-text="hb.duracaoMs"></span>ms
                        </span>
                        <span class="text-es-ink-dim text-xs ml-auto truncate max-w-md" x-text="hb.detalhe || ''"></span>
                    </div>
                </template>
                <template x-if="!d.heartbeats.length">
                    <div class="px-5 py-6 text-es-ink-mute text-sm">
                        Nenhum heartbeat registrado ainda. Verifique se o Worker está rodando e
                        se a tabela <code class="text-xs">worker_heartbeats</code> existe.
                    </div>
                </template>
            </div>
        </div>
    </template>

    <!-- Cards de pipelines -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

        <!-- Notifications -->
        <template x-if="d?.notifications">
            <div class="rounded-xl p-5"
                 style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
                <div class="text-[10px] uppercase tracking-widest text-es-ink-mute font-semibold">Notificações 24h</div>
                <div class="mt-3 grid grid-cols-3 gap-3">
                    <div>
                        <div class="text-es-ink text-2xl font-bold" x-text="d.notifications.enviadas24h"></div>
                        <div class="text-es-ink-mute text-xs">enviadas</div>
                    </div>
                    <div>
                        <div class="text-2xl font-bold"
                             :style="`color:${d.notifications.falhadas24h > 0 ? '#ef4444' : 'var(--es-ink)'}`"
                             x-text="d.notifications.falhadas24h"></div>
                        <div class="text-es-ink-mute text-xs">falhadas</div>
                    </div>
                    <div>
                        <div class="text-2xl font-bold"
                             :style="`color:${d.notifications.pendentes > 50 ? '#f59e0b' : 'var(--es-ink)'}`"
                             x-text="d.notifications.pendentes"></div>
                        <div class="text-es-ink-mute text-xs">pendentes</div>
                    </div>
                </div>
                <div class="mt-4 pt-3 border-t text-xs text-es-ink-mute" style="border-color:rgba(247,242,232,.08)">
                    Lag do outbox: <span class="text-es-ink font-medium"
                                         :style="`color:${d.notifications.lagSegundos > 60 ? '#f59e0b' : 'var(--es-ink)'}`"
                                         x-text="formatarSegundos(d.notifications.lagSegundos)"></span>
                </div>
                <div class="mt-3 text-xs" x-show="d.notifications.porCanal && d.notifications.porCanal.length">
                    <div class="text-es-ink-mute mb-2">Por canal (24h):</div>
                    <template x-for="canal in d.notifications.porCanal" :key="canal.canal">
                        <div class="flex items-center justify-between py-1">
                            <span class="text-es-ink" x-text="canal.canal"></span>
                            <span class="text-es-ink-mute">
                                <span class="text-es-ink" x-text="canal.enviadas"></span> envio(s)
                                <span x-show="canal.falhadas > 0" class="text-red-400 ml-1">
                                    · <span x-text="canal.falhadas"></span> falha(s)
                                </span>
                            </span>
                        </div>
                    </template>
                </div>
            </div>
        </template>

        <!-- Helpdesk SLA -->
        <template x-if="d?.helpdesk">
            <div class="rounded-xl p-5"
                 style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
                <div class="text-[10px] uppercase tracking-widest text-es-ink-mute font-semibold">Helpdesk SLA</div>
                <div class="mt-3 grid grid-cols-2 gap-3">
                    <div>
                        <div class="text-es-ink text-2xl font-bold" x-text="d.helpdesk.ticketsAbertos"></div>
                        <div class="text-es-ink-mute text-xs">tickets abertos</div>
                    </div>
                    <div>
                        <div class="text-2xl font-bold"
                             :style="`color:${d.helpdesk.slasViolacaoAtiva > 0 ? '#ef4444' : 'var(--es-ink)'}`"
                             x-text="d.helpdesk.slasViolacaoAtiva"></div>
                        <div class="text-es-ink-mute text-xs">SLAs em violação</div>
                    </div>
                    <div>
                        <div class="text-es-ink text-xl font-semibold" x-text="d.helpdesk.slasViolados24h"></div>
                        <div class="text-es-ink-mute text-xs">violados 24h</div>
                    </div>
                    <div>
                        <div class="text-xl font-semibold"
                             :style="`color:${d.helpdesk.slasProximosVencer > 0 ? '#f59e0b' : 'var(--es-ink)'}`"
                             x-text="d.helpdesk.slasProximosVencer"></div>
                        <div class="text-es-ink-mute text-xs">próximos do prazo</div>
                    </div>
                </div>
            </div>
        </template>

        <!-- Integration Outbox -->
        <template x-if="d?.integrationOutbox">
            <div class="rounded-xl p-5"
                 style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
                <div class="text-[10px] uppercase tracking-widest text-es-ink-mute font-semibold">Outbox de integração</div>
                <div class="mt-3 grid grid-cols-2 gap-3">
                    <div>
                        <div class="text-es-ink text-2xl font-bold" x-text="d.integrationOutbox.pendentes"></div>
                        <div class="text-es-ink-mute text-xs">pendentes</div>
                    </div>
                    <div>
                        <div class="text-es-ink text-2xl font-bold" x-text="d.integrationOutbox.emEnvio"></div>
                        <div class="text-es-ink-mute text-xs">em envio</div>
                    </div>
                    <div>
                        <div class="text-es-ink text-xl font-semibold" x-text="d.integrationOutbox.enviados24h"></div>
                        <div class="text-es-ink-mute text-xs">enviados 24h</div>
                    </div>
                    <div>
                        <div class="text-xl font-semibold"
                             :style="`color:${d.integrationOutbox.falhados > 0 ? '#ef4444' : 'var(--es-ink)'}`"
                             x-text="d.integrationOutbox.falhados"></div>
                        <div class="text-es-ink-mute text-xs">falhados</div>
                    </div>
                </div>
                <div class="mt-3 pt-3 border-t text-xs text-es-ink-mute" style="border-color:rgba(247,242,232,.08)" x-show="d.integrationOutbox.pendentes === 0 && d.integrationOutbox.enviados24h === 0 && d.integrationOutbox.emEnvio === 0">
                    Sem handlers de integração implementados — fluxo idle.
                </div>
            </div>
        </template>
    </div>

</div>

@section Scripts {
    <script>
        window.__workerDashboardInitial = @Html.Raw(SerializarDadosIniciais());

        function workerDashboard() {
            return {
                d: window.__workerDashboardInitial,
                loading: false,
                ultimaAtualizacao: window.__workerDashboardInitial ? new Date() : null,
                _intervalId: null,

                async init() {
                    // Se o servidor nao hidratou (erro), tenta carregar.
                    if (!this.d) await this.refresh();
                    this._intervalId = setInterval(() => this.refresh(), 30000);
                },

                async refresh() {
                    this.loading = true;
                    try {
                        const res = await fetch('?handler=Data', {
                            headers: { 'Accept': 'application/json' },
                            credentials: 'same-origin'
                        });
                        if (!res.ok) throw new Error('http ' + res.status);
                        const json = await res.json();
                        // O endpoint da API retorna { data, meta } envelope; ja desempacotamos no AdminApiClient,
                        // mas o handler do PageModel retorna o JsonElement cru. Pode ser direto ou data{...}.
                        this.d = json && json.data ? json.data : json;
                        this.ultimaAtualizacao = new Date();
                    } catch (err) {
                        console.error('Falha refresh worker dashboard:', err);
                    } finally {
                        this.loading = false;
                    }
                },

                // ---- Helpers visuais ----
                formatarSegundos(s) {
                    if (s == null) return '–';
                    if (s < 60) return s + 's';
                    if (s < 3600) return Math.floor(s / 60) + 'm' + (s % 60 > 0 ? ' ' + (s % 60) + 's' : '');
                    return Math.floor(s / 3600) + 'h ' + Math.floor((s % 3600) / 60) + 'm';
                },
                formatarHorario(d) {
                    if (!d) return '';
                    return d.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                },
                corStatusHeartbeat(hb) {
                    if (hb.status === 'Erro') return '#ef4444';
                    if (hb.status === 'Skip') return '#6b7280';
                    if (hb.segundosDesdeUltimoTick > 300) return '#ef4444';
                    if (hb.segundosDesdeUltimoTick > 120) return '#f59e0b';
                    return '#10b981';
                },
                corTexto(hb) {
                    if (hb.segundosDesdeUltimoTick > 300) return '#ef4444';
                    if (hb.segundosDesdeUltimoTick > 120) return '#f59e0b';
                    return 'var(--es-ink-mute)';
                },
                corDotSaude() {
                    if (!this.d || !this.d.saude) return '#6b7280';
                    return this.d.saude.workerSaudavel ? '#10b981' : '#ef4444';
                },
                corBordaSaude() {
                    if (!this.d || !this.d.saude) return 'rgba(247,242,232,.08)';
                    return this.d.saude.workerSaudavel ? 'rgba(16,185,129,.30)' : 'rgba(239,68,68,.30)';
                },
                rotuloSaude() {
                    if (!this.d || !this.d.saude) return 'Sem dados';
                    if (this.d.saude.workerSaudavel) return 'Worker saudável';
                    if (this.d.saude.worstHeartbeat === 'sem-dados') return 'Aguardando primeiro heartbeat';
                    if (this.d.saude.worstHeartbeat === 'erro') return 'Worker com erro em algum job';
                    return 'Worker pode estar parado — sem tick recente';
                },
            };
        }
    </script>
}
