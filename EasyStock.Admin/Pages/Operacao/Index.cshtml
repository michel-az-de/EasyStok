@page
@model EasyStock.Admin.Pages.Operacao.IndexModel
@{
    ViewData["Title"] = "Operação";
}

<div x-data="operacaoPage()" x-init="init()" class="space-y-6">

    <div class="flex items-center justify-between gap-4">
        <div>
            <h2 class="text-es-ink text-2xl font-bold tracking-tight">Operação</h2>
            <p class="text-es-ink-mute text-sm">KPIs do dia · atualiza a cada 15s</p>
        </div>
        <div class="text-xs text-es-ink-mute" x-show="ultimaAtualizacao" x-cloak>
            <span>atualizado <span x-text="formatLastUpdate()"></span></span>
        </div>
    </div>

    <template x-if="!empresaId">
        <div class="rounded-xl p-6"
             style="background:var(--es-surface);border:1px dashed rgba(247,242,232,.18)">
            <p class="text-es-ink-dim text-sm mb-3">Selecione um cliente para ver os dados de operação.</p>
            <button type="button"
                    class="btn-secondary text-sm flex items-center gap-2"
                    @@click="$dispatch('open-cmdk', { onPick: id => window.location.href = '/Operacao?empresaId=' + id })">
                🔍 Buscar cliente…
                <kbd class="text-[10px] px-1.5 py-0.5 rounded bg-es-surface-2 text-es-ink-mute font-mono">Ctrl K</kbd>
            </button>
            <p class="text-es-ink-mute text-xs mt-3">
                ou informe na URL: <code class="text-xs bg-es-surface-2 px-2 py-1 rounded">?empresaId=&lt;guid&gt;</code>
            </p>
        </div>
    </template>

    <template x-if="empresaId">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">

            <!-- Vendas hoje -->
            <div class="rounded-xl p-5"
                 style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
                <div class="text-[10px] uppercase tracking-widest text-es-ink-mute font-semibold">Vendas hoje</div>
                <div class="text-3xl font-bold text-es-ink mt-2" x-text="brl(d.vendasHojeValor)"></div>
                <div class="text-xs text-es-ink-mute mt-1"><span x-text="d.vendasHojeCount || 0"></span> pedido(s) entregue(s)</div>
            </div>

            <!-- Caixa -->
            <div class="rounded-xl p-5"
                 style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
                <div class="text-[10px] uppercase tracking-widest text-es-ink-mute font-semibold">Saldo do caixa</div>
                <div class="text-3xl font-bold text-es-ink mt-2" x-text="brl(d.caixaSaldoHoje)"></div>
                <div class="text-xs text-es-ink-mute mt-1">
                    +<span x-text="brl(d.caixaEntradasExtras)"></span> entradas ·
                    -<span x-text="brl(d.caixaSaidas)"></span> saídas
                </div>
            </div>

            <!-- Pedidos abertos -->
            <div class="rounded-xl p-5"
                 style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
                <div class="text-[10px] uppercase tracking-widest text-es-ink-mute font-semibold">Pedidos abertos</div>
                <div class="text-3xl font-bold text-es-ink mt-2" x-text="d.pedidosAbertos || 0"></div>
                <div class="text-xs text-es-ink-mute mt-1">
                    <span x-text="d.pedidosPreparando || 0"></span> preparando ·
                    <span x-text="d.pedidosProntos || 0"></span> prontos
                </div>
            </div>

            <!-- Devices -->
            <div class="rounded-xl p-5"
                 style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
                <div class="text-[10px] uppercase tracking-widest text-es-ink-mute font-semibold">Dispositivos ativos</div>
                <div class="text-3xl font-bold text-es-ink mt-2">
                    <span x-text="d.devicesAtivos || 0"></span>
                    <span class="text-es-ink-mute text-base">/ <span x-text="d.devicesTotal || 0"></span></span>
                </div>
                <div class="text-xs mt-1">
                    <a :href="'/Dispositivos?empresaId=' + empresaId" class="text-es-accent hover:underline">gerenciar →</a>
                </div>
            </div>

            <!-- Pedidos travados -->
            <div class="rounded-xl p-5"
                 style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
                <div class="text-[10px] uppercase tracking-widest text-es-ink-mute font-semibold">Pedidos travados</div>
                <div class="text-3xl font-bold mt-2"
                     :class="(d.pedidosTravados || 0) > 0 ? 'text-yellow-300' : 'text-es-ink'"
                     x-text="d.pedidosTravados || 0"></div>
                <div class="text-xs text-es-ink-mute mt-1">preparando há +30 min</div>
            </div>

            <!-- Conferência pendente -->
            <div class="rounded-xl p-5"
                 style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
                <div class="text-[10px] uppercase tracking-widest text-es-ink-mute font-semibold">Conferência pendente</div>
                <div class="text-3xl font-bold text-es-ink mt-2" x-text="d.conferenciaPendente || 0"></div>
                <div class="text-xs text-es-ink-mute mt-1">prontos sem confirmar</div>
            </div>

            <!-- Lotes -->
            <div class="rounded-xl p-5"
                 style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
                <div class="text-[10px] uppercase tracking-widest text-es-ink-mute font-semibold">Lotes hoje</div>
                <div class="text-3xl font-bold text-es-ink mt-2" x-text="d.lotesHoje || 0"></div>
            </div>

            <!-- Divergências de estoque -->
            <div class="rounded-xl p-5"
                 style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
                <div class="text-[10px] uppercase tracking-widest text-es-ink-mute font-semibold">Divergências estoque</div>
                <div class="text-3xl font-bold mt-2"
                     :class="(d.divergenciasEstoque || 0) > 0 ? 'text-yellow-300' : 'text-es-ink'"
                     x-text="d.divergenciasEstoque || 0"></div>
                <div class="text-xs text-es-ink-mute mt-1">PWA × ERP</div>
            </div>
        </div>
    </template>

    <!-- Onda 1.4 — widget Tickets criticos do helpdesk SaaS -->
    <template x-if="empresaId && tk.total > 0">
        <div class="rounded-xl p-5"
             style="background:var(--es-surface);border:1px solid rgba(247,242,232,.08)">
            <div class="flex items-center justify-between mb-3">
                <div>
                    <h3 class="text-es-ink text-sm font-semibold uppercase tracking-widest">⚠ Tickets críticos</h3>
                    <p class="text-xs text-es-ink-mute mt-0.5">SLA violado ou prioridade Alta/Crítica · atualiza a cada 60s</p>
                </div>
                <div class="flex items-center gap-3 text-xs">
                    <span class="text-red-400 font-bold"><span x-text="tk.slaViolados"></span> SLA</span>
                    <span class="text-amber-300 font-bold"><span x-text="tk.altaOuCritica"></span> alta/crit</span>
                    <a :href="'/Tickets?empresaId=' + empresaId + '&slaStatus=violado'" class="text-es-accent hover:underline">ver todos →</a>
                </div>
            </div>
            <ul class="divide-y divide-es-surface-2">
                <template x-for="t in tk.top" :key="t.id">
                    <li class="py-2 flex items-center gap-3 text-sm">
                        <span class="px-1.5 py-0.5 rounded text-[10px] font-bold uppercase"
                              :class="t.prioridade === 'Critica' ? 'bg-red-500/20 text-red-300' : 'bg-amber-500/20 text-amber-300'"
                              x-text="t.prioridade"></span>
                        <a :href="'/Tickets/Detail/' + t.id" class="text-es-ink hover:text-es-accent flex-1 truncate" x-text="t.titulo"></a>
                        <span class="text-xs text-es-ink-mute" x-text="t.status"></span>
                        <span x-show="t.slaRespostaViolado || t.slaResolucaoViolado" class="text-red-400 text-xs" title="SLA violado">⏱</span>
                    </li>
                </template>
            </ul>
        </div>
    </template>

    <p x-show="erro" x-cloak class="text-red-400 text-sm" x-text="erro"></p>
</div>

@section Scripts {
<script>
function operacaoPage() {
    return {
        empresaId: '@(Model.EmpresaId?.ToString() ?? "")',
        lojaId: '@(Model.LojaId?.ToString() ?? "")',
        d: {},
        tk: { total: 0, slaViolados: 0, altaOuCritica: 0, top: [] },
        erro: '',
        ultimaAtualizacao: 0,
        _timer: null,
        _tkTimer: null,

        async init() {
            if (!this.empresaId) return;
            await Promise.all([this.fetchDashboard(), this.fetchTicketsCriticos()]);
            this._timer = setInterval(() => this.fetchDashboard(), 15000);
            // Onda 1.4 — tickets criticos atualizam a cada 60s (mais lento, menor frequencia de mudanca)
            this._tkTimer = setInterval(() => this.fetchTicketsCriticos(), 60000);
        },

        async fetchDashboard() {
            try {
                let url = '/api-proxy/mobile/operacao/dashboard?empresaId=' + this.empresaId;
                if (this.lojaId) url += '&lojaId=' + this.lojaId;
                const r = await fetch(url, { credentials: 'same-origin' });
                if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                if (!r.ok) throw new Error('HTTP ' + r.status);
                const data = await r.json();
                // Normaliza camel-case do backend (data.vendasHojeValor) — JsonElement
                // do proxy preserva como veio.
                this.d = data || {};
                this.ultimaAtualizacao = Date.now();
                this.erro = '';
            } catch (e) {
                this.erro = 'Falha ao carregar dashboard: ' + (e.message || e);
            }
        },

        async fetchTicketsCriticos() {
            try {
                const url = '/api-proxy/admin/tickets/criticos-resumo?empresaId=' + this.empresaId + '&limit=5';
                const r = await fetch(url, { credentials: 'same-origin' });
                if (!r.ok) return; // silencioso — widget se esconde se total=0
                const data = await r.json();
                this.tk = {
                    total: data.total || 0,
                    slaViolados: data.slaViolados || 0,
                    altaOuCritica: data.altaOuCritica || 0,
                    top: Array.isArray(data.top) ? data.top : []
                };
            } catch { /* falha silenciosa — não quebra o resto do dashboard */ }
        },

        brl(v) {
            const n = Number(v || 0);
            try { return n.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }); }
            catch { return 'R$ ' + n.toFixed(2); }
        },

        formatLastUpdate() {
            const sec = Math.floor((Date.now() - this.ultimaAtualizacao) / 1000);
            if (sec < 5) return 'agora';
            if (sec < 60) return sec + 's atrás';
            return Math.floor(sec / 60) + ' min atrás';
        }
    };
}
</script>
}
