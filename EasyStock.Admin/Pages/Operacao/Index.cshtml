@page
@model EasyStock.Admin.Pages.Operacao.IndexModel
@{
    ViewData["Title"] = "Operação";
}

<div x-data="operacaoPage()" x-init="init()" style="display:flex; flex-direction:column; gap:24px;">

    <div style="display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;">
        <div>
            <es-breadcrumb>
                <es-breadcrumb-item href="/">Dashboard</es-breadcrumb-item>
                <es-breadcrumb-item>Operação</es-breadcrumb-item>
            </es-breadcrumb>
            <h2 class="admin-page-title">Operação</h2>
            <p style="margin:4px 0 0; color:var(--text-muted); font-size:13px;">KPIs do dia · atualiza a cada 15s</p>
        </div>
        <div x-show="ultimaAtualizacao" x-cloak style="display:flex; align-items:center; gap:6px; color:var(--text-muted); font-size:12px;">
            <span style="display:inline-block; width:8px; height:8px; border-radius:999px; background:var(--ok-600); animation:pulse 2s infinite;"></span>
            atualizado <span x-text="formatLastUpdate()"></span>
        </div>
    </div>

    <template x-if="!empresaId">
        <es-card>
            <es-empty-state icon="building-2"
                            title="Selecione uma empresa"
                            description="Vá até /Tenants para escolher um cliente, ou informe ?empresaId=<guid> na URL.">
                <es-button variant="primary" href="/Tenants" icon="building-2">Ir para clientes</es-button>
            </es-empty-state>
        </es-card>
    </template>

    <template x-if="empresaId">
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:16px;">

            <div class="es-stat-card">
                <div class="es-stat-label">Vendas hoje</div>
                <div class="es-stat-value" x-text="brl(d.vendasHojeValor)"></div>
                <div class="es-stat-meta">
                    <span><strong style="color:var(--text-primary);" x-text="d.vendasHojeCount || 0"></strong> pedido(s) entregue(s)</span>
                </div>
            </div>

            <div class="es-stat-card">
                <div class="es-stat-label">Saldo do caixa</div>
                <div class="es-stat-value" x-text="brl(d.caixaSaldoHoje)"></div>
                <div class="es-stat-meta" style="font-size:11px;">
                    +<span x-text="brl(d.caixaEntradasExtras)"></span> entradas ·
                    -<span x-text="brl(d.caixaSaidas)"></span> saídas
                </div>
            </div>

            <div class="es-stat-card">
                <div class="es-stat-label">Pedidos abertos</div>
                <div class="es-stat-value" x-text="d.pedidosAbertos || 0"></div>
                <div class="es-stat-meta">
                    <span><strong style="color:var(--text-primary);" x-text="d.pedidosPreparando || 0"></strong> preparando ·
                    <strong style="color:var(--text-primary);" x-text="d.pedidosProntos || 0"></strong> prontos</span>
                </div>
            </div>

            <a class="es-stat-card is-link card-interactive" :href="'/Dispositivos?empresaId=' + empresaId">
                <div class="es-stat-label">Dispositivos ativos</div>
                <div class="es-stat-value">
                    <span x-text="d.devicesAtivos || 0"></span>
                    <span style="color:var(--text-muted); font-size:18px;"> / <span x-text="d.devicesTotal || 0"></span></span>
                </div>
                <div class="es-stat-meta">
                    <span style="color:var(--orange-500);">gerenciar →</span>
                </div>
            </a>

            <div class="es-stat-card">
                <div class="es-stat-label">Pedidos travados</div>
                <div class="es-stat-value" :style="(d.pedidosTravados || 0) > 0 ? 'color: var(--warn-600);' : ''" x-text="d.pedidosTravados || 0"></div>
                <div class="es-stat-meta"><span>preparando há +30 min</span></div>
            </div>

            <div class="es-stat-card">
                <div class="es-stat-label">Conferência pendente</div>
                <div class="es-stat-value" x-text="d.conferenciaPendente || 0"></div>
                <div class="es-stat-meta"><span>prontos sem confirmar</span></div>
            </div>

            <div class="es-stat-card">
                <div class="es-stat-label">Lotes hoje</div>
                <div class="es-stat-value" x-text="d.lotesHoje || 0"></div>
            </div>

            <div class="es-stat-card">
                <div class="es-stat-label">Divergências estoque</div>
                <div class="es-stat-value" :style="(d.divergenciasEstoque || 0) > 0 ? 'color: var(--warn-600);' : ''" x-text="d.divergenciasEstoque || 0"></div>
                <div class="es-stat-meta"><span>PWA × ERP</span></div>
            </div>
        </div>
    </template>

    <!-- Onda 1.4 — widget Tickets críticos do helpdesk SaaS -->
    <template x-if="empresaId && tk.total > 0">
        <es-card padding="none">
            <header class="es-card-header" style="display:flex; align-items:center; justify-content:space-between;">
                <div>
                    <h3 class="es-card-title">Tickets críticos</h3>
                    <div class="es-card-desc">SLA violado ou prioridade Alta/Crítica · atualiza a cada 60s</div>
                </div>
                <div style="display:flex; align-items:center; gap:12px; font-size:12px;">
                    <span style="color:var(--crit-600); font-weight:700;"><span x-text="tk.slaViolados"></span> SLA</span>
                    <span style="color:var(--warn-600); font-weight:700;"><span x-text="tk.altaOuCritica"></span> alta/crit</span>
                    <a :href="'/Tickets?empresaId=' + empresaId + '&slaStatus=violado'" style="color:var(--orange-500); text-decoration:none;">ver todos →</a>
                </div>
            </header>
            <div style="padding:0 0 8px;">
                <template x-for="t in tk.top" :key="t.id">
                    <div style="display:flex; align-items:center; gap:10px; padding:10px 20px; border-top:1px solid var(--border-soft); font-size:13px;">
                        <es-badge :variant="t.prioridade === 'Critica' ? 'crit' : 'warn'" x-text="t.prioridade"></es-badge>
                        <a :href="'/Tickets/Detail/' + t.id" style="color:var(--text-primary); font-weight:500; text-decoration:none; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" x-text="t.titulo"></a>
                        <span style="color:var(--text-muted); font-size:12px;" x-text="t.status"></span>
                        <es-icon x-show="t.slaRespostaViolado || t.slaResolucaoViolado" name="clock" size="14" style="color:var(--crit-600);" title="SLA violado"></es-icon>
                    </div>
                </template>
            </div>
        </es-card>
    </template>

    <p x-show="erro" x-cloak style="color:var(--crit-600); font-size:13px;" x-text="erro"></p>
</div>

<style>@@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:.4;} }</style>

@section Scripts {
<script>
function operacaoPage() {
    return {
        empresaId: '@(Model.EmpresaId?.ToString() ?? "")',
        lojaId: '@(Model.LojaId?.ToString() ?? "")',
        d: {},
        erro: '',
        ultimaAtualizacao: 0,
        _timer: null,

        async init() {
            if (!this.empresaId) return;
            await this.fetchDashboard();
            this._timer = setInterval(() => this.fetchDashboard(), 15000);
        },

        async fetchDashboard() {
            try {
                let url = '/api-proxy/mobile/operacao/dashboard?empresaId=' + this.empresaId;
                if (this.lojaId) url += '&lojaId=' + this.lojaId;
                const r = await fetch(url, { credentials: 'same-origin' });
                if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                if (!r.ok) throw new Error('HTTP ' + r.status);
                const data = await r.json();
                this.d = data || {};
                this.ultimaAtualizacao = Date.now();
                this.erro = '';
            } catch (e) {
                this.erro = 'Falha ao carregar dashboard: ' + (e.message || e);
            }
        },

        brl(v) {
            const n = Number(v || 0);
            try { return n.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }); }
            catch { return 'R$ ' + n.toFixed(2); }
        },

        formatLastUpdate() {
            const sec = Math.floor((Date.now() - this.ultimaAtualizacao) / 1000);
            if (sec < 5) return 'agora';
            if (sec < 60) return sec + 's atrás';
            return Math.floor(sec / 60) + ' min atrás';
        }
    };
}
</script>
}
