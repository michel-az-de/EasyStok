@page
@model EasyStock.Admin.Pages.Operacao.IndexModel
@{
    ViewData["Title"] = "Operação";
}

<link rel="stylesheet" href="~/css/operacao.css" asp-append-version="true" />

<div x-data="operacaoClientes()" x-init="init()" class="op">

    <header class="op-head">
        <div>
            <h2 class="admin-page-title">Operação</h2>
            <p class="op-sub">Como estão os seus clientes agora: vendas do dia, assinatura, suporte e cobrança. A lista atualiza sozinha e mostra primeiro quem precisa de atenção.</p>
        </div>
        <span class="op-updated" x-show="atualizadoEm" x-cloak>
            <span class="op-dot op-dot-ok"></span> atualizado <span x-text="formatAtualizado()"></span>
        </span>
    </header>

    @* ---- resumo (números com rótulo) ---- *@
    <div class="op-resumo" x-show="!carregando" x-cloak>
        <div class="op-kpi">
            <span class="op-kpi-num" x-text="totais.clientesAtivos || 0"></span>
            <span class="op-kpi-label">clientes ativos</span>
        </div>
        <div class="op-kpi" :class="{ 'op-kpi-alerta': (totais.precisamAtencao || 0) > 0 }">
            <span class="op-kpi-num" x-text="totais.precisamAtencao || 0"></span>
            <span class="op-kpi-label">precisam de atenção</span>
        </div>
        <div class="op-kpi">
            <span class="op-kpi-num" x-text="brl(totais.vendasHojeTotal)"></span>
            <span class="op-kpi-label">vendido hoje (todos)</span>
        </div>
        <div class="op-kpi">
            <span class="op-kpi-num" x-text="brl(totais.mrrAtivo)"></span>
            <span class="op-kpi-label">receita mensal (MRR)</span>
        </div>
    </div>

    @* ---- filtro simples ---- *@
    <label class="op-filtro" x-show="!carregando && clientes.length > 0" x-cloak>
        <input type="checkbox" x-model="soAtencao" />
        Mostrar só quem precisa de atenção
    </label>

    @* ---- carregando ---- *@
    <div class="op-lista" x-show="carregando" x-cloak>
        <div class="op-card op-skel"></div>
        <div class="op-card op-skel"></div>
        <div class="op-card op-skel"></div>
    </div>

    @* ---- erro ---- *@
    <div class="op-aviso op-aviso-erro" x-show="erro" x-cloak>
        <div>
            <strong>Não foi possível carregar a operação agora.</strong>
            <p x-text="erro"></p>
        </div>
        <button type="button" class="btn btn-secondary" x-on:click="carregar()">Tentar de novo</button>
    </div>

    @* ---- sem clientes ---- *@
    <div class="op-vazio" x-show="!carregando && !erro && clientes.length === 0" x-cloak>
        <h3>Você ainda não tem clientes ativos</h3>
        <p>Quando um cliente assinar, ele aparece aqui com as vendas do dia e o que precisa de atenção.</p>
        <a class="btn btn-primary" href="/Tenants">Ver clientes</a>
    </div>

    @* ---- tudo tranquilo (todos ok) ---- *@
    <div class="op-aviso op-aviso-ok" x-show="!carregando && !erro && clientes.length > 0 && (totais.precisamAtencao || 0) === 0" x-cloak>
        <span class="op-dot op-dot-ok"></span>
        <span>Tudo tranquilo. Nenhum cliente precisa de atenção agora.</span>
    </div>

    @* ---- lista de clientes ---- *@
    <div class="op-lista" x-show="!carregando && !erro && clientes.length > 0" x-cloak>
        <template x-for="c in clientesVisiveis" :key="c.empresaId">
            <article class="op-card" :class="'op-card-' + c.statusBand">
                <div class="op-card-topo">
                    <div class="op-card-id">
                        <span class="op-status" :class="'op-status-' + c.statusBand" x-text="statusLabel(c.statusBand)"></span>
                        <h3 class="op-nome" x-text="c.nome"></h3>
                        <span class="op-plano" x-show="c.plano" x-text="c.plano"></span>
                        <span class="op-suspensa" x-show="c.statusAssinatura === 'Suspensa'">assinatura suspensa</span>
                    </div>
                    <a class="btn btn-secondary btn-sm op-abrir" :href="'/Tenants/Detail/' + c.empresaId">Abrir cliente</a>
                </div>

                <p class="op-motivos" x-show="c.motivos && c.motivos.length > 0">
                    <template x-for="(m, i) in c.motivos" :key="m">
                        <span><span x-show="i > 0"> · </span><span x-text="motivoTexto(m, c)"></span></span>
                    </template>
                </p>

                <dl class="op-numeros">
                    <div class="op-num">
                        <dt>Vendas hoje</dt>
                        <dd><span x-text="brl(c.vendasHoje)"></span> <span class="op-num-sub" x-text="'· ' + (c.vendasHojeCount || 0) + ' venda(s)'"></span></dd>
                    </div>
                    <div class="op-num">
                        <dt>Mensalidade</dt>
                        <dd x-text="brl(c.mrr)"></dd>
                    </div>
                    <div class="op-num">
                        <dt>Última venda</dt>
                        <dd x-text="ultimaVendaTexto(c.ultimaVendaEm)"></dd>
                    </div>
                    <div class="op-num" x-show="c.ticketsAbertos > 0">
                        <dt>Chamados</dt>
                        <dd><a :href="'/Tickets?empresaId=' + c.empresaId" x-text="c.ticketsAbertos + ' em aberto'"></a></dd>
                    </div>
                    <div class="op-num" x-show="c.faturasVencidasCount > 0">
                        <dt>Faturas vencidas</dt>
                        <dd><a :href="'/Faturas?empresaId=' + c.empresaId" x-text="brl(c.faturasVencidasValor)"></a></dd>
                    </div>
                </dl>
            </article>
        </template>

        <p class="op-rodape" x-show="totalClientes > clientes.length" x-cloak
           x-text="'Mostrando ' + clientes.length + ' de ' + totalClientes + ' clientes.'"></p>
    </div>
</div>

@section Scripts {
<script>
function operacaoClientes() {
    return {
        carregando: true,
        erro: '',
        totais: {},
        clientes: [],
        totalClientes: 0,
        soAtencao: false,
        atualizadoEm: 0,
        _timer: null,

        async init() {
            await this.carregar();
            document.addEventListener('visibilitychange', () => { if (!document.hidden) this.carregar(); });
            this._timer = setInterval(() => { if (!document.hidden) this.carregar(); }, 30000);
        },

        async carregar() {
            try {
                const r = await fetch('/api-proxy/admin/operacao/fleet', { credentials: 'same-origin' });
                if (r.status === 401) { window.location.href = '/Auth/Login'; return; }
                if (!r.ok) throw new Error('Erro ' + r.status + ' ao falar com o servidor.');
                const data = await r.json();
                this.totais = data.totais || {};
                this.clientes = data.clientes || [];
                this.totalClientes = data.totalClientes || 0;
                this.atualizadoEm = Date.now();
                this.erro = '';
                this.carregando = false;
            } catch (e) {
                this.erro = (e && e.message) ? e.message : 'Falha de conexão.';
                this.carregando = false;
            }
        },

        get clientesVisiveis() {
            return this.soAtencao ? this.clientes.filter(c => c.statusBand !== 'ok') : this.clientes;
        },

        statusLabel(band) {
            return ({ ok: 'Tudo certo', warn: 'Atenção', crit: 'Crítico' })[band] || band;
        },

        motivoTexto(m, c) {
            const n = c.faturasVencidasCount || 0;
            const tk = c.ticketsSlaViolado || 0;
            const ab = c.ticketsAbertos || 0;
            switch (m) {
                case 'suspensa': return 'Assinatura suspensa';
                case 'fatura-vencida': return (n === 1 ? 'Fatura vencida' : n + ' faturas vencidas') + ' (' + this.brl(c.faturasVencidasValor) + ')';
                case 'sla-violado': return tk + (tk === 1 ? ' chamado' : ' chamados') + ' sem resposta no prazo';
                case 'trial-vencendo': return 'Período de teste acabando';
                case 'sem-vendas': return c.ultimaVendaEm ? ('Sem vendas há ' + this.diasDesde(c.ultimaVendaEm) + ' dias') : 'Ainda não registrou vendas';
                case 'ticket-aberto': return ab + (ab === 1 ? ' chamado' : ' chamados') + ' em aberto';
                default: return m;
            }
        },

        ultimaVendaTexto(iso) {
            if (!iso) return 'ainda não vendeu';
            const d = this.diasDesde(iso);
            if (d <= 0) return 'hoje';
            if (d === 1) return 'ontem';
            return 'há ' + d + ' dias';
        },

        diasDesde(iso) {
            const ms = Date.now() - new Date(iso).getTime();
            return Math.max(0, Math.floor(ms / 86400000));
        },

        brl(v) {
            const n = Number(v || 0);
            try { return n.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }); }
            catch (e) { return 'R$ ' + n.toFixed(2); }
        },

        formatAtualizado() {
            const s = Math.floor((Date.now() - this.atualizadoEm) / 1000);
            if (s < 5) return 'agora';
            if (s < 60) return s + 's atrás';
            return Math.floor(s / 60) + ' min atrás';
        }
    };
}
</script>
}
