# Copie este arquivo para .env e preencha com os valores reais.
# O arquivo .env NUNCA deve ser commitado no git.

# Connection string do banco de dados (Azure PostgreSQL ou local)
AZURE_PG_CONNECTION=Host=pg-easystock.postgres.database.azure.com;Port=5432;Database=easystock;Username=<usuario>;Password=<senha>;SSL Mode=Require;Trust Server Certificate=true

# Chave secreta JWT (mínimo 32 caracteres)
# Gerar: openssl rand -base64 32
JWT_SECRET_KEY=

# Ambiente (Development | Production)
ASPNETCORE_ENVIRONMENT=Production

# Opcional
JWT_ISSUER=EasyStock
JWT_AUDIENCE=EasyStock
REDIS_CONNECTION=localhost:6379
OTLP_ENDPOINT=http://localhost:4317
