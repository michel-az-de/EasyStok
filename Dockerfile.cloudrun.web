# syntax=docker/dockerfile:1.7
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

# Node 20 LTS para gerar tailwind.dist.css. Mantido enxuto (sem dev tools).
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

COPY EasyStock.Web/EasyStock.Web.csproj EasyStock.Web/
COPY EasyStock.Web/package.json         EasyStock.Web/

RUN --mount=type=cache,target=/root/.nuget/packages,id=nuget \
    dotnet restore EasyStock.Web/EasyStock.Web.csproj
RUN --mount=type=cache,target=/root/.npm,id=npm \
    cd EasyStock.Web && npm install --no-audit --no-fund --prefer-offline

COPY EasyStock.Web/ EasyStock.Web/

WORKDIR /src/EasyStock.Web
RUN npm run css:build
RUN --mount=type=cache,target=/root/.nuget/packages,id=nuget \
    dotnet publish -c Release -o /app/publish --no-restore /p:UseAppHost=false /p:SkipTailwind=true

FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .

ENV ASPNETCORE_ENVIRONMENT=Production
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

ENTRYPOINT ["dotnet", "EasyStock.Web.dll"]
