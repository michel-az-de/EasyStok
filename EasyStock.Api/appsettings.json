{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=EasyStockDb;Username=postgres;Password=postgres",
    "MongoConnection": "mongodb://localhost:27017",
    "SqliteConnection": "Data Source=easystock.db",
    "Redis": "localhost:6379"
  },
  "Database": {
    "Provider": "Auto",
    "MongoDatabase": "EasyStockDbMongo"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore.Diagnostics": "Critical"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/easystock-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithProcessId" ],
    "Properties": {
      "Application": "EasyStock.Api"
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EasyStock": {
    "LimiteEstoqueBaixoDefault": 5,
    "DiasAlertaVencimento": 30,
    "DiasItemParado": 90
  },
  "Jwt": {
    "Issuer": "EasyStock",
    "Audience": "EasyStock",
    "SecretKey": "EasyStock-SuperSecretKey-Min32Chars!!",
    "ExpirationMinutes": 480
  },
  "Anthropic": {
    "Enabled": true,
    "ApiKey": "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"
  },
  "OpenAI": {
    "Enabled": false,
    "ApiKey": "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",
    "Model": "gpt-4o-mini"
  },
  "FileStorage": {
    "Provider": "Local",
    "LocalRootPath": "uploaded-files",
    "PublicBaseUrl": "/files",
    "S3": {
      "BucketName": "",
      "ServiceUrl": "",
      "Region": "us-east-1",
      "AccessKey": "",
      "SecretKey": "",
      "ForcePathStyle": true,
      "PublicBaseUrl": ""
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5173" ]
  },
  "Smtp": {
