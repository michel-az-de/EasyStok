# syntax=docker/dockerfile:1.7
# ─── Stage 1: build ──────────────────────────────────────────────────────────
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

# Node 20 LTS para gerar tailwind.dist.css.
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# .csproj e package.json primeiro (cache de dependencias)
COPY EasyStock.Web/EasyStock.Web.csproj EasyStock.Web/
COPY EasyStock.Web/package.json         EasyStock.Web/

# Restore com cache mount BuildKit
RUN --mount=type=cache,target=/root/.nuget/packages,id=nuget \
    dotnet restore EasyStock.Web/EasyStock.Web.csproj

RUN --mount=type=cache,target=/root/.npm,id=npm \
    cd EasyStock.Web && npm install --no-audit --no-fund --prefer-offline

# Codigo fonte do Web apenas
COPY EasyStock.Web/ EasyStock.Web/

# Tokens de design compartilhados — tailwind.config.js faz require('../design/tokens.colors')
COPY design/ design/

WORKDIR /src/EasyStock.Web
RUN npm run css:build
RUN --mount=type=cache,target=/root/.nuget/packages,id=nuget \
    dotnet publish -c Release -o /app/publish /p:SkipTailwind=true

# ─── Stage 2: runtime ────────────────────────────────────────────────────────
FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime
WORKDIR /app

RUN addgroup --system --gid 1001 appgroup \
 && adduser  --system --uid 1001 --ingroup appgroup appuser

COPY --from=build /app/publish .

# Mountpoint do volume de chaves do DataProtection. Criado aqui pra herdar o dono
# appuser no chown abaixo: assim o volume nomeado montado neste path nasce gravavel
# pelo appuser (uid 1001). Sem isso o volume seria root-owned, o appuser nao gravaria
# as chaves e a sessao nao sobreviveria a deploy. Ver EasyStock.Web/Program.cs (8b).
RUN mkdir -p /app/dataprotection-keys

RUN chown -R appuser:appgroup /app
USER appuser

EXPOSE 8081
ENV ASPNETCORE_URLS=http://+:8081
ENV ASPNETCORE_ENVIRONMENT=Production

# GIT_SHA do commit (passado via --build-arg). Declarado so no runtime para nao
# invalidar o cache das camadas de build/publish a cada commit. Exposto em /health.
ARG GIT_SHA=unknown
ENV GIT_SHA=$GIT_SHA

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD wget -qO- http://localhost:8081/health || exit 1

ENTRYPOINT ["dotnet", "EasyStock.Web.dll"]
