# ─── .env para docker-compose.azure.yml ──────────────────────────────────────
# Copie para .env na VM e preencha. NAO commitar o .env real (apenas este .example).

# Hosts publicos — apos criar a VM, usar sslip.io com o IP publico dela.
# Ex.: se o IP publico for 20.30.40.50:
#   APP_HOST=app.20.30.40.50.sslip.io
APP_HOST=app.SEU_IP_PUBLICO.sslip.io
ADMIN_HOST=admin.SEU_IP_PUBLICO.sslip.io
API_HOST=api.SEU_IP_PUBLICO.sslip.io
CASA_HOST=casa.SEU_IP_PUBLICO.sslip.io
CASADABABA_HOST=casadababa.SEU_IP_PUBLICO.sslip.io

# E-mail para o Let's Encrypt (avisos de expiracao de certificado).
ACME_EMAIL=felipe.azevedo@gmail.com

# ─── Postgres (gerar senha forte) ────────────────────────────────────────────
POSTGRES_DB=easystock
POSTGRES_USER=easystock
POSTGRES_PASSWORD=GERAR_SENHA_FORTE_AQUI

# ─── JWT (chave com 32+ caracteres) ──────────────────────────────────────────
Jwt__SecretKey=GERAR_CHAVE_COM_32_OU_MAIS_CARACTERES
Jwt__Issuer=EasyStock
Jwt__Audience=EasyStock

# ─── SuperAdmin do painel /admin (obrigatorio em Production) ──────────────────
# Senha: >= 12 chars e fora da lista de senhas conhecidas/fracas. Gere uma forte.
SEED_SUPERADMIN_EMAIL=admin@easystok.com
SEED_SUPERADMIN_PASSWORD=GERAR_SENHA_FORTE_12+_CHARS
SEED_SUPERADMIN_NOME=Super Admin
